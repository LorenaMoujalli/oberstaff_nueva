---
interface Props {
  title?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl?: string;
  ogImage?: string;
}

const {
  title = "Informe Estratégico | Oberstaff",
  ogTitle = title,
  ogDescription = "Informe Estratégico de Oberstaff",
  ogUrl = Astro.url.href,
  ogImage = "",
} = Astro.props;

const canonicalOgImage = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : new URL(
        ogImage.startsWith("/") ? ogImage : `/${ogImage}`,
        Astro.url.origin,
      ).href
  : new URL("", Astro.url.origin).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={canonicalOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={canonicalOgImage} />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Poppins:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/webp" href="/icono_oberstaff.webp" />
    <title>{title}</title>
    <slot name="head" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-16507199657"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'AW-16507199657');
    </script>
    <!-- Meta Pixel Code -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=f.fbq||function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1399493591830432');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=1399493591830432&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->
  </head>
  <body>
    <!-- Logo fijo en esquina superior izquierda -->
    <a
      href="/"
      class="report-logo-link"
      aria-label="Ir al inicio de Oberstaff"
    >
      <img
        src="/logo-oberstaff-blanco.webp"
        alt="Oberstaff"
        class="report-logo-img"
        width="140"
        height="auto"
      />
    </a>

    <main class="report-layout-container">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --brand-pink: #ff66cc;
    /* Colores para el degradado de fondo profundo */
    --bg-dark-void: #0a0a0a; /* Negro casi total para la parte superior */
    --bg-light-glow: #2a2a2a; /* Gris con luz para la base */
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    height: 100%;
    margin: 0;
    /* Gradiente Radial elíptico posicionado en la parte inferior central */
    background: radial-gradient(
      ellipse at 50% 100%,
      var(--bg-light-glow) 0%,
      var(--bg-dark-void) 70%
    );
    background-color: var(--bg-dark-void);
    background-attachment: fixed;
    color: #ffffff;
    font-family: "Poppins", sans-serif;
  }

  .report-layout-container {
    min-height: 100vh;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;
    position: relative;
  }

  /* Estado desbloqueado: fondo blanco, layout en bloque */
  body.report-unlocked {
    background: #ffffff !important;
    background-image: none !important;
    background-color: #ffffff !important;
  }

  body.report-unlocked .report-layout-container {
    display: block;
    align-items: unset;
    justify-content: unset;
    padding: 0;
    min-height: unset;
  }

  /* ── Logo fijo esquina superior izquierda ── */
  .report-logo-link {
    position: fixed;
    top: 20px;
    left: 24px;
    z-index: 9999;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    opacity: 0.95;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }
  .report-logo-link:hover {
    opacity: 1;
    transform: scale(1.04);
  }
  .report-logo-img {
    width: 130px;
    height: auto;
    display: block;
    /* Sombra sutil para que se vea bien sobre el fondo oscuro */
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.4));
  }

  /* El modal con el glow rosado sutil de la captura */
  .gate-modal-card {
    background-color: #1b1b1b;
    border: 1px solid rgba(255, 102, 204, 0.1); /* Toque rosa en el borde */
    border-radius: 28px;
    padding: 60px 45px;
    max-width: 580px;
    width: 100%;
    position: relative;
    box-shadow:
      0 30px 60px rgba(0, 0, 0, 0.8),
      0 0 40px rgba(255, 102, 204, 0.05); /* Glow exterior muy suave */
    z-index: 2;
  }
</style>
