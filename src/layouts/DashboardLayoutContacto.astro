---
import Header from "../components/Header.astro";
import FooterServicios from "../components/FooterServicios.astro";
//import VideoTestimonialModal from "../components/video/VideoTestimonialModal.astro";

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogUrl?: string;
	ogImage?: string;
}

const {
	title = "",
	description = "",
	keywords = "",
	ogTitle = title,
	ogDescription = description,
	ogUrl = Astro.url.href,
	ogImage = "Contratar-Talento.webp",
} = Astro.props;

const canonicalOgImage = ogImage 
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage.startsWith('/') ? ogImage : `/${ogImage}`, Astro.url.origin).href)
  : new URL('/Contratar-Talento.webp', Astro.url.origin).href;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="index, follow" />
		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={ogUrl} />
		<meta property="og:image" content={canonicalOgImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={ogDescription} />
		<meta name="twitter:image" content={canonicalOgImage} />
		<link rel="icon" type="image/webp" href="/icono_oberstaff.webp" />
		<link rel="preconnect" href="https://fonts.googleapis.com" /> 
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Montserrat:wght@100..900&display=swap"
			rel="stylesheet"
		/>
		<script
			src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"
		></script>
		<script src="../scripts/scroll-animations.ts"></script>
		<title>{title}</title>
		<slot name="head" />
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=AW-16507199657"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'AW-16507199657');
		</script>
		<!-- Meta Pixel Code -->
		<script is:inline>
			!function(f,b,e,v,n,t,s)
			{if(f.fbq)return;n=f.fbq=f.fbq||function(){n.callMethod?
			n.callMethod.apply(n,arguments):n.queue.push(arguments)};
			if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
			n.queue=[];t=b.createElement(e);t.async=!0;
			t.src=v;s=b.getElementsByTagName(e)[0];
			s.parentNode.insertBefore(t,s)}(window, document,'script',
			'https://connect.facebook.net/en_US/fbevents.js');
			fbq('init', '1399493591830432');
			fbq('track', 'PageView');
		</script>
		<noscript><img height="1" width="1" style="display:none"
			src="https://www.facebook.com/tr?id=1399493591830432&ev=PageView&noscript=1"
		/></noscript>
		<!-- End Meta Pixel Code -->
	</head>
	<body>
		<div class="app-container">
			<Header />
			<main class="main-content">
				<slot />
			</main>
			<FooterServicios />
		</div>
	</body>
</html>

<style is:global>
	:root {
		--primary: #1a1a1a;
		--primary-hover: #333333;
		--bg-gradient-start: #fff0f7; /* Very light pink based on #ff66cc */
		--bg-gradient-end: #f5d0fe;
		--sidebar-bg: #fff0f7; /* Consistent light pink */
		--text-color: #1a1a1a;
		--card-bg: #ffffff;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		font-family: "Inter", sans-serif;
		background-color: white; /* Light pinkish background for the whole app */
		color: var(--text-color);
		scroll-behavior: smooth;
	}

	h1,
	h2,
	h3,
	h4,
	h5,
	h6 {
		font-family: "Poppins", sans-serif;
	}

	p {
		font-family: "Inter", sans-serif;
	}

	body {
		min-height: 100vh;
	}

	.app-container {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	.main-content {
		flex: 1;

		display: flex;
		flex-direction: column;
	}

	/* Utility for cards */
	.card {
		background: white;
		border-radius: 20px;
		padding: 1.5rem;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
	}

	button {
		cursor: pointer;
		font-family: inherit;
	}

	/* Animación de aparición al hacer scroll */
	.fade-in-section {
		opacity: 0;
		transform: translateY(40px);
		transition:
			opacity 1s ease-out,
			transform 1s ease-out;
		will-change: opacity, transform;
	}

	.fade-in-section.is-visible {
		opacity: 1;
		transform: translateY(0);
	}
</style>
