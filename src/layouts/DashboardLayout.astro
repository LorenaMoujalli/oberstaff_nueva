---
import Sidebar from '../components/Sidebar.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Agente de voz IA" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
		<div class="app-container">
			<Sidebar />
			<main class="main-content">
				<slot />
				<footer class="main-footer">
					<p>&copy; 2025. Todos los derechos reservados</p>
					<div class="footer-links">
						<a href="#">Política de Privacidad</a>
						<span class="separator">|</span>
						<a href="#">Términos de Uso</a>
					</div>
				</footer>
			</main>
		</div>
	</body>
</html>

<style is:global>
	:root {
		--primary: #1a1a1a;
		--primary-hover: #333333;
		--bg-gradient-start: #fce7f3;
		--bg-gradient-end: #f5d0fe;
		--sidebar-bg: #fff0f5; /* Very light pink/off-white for sidebar */
		--text-color: #1a1a1a;
		--card-bg: #ffffff;
	}
	
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		font-family: 'Outfit', sans-serif;
		background-color: #fcf4f9; /* Light pinkish background for the whole app */
		color: var(--text-color);
	}

	body {
		min-height: 100vh;
	}
	
	.app-container {
		display: flex;
		min-height: 100vh;
	}

	.main-content {
		flex: 1;
		padding: 2rem 3rem;
		display: flex;
		flex-direction: column;
		overflow-y: auto;
		height: 100vh;
	}

	.main-footer {
		margin-top: auto;
		padding-top: 3rem;
		padding-bottom: 1rem;
		text-align: center;
		color: #666;
		font-size: 0.9rem;
	}

	.footer-links {
		display: flex;
		justify-content: center;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}

	.separator {
		color: #ccc;
	}

	.footer-links a {
		text-decoration: none;
		color: #888;
	}
	
	/* Utility for cards */
	.card {
		background: white;
		border-radius: 20px;
		padding: 1.5rem;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
	}
	
	button {
		cursor: pointer;
		font-family: inherit;
	}
</style>
