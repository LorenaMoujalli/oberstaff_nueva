---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Agente de voz IA" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--primary: #1a1a1a;
		--primary-hover: #333333;
		--bg-gradient-start: #fce7f3; /* Light pink */
		--bg-gradient-end: #f5d0fe; /* Light purple */
		--text-color: #1a1a1a;
		--input-bg: #f3f4f6;
		--input-placeholder: #9ca3af;
	}
	
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		font-family: 'Outfit', sans-serif;
		background: linear-gradient(135deg, #ffeef6 0%, #fcecf4 50%, #f6eaf8 100%);
		min-height: 100vh;
	}

	body {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		color: var(--text-color);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	input {
		font-family: inherit;
	}

	button {
		font-family: inherit;
		cursor: pointer;
	}
</style>
