---
interface Props {
    preTitle?: string;
    title: string;
    highlight: string;
    description: string;
    primaryBtnText?: string;
    primaryBtnHref?: string;
    secondaryBtnText?: string;
    secondaryBtnHref?: string;
    underBtnText?: string;
}

const { 
    preTitle,
    title, 
    highlight, 
    description,
    primaryBtnText = "Agendar llamada gratis",
    primaryBtnHref = "#contacto",
    secondaryBtnText = "Conoce los perfiles profesionales",
    secondaryBtnHref = "#roles",
    underBtnText
} = Astro.props;
import "../../styles/hero-servicios/HeroContent.css";
---


{preTitle ? (
    <>
        <h1 class="pre-title">{preTitle}</h1>
        <p class="main-title">
            <span set:html={title}></span>
            {highlight && <><br /><span class="pink-highlight">{highlight}</span></>}
        </p>
    </>
) : (
    <h1 class="main-title">
        <span set:html={title}></span>
        {highlight && <><br /><span class="pink-highlight">{highlight}</span></>}
    </h1>
)}

<p class="hero-description" set:html={description}></p>

<div class="hero-actions">
    <div class="primary-btn-container">
        <a href={primaryBtnHref} class="btn-pink">{primaryBtnText}</a>
        {underBtnText && <span class="under-btn-text">{underBtnText}</span>}
    </div>
    <a href={secondaryBtnHref} class="btn-outline">{secondaryBtnText}</a>
</div>
