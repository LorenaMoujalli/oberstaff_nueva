---
import HeroContent from "./HeroContent.astro";
import HeroVisual from "./HeroVisual.astro";
import "../../styles/hero-servicios/HeroService.css";

interface Props {
    label: string;
    preTitle?: string;
    title: string;
    highlight: string;
    description: string;
    videoImg: string;
    remoteCountry: string;
    floatingText: string;
    floatingIcon?: string;
    badgeRightTitle?: string;
    badgeRightText?: string;
    badgeRightIcon?: string;
    primaryBtnText?: string;
    primaryBtnHref?: string;
    secondaryBtnText?: string;
    secondaryBtnHref?: string;
    underBtnText?: string;
    modalTitle?: string;
    modalDescription?: string;
    modalBtnText?: string;
}

const props = Astro.props;
---

<section class="hero-section">
    <!-- Aurora background elements -->
    <div class="blur-glow pink-glow"></div>
    <div class="blur-glow purple-glow"></div>

    <div class="service-label">{props.label}</div>

    <div class="hero-container">
        <HeroVisual 
            videoImg={props.videoImg} 
            remoteCountry={props.remoteCountry} 
            floatingText={props.floatingText} 
            floatingIcon={props.floatingIcon}
            badgeRightTitle={props.badgeRightTitle}
            badgeRightText={props.badgeRightText}
            badgeRightIcon={props.badgeRightIcon}
            modalTitle={props.modalTitle}
            modalDescription={props.modalDescription}
            modalBtnText={props.modalBtnText}
        />
        
        <HeroContent 
            preTitle={props.preTitle}
            title={props.title}
            highlight={props.highlight}
            description={props.description}
            primaryBtnText={props.primaryBtnText}
            primaryBtnHref={props.primaryBtnHref}
            secondaryBtnText={props.secondaryBtnText}
            secondaryBtnHref={props.secondaryBtnHref}
            underBtnText={props.underBtnText}
        />
    </div>
</section>
