---
import VideoPrincipalModal from "../video/VideoPrincipalModal.astro";
interface Props {
    videoImg: string;
    remoteCountry?: string;
    floatingText: string;
    floatingIcon?: string;
    badgeRightTitle?: string;
    badgeRightText?: string;
    badgeRightIcon?: string;
    modalTitle?: string;
    modalDescription?: string;
    modalBtnText?: string;
    videoAlt?: string;
}

const { 
    videoImg, 
    remoteCountry = "CO", 
    floatingText, 
    floatingIcon = "🛡️",
    badgeRightTitle = "100%", 
    badgeRightText = "cumplimiento",
    badgeRightIcon = "🔹",
    modalTitle,
    modalDescription,
    modalBtnText,
    videoAlt = "Visual Service"
} = Astro.props;
import "../../styles/hero-servicios/HeroVisual.css";
---

<div class="hero-visual-wrapper">
    <!-- Elemento flotante Izquierdo -->
    <div class="floating-badge badge-left">
        <span class="icon-emoji-hero" aria-hidden="true">{floatingIcon}</span>
        <span>{floatingText}</span>
    </div>

    <!-- Video Central -->
    <div class="video-preview">
        <img src={videoImg} alt={videoAlt}>
        <button type="button" id="openVideoModal" class="play-button" aria-label="Reproducir video principal">
            <iconify-icon icon="solar:play-bold" aria-hidden="true"></iconify-icon>
        </button>
    </div>

    <!-- Elemento flotante Derecho -->
    <div class="floating-badge badge-right">
        <span class="icon-emoji-hero">{badgeRightIcon}</span>
        <span class="text">{badgeRightTitle}</span>
        <span class="country">{badgeRightText}</span>
    </div>
</div>

<VideoPrincipalModal 
    modalTitle={modalTitle}
    modalDescription={modalDescription}
    modalBtnText={modalBtnText}
/>
