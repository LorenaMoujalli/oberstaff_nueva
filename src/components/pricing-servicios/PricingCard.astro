---
import "../../styles/pricing-servicios/PricingCard.css";

interface Props {
    badge?: string;
    title: string;
    price: string;
    currency: string;
    period: string;
    teamSize: string;
    features: string[];
    ctaText: string;
    ctaHref: string;
}

const { 
    badge, 
    title, 
    price, 
    currency, 
    period, 
    features, 
    ctaText, 
    ctaHref 
} = Astro.props;
---

<div class="pricing-card">
    {badge && (
        <div class="badge-popular">
            <span>★</span> {badge}
        </div>
    )}
    
    <div class="card-body">

        <!-- Columna izquierda: título, precio, CTA link -->
        <div class="card-left">
            <h3 class="card-title">{title}</h3>
            
            <div class="price-block">
                <span class="price-desde">DESDE</span>
                <div class="price-main">
                    <span class="price-amount">{price}</span>
                    <span class="price-currency">{currency}</span>
                </div>
                <span class="price-period">{period}</span>
            </div>
            
            <a href={ctaHref} class="btn-pricing-link">{ctaText}</a>
        </div>

        <!-- Divisor vertical -->
        <div class="card-divider"></div>

        <!-- Columna derecha: features -->
        <div class="card-right">
            <ul class="pricing-features">
                {features.map((feature) => (
                    <li>
                        <span class="check-icon">✓</span>
                        <span set:html={feature}></span>
                    </li>
                ))}
            </ul>
        </div>

    </div>
</div>
