---
import QueEsHeader from "./QueEsHeader.astro";
import QueEsContent from "./QueEsContent.astro";
import QueEsDifference from "./QueEsDifference.astro";

interface InfoItem {
    icon: string;
    title: string;
    description: string;
}

interface Props {
    title: string;
    description: string;
    highlightWord?: string;
    imageSrc: string;
    imageAlt: string;
    badgeText: string;
    quoteText: string;
    infoItems?: InfoItem[];
    diffIcon?: string;
    diffTitle?: string;
    diffDescription?: string;
    checklistTitle?: string;
    checklistItems?: string[];
    checklistIcon?: string;
    checklistIconClass?: string;
    ctaText?: string;
    ctaHref?: string;
}

const { 
    title, 
    description, 
    highlightWord, 
    imageSrc, 
    imageAlt, 
    badgeText, 
    quoteText, 
    infoItems = [],
    diffIcon,
    diffTitle,
    diffDescription,
    checklistTitle,
    checklistItems,
    checklistIcon,
    checklistIconClass,
    ctaText,
    ctaHref,
} = Astro.props;

import "../../styles/QueEsServicio/QueEsServicio.css";
---

<section class="que-es-servicio-section">
    <div class="que-es-container">
        <QueEsHeader 
            title={title} 
            description={description} 
            highlightWord={highlightWord} 
        />

        <QueEsContent 
            imageSrc={imageSrc} 
            imageAlt={imageAlt} 
            badgeText={badgeText} 
            quoteText={quoteText} 
            infoItems={infoItems}
            checklistTitle={checklistTitle}
            checklistItems={checklistItems}
            checklistIcon={checklistIcon}
            checklistIconClass={checklistIconClass}
            ctaText={ctaText}
            ctaHref={ctaHref}
        />

        {diffTitle && (
            <QueEsDifference 
                icon={diffIcon || "💡"} 
                title={diffTitle} 
                description={diffDescription || ""} 
            />
        )}
    </div>
</section>
