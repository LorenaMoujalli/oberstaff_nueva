---
interface InfoItem {
    icon: string;
    title: string;
    description: string;
}

interface Props {
    imageSrc: string;
    imageAlt: string;
    badgeText: string;
    quoteText: string;
    infoItems?: InfoItem[];
    checklistTitle?: string;
    checklistItems?: string[];
    ctaText?: string;
    ctaHref?: string;
    checklistIcon?: string;
    checklistIconClass?: string;
    itemTitleTag?: string;
}

const {
    imageSrc,
    imageAlt,
    badgeText,
    quoteText,
    infoItems = [],
    checklistTitle,
    checklistItems,
    ctaText,
    ctaHref,
    checklistIcon,
    checklistIconClass,
    itemTitleTag = "p",
} = Astro.props;
const TitleTag = itemTitleTag as any;
import "../../styles/QueEsServicio/QueEsContent.css";
---

<div class="que-es-main-content">
    <div class="que-es-image-wrapper">
        <div class="image-card">
            <img src={imageSrc} alt={imageAlt} />
        </div>
        <div class="floating-badge-bottom">
            <span class="check-pink" aria-hidden="true">✓</span>
            <strong>{badgeText}</strong>
        </div>
    </div>

    <div class="que-es-info-list">
        {
            quoteText && (
                <div class="quote-blue-border" set:html={quoteText}></div>
            )
        }

        {
            checklistTitle && checklistItems && checklistItems.length > 0 ? (
                <>
                    <div class="ques-checklist-block">
                        <p class="ques-checklist-title">
                            <strong set:html={checklistTitle} />
                        </p>
                        <ul class="ques-checklist">
                            {checklistItems.map((item) => (
                                <li class="ques-checklist-item">
                                    <span
                                        class={`ques-check-icon ${checklistIconClass || ""}`}
                                        aria-hidden="true"
                                    >
                                        {checklistIcon || "✓"}
                                    </span>
                                    <span set:html={item} />
                                </li>
                            ))}
                        </ul>
                    </div>
                </>
            ) : (
                infoItems.map((item) => (
                    <div class="info-item">
                        <div class="icon-box" aria-hidden="true">
                            {item.icon.includes(":") ? (
                                <iconify-icon
                                    icon={item.icon}
                                    aria-hidden="true"
                                />
                            ) : (
                                <span class="emoji-icon" aria-hidden="true">
                                    {item.icon}
                                </span>
                            )}
                        </div>
                        <div class="text-box">
                            {item.title && (
                                <TitleTag class="text-box-title">
                                    <strong set:html={item.title} />
                                </TitleTag>
                            )}
                            {item.description && (
                                <p set:html={item.description} />
                            )}
                        </div>
                    </div>
                ))
            )
        }

        {
            ctaText && (
                <a href={ctaHref || "#"} class="ques-cta-btn">
                    {ctaText}
                </a>
            )
        }
    </div>
</div>

<style>
    .orange-bullet-icon {
        color: #ffa500 !important;
        font-weight: 900 !important;
        font-size: 16px !important;
        line-height: 1 !important;
        margin-top: 5px;
        display: inline-block;
    }
</style>
