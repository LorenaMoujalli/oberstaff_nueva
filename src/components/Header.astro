                </div>
            </div>
        </div>
    </div>
</header>

<script>
    // Mobile menu toggle
    const menuToggle = document.getElementById("menu-toggle");
    const navWrapper = document.getElementById("nav-wrapper");

    function toggleMobileMenu() {
        if (!navWrapper) return;
        navWrapper.classList.toggle("is-open");
        const icon = menuToggle?.querySelector("iconify-icon");
        if (icon) {
            icon.setAttribute(
                "icon",
                navWrapper.classList.contains("is-open")
                    ? "solar:close-square-linear"
                    : "solar:hamburger-menu-linear",
            );
        }
    }

    menuToggle?.addEventListener("click", toggleMobileMenu);

    // Dropdowns: click on mobile, hover handled by CSS on desktop
    const dropdownItems = document.querySelectorAll(".has-dropdown");
    dropdownItems.forEach((item) => {
        const btn = item.querySelector(".nav-dropdown-btn");

        // Mobile: toggle on click
        btn?.addEventListener("click", (e) => {
            const isMobile = window.innerWidth <= 1024;
            if (!isMobile) return;

            e.stopPropagation();
            const isOpen = item.classList.contains("open");

            dropdownItems.forEach((d) => {
                d.classList.remove("open");
                d.querySelector(".nav-dropdown-btn")?.setAttribute(
                    "aria-expanded",
                    "false",
                );
            });

            if (!isOpen) {
                item.classList.add("open");
                btn.setAttribute("aria-expanded", "true");
            }
        });
    });

    // Close mobile dropdowns on outside click
    document.addEventListener("click", () => {
        if (window.innerWidth <= 1024) {
            dropdownItems.forEach((d) => {
                d.classList.remove("open");
                d.querySelector(".nav-dropdown-btn")?.setAttribute(
                    "aria-expanded",
                    "false",
                );
            });
        }
    });

    // Language switcher
    document.querySelectorAll(".lang-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            document
                .querySelectorAll(".lang-btn")
                .forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
        });
    });
</script>

<style>
    /* ===== HEADER WRAPPER ===== */
    .main-header {
        width: 100%;
        display: flex;
        justify-content: center;
        padding: 12px 20px;
        position: sticky;
        top: 0;
        z-index: 1000;
        background: transparent;
        pointer-events: none;
    }

    /* ===== PILL ===== */
    .header-pill {
        pointer-events: all;
        background: #1b1b1b;
        border-radius: 60px;
        padding: 10px 25px;
        height: 52px;
        max-width: 1200px;
        width: 100%;
        display: flex;
        align-items: center;
        gap: 24px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    /* ===== LOGO ===== */
    .logo-section {
        flex-shrink: 0;
    }

    .logo-link {
        text-decoration: none;
    }

    .logo-text {
        font-family: "Montserrat", sans-serif;
        font-weight: 800;
        font-size: 18px;
        color: #ffffff;
        letter-spacing: -0.5px;
    }

    .logo-text:hover {
        opacity: 0.8;
    }

    .logo-dot {
        color: #ff66cc;
    }

    /* ===== MOBILE TOGGLE ===== */
    .mobile-menu-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        color: #ffffff;
        margin-left: auto;
        -webkit-tap-highlight-color: transparent;
        outline: none;
    }

    .mobile-menu-toggle:focus,
    .mobile-menu-toggle:active {
        outline: none;
        background: none;
        -webkit-tap-highlight-color: transparent;
    }

    .hamburger-icon {
        font-size: 1.6rem;
        color: #ffffff;
    }

    /* ===== NAV WRAPPER ===== */
    .header-nav-wrapper {
        display: contents;
    }

    /* ===== NAV LINKS ===== */
    .nav-links {
        flex: 1;
        display: flex;
        justify-content: flex-start;
    }

    .nav-links ul {
        list-style: none;
        display: flex;
        align-items: center;
        gap: 4px;
        margin: 0;
        padding: 0;
    }

    .nav-links ul li {
        position: relative;
    }

    .nav-links ul li > a,
    .nav-dropdown-btn {
        font-family: "Poppins", sans-serif;
        font-size: 14px;
        font-weight: 300;
        color: #e0e0e0;
        text-decoration: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 6px 10px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        gap: 4px;
        transition:
            color 0.2s ease,
            background 0.2s ease;
        white-space: nowrap;
        -webkit-tap-highlight-color: transparent;
        outline: none;
    }

    .nav-links ul li > a:focus,
    .nav-links ul li > a:active,
    .nav-dropdown-btn:focus,
    .nav-dropdown-btn:active {
        background: none;
        outline: none;
        -webkit-tap-highlight-color: transparent;
    }

    .nav-links ul li > a:hover,
    .nav-dropdown-btn:hover {
        color: #ffffff;
    }

    .chevron {
        font-size: 0.75rem;
        transition: transform 0.2s ease;
    }

    .has-dropdown.open .chevron {
        transform: rotate(180deg);
    }

    /* ===== DROPDOWN MENU — desktop hover ===== */
    .dropdown-menu {
        display: flex;
        flex-direction: column;
        gap: 0;
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        transform: translateY(-6px);
        opacity: 0;
        pointer-events: none;
        visibility: hidden;
        transition:
            opacity 0.2s ease,
            transform 0.2s ease,
            visibility 0.2s ease;

        background: #ffffff;
        border-radius: 14px;
        padding: 8px;
        min-width: 230px;
        box-shadow:
            0 4px 6px rgba(0, 0, 0, 0.04),
            0 12px 40px rgba(0, 0, 0, 0.14);
        z-index: 2000;
    }

    /* Small caret pointing up — left aligned */
    .dropdown-menu::before {
        content: "";
        position: absolute;
        top: -7px;
        left: 22px;
        transform: none;
        border-left: 7px solid transparent;
        border-right: 7px solid transparent;
        border-bottom: 7px solid #ffffff;
        filter: drop-shadow(0 -2px 2px rgba(0, 0, 0, 0.06));
    }

    /* Show on hover (desktop only) */
    @media (min-width: 1025px) {
        /* Invisible bridge to prevent hover gap from closing the dropdown */
        .has-dropdown::after {
            content: "";
            position: absolute;
            bottom: -12px; /* matches the gap between button and dropdown */
            left: 0;
            width: 100%;
            height: 14px; /* slightly taller than the gap */
            background: transparent;
        }

        .has-dropdown:hover .dropdown-menu {
            opacity: 1;
            pointer-events: all;
            visibility: visible;
            transform: translateY(0);
        }

        .has-dropdown:hover .chevron {
            transform: rotate(180deg);
        }

        /* Small close delay so the dropdown doesn’t snap shut instantly */
        .dropdown-menu {
            transition:
                opacity 0.2s ease 0.1s,
                transform 0.2s ease 0.1s,
                visibility 0s ease 0.3s;
        }

        .has-dropdown:hover .dropdown-menu {
            transition:
                opacity 0.2s ease,
                transform 0.2s ease,
                visibility 0s ease;
        }
    }

    /* Mobile: show on .open class (JS-toggled) */
    @media (max-width: 1024px) {
        .dropdown-menu {
            position: static;
            display: none;
            opacity: 1;
            pointer-events: all;
            visibility: visible;
            transform: none;
            box-shadow: none;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 8px;
            margin-top: 4px;
            padding: 4px;
        }
        .has-dropdown.open .dropdown-menu {
            display: flex;
        }
    }

    .dropdown-menu a {
        font-family: "Times New Roman", Times, serif;
        font-size: 0.85rem;
        font-weight: 400;
        color: #444444;
        text-decoration: none;
        padding: 10px 14px;
        border-radius: 8px;
        transition:
            color 0.15s ease,
            background 0.15s ease,
            transform 0.15s ease;
        white-space: nowrap;
    }

    .dropdown-menu a:hover {
        color: #6663fd;
        background-color: #fafafc;
        transform: translateX(5px);
    }

    /* Mobile dropdown links stay light */
    @media (max-width: 1024px) {
        .dropdown-menu a {
            color: #cccccc;
        }
        .dropdown-menu a:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.08);
        }
    }

    /* ===== RIGHT SECTION ===== */
    .header-right {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-shrink: 0;
        margin-left: auto;
    }

    .phone-number {
        font-family: "Poppins", sans-serif;
        font-size: 0.82rem;
        font-weight: 600;
        color: #cccccc;
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }

    .phone-flag {
        font-size: 0.9rem;
    }

    /* Inline nav phone item */
    .nav-phone {
        margin-left: 4px;
    }

    .nav-phone .phone-number {
        font-family: "Times New Roman", Times, serif;
        color: #ffffff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        white-space: nowrap;
        opacity: 0.9;
        transition: all 0.3s ease;
        padding: 5px 12px;
        border-radius: 50px;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .nav-phone .phone-number:hover {
        opacity: 1;
        background: rgba(255, 255, 255, 0.1);
        border-color: #ffffff;
        cursor: pointer;
    }

    /* ===== LANGUAGE SWITCHER ===== */
    .lang-switcher {
        display: flex;
        align-items: center;
        background: #000000;
        border-radius: 50px;
        padding: 4px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .lang-btn {
        font-family: "Times New Roman", Times, serif;
        font-size: 12px;
        font-weight: 600;
        color: #888888;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px 14px;
        border-radius: 100px;
        transition: all 0.2s ease;
        border-radius: 50px;
    }

    .lang-btn:hover {
        color: #ffffff;
    }

    .lang-btn.active {
        font-family: "Times New Roman", Times, serif;
        background: #ffffff;
        color: #1a1a1a;
    }

    /* ===== MOBILE ===== */
    @media (max-width: 1024px) {
        .main-header {
            padding: 10px 16px;
        }

        .header-pill {
            border-radius: 25px;
            padding: 0 16px;
        }

        .mobile-menu-toggle {
            display: flex;
        }

        .header-nav-wrapper {
            display: none;
            position: fixed;
            top: 74px;
            left: 16px;
            right: 16px;
            background: #1a1a1a;
            border-radius: 16px;
            padding: 20px;
            flex-direction: column;
            gap: 12px;
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
            z-index: 999;
        }

        .header-nav-wrapper.is-open {
            display: flex;
        }

        .nav-links {
            width: 100%;
        }

        .nav-links ul {
            flex-direction: column;
            align-items: flex-start;
            gap: 4px;
            width: 100%;
        }

        .nav-links ul li {
            width: 100%;
        }

        .nav-links ul li > a,
        .nav-dropdown-btn {
            width: 100%;
            font-size: 1rem;
            padding: 10px 12px;
        }

        .dropdown-menu {
            position: static;
            box-shadow: none;
            border: none;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 8px;
            margin-top: 4px;
            padding: 4px;
        }

        .dropdown-menu::before {
            display: none;
        }

        .dropdown-menu a {
            font-size: 0.9rem;
        }

        .header-right {
            margin-left: 0;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            width: 100%;
        }

        .nav-phone {
            width: 100%;
            margin-left: 0;
            padding-left: 0;
        }

        .nav-phone .phone-number {
            width: 100%;
            justify-content: center;
            padding: 10px 14px;
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .lang-switcher {
            justify-content: center;
        }

        .phone-number {
            font-size: 0.9rem;
        }
    }
</style>
