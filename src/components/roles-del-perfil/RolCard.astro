---
import "../../styles/roles-del-perfil/rol-card.css";

interface Props {
  title: string;
  description: string;
  icon: string;
  iconColor: string;
  borderColorClass: string;
  techStack?: string[];
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
  layout?: "classic" | "modern";
}

const { 
  title, 
  description, 
  icon, 
  iconColor, 
  borderColorClass, 
  techStack = [],
  subtitle,
  buttonText,
  buttonHref = "#",
  layout = "classic",
} = Astro.props;

const isEmoji = (str: string) => !str.includes(":");
---

{layout === "modern" ? (
  <div class={`perfil-card layout-modern ${borderColorClass}`}>
    <div class="card-top">
      <div class="card-title-row">
        <span class="profile-icon-modern">
          {isEmoji(icon) ? icon : <iconify-icon icon={icon} style={`color: ${iconColor};`}></iconify-icon>}
        </span>
        <h3 set:html={title}></h3>
      </div>
      {subtitle && <p class="card-subtitle-modern">{subtitle}</p>}
      {techStack.length > 0 && (
        <div class="tech-stack-modern">
          {techStack.map((tech) => (
            <span class="tag-modern">{tech}</span>
          ))}
        </div>
      )}
    </div>
    {buttonText && (
      <a href={buttonHref} class="card-btn-modern">
        {buttonText}
      </a>
    )}
  </div>
) : (
  <div class={`perfil-card ${borderColorClass}`}>
    <div class="card-content">
      <span class="profile-icon">
        {isEmoji(icon) ? (
          <span>{icon}</span>
        ) : (
          <iconify-icon icon={icon} style={`color: ${iconColor};`}></iconify-icon>
        )}
      </span>
      <h3 set:html={title}></h3>
      <p set:html={description}></p>
    </div>
    {techStack.length > 0 && (
      <div class="tech-stack">
        {techStack.map((tech) => (
          <span class="tag">{tech}</span>
        ))}
      </div>
    )}
  </div>
)}
