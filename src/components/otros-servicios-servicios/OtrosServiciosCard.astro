---
import "../../styles/otros-servicios-servicios/OtrosServiciosCard.css";

interface Props {
    icon: string;
    title: string;
    description: string;
    href: string;
    linkText?: string;
    colorClass?: string;
    hoverClass?: string;
}

const { 
    icon, 
    title, 
    description, 
    href, 
    linkText = "Ver más",
    colorClass = "icon-blue",
    hoverClass = "" 
} = Astro.props;
---

<div class={`servicio-card ${hoverClass}`}>
    <div class={`servicio-icon ${colorClass}`}>
        {icon.length <= 2 ? (
            <span class="emoji-icon">{icon}</span>
        ) : (
            <iconify-icon icon={icon}></iconify-icon>
        )}
    </div>
    <h4 set:html={title} />
    <p set:html={description} />
    <a href={href} class="link-mas">
        {linkText}
        <span class="arrow"> →</span>
    </a>
</div>
