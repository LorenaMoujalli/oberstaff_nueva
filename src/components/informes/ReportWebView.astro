  }
  .form-feedback.error {
    color: #ef4444;
  }
  .captcha-input.invalid {
    border-color: #ef4444 !important;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.12) !important;
  }
  .captcha-refresh-btn:hover {
    background: #6663fd !important;
    color: #fff !important;
  }
  :global(.captcha-input) {
    color: #1b1b1b !important;
  }
</style>

<style is:global>
  /* ── Toast Notification ── */
  .form-toast {
    position: fixed;
    bottom: 32px;
    right: 32px;
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-radius: 14px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
    font-family: "Poppins", sans-serif;
    font-size: 14px;
    font-weight: 500;
    max-width: 420px;
    min-width: 280px;
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
    pointer-events: auto;
  }
  .form-toast--visible {
    opacity: 1;
    transform: translateY(0);
  }
  .form-toast--success {
    background: #ffffff;
    border-left: 5px solid #22c55e;
    color: #1b1b1b;
  }
  .form-toast--error {
    background: #ffffff;
    border-left: 5px solid #ef4444;
    color: #1b1b1b;
  }
  .toast-icon {
    font-size: 20px;
    flex-shrink: 0;
  }
  .toast-msg {
    flex: 1;
    line-height: 1.5;
  }
  .toast-close {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    color: #999;
    padding: 0 2px;
    line-height: 1;
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .toast-close:hover {
    color: #333;
  }
  @media (max-width: 480px) {
    .form-toast {
      bottom: 16px;
      right: 12px;
      left: 12px;
      max-width: 100%;
      min-width: unset;
    }
  }
</style>

<script>
  // ── Toast Notification ─────────────────────────────────────────
  function showToast(message: string, type: "success" | "error" = "success") {
    const existing = document.getElementById("form-toast");
    if (existing) existing.remove();

    const toast = document.createElement("div");
    toast.id = "form-toast";
    toast.setAttribute("role", "alert");
    toast.setAttribute("aria-live", "assertive");
    toast.innerHTML = `<span class="toast-icon">${type === "success" ? "✅" : "❌"}</span><span class="toast-msg">${message}</span><button class="toast-close" aria-label="Cerrar">✕</button>`;
    toast.className = `form-toast form-toast--${type}`;
    document.body.appendChild(toast);

    // Force reflow for animation
    void toast.offsetHeight;
    toast.classList.add("form-toast--visible");

    const dismiss = () => {
      toast.classList.remove("form-toast--visible");
      setTimeout(() => toast.remove(), 400);
    };
    toast.querySelector(".toast-close")?.addEventListener("click", dismiss);
    setTimeout(dismiss, 6000);
  }

  // ── CAPTCHA Generator ──────────────────────────────────────────
  const CAPTCHA_CHARS = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";

  function generateCaptchaCode(length = 6): string {
    let code = "";
    for (let i = 0; i < length; i++) {
      code += CAPTCHA_CHARS[Math.floor(Math.random() * CAPTCHA_CHARS.length)];
    }
    return code;
  }

  function drawCaptcha(canvas: HTMLCanvasElement, code: string) {
    const ctx = canvas.getContext("2d")!;
    const w = canvas.width;
    const h = canvas.height;

    // Background
    ctx.clearRect(0, 0, w, h);
    ctx.fillStyle = "#f0f0f6";
    ctx.fillRect(0, 0, w, h);

    // Noise lines
    for (let i = 0; i < 6; i++) {
      ctx.strokeStyle = `hsl(${Math.random() * 360}, 40%, 70%)`;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(Math.random() * w, Math.random() * h);
      ctx.lineTo(Math.random() * w, Math.random() * h);
      ctx.stroke();
    }

    // Noise dots
    for (let i = 0; i < 40; i++) {
      ctx.fillStyle = `hsl(${Math.random() * 360}, 40%, 65%)`;
      ctx.beginPath();
      ctx.arc(Math.random() * w, Math.random() * h, 1, 0, Math.PI * 2);
      ctx.fill();
    }

    // Draw characters
    const charW = w / (code.length + 1);
    for (let i = 0; i < code.length; i++) {
      ctx.save();
      const x = charW * (i + 0.9);
      const y = h / 2 + 8;
      const angle = (Math.random() - 0.5) * 0.4;
      ctx.translate(x, y);
      ctx.rotate(angle);
      ctx.font = `bold ${20 + Math.random() * 6}px monospace`;
      ctx.fillStyle = `hsl(${240 + Math.random() * 60}, 55%, 35%)`;
      ctx.strokeStyle = `hsl(${240 + Math.random() * 60}, 40%, 60%)`;
      ctx.lineWidth = 0.5;
      ctx.strokeText(code[i], 0, 0);
      ctx.fillText(code[i], 0, 0);
      ctx.restore();
    }
  }

  document.querySelectorAll("form[data-webhook-url]").forEach((form) => {
    const f = form as HTMLFormElement;
    const webhookUrl = f.dataset.webhookUrl;
    if (!webhookUrl) return;

    // Skip if this form is not the ReportWebView footer form
    if (!f.classList.contains("modern-form-light")) return;

    if (f.dataset.listenerAdded) return;
    f.dataset.listenerAdded = "true";

    // CAPTCHA state
    let currentCode = "";
    const canvas = f.querySelector(".captcha-canvas") as HTMLCanvasElement;
    const captchaInput = f.querySelector(".captcha-input") as HTMLInputElement;
    const captchaRefresh = f.querySelector(
      ".captcha-refresh-btn",
    ) as HTMLButtonElement;
    const captchaError = f.querySelector(".captcha-error") as HTMLElement;

    function refreshCaptcha() {
      currentCode = generateCaptchaCode();
      drawCaptcha(canvas, currentCode);
      captchaInput.value = "";
      captchaInput.classList.remove("invalid");
      if (captchaError) captchaError.textContent = "";
    }

    refreshCaptcha();
    captchaRefresh?.addEventListener("click", refreshCaptcha);

    // Consent elements
    // Consent elements
    const consentCheckbox = f.querySelector(
      ".consent-checkbox",
    ) as HTMLInputElement;
    const consentError = f.querySelector(".consent-error") as HTMLElement;

    // Save original button text
    const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (btn) btn.dataset.originalHtml = btn.innerHTML ?? "";

    f.addEventListener("submit", async (e) => {
      e.preventDefault();
      const feedback = f.querySelector(".form-feedback") as HTMLElement;

      // ── Validate consent ──
      let hasError = false;
      if (!consentCheckbox?.checked) {
        if (consentError)
          consentError.textContent =
            "⚠ Debes aceptar el consentimiento para continuar.";
        hasError = true;
      } else {
        if (consentError) consentError.textContent = "";
      }

      // ── Validate CAPTCHA ──
      const userCode = captchaInput?.value.trim().toUpperCase();
      if (!userCode) {
        if (captchaError)
          captchaError.textContent =
            "⚠ Este campo es obligatorio. Ingresa el código de la imagen.";
        captchaInput?.classList.add("invalid");
        hasError = true;
      } else if (userCode !== currentCode) {
        refreshCaptcha();
        if (captchaError)
          captchaError.textContent =
            "❌ El código ingresado es incorrecto. Se generó un nuevo código, inténtalo de nuevo.";
        captchaInput?.classList.add("invalid");
        hasError = true;
      } else {
        if (captchaError) captchaError.textContent = "";
        captchaInput?.classList.remove("invalid");
      }

             // ── Validate required fields ──
            const requiredFields = f.querySelectorAll('[required]');
            requiredFields.forEach((el) => {
                const input = el as HTMLInputElement | HTMLSelectElement;
                if (input.type !== 'checkbox') {
                    if (!input.value || !input.value.trim()) {
                        hasError = true;
                        input.classList.add('invalid');
                    } else {
                        input.classList.remove('invalid');
                    }
                }
            });

            if (hasError) return;

      const formName = f.dataset.formName || "";
      // ── Collect data ──
      const inputs = f.querySelectorAll(
        'input:not([type="checkbox"]):not(.captcha-input), textarea',
      );
      const data: Record<string, string> = {};
      inputs.forEach((el) => {
        const input = el as HTMLInputElement | HTMLTextAreaElement;
        const placeholder = input.getAttribute("placeholder") || "";
        const key = placeholder.replace(" *", "").trim() || input.type;
        const isPhone = input.type === "tel" || input.dataset.phone === "true";
        if (key) {
          data[key] = isPhone ? `+34 ${input.value}` : input.value;
        }
      });
      data["Consentimiento SMS"] = "Aceptado";
      const pais = f.dataset.pais || "";
      if (formName) {
        data["Origen Formulario"] = formName;
      }
      if (pais) {
        data["Pais"] = pais;
      }

      btn.disabled = true;
      btn.innerHTML = "Enviando...";
      if (feedback) {
        feedback.className = "form-feedback";
        feedback.textContent = "";
      }

      try {
        // 1. Envío al webhook original (sin alterar)
        fetch(webhookUrl, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
          mode: "no-cors",
        }).catch(err => console.error("Error al enviar webhook:", err));

        // 2. Envío a la base de datos local
        fetch('/api/guardar-lead', {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            formId: f.id || 'report-webview-form',
            formName: formName || undefined,
            pais: pais || undefined,
            webhookUrl: webhookUrl,
            data: data
          }),
        }).catch(err => console.error("Error al guardar en base de datos:", err));

        f.reset();
        refreshCaptcha();
        showToast(
          "¡Mensaje enviado con éxito! Nos pondremos en contacto contigo pronto.",
          "success",
        );
      } catch {
        if (feedback) {
          feedback.className = "form-feedback error";
          feedback.textContent =
            "❌ Error al enviar. Por favor inténtalo de nuevo.";
        }
      } finally {
        btn.disabled = false;
        btn.innerHTML =
          btn.dataset.originalHtml ?? "SOLICITAR AUDITORÍA OPERATIVA GRATUITA";
      }
    });

    // Clear captcha error on input
    captchaInput?.addEventListener("input", () => {
      captchaInput.classList.remove("invalid");
      if (captchaError) captchaError.textContent = "";
    });

    // Clear consent error on check
    consentCheckbox?.addEventListener("change", () => {
      if (consentCheckbox.checked && consentError)
        consentError.textContent = "";
    });
  });
</script>
