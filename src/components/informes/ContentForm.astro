---
import "../../styles/informes/ContentForm.css";
import InformePdf from "./informe-pdf.astro";

interface Props {
  webhookUrl?: string;
}

const { webhookUrl = "" } = Astro.props;
---

<!-- Cargar html2pdf.js desde CDN para evitar problemas de optimización/pre-bundling de Vite -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" referrerpolicy="no-referrer"></script>

<!-- Contenedor para la generación del PDF (se mantiene en el DOM pero no ocupa espacio visual) -->
<div
  style="height: 0; overflow: hidden; position: absolute; top: 0; width: 210mm; z-index: -1;"
>
  <InformePdf />
</div>

<form class="modern-form" id="report-download-form" data-webhook-url={webhookUrl}>
  <div class="form-group">
    <input
      type="text"
      name="name"
      id="userName"
      placeholder="Nombre completo *"
      required
    />
  </div>

  <div class="form-group">
    <input
      type="email"
      name="email"
      id="userEmail"
      placeholder="Email corporativo *"
      required
    />
  </div>

  <div class="form-group">
    <select name="role" required>
      <option value="" disabled selected hidden>Selecciona tu cargo *</option>
      <option value="CEO / Fundador">CEO / Fundador</option>
      <option value="CFO / Dirección Financiera">CFO / Dirección Financiera</option>
      <option value="HR / Recursos Humanos">HR / Recursos Humanos</option>
      <option value="Otro">Otro</option>
    </select>
  </div>

  <!-- SMS Consent Checkbox -->
  <div class="form-group full-width consent-group" style="margin-bottom: 15px;">
      <label class="consent-label" style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer; text-align: left;">
          <input
              type="checkbox"
              id="sms-consent"
              class="consent-checkbox"
              required
              style="flex-shrink: 0; width: 18px; height: 18px; margin-top: 3px; accent-color: #6663FD; cursor: pointer;"
          />
          <span class="consent-text" style="font-family: 'Poppins', sans-serif; font-size: 10px; line-height: 1.6; color: #d0d0d0;">
              <strong>Al facilitar su número de teléfono</strong>, aceptas recibir mensajes SMS relacionados con atención al cliente de <strong>Oberstaff<span style="color: #FF66CC;">.</span></strong>
              La frecuencia de los mensajes puede variar. Pueden aplicarse tarifas estándar de mensajes y datos.
              Responde STOP para cancelar la suscripción. Responde Help para obtener ayuda.
              <a href="/politica-de-privacidad-y-cookies-de-oberstaff" target="_blank" class="consent-link" style="color: #6663FD; text-decoration: underline;">Política de privacidad y uso de cookies.</a>
              <span class="required-star" style="color: #ef4444; font-weight: 700; margin-left: 2px;">*</span>
          </span>
      </label>
      <p class="consent-error" id="consent-error" aria-live="polite" style="font-size: 12px; color: #ef4444; margin-top: 4px; min-height: 1em; text-align: left;"></p>
  </div>

  <!-- CAPTCHA Verification -->
  <div class="form-group full-width captcha-group" style="margin-bottom: 20px; text-align: left;">
      <label class="captcha-label" style="font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600; color: #ffffff; display: block; margin-bottom: 4px;">Código de verificación <span class="required-star" style="color: #ef4444; font-weight: 700; margin-left: 2px;">*</span></label>
      <p class="captcha-hint" style="font-family: 'Poppins', sans-serif; font-size: 12px; color: #888; margin: 0 0 8px 0;">Ingresa el texto que ves en la imagen</p>
      <div class="captcha-input-row" style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
          <input
              type="text"
              id="captcha-input"
              class="captcha-input"
              placeholder="Escribe el código"
              autocomplete="off"
              maxlength="8"
              required
              style="font-family: 'Poppins', sans-serif; background-color: #FAFAFC; border: 1px solid #E0E0E0; padding: 10px 14px; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.3s ease, box-shadow 0.3s ease; width: 200px; color: #1B1B1B; letter-spacing: 2px;"
          />
          <button type="button" id="captcha-refresh" class="captcha-refresh-btn" title="Nuevo código" aria-label="Generar nuevo código" style="background: none; border: 1.5px solid #6663FD; border-radius: 6px; color: #6663FD; font-size: 18px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s, color 0.2s; padding: 0; flex-shrink: 0;">
              &#x21bb;
          </button>
      </div>
      <canvas id="captcha-canvas" class="captcha-canvas" width="200" height="60" aria-label="Código de verificación visual" style="display: block; border-radius: 8px; border: 1px solid #ddd; background: #f4f4f8; user-select: none; pointer-events: none;"></canvas>
      <p class="captcha-error" id="captcha-error" aria-live="polite" style="font-size: 12px; color: #ef4444; margin-top: 4px; min-height: 1em;"></p>
  </div>

  <button type="submit" class="btn-download-main" id="submitBtn">
    <span class="btn-icon">🔓</span>
    <span class="btn-text">
      DESCARGAR <span class="text-accent">INFORME ESTRATÉGICO</span> AHORA
    </span>
  </button>
</form>

<p class="footer-microcopy">
  PDF gratuito. Lectura de 5 minutos diseñada para Dirección Financiera.
</p>

<style>
  .captcha-input.invalid {
      border-color: #ef4444 !important;
      box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.12) !important;
  }
  .captcha-refresh-btn:hover {
      background: #6663FD !important;
      color: #fff !important;
  }
</style>

<style is:global>
    /* ── Toast Notification ── */
    .form-toast {
        position: fixed;
        bottom: 32px;
        right: 32px;
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        border-radius: 14px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18);
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        font-weight: 500;
        max-width: 420px;
        min-width: 280px;
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.35s ease, transform 0.35s ease;
        pointer-events: auto;
    }
    .form-toast--visible {
        opacity: 1;
        transform: translateY(0);
    }
    .form-toast--success {
        background: #ffffff;
        border-left: 5px solid #22c55e;
        color: #1b1b1b;
    }
    .form-toast--error {
        background: #ffffff;
        border-left: 5px solid #ef4444;
        color: #1b1b1b;
    }
    .toast-icon {
        font-size: 20px;
        flex-shrink: 0;
    }
    .toast-msg {
        flex: 1;
        line-height: 1.5;
    }
    .toast-close {
        background: none;
        border: none;
        cursor: pointer;
        font-size: 14px;
        color: #999;
        padding: 0 2px;
        line-height: 1;
        flex-shrink: 0;
        transition: color 0.2s;
    }
    .toast-close:hover {
        color: #333;
    }
    @media (max-width: 480px) {
        .form-toast {
            bottom: 16px;
            right: 12px;
            left: 12px;
            max-width: 100%;
            min-width: unset;
        }
    }
</style>

<script>
  // ── Toast Notification ─────────────────────────────────────────
  function showToast(message: string, type: 'success' | 'error' = 'success') {
      const existing = document.getElementById('form-toast');
      if (existing) existing.remove();

      const toast = document.createElement('div');
      toast.id = 'form-toast';
      toast.setAttribute('role', 'alert');
      toast.setAttribute('aria-live', 'assertive');
      toast.innerHTML = `<span class="toast-icon">${type === 'success' ? '✅' : '❌'}</span><span class="toast-msg">${message}</span><button class="toast-close" aria-label="Cerrar">✕</button>`;
      toast.className = `form-toast form-toast--${type}`;
      document.body.appendChild(toast);

      // Force reflow for animation
      void toast.offsetHeight;
      toast.classList.add('form-toast--visible');

      const dismiss = () => {
          toast.classList.remove('form-toast--visible');
          setTimeout(() => toast.remove(), 400);
      };
      toast.querySelector('.toast-close')?.addEventListener('click', dismiss);
      setTimeout(dismiss, 6000);
  }

  // ── CAPTCHA Generator ──────────────────────────────────────────
  const CAPTCHA_CHARS = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';

  function generateCaptchaCode(length = 6): string {
      let code = '';
      for (let i = 0; i < length; i++) {
          code += CAPTCHA_CHARS[Math.floor(Math.random() * CAPTCHA_CHARS.length)];
      }
      return code;
  }

  function drawCaptcha(canvas: HTMLCanvasElement, code: string) {
      const ctx = canvas.getContext('2d')!;
      const w = canvas.width;
      const h = canvas.height;

      // Background
      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = '#f0f0f6';
      ctx.fillRect(0, 0, w, h);

      // Noise lines
      for (let i = 0; i < 6; i++) {
          ctx.strokeStyle = `hsl(${Math.random() * 360}, 40%, 70%)`;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(Math.random() * w, Math.random() * h);
          ctx.lineTo(Math.random() * w, Math.random() * h);
          ctx.stroke();
      }

      // Noise dots
      for (let i = 0; i < 40; i++) {
          ctx.fillStyle = `hsl(${Math.random() * 360}, 40%, 65%)`;
          ctx.beginPath();
          ctx.arc(Math.random() * w, Math.random() * h, 1, 0, Math.PI * 2);
          ctx.fill();
      }

      // Draw characters
      const charW = w / (code.length + 1);
      for (let i = 0; i < code.length; i++) {
          ctx.save();
          const x = charW * (i + 0.9);
          const y = h / 2 + 8;
          const angle = (Math.random() - 0.5) * 0.4;
          ctx.translate(x, y);
          ctx.rotate(angle);
          ctx.font = `bold ${20 + Math.random() * 6}px monospace`;
          ctx.fillStyle = `hsl(${240 + Math.random() * 60}, 55%, 35%)`;
          ctx.strokeStyle = `hsl(${240 + Math.random() * 60}, 40%, 60%)`;
          ctx.lineWidth = 0.5;
          ctx.strokeText(code[i], 0, 0);
          ctx.fillText(code[i], 0, 0);
          ctx.restore();
      }
  }

  const form = document.getElementById(
    "report-download-form",
  ) as HTMLFormElement;
  const btn = document.getElementById("submitBtn") as HTMLButtonElement;

  console.log("PDF Generator Initialized");

  // CAPTCHA state
  let currentCode = '';
  const canvas = form?.querySelector('#captcha-canvas') as HTMLCanvasElement;
  const captchaInput = form?.querySelector('#captcha-input') as HTMLInputElement;
  const captchaRefresh = form?.querySelector('#captcha-refresh') as HTMLButtonElement;
  const captchaError = form?.querySelector('#captcha-error') as HTMLElement;

  function refreshCaptcha() {
      if (canvas && captchaInput) {
          currentCode = generateCaptchaCode();
          drawCaptcha(canvas, currentCode);
          captchaInput.value = '';
          captchaInput.classList.remove('invalid');
          if (captchaError) captchaError.textContent = '';
      }
  }

  if (form) {
      refreshCaptcha();
      captchaRefresh?.addEventListener('click', refreshCaptcha);
  }

  // Consent elements
  const consentCheckbox = form?.querySelector('#sms-consent') as HTMLInputElement;
  const consentError = form?.querySelector('#consent-error') as HTMLElement;

  // === FUNCIÓN: Desbloquear contenido web ===
  function unlockReportContent() {
    const gateOverlay = document.getElementById('contentGateOverlay');
    const mainContent = document.getElementById('mainReportContent');
    const body = document.body;

    // 1. Desvanecer y ocultar el formulario
    if (gateOverlay) {
      gateOverlay.style.transition = 'opacity 0.3s ease';
      gateOverlay.style.opacity = '0';
      setTimeout(() => {
        gateOverlay.style.display = 'none';
      }, 300);
    }

    // 2. Revelar el contenido del informe web
    if (mainContent) {
      mainContent.classList.remove('locked-content');
      mainContent.classList.add('unlocked-content');
    }

    // 3. Restaurar scroll y cambiar fondo de body
    body.classList.remove('locked-scroll');
    body.classList.add('report-unlocked');
    body.style.background = '#ffffff';
    body.style.backgroundImage = 'none';

    // 4. Animar el gráfico TCO
    setTimeout(() => {
      const chartContainer = document.querySelector('.chart-container');
      if (chartContainer) chartContainer.classList.add('animate-chart');
    }, 400);

    // 5. Scroll suave al inicio del contenido
    setTimeout(() => {
      if (mainContent) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }, 400);
  }

   if (form && !form.dataset.listenerAdded) {
    form.dataset.listenerAdded = "true";
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // ── Validate consent ──
      let hasError = false;
      if (!consentCheckbox?.checked) {
          if (consentError) consentError.textContent = '⚠ Debes aceptar el consentimiento para continuar.';
          hasError = true;
      } else {
          if (consentError) consentError.textContent = '';
      }

      // ── Validate CAPTCHA ──
      const userCode = captchaInput?.value.trim().toUpperCase();
      if (!userCode) {
          if (captchaError) captchaError.textContent = '⚠ Este campo es obligatorio. Ingresa el código de la imagen.';
          captchaInput?.classList.add('invalid');
          hasError = true;
      } else if (userCode !== currentCode) {
          refreshCaptcha();
          if (captchaError) captchaError.textContent = '❌ El código ingresado es incorrecto. Se generó un nuevo código, inténtalo de nuevo.';
          captchaInput?.classList.add('invalid');
          hasError = true;
      } else {
          if (captchaError) captchaError.textContent = '';
          captchaInput?.classList.remove('invalid');
      }

      // ── Validate required fields ──
      const requiredFields = form.querySelectorAll('[required]');
      requiredFields.forEach((el) => {
          const input = el as HTMLInputElement | HTMLSelectElement;
          if (input.type !== 'checkbox') {
              if (!input.value || !input.value.trim()) {
                  hasError = true;
                  input.classList.add('invalid');
              } else {
                  input.classList.remove('invalid');
              }
          }
      });

      if (hasError) return;

    // Send the lead to Zapier
    const data: Record<string, string> = {
        Nombre: (document.getElementById('userName') as HTMLInputElement)?.value || '',
        Email: (document.getElementById('userEmail') as HTMLInputElement)?.value || '',
        Cargo: (form.querySelector('select[name="role"]') as HTMLSelectElement)?.value || '',
        'Consentimiento SMS': 'Aceptado'
    };

    // Send lead to webhook asynchronously
    const gateWebhookUrl = document.getElementById('report-download-form')?.dataset.webhookUrl || "https://hooks.zapier.com/hooks/catch/12433184/4bye64r/";
    // 1. Envío al webhook original (sin alterar)
    fetch(gateWebhookUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        mode: 'no-cors'
    }).catch(err => console.error("Error al enviar webhook:", err));

    // 2. Envío a la base de datos local
    fetch('/api/guardar-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            formId: 'report-download-form',
            webhookUrl: gateWebhookUrl,
            data: data
        })
    }).catch(err => console.error("Error al guardar en base de datos:", err));

    // Feedback visual en el botón (solo deshabilitar)
    btn.disabled = true;

    const element = document.getElementById("report-pdf-template");

    if (!element) {
      console.error("No se encontró la plantilla del PDF");
      return;
    }

    const opt = {
      margin: 0,
      filename: "Informe-Oberstaff-Talento-Internacional.pdf",
      image: { type: "jpeg", quality: 0.98 },
      html2canvas: {
        scale: 2,
        useCORS: true,
        letterRendering: true,
        backgroundColor: "#ffffff",
        scrollX: 0,
        scrollY: 0,
      },
      jsPDF: { unit: "mm", format: "a4", orientation: "portrait" },
      pagebreak: { mode: ["avoid-all", "css", "legacy"] },
    };

    try {
      // @ts-ignore
      await html2pdf().set(opt).from(element).save();

      // Desbloquear el contenido web
      unlockReportContent();

    } catch (error) {
      console.error("Error al generar PDF:", error);
      btn.disabled = false;
      refreshCaptcha();
    }
  });
}

  // Clear captcha error on input
  captchaInput?.addEventListener('input', () => {
      captchaInput.classList.remove('invalid');
      if (captchaError) captchaError.textContent = '';
  });

  // Clear consent error on check
  consentCheckbox?.addEventListener('change', () => {
      if (consentCheckbox.checked && consentError) consentError.textContent = '';
  });

  // === SMOOTH SCROLL para enlaces internos del informe ===
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const link = target.closest('a[href^="#"]') as HTMLAnchorElement | null;
    if (link) {
      e.preventDefault();
      const dest = document.querySelector(link.getAttribute('href') || '');
      if (dest) {
        window.scrollTo({
          top: (dest as HTMLElement).offsetTop - 50,
          behavior: 'smooth'
        });
      }
    }
  });
</script>