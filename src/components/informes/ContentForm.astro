---
import "../../styles/informes/ContentForm.css";
import InformePdf from "./informe-pdf.astro";
---

<!-- Contenedor para la generación del PDF (se mantiene en el DOM pero no ocupa espacio visual) -->
<div
  style="height: 0; overflow: hidden; position: absolute; top: 0; width: 210mm; z-index: -1;"
>
  <InformePdf />
</div>

<form class="modern-form" id="report-download-form">
  <div class="form-group">
    <input
      type="text"
      name="name"
      id="userName"
      placeholder="Nombre completo *"
      required
    />
  </div>

  <div class="form-group">
    <input
      type="email"
      name="email"
      id="userEmail"
      placeholder="Email corporativo *"
      required
    />
  </div>

  <div class="form-group">
    <select name="role" required>
      <option value="" disabled selected hidden>Selecciona tu cargo *</option>
      <option value="CEO">CEO / Fundador</option>
      <option value="CFO">CFO / Dirección Financiera</option>
      <option value="HR">HR / Recursos Humanos</option>
      <option value="Otro">Otro</option>
    </select>
  </div>

  <button type="submit" class="btn-download-main" id="submitBtn">
    <span class="btn-icon">🔓</span>
    <span class="btn-text">
      DESCARGAR <span class="text-accent">INFORME ESTRATÉGICO</span> AHORA
    </span>
  </button>
</form>

<p class="footer-microcopy">
  PDF gratuito. Lectura de 5 minutos diseñada para Dirección Financiera.
</p>

<script>
  // @ts-ignore
  import html2pdf from "html2pdf.js/dist/html2pdf.js";

  const form = document.getElementById(
    "report-download-form",
  ) as HTMLFormElement;
  const btn = document.getElementById("submitBtn") as HTMLButtonElement;

  console.log("PDF Generator Initialized");

  // === FUNCIÓN: Desbloquear contenido web ===
  function unlockReportContent() {
    const gateOverlay = document.getElementById('contentGateOverlay');
    const mainContent = document.getElementById('mainReportContent');
    const body = document.body;

    // 1. Desvanecer y ocultar el formulario
    if (gateOverlay) {
      gateOverlay.style.transition = 'opacity 0.3s ease';
      gateOverlay.style.opacity = '0';
      setTimeout(() => {
        gateOverlay.style.display = 'none';
      }, 300);
    }

    // 2. Revelar el contenido del informe web
    if (mainContent) {
      mainContent.classList.remove('locked-content');
      mainContent.classList.add('unlocked-content');
    }

    // 3. Restaurar scroll y cambiar fondo de body
    body.classList.remove('locked-scroll');
    body.classList.add('report-unlocked');
    body.style.background = '#ffffff';
    body.style.backgroundImage = 'none';

    // 4. Animar el gráfico TCO
    setTimeout(() => {
      const chartContainer = document.querySelector('.chart-container');
      if (chartContainer) chartContainer.classList.add('animate-chart');
    }, 400);

    // 5. Scroll suave al inicio del contenido
    setTimeout(() => {
      if (mainContent) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }, 400);
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Feedback visual en el botón (solo deshabilitar)
    btn.disabled = true;

    const element = document.getElementById("report-pdf-template");

    if (!element) {
      console.error("No se encontró la plantilla del PDF");
      return;
    }

    const opt = {
      margin: 0,
      filename: "Informe-Oberstaff-Talento-Internacional.pdf",
      image: { type: "jpeg", quality: 0.98 },
      html2canvas: {
        scale: 2,
        useCORS: true,
        letterRendering: true,
        backgroundColor: "#ffffff",
        scrollX: 0,
        scrollY: 0,
      },
      jsPDF: { unit: "mm", format: "a4", orientation: "portrait" },
      pagebreak: { mode: ["avoid-all", "css", "legacy"] },
    };

    try {
      // @ts-ignore
      await html2pdf().set(opt).from(element).save();

      // Desbloquear el contenido web
      unlockReportContent();

    } catch (error) {
      console.error("Error al generar PDF:", error);
      btn.disabled = false;
    }
  });

  // === SMOOTH SCROLL para enlaces internos del informe ===
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const link = target.closest('a[href^="#"]') as HTMLAnchorElement | null;
    if (link) {
      e.preventDefault();
      const dest = document.querySelector(link.getAttribute('href') || '');
      if (dest) {
        window.scrollTo({
          top: (dest as HTMLElement).offsetTop - 50,
          behavior: 'smooth'
        });
      }
    }
  });
</script>