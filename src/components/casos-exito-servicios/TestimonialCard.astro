---
import "../../styles/casos-exito-servicios/TestimonialCard.css";

interface Props {
    stars: number;
    text: string;
    author: string;
    role: string;
    avatar?: string;
    videoId?: string;
    imageAlt?: string;
}

const { stars, text, author, role, avatar, videoId, imageAlt } = Astro.props;

const isPrPage = Astro.url.pathname.startsWith('/pr') || Astro.url.pathname.includes('/pr/');
const isSpainPage = !isPrPage;

const formattedText = isSpainPage 
    ? text.replace(/Oberstaff\.?/gi, "<strong style='font-weight: 700;'>Oberstaff<span style='color: #FF66CC;'>.</span></strong>")
    : text;
---

<div class={`testimonial-card ${isPrPage ? 'is-pr-page' : ''}`}>

    <!-- Header: avatar + estrellas + nombre + cargo -->
    <div class="testimonial-header">
        {avatar && (
            <img
                src={avatar}
                alt={imageAlt || `Foto de ${author}`}
                class="testimonial-avatar"
            />
        )}
        <div class="testimonial-header-info">
            <div class="stars">
                {[...Array(stars)].map((_) => (
                    <span>★</span>
                ))}
            </div>
            <p class="testimonial-author"><strong>{author}</strong></p>
            <p class="testimonial-role">{role}</p>
        </div>
    </div>

    <!-- Cita -->
    <blockquote class="testimonial-text">
        <span set:html={`"${formattedText}"`}></span>
        <cite style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;">{author}, {role}</cite>
    </blockquote>

    {videoId && (
        <button type="button" class="video-link open-testimonial-video" data-video-id={videoId}>
            Ver testimonio en vídeo →
        </button>
    )}
</div>
