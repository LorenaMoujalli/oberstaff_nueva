---
import "../../styles/casos-exito-servicios/TestimonialCard.css";

interface Props {
    stars: number;
    text: string;
    author: string;
    role: string;
    avatar?: string;
    videoId?: string;
}

const { stars, text, author, role, avatar, videoId } = Astro.props;
---

<div class="testimonial-card">

    <!-- Header: avatar + estrellas + nombre + cargo -->
    <div class="testimonial-header">
        {avatar && (
            <img
                src={avatar}
                alt={`Foto de ${author}`}
                class="testimonial-avatar"
            />
        )}
        <div class="testimonial-header-info">
            <div class="stars">
                {[...Array(stars)].map((_) => (
                    <span>★</span>
                ))}
            </div>
            <h4 class="testimonial-author">{author}</h4>
            <p class="testimonial-role">{role}</p>
        </div>
    </div>

    <!-- Cita -->
    <p class="testimonial-text" set:html={`"${text}"`}></p>

    {videoId && (
        <a href="javascript:void(0)" class="video-link open-testimonial-video" data-video-id={videoId}>
            Ver testimonio en vídeo →
        </a>
    )}
</div>
