---
import "../../styles/eor-steps-servicios/EorSteps.css";
import StepItem from "./StepItem.astro";

interface Step {
    title: string;
    description: string;
    lineColorClass: string;
}

interface Props {
    label?: string;
    title: string;
    subtitle: string;
    steps: Step[];
}

const { label, title, subtitle, steps } = Astro.props;
---

<section class="eor-steps">
    <div class="steps-header">
        {label && <span class="section-label" style="display: block; color: #ff66cc; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 15px;">{label}</span>}
        <h2 set:html={title}></h2>
        <p>{subtitle}</p>
    </div>

    <div class="steps-grid">
        {steps.map((step) => (
            <StepItem 
                title={step.title}
                description={step.description}
                lineColorClass={step.lineColorClass}
            />
        ))}
    </div>
</section>
