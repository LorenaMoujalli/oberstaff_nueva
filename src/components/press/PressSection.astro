---
import PressHeader from "./PressHeader.astro";
import PressItem from "./PressItem.astro";
import "../../styles/press/press-section.css";

interface Mention {
    name: string;
    className: string;
    href: string;
    logo: string;
    alt: string;
}

interface Props {
    title?: string;
    mentions?: Mention[];
    trustBadgeText?: string;
}

const {
    title = "Nos han mencionado en:",
    mentions: customMentions,
    trustBadgeText = "Solución segura para <strong>contratar talentos en el extranjero</strong> con soporte integral"
} = Astro.props;

const spainDefaultMentions: Mention[] = [
    {
        name: "Madridiario",
        className: "mdo-madridiario",
        href: "https://www.madridiario.es/actualidad-empresarial/fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas-7128?target=external",
        logo: "/logo-madridiario.webp",
        alt: "Logo de Madridiario, medio que mencionó a Oberstaff"
    },
    {
        name: "El Mundo Financiero",
        className: "em-financiero",
        href: "https://www.elmundofinanciero.com/seccion/40/actividad-empresarial/fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas-7606?target=external",
        logo: "/logo-mundo-financiero.webp",
        alt: "Logo de El Mundo Financiero, medio que mencionó a Oberstaff"
    },
    {
        name: "Region Digital",
        className: "region-digital",
        href: "https://www.regiondigital.com/empresas/fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas-9827?target=external",
        logo: "/logo-region-digital.webp",
        alt: "Logo de Región Digital, medio que mencionó a Oberstaff"
    },
    {
        name: "Cámara de Comercio",
        className: "camara-comercio",
        href: "https://www.camaraespanapr.org",
        logo: "/logo-camara-comercio.webp",
        alt: "Logo de Cámara de Comercio, patrocinador oficial de Oberstaff"
    },
    {
        name: "Digital Sevilla",
        className: "digital-sevilla",
        href: "https://digitalsevilla.com/2026/02/14/fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas/?target=external",
        logo: "/logo-digital-sevilla.webp",
        alt: "Logo de Digital Sevilla"
    },
    {
        name: "Negocios Expansión",
        className: "negocios",
        href: "https://negociosexpansion.com/fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas?target=external",
        logo: "/logo-negocios.webp",
        alt: "Logo de Negocios"
    },
    {
        name: "Orientario",
        className: "orientario",
        href: "https://orientarioja.com/fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas?target=external",
        logo: "/logo-orientario.webp",
        alt: "Logo de Orientario"
    },
    {
        name: "Madrid Noticias",
        className: "madrid-noticias",
        href: "https://madrid-noticias.com/actualidad-empresarial/175033-fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas.htm?target=external",
        logo: "/logo-madrid-noticias.webp",
        alt: "Logo de Madrid Noticias"
    },
    {
        name: "Reporteros sin fronteras",
        className: "rsf",
        href: "https://informeanualrsf.es/fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas?target=external",
        logo: "/logo-rsf.webp",
        alt: "Logo de RSF"
    }
];

const prDefaultMentions: Mention[] = [
    {
        name: "Madridiario",
        className: "mdo-madridiario",
        href: "https://www.madridiario.es/actualidad-empresarial/fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas-7128?target=external",
        logo: "/logo-madridiario.webp",
        alt: "Logo de Madridiario, medio que mencionó a Oberstaff"
    },
    {
        name: "El Mundo Financiero",
        className: "em-financiero",
        href: "https://www.elmundofinanciero.com/seccion/40/actividad-empresarial/fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas-7606?target=external",
        logo: "/logo-mundo-financiero.webp",
        alt: "Logo de El Mundo Financiero, medio que mencionó a Oberstaff"
    },
    {
        name: "Region Digital",
        className: "region-digital",
        href: "https://www.regiondigital.com/empresas/fuga-de-capital-la-friccion-operativa-y-el-sobrecosto-del-talento-estan-frenando-las-pymes-espanolas-9827?target=external",
        logo: "/logo-region-digital.webp",
        alt: "Logo de Región Digital, medio que mencionó a Oberstaff"
    },
    {
        name: "Cámara de Comercio",
        className: "camara-comercio",
        href: "https://www.camaraespanapr.org",
        logo: "/logo-camara-comercio.webp",
        alt: "Logo de Cámara de Comercio, patrocinador oficial de Oberstaff"
    }
];

const isPrPage = Astro.url.pathname.startsWith('/pr') || Astro.url.pathname.includes('/pr/');
const mentions = customMentions || (isPrPage ? prDefaultMentions : spainDefaultMentions);

const isPrHome = Astro.url.pathname.includes('/pr') && !Astro.url.pathname.includes('/perfiles/') && !Astro.url.pathname.includes('/servicios/');
---

<section class={`press-mentions ${isPrHome ? 'is-pr-home' : ''}`}>
    <div class="press-container">
        <PressHeader title={title} />

        <div class="mentions-wrapper">
            {mentions.map((mention) => (
                <PressItem 
                    name={mention.name} 
                    className={mention.className}
                    href={mention.href}
                >
                    <img
                        src={mention.logo}
                        alt={mention.alt}
                        class="press-logo"
                        aria-hidden="true"
                    />
                </PressItem>
            ))}
        </div>
 
        <div style="text-align: center;">
            <div class="press-trust-badge">
                <span class="badge-icon" aria-hidden="true">
                    ✅
                </span>
                <span set:html={trustBadgeText} />
            </div>
        </div>
    </div>
</section>
