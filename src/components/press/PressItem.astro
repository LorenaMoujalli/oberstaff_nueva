---
import "../../styles/press/press-item.css";

interface Props {
    name: string;
    className?: string;
    href?: string;
}

const { name, className = "", href } = Astro.props;
---

<div class={`mention-item ${className}`}>
    {href ? (
        <a href={href} target="_blank" rel="noopener noreferrer" title={name}>
            <slot />
        </a>
    ) : (
        <slot />
    )}
</div>
