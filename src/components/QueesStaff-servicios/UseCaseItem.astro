---
import "../../styles/QueesStaff-servicios/use-case-item.css";

interface Props {
  icon?: string;
  colorClass?: string;
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<div class="use-case-item">
    <div class="uc-header">
        <h3>{title}</h3>
    </div>
    <p>{description}</p>
</div>
