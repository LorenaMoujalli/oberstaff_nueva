---
import "../../styles/banner-patrocinadores/trust-section.css";
---

<section class="trust-section">
    <div class="trust-container">
        <h2 class="trust-title">
            Patrocinadores oficiales
        </h2>

        <div class="sponsors-static">
            <img src="/logo-one-planet.webp" alt="Logo de One Planet, patrocinador oficial de Oberstaff" class="sponsor-logo logo-oneplanet" aria-hidden="true" />
            <img src="/logo-camara-comercio.webp" alt="Logo de Cámara de Comercio, patrocinador oficial de Oberstaff" class="sponsor-logo logo-camara" aria-hidden="true" />
        </div>

        <div class="trust-description">
            <p>
               ✅ Solución segura para <strong
                    >Contratar talentos en el extranjero</strong
                > con soporte integral
            </p>
        </div>
    </div>
</section>
