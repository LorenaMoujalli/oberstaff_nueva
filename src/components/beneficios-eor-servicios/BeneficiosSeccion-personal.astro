---
import "../../styles/beneficios-eor-servicios/beneficios-personal.css";
import BeneficioItem from "./BeneficioItem.astro";

interface Beneficio {
    icon: string;
    title: string;
    description: string;
    colorClass: string;
}

interface Props {
    beneficios: Beneficio[];
}

const { beneficios } = Astro.props;
---

<section class="beneficios-personal">
    <div class="beneficios-personal-container">
        <div class="beneficios-personal-header">
            <h2>Somos tu empresa selección de personal remoto</h2>
            <h3>Todo el ciclo laboral, externalizado.</h3>
            <p>Desde la búsqueda del candidato en LATAM hasta la gestión mensual de la nómina. Oberstaff cubre cada fase, las empresas españolas solo tienen que dirigir el trabajo.</p>
        </div>

        <div class="beneficios-personal-grid">
            {beneficios.map((beneficio) => (
                <BeneficioItem 
                    icon={beneficio.icon}
                    title={beneficio.title}
                    description={beneficio.description}
                    colorClass={beneficio.colorClass}
                />
            ))}
        </div>
    </div>
</section>
