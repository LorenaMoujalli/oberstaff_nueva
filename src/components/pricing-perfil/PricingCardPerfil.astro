---
import "../../styles/pricing-perfil/pricing-card.css";

interface Props {
    sectionTitle?: string;
    sectionSubtitle?: string;
    cardTitle?: string;
    cardSubtitle?: string;
    priceLabel?: string;
    priceAmount?: string;
    pricePeriod?: string;
    features?: string[];
    ctaText?: string;
    ctaHref?: string;
    disclaimer?: string;
    titleTag?: string;
}

const {
    sectionTitle = "",
    sectionSubtitle = "",
    cardTitle = "Fee integral",
    cardSubtitle = "Jornada completa dedicada a tu línea gráfica",
    priceLabel = "DESDE",
    priceAmount = "850€",
    pricePeriod = "/ mes",
    features = [],
    ctaText = "Solicitar propuesta",
    ctaHref = "#",
    disclaimer = "",
    titleTag = "h3",
} = Astro.props;

const TitleTag = titleTag as any;
---

<section class="pricing-card-section">
    <div class="pricing-card-wrapper">
        {(sectionTitle || sectionSubtitle) && (
            <div class="pricing-section-header">
                {sectionTitle && <h2 class="pricing-section-title" set:html={sectionTitle}></h2>}
                {sectionSubtitle && <p class="pricing-section-subtitle" set:html={sectionSubtitle}></p>}
            </div>
        )}

        <div class="pricing-card-new">
            <!-- Left column -->
            <div class="pricing-left">
                <TitleTag class="pricing-card-title">{cardTitle}</TitleTag>
                <p class="pricing-card-subtitle">{cardSubtitle}</p>

                <div class="pricing-price-block">
                    <span class="pricing-label">{priceLabel}</span>
                    <span class="pricing-amount">{priceAmount}</span>
                    <span class="pricing-period">{pricePeriod}</span>
                </div>

                <a href={ctaHref} class="pricing-cta-btn">{ctaText}</a>

                {disclaimer && <p class="pricing-disclaimer" set:html={disclaimer}></p>}
            </div>

            <!-- Divider -->
            <div class="pricing-divider-v"></div>

            <!-- Right column: features -->
            <div class="pricing-right">
                {features.length > 0 && (
                    <ul class="pricing-features-list">
                        {features.map((f) => (
                            <li class="pricing-feature-item">
                                <span class="pricing-check" aria-hidden="true">✓</span>
                                <span set:html={f}></span>
                            </li>
                        ))}
                    </ul>
                )}
            </div>
        </div>
    </div>
</section>
