---
import "../../styles/franja-empresas-home/FranjaEmpresasHome.css";

interface Props {
    stat1Number: string;
    stat1Label: string;
    stat2Number: string;
    stat2Label: string;
    stat3Number?: string;
    stat3Label?: string;
}

const { stat1Number, stat1Label, stat2Number, stat2Label, stat3Number, stat3Label } = Astro.props;
---

<div class="franja-empresas-section">
    <div class="franja-empresas-container">
        
        <!-- Bloque Izquierdo: Estadísticas -->
        <div class="franja-stats-left">
            <div class="franja-stat-block">
                <span class="franja-number franja-gradient-text">{stat1Number}</span>
                <span class="franja-label" set:html={stat1Label}></span>
            </div>

            <div class="franja-vertical-divider"></div>

            <div class="franja-stat-block">
                <span class="franja-number franja-gradient-text">{stat2Number}</span>
                <span class="franja-label" set:html={stat2Label}></span>
            </div>

            {stat3Number && stat3Label && (
                <>
                    <div class="franja-vertical-divider"></div>

                    <div class="franja-stat-block">
                        <span class="franja-number franja-gradient-text">{stat3Number}</span>
                        <span class="franja-label" set:html={stat3Label}></span>
                    </div>
                </>
            )}
        </div>

        <!-- Bloque Derecho: Slider de Logos -->
        <div class="franja-logos-slider">
            <div class="logos-track">
                <!-- Logos dinámicos de public -->
                <img src="/logo-terranova.webp" alt="Logo de Terranova, empresa que confía en Oberstaff" class="logo-item" />
                <img src="/logo-orion.webp" alt="Logo de Orion, empresa que confía en Oberstaff" class="logo-item" />
                <img src="/logo-aether-nexus.webp" alt="Logo de Aether Nexus, empresa que confía en Oberstaff" class="logo-item" />
                <img src="/logo-orbital.webp" alt="Logo de Orbital, empresa que confía en Oberstaff" class="logo-item" />
                <img src="/logo-aether.webp" alt="Logo de Aether, empresa que confía en Oberstaff" class="logo-item" />
                
                <!-- Duplicados para el loop suave -->
                <img src="/logo-terranova.webp" alt="" class="logo-item" aria-hidden="true" />
                <img src="/logo-orion.webp" alt="" class="logo-item" aria-hidden="true" />
                <img src="/logo-aether-nexus.webp" alt="" class="logo-item" aria-hidden="true" />
                <img src="/logo-orbital.webp" alt="" class="logo-item" aria-hidden="true" />
                <img src="/logo-aether.webp" alt="" class="logo-item" aria-hidden="true" />
            </div>
        </div>

    </div>
</div>
