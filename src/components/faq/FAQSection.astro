---
import FAQItem from "./FAQItem.astro";
import "../../styles/faq/faq-section.css";

interface FAQ {
    question: string;
    answers?: string[];
    content?: string;
}

const homeFaqs: FAQ[] = [
    {
        question: "¿Es legal contratar talento en LATAM desde España y por qué lo hacen las empresas españolas?",
        answers: [
            "Sí, siempre que el modelo de contratación esté bien estructurado según el tipo de relación. Las empresas españolas lo hacen principalmente para reducir costes de personal, acceder a perfiles escasos en el mercado local y mantener compatibilidad horaria con España. <strong class=\"brand-oberstaff\">Oberstaff<span class=\"brand-dot\">.</span></strong> gestiona la estructura legal y operativa para que tú solo dirijas el trabajo.",
        ],
    },
    {
        question: "¿Cómo sé qué modelo de contratación necesito?",
        answers: [
            "Depende de si necesitas un empleado formal, un freelancer, un refuerzo IT integrado en tu equipo o una función más delegada. Si no lo tienes claro, te orientamos antes de empezar para evitar errores de estructura.",
        ],
    },
    {
        question: "¿Cuánto tiempo tarda el proceso de incorporación?",
        answers: [
            "Varía según el perfil y el modelo, pero normalmente, entre 2 semanas y 1 mes. Así que, si necesitas contratar personal extranjero, el proceso suele ser ágil gracias a nuestro pool de perfiles preseleccionados.",
        ],
    },
    {
        question: "¿Los profesionales trabajan en horario de España?",
        answers: [
            "Sí. Todos los mercados en los que opera <strong class=\"brand-oberstaff\">Oberstaff<span class=\"brand-dot\">.</span></strong> tienen husos horarios compatibles con España, lo que permite reuniones, seguimiento y coordinación diaria en tiempo real sin desfase.",
        ],
    },
    {
        question: "¿Pueden ayudarme si aún no sé qué perfil o qué estructura necesito?",
        answers: [
            "Sí, parte del valor de <strong class=\"brand-oberstaff\">Oberstaff<span class=\"brand-dot\">.</span></strong> es ayudar a definir qué perfil conviene, qué nivel de control se necesita y qué modelo encaja mejor con la operación antes de iniciar la contratación. Así se evitan errores de estructura desde el principio.",
        ],
    },
    {
        question: "¿En qué países de Latinoamérica operan?",
        content: "countries",
    },
    {
        question: "¿Puedo cancelar el servicio cuando quiera?",
        answers: [
            "Sí. Puedes cancelar el servicio con un preaviso de 30 días, sin penalizaciones ni compromisos de permanencia. Esta flexibilidad te permite ajustar tu equipo remoto según las necesidades reales de tu empresa",
        ],
    },
    {
        question: "¿Tiene algún coste cancelar el servicio?",
        answers: [
            "No aplicamos penalizaciones por cancelación. Nuestro modelo está pensado para que puedas ampliar, ajustar o reducir tu equipo sin asumir costes de despido, finiquitos locales o cargas laborales innecesarias.",
        ],
    },
     {
        question: "¿Tengo que pagar Seguridad Social, beneficios laborales o nómina?",
        answers: [
            "No gestionas directamente la nómina, Seguridad Social ni beneficios laborales del profesional. <strong class=\"brand-oberstaff\">Oberstaff<span class=\"brand-dot\">.</span></strong> centraliza la estructura administrativa y tu empresa recibe una factura mensual por el servicio, reduciendo trámites y carga operativa.",
        ],
    },
    {
        question: "¿Puedo entrevistar al profesional antes de contratarlo?",
        answers: [
            "Sí. Te presentamos perfiles previamente evaluados para que puedas entrevistarlos, validar experiencia, revisar encaje cultural y elegir al candidato que mejor se adapte a tu empresa.",
        ], 
    },
    {
        question: "¿Cómo gestiono a un profesional remoto en el día a día?",
        answers: [
            "Nosotros no lo hacemos, lo harás tú. Te recomendaremos herramientas tecnológicas y métodos para gestionar a tus profesionales remotos y sus tareas. Además, ofrecemos servicios de telefonía VOIP para que tu asistente virtual o cualquier miembro del equipo tenga un teléfono de empresa en tu país.",
        ],
    },
    {
        question: "¿Cómo se realiza el cobro?",
        answers: [
            "Mediante cobro automático mensual a una tarjeta de débito o crédito. Recibes una única factura que simplifica la gestión administrativa, sin complicaciones de seguridad social ni trámites laborales adicionales.",
        ],
    },
    {
        question: "¿Cuánto cuesta contratar talento remoto con <strong class=\"brand-oberstaff\">Oberstaff<span class=\"brand-dot\">.</span></strong>?",
        answers: [
            "El coste depende del perfil, experiencia, país de residencia, seniority y modelo de contratación. Te damos una propuesta mensual cerrada para que conozcas el coste total antes de iniciar el proceso, sin cargos ocultos ni sorpresas.",
        ],
    },
]; 

interface Props {
    title?: string;
    faqs?: FAQ[];
    ctaText?: string;
    ctaButtonText?: string;
    customClass?: string;
}

const { 
    title = "Todo lo que necesitas saber antes de <strong>contratar talento</strong> en LATAM", 
    faqs = homeFaqs,
    ctaText = "¿No sabes qué modelo de contratación necesitas para tu empresa?",
    ctaButtonText = "Agenda una llamada gratuita",
    customClass = ""
} = Astro.props;
---

<section class={`faq-section ${customClass}`}>
    <div class="faq-container">
        <div class="faq-columns">
            <div class="faq-left-column">
                <h2 class="faq-main-title" set:html={title} />
                
                <div class="faq-cta-card">
                    <p set:html={ctaText} />
                    <a href="#contacto" class="faq-cta-button">
                        {ctaButtonText}
                    </a>
                </div>
            </div>

            <div class="faq-right-column">
                <div class="faq-scroll-container">
                    {
                        faqs.map((faq: FAQ) => (
                            <FAQItem question={faq.question}>
                                {faq.answers &&
                                    faq.answers.map((answer: string) => <p set:html={answer}></p>)}

                                {faq.content === "countries" && (
                                    <>
                                        <p>
                                            Operamos en los principales mercados, los
                                            que poseen la mayor concentración de talento
                                            profesional y zonas horarias compatibles con
                                            España:
                                        </p>
                                        <p>
                                            <span class="subtle-bold">
                                                Colombia, Argentina, México, Venezuela,
                                                Chile, Perú y Uruguay.
                                            </span>
                                        </p>
                                    </>
                                )}

                                {faq.content === "definitions" && (
                                    <>
                                        <ul class="faq-list-bullets">
                                            <li>
                                                <span class="subtle-bold">EOR:</span>{" "}
                                                contratas en LATAM sin abrir empresa;
                                                <strong class="brand-oberstaff">Oberstaff<span class="brand-dot">.</span></strong> es el empleador legal.
                                            </li>
                                            <li>
                                                <span class="subtle-bold">
                                                    Outsourcing:
                                                </span>{" "}
                                                externalizas un servicio completo; el
                                                proveedor gestiona al equipo.
                                            </li>
                                            <li>
                                                <span class="subtle-bold">
                                                    Staff Augmentation:
                                                </span>{" "}
                                                añades perfiles a tu equipo existente;
                                                tú los gestionas en el día a día.
                                            </li>
                                        </ul>
                                    </>
                                )}
                            </FAQItem>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>

    <script src="../../scripts/faq.js"></script>
</section>
