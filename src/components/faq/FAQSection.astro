---
import FAQItem from "./FAQItem.astro";
import "../../styles/faq/faq-section.css";

interface FAQ {
    question: string;
    answers?: string[];
    content?: string;
}

const homeFaqs: FAQ[] = [
    {
        question: "¿Es legal contratar talento en LATAM desde España y por qué lo hacen las empresas españolas?",
        answers: [
            "Sí, siempre que el modelo de contratación esté bien estructurado según el tipo de relación. Las empresas españolas lo hacen principalmente para reducir costes de personal, acceder a perfiles escasos en el mercado local y mantener compatibilidad horaria con España. Oberstaff gestiona la estructura legal y operativa para que tú solo dirijas el trabajo.",
        ],
    },
    {
        question: "¿Cómo sé qué modelo de contratación necesito?",
        answers: [
            "Depende de si necesitas un empleado formal, un freelancer, un refuerzo IT integrado en tu equipo o una función más delegada. Si no lo tienes claro, te orientamos antes de empezar para evitar errores de estructura.",
        ],
    },
    {
        question: "¿Cuánto tiempo tarda el proceso de incorporación?",
        answers: [
            "Varía según el perfil y el modelo, pero normalmente, entre 2 semanas y 1 mes. Así que, si necesitas Contratar personal extranjero el proceso suele ser ágil gracias a nuestro pool de perfiles preseleccionado.",
        ],
    },
    {
        question: "¿Los profesionales trabajan en horario de España?",
        answers: [
            "Sí. Todos los mercados en los que opera Oberstaff tienen husos horarios compatibles con España, lo que permite reuniones, seguimiento y coordinación diaria en tiempo real sin desfase.",
        ],
    },
    {
        question: "¿Pueden ayudarme si aún no sé qué perfil o qué estructura necesito?",
        answers: [
            "Si, parte del valor de Oberstaff es ayudar a definir qué perfil conviene, qué nivel de control se necesita y qué modelo encaja mejor con la operación antes de iniciar la contratación. Así se evitan errores de estructura desde el principio.",
        ],
    },
    {
        question: "¿En qué países de Latinoamérica operan?",
        content: "countries",
    } 
];

interface Props {
    title?: string;
    faqs?: FAQ[];
    ctaText?: string;
    ctaButtonText?: string;
    customClass?: string;
}

const { 
    title = "Todo lo que necesitas saber antes de <strong>contratar talento</strong> en LATAM", 
    faqs = homeFaqs,
    ctaText = "¿No sabes qué modelo de contratación necesitas para tu empresa?",
    ctaButtonText = "Agenda una llamada gratuita",
    customClass = ""
} = Astro.props;
---

<section class={`faq-section ${customClass}`}>
    <div class="faq-container">
        <div class="faq-columns">
            <div class="faq-left-column">
                <h2 class="faq-main-title" set:html={title} />
                
                <div class="faq-cta-card">
                    <p set:html={ctaText} />
                    <a href="#contacto" class="faq-cta-button">
                        {ctaButtonText}
                    </a>
                </div>
            </div>

            <div class="faq-right-column">
                <div class="faq-scroll-container">
                    {
                        faqs.map((faq: FAQ) => (
                            <FAQItem question={faq.question}>
                                {faq.answers &&
                                    faq.answers.map((answer: string) => <p>{answer}</p>)}

                                {faq.content === "countries" && (
                                    <>
                                        <p>
                                            Operamos en los principales mercados, los
                                            que poseen la mayor concentración de talento
                                            profesional y zonas horarias compatibles con
                                            España:
                                        </p>
                                        <p>
                                            <span class="subtle-bold">
                                                Colombia, Argentina, México, Venezuela,
                                                Chile, Perú y Uruguay.
                                            </span>
                                        </p>
                                    </>
                                )}

                                {faq.content === "definitions" && (
                                    <>
                                        <ul class="faq-list-bullets">
                                            <li>
                                                <span class="subtle-bold">EOR:</span>{" "}
                                                contratas en LATAM sin abrir empresa;
                                                Oberstaff es el empleador legal.
                                            </li>
                                            <li>
                                                <span class="subtle-bold">
                                                    Outsourcing:
                                                </span>{" "}
                                                externalizas un servicio completo; el
                                                proveedor gestiona al equipo.
                                            </li>
                                            <li>
                                                <span class="subtle-bold">
                                                    Staff Augmentation:
                                                </span>{" "}
                                                añades perfiles a tu equipo existente;
                                                tú los gestionas en el día a día.
                                            </li>
                                        </ul>
                                    </>
                                )}
                            </FAQItem>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>

    <script src="../../scripts/faq.js"></script>
</section>
