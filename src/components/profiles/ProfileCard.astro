---
import "../../styles/profiles/profile-card.css";

interface Role {
    label: string;
    href: string;
}

interface Props {
    icon: string;
    title: string;
    quote: string;
    description?: string;
    roles: Role[];
    iconColorClass: string;
    url?: string;
}

const { icon, title, quote, description, roles, iconColorClass, url } = Astro.props;
---

<article class={`profile-card${url ? " clickable-card" : ""}`} data-url={url}>
    <div class="card-header">
        <span class={`profile-icon ${iconColorClass}`}>{icon}</span>
        <h3>{title}</h3>
    </div>
    {description && <p class="card-description" set:html={description}></p>}
    <p class="quote" set:html={quote}></p>
    <ul class="roles-list">
        {roles.map((role) => (
            <li>
                <a href={role.href} class="role-link">
                    {role.label} <span class="arrow">→</span>
                </a>
            </li>
        ))}
    </ul>
</article>

<script>
    document.querySelectorAll<HTMLElement>(".clickable-card[data-url]").forEach((card) => {
        card.addEventListener("click", (e) => {
            const target = e.target as HTMLElement;
            // Don't navigate if user clicked a role link
            if (target.closest("a")) return;
            const url = card.dataset.url;
            if (url) window.location.href = url;
        });
    });
</script>

<style>
    .clickable-card {
        cursor: pointer;
    }
</style>
