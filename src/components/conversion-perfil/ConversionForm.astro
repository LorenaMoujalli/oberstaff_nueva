---
import "../../styles/conversion-perfil/conversion-form.css";
interface Props {
  buttonText?: string;
}
const { buttonText = "<iconify-icon icon='solar:arrow-right-bold-duotone' style='font-size: 20px;'></iconify-icon> Solicitar propuesta gratuita" } = Astro.props;
const isPrPage = Astro.url.pathname.includes('/pr');
---
<!-- intl-tel-input library -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.10/build/css/intlTelInput.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.10/build/js/intlTelInput.min.js"></script>

<div class="form-card-horizontal">
    <form class="horizontal-form" data-is-pr={isPrPage ? "true" : "false"}>
        <div class="form-grid">
            <input type="text" placeholder="Nombre completo *" required>
            <input type="email" placeholder="Email corporativo *" required>
            <input type="text" placeholder="Empresa *" required>
            <input type="tel" placeholder="Teléfono *" required style="width: 100%; box-sizing: border-box;" oninput="this.value = this.value.replace(/[^0-9 ]/g, '')" data-phone="true">
        </div>
        <button type="submit" class="btn-submit-blue" set:html={buttonText}></button>
    </form>
</div>

<script>
    function initConversionFormPhone() {
        const form = document.querySelector('.form-card-horizontal .horizontal-form') as HTMLFormElement;
        const phoneInput = document.querySelector('.form-card-horizontal input[data-phone="true"]') as HTMLInputElement;
        if (phoneInput && (window as any).intlTelInput) {
            const isPr = form ? form.dataset.isPr === 'true' : false;
            (window as any).intlTelInput(phoneInput, {
                initialCountry: isPr ? "pr" : "es",
                separateDialCode: true,
                preferredCountries: isPr
                    ? ["pr", "co", "ar", "mx", "cl", "pe", "ve"]
                    : ["es", "co", "ar", "mx", "cl", "pe", "ve"],
                utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.10/build/js/utils.js",
            });
        }
    }
    document.addEventListener('astro:page-load', initConversionFormPhone);
    document.addEventListener('DOMContentLoaded', initConversionFormPhone);
</script>
