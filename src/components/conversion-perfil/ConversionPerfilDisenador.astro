---
interface Props {
    title?: string;
    subtitle?: string;
    buttonText?: string;
    noteText?: string;
    extraTitle?: string;
    webhookUrl?: string;
}

const {
    title = "¿Listo para contratar diseñador gráfico dedicado y <strong>transformar la calidad visual de tu negocio?</strong>",
    subtitle = "Completa este breve formulario y en un plazo inferior a 24 horas te enviaremos una propuesta de talento creativo, sin ningún tipo de atadura.",
    buttonText = "Solicitar propuesta gratuita →",
    noteText = "Nota: Rellenarlo te lleva menos de 1 minuto",
    extraTitle = "",
    webhookUrl = "",
} = Astro.props;
---

<style>
    .conv-d-section {
        background: white;
        padding: 100px 20px;
        border-top: 1px solid #f0f0f0;
    }

    .conv-d-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        max-width: 1100px;
        margin: 0 auto;
        align-items: center;
    }

    /* ── Left column ── */
    .conv-d-left h2 {
        font-family: 'Montserrat', sans-serif;
        font-size: 32px;
        font-weight: 700;
        line-height: 1.25;
        color: #1B1B1B;
        margin: 0 0 20px 0;
        letter-spacing: -0.5px;
    }

    .conv-d-left h2 :global(strong) {
        color: #6663FD;
        font-weight: 900;
    }

    .conv-d-left p {
        font-family: 'Poppins', sans-serif;
        font-size: 18px;
        font-weight: 400;
        color: #5A5A5A;
        line-height: 1.7;
        margin: 0;
    }

    .conv-d-left .conv-d-extra-title {
        font-family: 'Poppins', sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: #5a5a5a;
        margin-top: 35px;
        text-transform: uppercase;
      
    }

    /* ── Right column: card ── */
    .conv-d-card {
           background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.05);
    }

    .conv-d-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .conv-d-form input {
        width: 100%;
       border: 1px solid #E0E0E0;
        border-radius: 8px;
        padding: 14px 18px;
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        color: #1B1B1B;
       background-color: #FAFAFC;
    transition: all 0.3s ease;
    width: 100%;
    }

    .conv-d-form input::placeholder {
        color: #AAAAAA;
    }

    .conv-d-form input:focus {
        border-color: #6663FD;
        outline: none;
        box-shadow: 0 0 0 3px rgba(102, 99, 253, 0.1);
    }

    .conv-d-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .conv-d-btn {
        font-family: 'Poppins', sans-serif;
        width: 100%;
        background: #6663FD;
        color: #ffffff;
        border: 2px solid transparent;
        border-radius: 50px;
        padding: 10px;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        margin-top: 4px;
    }

    .conv-d-btn:hover {
        background: transparent;
        color: #6663FD;
        border: 2px solid #6663FD;
    }

    .conv-d-note {
        font-family: 'Poppins', sans-serif;
        font-size: 12px;
        color: #5A5A5A;
        text-align: center;
        margin: 0;
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
        .conv-d-container {
            grid-template-columns: 1fr;
            gap: 48px;
        }

        .conv-d-left h2 {
            font-size: 28px;
        }
    }

    @media (max-width: 600px) {
        .conv-d-section {
            padding: 60px 20px;
        }

        .conv-d-left h2 {
            font-size: 24px;
            text-align: center;
        }

        .conv-d-row {
            grid-template-columns: 1fr;
        }

        .conv-d-card {
            padding: 28px 20px;
        }

        .conv-d-left p {
            font-size: 16px;
            text-align: center;
        }

        .conv-d-left .conv-d-extra-title {
            text-align: center;
            font-size: 18px;
        }
    }

    .form-feedback {
        text-align: center;
        margin-top: 0.75rem;
        font-size: 0.9rem;
        font-weight: 500;
        min-height: 1.2em;
        font-family: 'Poppins', sans-serif;
    }
    .form-feedback.success {
        color: #22c55e;
    }
    .form-feedback.error {
        color: #ef4444;
    }
</style>

<section class="conv-d-section" id="formulario-perfil">
    <div class="conv-d-container">

        <!-- Columna izquierda: texto -->
        <div class="conv-d-left">
            <h2 set:html={title} />
            <p>{subtitle}</p>
            {extraTitle && <p class="conv-d-extra-title">{extraTitle}</p>}
        </div>

        <!-- Columna derecha: formulario -->
        <div class="conv-d-card">
            <form class="conv-d-form" data-webhook-url={webhookUrl}>
                <input type="text" placeholder="Nombre completo *" required />
                <input type="text" placeholder="Nombre de la empresa *" required />
                <div class="conv-d-row">
                    <input type="email" placeholder="Email *" required />
                    <div style="position: relative; display: flex; align-items: center; width: 100%;">
                        <span style="position: absolute; left: 16px; color: #5A5A5A; font-family: inherit; font-size: 14px; pointer-events: none;">+34</span>
                        <input type="tel" placeholder="Teléfono *" required style="padding-left: 50px; width: 100%; box-sizing: border-box;" oninput="this.value = this.value.replace(/[^0-9 ]/g, '')" />
                    </div>
                </div>
                <button type="submit" class="conv-d-btn">{buttonText}</button>
                <p class="form-feedback" aria-live="polite"></p>
                <p class="conv-d-note">{noteText}</p>
            </form>
        </div>

    </div>
</section>

<script>
    document.querySelectorAll('form[data-webhook-url].conv-d-form').forEach((form) => {
        const f = form as HTMLFormElement;
        const webhookUrl = f.dataset.webhookUrl;
        if (!webhookUrl) return;

        if (f.dataset.listenerAdded) return;
        f.dataset.listenerAdded = 'true';

        f.addEventListener('submit', async (e) => {
            e.preventDefault();
            const feedback = f.querySelector('.form-feedback') as HTMLElement;
            const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement;

            const inputs = f.querySelectorAll('input');
            const data: Record<string, string> = {};
            inputs.forEach((el) => {
                const input = el as HTMLInputElement;
                const placeholder = input.getAttribute('placeholder') || '';
                const key = placeholder.replace(' *', '').trim() || input.type;
                const isPhone = input.type === 'tel';
                if (key) {
                    data[key] = isPhone ? `+34 ${input.value}` : input.value;
                }
            });

            btn.disabled = true;
            btn.innerHTML = 'Enviando...';
            if (feedback) {
                feedback.className = 'form-feedback';
                feedback.textContent = '';
            }

            try {
                await fetch(webhookUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                    mode: 'no-cors'
                });
                if (feedback) {
                    feedback.className = 'form-feedback success';
                    feedback.textContent = '✅ ¡Mensaje enviado! Nos pondremos en contacto contigo pronto.';
                }
                f.reset();
            } catch {
                if (feedback) {
                    feedback.className = 'form-feedback error';
                    feedback.textContent = '❌ Error al enviar. Por favor inténtalo de nuevo.';
                }
            } finally {
                btn.disabled = false;
                btn.innerHTML = btn.dataset.originalHtml ?? 'Solicitar propuesta gratuita →';
            }
        });

        // Guardar texto original del botón
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        if (btn) btn.dataset.originalHtml = btn.innerHTML ?? '';
    });
</script>
