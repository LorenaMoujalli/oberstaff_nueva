---
interface Service {
    icon: string;
    title: string;
    description: string;
    linkText: string;
    href: string;
    colorClass?: string;
    cardClass: string;
    customIconBg?: string;
}

interface Props {
    title?: string;
    description?: string;
    services?: Service[];
    customClass?: string;
    cardTitleTag?: "h3" | "p";
    image?: string;
    imageAlt?: string;
}

const {
    title = "Servicios para <strong>incorporar profesionales remotos de Latinoamérica</strong>",
    description = "No todas las empresas necesitan la misma estructura. Por eso <span style=\"font-weight: bold;\">Oberstaff<span style=\"color: #ff66cc;\">.</span></span> te orienta hacia el modelo más eficiente según el tipo de perfil, la relación de trabajo y el nivel de control que buscas.",
    services = [
        {
            icon: "⚖️",
            title: "Employer of Record (EOR)",
            description:
                "Contrata empleados en LATAM con contrato laboral formal, sin abrir una filial en el país.",
            linkText: "Conoce nuestro servicio de Employer of Record (EOR)",
            href: "/servicios/employer-of-record",
            colorClass: "purple-bg",
            cardClass: "card-purple",
        },
        {
            icon: "👥",
            title: "Outsourcing de personal",
            description:
                "Delega la selección, contratación y gestión mensual de equipos comerciales, administrativos y de soporte.",
            linkText: "Conoce nuestro servicio de Outsourcing de personal",
            href: "/servicios/outsourcing-de-personal",
            colorClass: "pink-bg",
            cardClass: "card-green",
        },
        {
            icon: "💻",
            title: "Staff Augmentation",
            description:
                "Amplía tu equipo tech integrando desarrolladores remotos de LATAM a tus flujos y sprints diarios.",
            linkText: "Conoce nuestro servicio de Staff Augmentation",
            href: "/servicios/staff-augmentation",
            colorClass: "orange-bg",
            cardClass: "card-pink",
        },
        {
            icon: "📋",
            title: "Contractor of Record (CoR)",
            description:
                "Gestionamos los contratos, pagos y cumplimiento de tus freelancers y contratistas en Latinoamérica.",
            linkText: "Conoce nuestro servicio de Contractor of Record (CoR)",
            href: "/servicios/contractor-of-record",
            colorClass: "gray-bg",
            cardClass: "card-lime",
        },
    ],
    customClass = "",
    cardTitleTag = "p",
    image,
    imageAlt = "",
} = Astro.props;

import ServiceCard from "./ServiceCard.astro";
import "../../styles/services-oberstaff/services-section.css";
---

<section class={`services-oberstaff ${customClass}`} id="servicios">
    <div class="services-container">
        <header class={`services-header ${image ? 'has-header-image' : ''}`}>
            <div class="services-header-text">
                <h2 id="services-title" set:html={title} />
                <p class="section-description" set:html={description} />
            </div>
            {image && (
                <div class="services-header-image-container">
                    <img src={image} alt={imageAlt} class="services-header-image" />
                </div>
            )}
        </header>

        <div
            class={`services-grid ${customClass ? customClass + "-grid" : ""}`}
        >
            {
                services.map((service) => (
                    <ServiceCard
                        icon={service.icon}
                        title={service.title}
                        description={service.description}
                        linkText={service.linkText}
                        href={service.href}
                        colorClass={service.colorClass}
                        cardClass={service.cardClass}
                        customIconBg={service.customIconBg}
                        titleTag={cardTitleTag}
                    />
                ))
            }
        </div>
    </div>
</section>
