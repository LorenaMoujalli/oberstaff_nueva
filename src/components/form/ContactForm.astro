---
import "../../styles/form/form-elements.css";

interface Props {
    formTitle?: string;
    buttonText?: string;
    webhookUrl?: string;
    labels?: {
        name?: string;
        lastName?: string;
        company?: string;
        email?: string;
        phone?: string;
        comments?: string;
    };
    placeholders?: {
        name?: string;
        lastName?: string;
        company?: string;
        email?: string;
        phone?: string;
        comments?: string;
    };
    customClass?: string;
}

const {
    formTitle,
    buttonText = "Solicitar Presupuesto Gratuito",
    webhookUrl = "",
    labels = {
        name: "Nombre *",
        lastName: "Apellido *",
        company: "Nombre de la empresa",
        email: "Email corporativo *",
        phone: "Teléfono *",
        comments: "Comentarios / Perfil buscado"
    },
    placeholders = {
        name: "Tu nombre",
        lastName: "Tu apellido",
        company: "Ej. Mi Empresa S.L.",
        email: "nombre@tuempresa.com",
        phone: "+34 XXX XXX XXX",
        comments: "¿Qué tipo de profesional estás buscando?"
    },
    customClass = ""
} = Astro.props;
---

<div class={`form-card ${customClass}`}>
    {formTitle && <p class="form-title">{formTitle}</p>}
    <form action="#" method="POST" class="form-grid" data-webhook-url={webhookUrl}>
        <div class="form-group half-width">
            <label>{labels.name}</label>
            <input
                type="text"
                placeholder={placeholders.name}
                required
            />
        </div>
        <div class="form-group half-width">
            <label>{labels.lastName}</label>
            <input
                type="text"
                placeholder={placeholders.lastName}
                required
            />
        </div>
        <div class="form-group full-width">
            <label>{labels.company}</label>
            <input type="text" placeholder={placeholders.company} />
        </div>
        <div class="form-group half-width">
            <label>{labels.email}</label>
            <input
                type="email"
                placeholder={placeholders.email}
                required
            />
        </div>
        <div class="form-group half-width">
            <label>{labels.phone}</label>
            <div style="position: relative; display: flex; align-items: center; width: 100%;">
                <span style="position: absolute; left: 16px; color: #5A5A5A; font-family: inherit; font-size: 14px; pointer-events: none;">+34</span>
                <input
                    type="tel"
                    placeholder="XXX XXX XXX"
                    required
                    data-phone="true"
                    style="padding-left: 50px; width: 100%; box-sizing: border-box;"
                    oninput="this.value = this.value.replace(/[^0-9 ]/g, '')"
                />
            </div>
        </div>
        <div class="form-group full-width">
            <label>{labels.comments}</label>
            <textarea
                rows="4"
                placeholder={placeholders.comments}
            ></textarea>
        </div>
        <div class="button-container-centered">
            <button type="submit" class="btn-submit"
                >{buttonText}</button
            >
        </div>
        <p class="form-feedback" aria-live="polite"></p>
    </form>
</div>

<style>
    .form-feedback {
        text-align: center;
        margin-top: 0.75rem;
        font-size: 0.9rem;
        font-weight: 500;
        min-height: 1.2em;
    }
    .form-feedback.success {
        color: #22c55e;
    }
    .form-feedback.error {
        color: #ef4444;
    }
</style>

<script>
    document.querySelectorAll('form[data-webhook-url]').forEach((form) => {
        const webhookUrl = (form as HTMLFormElement).dataset.webhookUrl;
        if (!webhookUrl) return;

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const f = e.target as HTMLFormElement;
            const feedback = f.querySelector('.form-feedback') as HTMLElement;
            const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement;

            const inputs = f.querySelectorAll('input, textarea');
            const data: Record<string, string> = {};
            inputs.forEach((el) => {
                const input = el as HTMLInputElement | HTMLTextAreaElement;
                const label = input.closest('.form-group')?.querySelector('label')?.textContent?.replace(' *', '').trim() ?? input.type;
                const isPhone = (input as HTMLInputElement).dataset?.phone === 'true';
                if (label) data[label] = isPhone ? `+34 ${input.value}` : input.value;
            });

            btn.disabled = true;
            btn.textContent = 'Enviando...';
            feedback.className = 'form-feedback';
            feedback.textContent = '';

            try {
                await fetch(webhookUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                    mode: 'no-cors'
                });
                feedback.className = 'form-feedback success';
                feedback.textContent = '✅ ¡Mensaje enviado! Nos pondremos en contacto contigo pronto.';
                f.reset();
            } catch {
                feedback.className = 'form-feedback error';
                feedback.textContent = '❌ Error al enviar. Por favor inténtalo de nuevo.';
            } finally {
                btn.disabled = false;
                btn.textContent = btn.dataset.originalText ?? 'Solicitar Presupuesto Gratuito';
            }
        });

        // Guardar texto original del botón
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        if (btn) btn.dataset.originalText = btn.textContent ?? '';
    });
</script>
