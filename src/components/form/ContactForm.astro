---
import "../../styles/form/form-elements.css";

interface Props {
    buttonText?: string;
}

const {
    buttonText = "Solicitar Presupuesto Gratuito"
} = Astro.props;
---

<div class="form-card">
    <form action="#" method="POST" class="form-grid">
        <div class="form-group half-width">
            <label>Nombre *</label>
            <input
                type="text"
                placeholder="Tu nombre"
                required
            />
        </div>
        <div class="form-group half-width">
            <label>Apellido *</label>
            <input
                type="text"
                placeholder="Tu apellido"
                required
            />
        </div>
        <div class="form-group full-width">
            <label>Nombre de la empresa</label>
            <input type="text" placeholder="Ej. Mi Empresa S.L." />
        </div>
        <div class="form-group half-width">
            <label>Email corporativo *</label>
            <input
                type="email"
                placeholder="nombre@tuempresa.com"
                required
            />
        </div>
        <div class="form-group half-width">
            <label>Teléfono *</label>
            <input
                type="tel"
                placeholder="+34 XXX XXX XXX"
                required
            />
        </div>
        <div class="form-group full-width">
            <label>Comentarios / Perfil buscado</label>
            <textarea
                rows="4"
                placeholder="¿Qué tipo de profesional estás buscando?"
            ></textarea>
        </div>
        <div class="button-container-centered">
            <button type="submit" class="btn-submit"
                >{buttonText}</button
            >
        </div>
    </form>
</div>
