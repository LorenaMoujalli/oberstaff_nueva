---
import "../../styles/form/contact-form.css";
import ContactForm from "./ContactForm.astro";

interface Props {
    title?: string;
    subtitle?: string;
    formTitle?: string;
    buttonText?: string;
    directLabel?: string;
    phoneNumber?: string;
    phoneHref?: string;
    directEmoji?: string;
    formLabels?: any;
    formPlaceholders?: any;
    customClass?: string;
    webhookUrl?: string;
    formName?: string;
    pais?: string;
}

const {
    title = "¿Listo para <strong>contratar talento remoto</strong> en Latinoamérica desde España?",
    subtitle = "Cuéntanos qué perfil necesitas, qué objetivo buscas cubrir y qué nivel de control quieres tener sobre la operación. Con esa información podremos orientarte hacia la estructura más conveniente para tu negocio y ayudarte a activar el proceso con menos fricción.",
    formTitle,
    buttonText = "Solicitar Presupuesto Gratuito",
    directLabel = "Atención directa en España:",
    phoneNumber = "",
    phoneHref = "",
    directEmoji = "📞",
    formLabels,
    formPlaceholders,
    customClass = "",
    webhookUrl = "",
    formName = "",
    pais = "",
} = Astro.props;
---
 
<section class={`eor-contact-form ${customClass}`} id="contacto">
    <div class="contact-container">
        <div class="contact-info">
            <h2 set:html={title} />
            <p>{subtitle}</p>
 
            {phoneNumber && (
                <div class="contact-direct-card">
                    <div class="direct-icon-wrapper">
                        <span class="direct-phone-emoji">{directEmoji}</span>
                    </div>
                    <div class="direct-text">
                        <span class="direct-label">{directLabel}</span>
                        {phoneHref ? (
                            <a href={phoneHref} class="direct-phone-link">{phoneNumber}</a>
                        ) : (
                            <span class="direct-phone-link">{phoneNumber}</span>
                        )}
                    </div>
                </div>
            )}
        </div>

        <div class="form-wrapper">
            <ContactForm 
                formTitle={formTitle}
                buttonText={buttonText} 
                labels={formLabels}
                placeholders={formPlaceholders}
                customClass={customClass}
                webhookUrl={webhookUrl}
                formName={formName}
                pais={pais}
            />
        </div>
    </div>
</section>

<style>
    html {
        scroll-behavior: smooth;
    }
</style>
