---

---

<header class="main-header">
    <div class="header-container">
        <div class="logo-section">
            <a href="/home">
                <img
                    src="/logo-oberstaff.webp"
                    alt="Oberstaff Logo"
                    class="logo"
                />
            </a>
        </div>

        <!-- Desktop Auth Section -->
         <!--
        <div class="auth-section desktop-only">
            <a href="#como-contratar" class="proposal-button">Ver como funciona</a>
        </div>
         -->

        <!-- Mobile Menu Toggle -->
        <button
            class="mobile-menu-toggle"
            aria-label="Abrir menú"
            id="menu-toggle"
        >
            <iconify-icon
                icon="solar:hamburger-menu-linear"
                class="hamburger-icon"></iconify-icon>
        </button>

        <!-- Mobile Nav Wrapper -->
        <div class="header-nav-wrapper" id="nav-wrapper">
            <div class="mobile-menu-content">
                <a href="#como-contratar" class="proposal-button mobile-button">Ver como funciona</a>
            </div>
        </div>
    </div>
</header>

<script>
    const menuToggle = document.getElementById("menu-toggle");
    const navWrapper = document.getElementById("nav-wrapper");

    function toggleMenu() {
        if (!navWrapper) return;
        navWrapper.classList.toggle("is-open");

        const icon = menuToggle?.querySelector("iconify-icon");
        if (icon) {
            if (navWrapper.classList.contains("is-open")) {
                icon.setAttribute("icon", "solar:close-square-linear");
            } else {
                icon.setAttribute("icon", "solar:hamburger-menu-linear");
            }
        }
    }

    if (menuToggle && navWrapper) {
        menuToggle.addEventListener("click", toggleMenu);
        
        // Cierra el menú si se hace clic en el botón de propuesta (móvil)
        const mobileBtn = navWrapper.querySelector(".mobile-button");
        mobileBtn?.addEventListener("click", () => {
             if (navWrapper.classList.contains("is-open")) {
                toggleMenu();
            }
        });
    }
</script>

<style>
    .main-header {
        width: 100%;
        background: white;
        border-bottom: 1px solid #f0f0f0;
        position: sticky;
        top: 0;
        z-index: 1000;
        padding: 0.6rem 0;
    }

    .header-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo-section {
        display: flex;
        justify-content: flex-start;
    }

    .logo {
        height: 38px;
        display: block;
        transition: height 0.3s ease;
        object-fit: contain;
    }



    .auth-section {
        display: flex;
        justify-content: flex-end;
    }

    .proposal-button {
        font-family: "Poppins", sans-serif;
        text-decoration: none;
        background-color: #ffffff;
        color: rgb(18 43 93 / var(--tw-bg-opacity, 1));
        border: 2px solid rgb(18 43 93 / var(--tw-bg-opacity, 1));
        padding: 0.5rem 1.2rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s ease;
        display: inline-block;
        white-space: nowrap;
    }

    .proposal-button:hover {
        background-color: rgb(18 43 93 / var(--tw-bg-opacity, 1));
        color: #ffffff;
        transform: translateY(-2px);
    }

    /* Mobile Toggle Styles */
    .mobile-menu-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        z-index: 1001;
        padding: 0;
    }

    .hamburger-icon {
        font-size: 2rem;
        color: #1b1b1b;
    }

    .header-nav-wrapper {
        display: none;
    }

    @media (max-width: 850px) {
        .header-container {
            display: flex;
            justify-content: space-between;
            padding: 0 1.5rem;
        }

        .desktop-only {
            display: none;
        }

        .mobile-menu-toggle {
            display: flex;
        }

        .header-nav-wrapper {
            position: fixed;
            top: 58px; /* Header height approx */
            left: 0;
            width: 100%;
            height: calc(100vh - 58px);
            background: white;
            z-index: 1000;
            padding: 2rem;
            display: none;
            flex-direction: column;
        }

        .header-nav-wrapper.is-open {
            display: flex;
        }

        .mobile-menu-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2rem;
            width: 100%;
        }



        .mobile-button {
            width: fit-content;
            text-align: center;
            padding: 0.6rem 1.2rem;
            font-size: 0.9rem;
        }
    }
</style>

