---
import "../../styles/hero/HeroContent.css";

interface Props {
    title?: string;
    description?: string;
    socialProof?: string;
    buttonText?: string;
    buttonHref?: string;
    videoButtonText?: string;
    badge?: string;
}

const {
    title = `Contratar talento remoto en <br class="desktop-br"/>
        LATAM para empresas en<br class="desktop-br"/>
         España`,
    description = `En <span class="brand-text">Oberstaff<span class="brand-dot">.</span></span> <span class="brand-text2">encontramos el mejor talento por menos, ¡mucho menos!</span> A través del reclutamiento remoto, te ayudamos a externalizar posiciones y contratar
talento cualificado para tu empresa a un coste menor, reduciendo costes salariales y
gastos asociados a empleados en plantilla.`,
    socialProof = `Más de 500 empresas confían en <span class="brand-text">Oberstaff<span class="brand-dot">.</span></span>`,
    buttonText = `Agendar llamada gratis`,
    buttonHref = `#contacto`,
    videoButtonText = `Ver cómo funciona`,
    badge = ""
} = Astro.props;
---

<div class="hero-text-content">
    {badge && (
        <p class="hero-badge">{badge}</p>
    )}
    <h1 set:html={title} />
    <p class="hero-description" set:html={description} />
    <p class="social-proof" set:html={socialProof} />

    <div class="hero-actions">
        <a href={buttonHref} class="btn-primary">
            <span set:html={buttonText} /> <span class="btn-icon-right">→</span>
        </a>
        <button type="button" class="btn-secondary" id="openVideoModal">
            <span class="btn-icon-left">▶</span>
            <span set:html={videoButtonText} />
        </button>
    </div>
</div>

<style>
    .hero-badge {
        color: #ff66cc;
        font-family: "Montserrat", sans-serif;
        font-weight: 800;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 12px;
        display: block;
    }
</style>


