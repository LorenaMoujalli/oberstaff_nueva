---
import "../../styles/community-manager/lead-hero-section.css";
import LeadHeroContent from "./LeadHeroContent.astro";
import LeadHeroForm from "./LeadHeroForm.astro";

interface Feature {
    icon: string;
    iconColor?: string;
    text: string;
}

interface Badge {
    text: string;
    icon?: string;
    iconColor?: string;
}

interface Props {
    backgroundImage?: string;
    topLabel?: string;
    title?: string;
    cardTitle?: string;
    cardSubtitle?: string;
    buttonText?: string;
    buttonIcon?: string;
    buttonSubtext?: string;
    footerLinkText?: string;
    footerLinkHref?: string;
    features?: Feature[];
    badges?: Badge[];
    badgesClass?: string;
    cardTitleTag?: string;
    titleTag?: string;
    topLabelTag?: string;
    topLabelInsideH1?: boolean;
    webhookUrl?: string;
    placeholderName?: string;
    placeholderEmail?: string;
    placeholderCompany?: string;
    placeholderPhone?: string;
}

const {
    backgroundImage,
    topLabel = "CONTRATAR TALENTO REMOTO DESDE LATINOAMÉRICA",
    title = "Delega el crecimiento de tu empresa en talento experto",
    cardTitle = "Comienza ahora",
    cardSubtitle = "",
    buttonText = "Ver perfiles pre-evaluados",
    buttonIcon = "⚡",
    buttonSubtext = "↳ Tardarás menos de 1 minuto · Sin compromiso",
    footerLinkText = "Ver cómo funciona el modelo EOR →",
    footerLinkHref = "#",
    features = [],
    badges = [],
    badgesClass = "",
    cardTitleTag,
    titleTag = "h1",
    topLabelTag = "span",
    topLabelInsideH1 = false,
    webhookUrl = "",
    placeholderName,
    placeholderEmail,
    placeholderCompany,
    placeholderPhone,
} = Astro.props;

const sectionStyle = backgroundImage 
    ? `background: linear-gradient(to right, rgba(27, 27, 27, 0.95) 40%, rgba(27, 27, 27, 0.6) 100%), url('${backgroundImage}') !important; background-size: cover !important; background-position: center !important; background-repeat: no-repeat !important;`
    : undefined;
---

<section class="lead-hero-section" style={sectionStyle}>
    <!-- Aurora background elements -->
    <div class="blur-glow pink-glow"></div>
    <div class="blur-glow purple-glow"></div>
    <div class="lead-container">
        <LeadHeroContent 
            topLabel={topLabel} 
            title={title} 
            features={features} 
            badges={badges} 
            badgesClass={badgesClass}
            topLabelInsideH1={topLabelInsideH1}
            titleTag={titleTag}
            topLabelTag={topLabelTag}
        >
            <slot name="description" />
        </LeadHeroContent>

        <LeadHeroForm 
            cardTitle={cardTitle}
            cardSubtitle={cardSubtitle}
            buttonText={buttonText}
            buttonIcon={buttonIcon}
            buttonSubtext={buttonSubtext}
            footerLinkText={footerLinkText}
            footerLinkHref={footerLinkHref}
            cardTitleTag={cardTitleTag}
            webhookUrl={webhookUrl}
            placeholderName={placeholderName}
            placeholderEmail={placeholderEmail}
            placeholderCompany={placeholderCompany}
            placeholderPhone={placeholderPhone}
        />
    </div>
</section>
