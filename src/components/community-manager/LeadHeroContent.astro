---
import "../../styles/community-manager/lead-hero-content.css";

interface Feature {
    icon: string;
    iconColor?: string;
    text: string;
}

interface Badge {
    text: string;
    icon?: string;
    iconColor?: string;
}

interface Props {
    topLabel?: string;
    title?: string;
    features?: Feature[];
    badges?: Badge[];
    badgesClass?: string;
    topLabelInsideH1?: boolean;
    titleTag?: string;
    topLabelTag?: string;
}

const {
    topLabel = "",
    title = "",
    features = [],
    badges = [],
    badgesClass = "",
    topLabelInsideH1 = false,
    titleTag = "h1",
    topLabelTag = "span",
} = Astro.props;

// Un emoji no contiene ":", un iconify sí (e.g. "solar:check-circle-bold")
const isEmoji = (icon: string) => !icon.includes(":");

const TitleTag = titleTag as any;
const TopLabelTag = topLabelTag as any;
---

<div class="lead-text-content">
    {topLabelInsideH1 ? (
        <TitleTag class="title-as-h1">
            {topLabel && <TopLabelTag class="top-label">{topLabel}</TopLabelTag>}
            <span set:html={title} />
        </TitleTag>
    ) : (
        <>
            {topLabel && <TopLabelTag class="top-label">{topLabel}</TopLabelTag>}
            <TitleTag class="title-as-h1" set:html={title} />
        </>
    )}
    <p class="lead-description">
        <slot />
    </p>
    {badges.length > 0 && (
        <div class={`badges-grid ${badgesClass}`}>
            {badges.map((badge) => (
                <div class="badge-pill">
                    {badge.icon && isEmoji(badge.icon) ? (
                        <span class="badge-emoji" aria-hidden="true">{badge.icon}</span>
                    ) : badge.icon ? (
                        <iconify-icon
                            icon={badge.icon}
                            class="badge-icon"
                            style={badge.iconColor ? `color: ${badge.iconColor}` : ""}
                            aria-hidden="true"
                        ></iconify-icon>
                    ) : (
                        <iconify-icon icon="solar:check-circle-bold" class="badge-icon" aria-hidden="true"></iconify-icon>
                    )}
                    <span>{badge.text}</span>
                </div>
            ))}
        </div>
    )}
    {features.length > 0 && (
        <div class="lead-features">
            {features.map((feature) => (
                <div class="lead-feature-pill">
                    <iconify-icon icon={feature.icon} style={`color: ${feature.iconColor || '#ffffff'}`} aria-hidden="true"></iconify-icon>
                    <span>{feature.text}</span>
                </div>
            ))}
        </div>
    )}
</div>
