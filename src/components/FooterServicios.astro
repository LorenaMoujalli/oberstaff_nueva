<style>
    .oberstaff-footer {
        background-color: #0a0a0a;
        color: #a0a0a0;
        padding: 80px 0 30px;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .footer-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1fr;
        gap: 60px;
        margin-bottom: 80px;
    }

    /* Brand Column */
    .footer-logo {
        font-family: "Montserrat", sans-serif;
        font-size: 20px;
        font-weight: 800;
        margin-bottom: 30px;
        letter-spacing: -1px;
        color: #ffffff;
    }

    .footer-logo:hover {
        opacity: 0.8;
        cursor: pointer;
    }

    .footer-logo .dot {
        color: #ffffff;
    }

    .brand-description {
        font-family: "Poppins", sans-serif;
        color: #888888;
        font-size: 14px;
        line-height: 1.7;
        margin-bottom: 20px;
        max-width: 340px;
    }

    .badges-container {
        display: flex;
        gap: 12px;
    }

    .badge {
        font-size: 11px;
        padding: 8px 16px;
        border-radius: 50px;
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 500;
    }

    .badge-blue,
    .badge-dark {
        font-family: "Poppins", sans-serif;
        background-color: rgba(102, 99, 253, 0.1);
        color: #6663fd;
        padding: 6px 12px;
        border-radius: 50px;
        font-weight: 600;
    }

    .badge .check {
        font-weight: bold;
    }

    /* Columns */
    .footer-column h3 {
        font-family: "Montserrat", sans-serif;
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 25px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #ffffff;
    }

    .footer-column ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-column ul li {
        margin-bottom: 18px;
    }

    .footer-column ul li a {
        font-family: "Poppins", sans-serif;
        color: #a0a0a0;
        text-decoration: none;
        font-size: 14px;
        transition: all 0.3s ease;
        display: inline-block;
    }

    .footer-column ul li a:hover {
        color: #ff66cc;
        transform: translateX(5px);
    }

    .footer-column .contact-secondary-links li a:hover {
        color: #ffffff;
        transform: none;
    }

    /* Contact Section */
    .contact-info {
        margin-bottom: 25px;
    }

    .contact-info p {
        font-family: "Poppins", sans-serif;
        font-size: 14px;
        color: #a0a0a0;
        margin: 0 0 12px 0;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .contact-info a {
        color: #a0a0a0;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
    }

    .contact-info a:hover {
        color: #ff66cc;
        transform: translateX(5px);
    }

    .contact-info strong {
        color: #ffffff;
        font-family: "Montserrat", sans-serif;
        font-size: 14px;
        margin-right: 5px;
    }

    .contact-divider {
        border: 0;
        border-top: 1px solid #1a1a1a;
        margin: 25px 0;
    }

    /* Footer Bottom */
    .footer-bottom {
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        justify-content: space-between;
        align-items: center;
        padding-top: 30px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        color: #666666;
        font-size: 12px;
    }

    .footer-bottom-center {
        text-align: center;
    }

    .footer-bottom-right {
        display: flex;
        justify-content: flex-end;
    }

    .footer-copyright {
        font-family: "Poppins", sans-serif;
        font-size: 12px;
        color: #666666;
    }

    .legal-links {
        display: flex;
        gap: 25px;
        justify-content: center;
    }

    .legal-links a {
        font-family: "Poppins", sans-serif;
        font-size: 12px;
        color: #666666;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .legal-links a:hover {
        color: #ffffff;
    }

    .social-icons {
        display: flex;
        gap: 15px;
    }

    .social-link {
        font-family: "Poppins", sans-serif;
        width: 36px;
        height: 36px;
        background-color: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        text-decoration: none;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.3s;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .social-link:hover {
        background-color: #6663fd;
        border-color: #6663fd;
        transform: translateY(-3px);
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .footer-grid {
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }
        .footer-bottom {
            grid-template-columns: 1fr;
            gap: 20px;
            text-align: center;
        }
        .footer-bottom-left,
        .footer-bottom-center,
        .footer-bottom-right {
            justify-content: center;
            text-align: center;
        }
    }

    @media (max-width: 640px) {
        .footer-grid {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .brand-column {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .brand-description {
            max-width: 100%;
        }

        .badges-container {
            justify-content: center;
            flex-wrap: wrap;
        }

        .contact-info p {
            justify-content: center;
        }

        .contact-divider {
            margin: 25px auto;
        }

        .oberstaff-footer {
            padding: 60px 20px 30px 20px;
        }
    }
</style>
