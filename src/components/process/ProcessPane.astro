---
import "../../styles/process/process-pane.css";

interface Props {
    id: number;
    badge: string;
    title: string;
    description: string;
    active?: boolean;
    badgeColor?: string;
    badgeBg?: string;
}

const { id, badge, title, description, active = false, badgeColor, badgeBg } = Astro.props;
---

<div id={`process-pane-${id}`} class={`process-pane${active ? " active" : ""}`}>
    <span class="process-badge" style={{ color: badgeColor, backgroundColor: badgeBg }}>{badge}</span>
    <p class="process-pane-title"><strong>{title}</strong></p>
    <p>{description}</p>
</div>
