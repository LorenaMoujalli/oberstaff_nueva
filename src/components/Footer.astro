---

<footer class="oberstaff-footer">
    <div class="footer-container">
        <div class="footer-main-grid">
            <!-- Columna de Marca -->
            <div class="footer-col-brand">
                <div class="brand-logo-row">
                    <span class="brand-text"
                        >Oberstaff<span class="brand-dot">.</span></span
                    >
                </div>
                <p class="brand-description">
                    Infraestructura de talento remoto en Latinoamérica para
                    empresas en España y el mundo.
                </p>
                <div class="brand-contact-info">
                    <p>
                        Teléfono España: <a
                            href="tel:+34930289966"
                            class="footer-phone-link">+34 930 289 966</a
                        >
                    </p>
                </div>
            </div>

            <!-- Columna Servicios -->
            <div class="footer-col-links">
                <h3>Servicios</h3>
                <ul>
                    <li><a href="/servicios/employer-of-record">Employer of Record</a></li>
                    <li><a href="/servicios/outsourcing-de-personal">Outsourcing de Personal</a></li>
                    <li><a href="/servicios/staff-augmentation">Staff Augmentation</a></li>
                    <li><a href="/servicios/contractor-of-Record">Contractor of Record</a></li>
                </ul>
            </div>

            <!-- Columna Empresa --> 
            <div class="footer-col-links">
                <h3>Empresa</h3>
                <ul>
                    <li><a href="/quienesomos">Quiénes Somos</a></li>
                    <li><a href="/home#casos-de-exito">Casos de Éxito</a></li>
                    <li><a href="/contacto">Contacto</a></li>
                </ul>
            </div>
        </div>

        <hr class="footer-line" />

        <div class="footer-bottom-bar">
            <p>
                © 2026 <strong>Oberstaff<span class="brand-dot">.</span></strong
                > Todos los derechos reservados
            </p>
        </div>
    </div>

    <style>
        .oberstaff-footer {
            background-color: #0d0d0d;
            color: #ffffff;
            padding: 80px 20px 40px 20px;
            width: 100%;
            box-sizing: border-box;
            font-family: "Poppins", sans-serif;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .footer-main-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr;
            gap: 60px;
            margin-bottom: 60px;
        }

        /* Columna de Marca */
        .brand-text {
            font-family: "Montserrat", sans-serif;
            font-size: 28px;
            font-weight: 700;
            font-style: normal;
            color: #ffffff;
            letter-spacing: -1px;
        }

        .brand-dot {
            color: #ff66cc;
        }

        .brand-description {
            font-family: "Poppins", sans-serif;
            color: #a0a0a0;
            font-size: 15px;
            line-height: 1.6;
            margin-top: 20px;
            margin-bottom: 25px;
            max-width: 350px;
        }

        .brand-contact-info p {
            font-family: "Poppins", sans-serif;
            color: #A0A0A0;
            font-size: 14px;
            font-weight: 600;
        }

        .footer-phone-link {
            color: #66ff99;
            text-decoration: none;
            transition: opacity 0.3s;
        }

        .footer-phone-link:hover {
            opacity: 0.8;
            text-decoration: none;
        }

        /* Columnas de Enlaces */
        .footer-col-links h3 {
            font-family: "Montserrat", sans-serif;
            font-size: 16px;
            font-weight: 700;
            font-style: normal;
            margin-bottom: 25px;
            color: #ffffff;
        }

        .footer-col-links ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .footer-col-links li {
            font-family: "Poppins", sans-serif;
            font-size: 14px;
            margin-bottom: 15px;
        }

        .footer-col-links a {
            font-family: "Poppins", sans-serif;
            color: #a0a0a0;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s;
        }

        .footer-col-links a:hover {
            color: #ff66cc;
        }

        /* Separador */
        .footer-line {
            border: 0;
            border-top: 1px solid #222;
            margin-bottom: 30px;
        }

        /* Barra inferior */
        .footer-bottom-bar {
            text-align: center;
            color: #7a7a7a;
            font-family: "Poppins", sans-serif;
            font-size: 13px;
        }

        .footer-bottom-bar strong {
            color: #999;
        }

        /* Adaptive */
        @media (max-width: 900px) {
            .footer-main-grid {
                grid-template-columns: 1fr;
                gap: 40px;
                text-align: center;
            }
            .brand-description {
                margin: 20px auto;
            }
        }
    </style>
</footer>
