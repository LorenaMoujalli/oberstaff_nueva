---

---

<footer class="oberstaff-footer">
    <div class="footer-container">
        <div class="footer-main-grid">
            <div class="footer-col-brand">
                <div class="brand-logo-row">
                    <div class="pink-box">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="white"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><circle cx="12" cy="12" r="10"></circle><line
                                x1="2"
                                y1="12"
                                x2="22"
                                y2="12"></line><path
                                d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                            ></path></svg
                        >
                    </div>
                    <span class="brand-text">Oberstaff</span>
                </div>
                <p class="brand-description">
                    Conectamos a empresas españolas con el mejor talento remoto
                    de LATAM.
                </p>
                <div class="brand-contact-info">
                    <p>
                        <iconify-icon
                            icon="solar:phone-bold"
                            class="contact-icon"
                            color="#ff66cc"></iconify-icon> +34 930 289 966
                    </p>
                    <p>
                        <iconify-icon
                            icon="solar:calendar-date-bold"
                            class="contact-icon"
                            color="#ff66cc"></iconify-icon> Operando desde 2018
                    </p>
                    <p>
                        <iconify-icon
                            icon="solar:user-bold"
                            class="contact-icon"
                            color="#ff66cc"></iconify-icon> Fundada por [Nombre del
                        CEO]
                    </p>
                </div>
            </div>

            <div class="footer-col-links">
                <h3>Servicios</h3>
                <ul>
                    <li><a href="/home">Employer of Record (EOR)</a></li>
                    <li><a href="/home">Outsourcing de Personal</a></li>
                    <li><a href="/home">Staff Augmentation</a></li>
                    <li><a href="/home">Contract of Record (CoR)</a></li>
                </ul>
            </div>

            <div class="footer-col-links">
                <h3>Perfiles</h3>
                <ul>
                    <li><a href="/home">Estrategia Comercial</a></li>
                    <li><a href="/home">Marketing Digital</a></li>
                    <li><a href="/home">Diseño y UI/UX</a></li>
                    <li><a href="/home">Desarrollo y Tech</a></li>
                </ul>
            </div>

            <div class="footer-col-links">
                <h3>Blog y Recursos</h3>
                <ul>
                    <li><a href="/home">Ver Blog</a></li>
                    <li><a href="/home">Patrocinadores oficiales</a></li>
                    <li><a href="/home">Casos de Éxito</a></li>
                    <li><a href="/home">Preguntas Frecuentes</a></li>
                </ul>
            </div>
        </div>

        <hr class="footer-line" />

        <div class="footer-bottom-bar">
            <p>&copy; 2026 Oberstaff. Todos los derechos reservados.</p>
            <div class="legal-nav">
                <a href="/home">Términos de Servicio</a>
                <a href="/home">Política de Privacidad</a>
            </div>
        </div>
    </div>

    <style>
        /* Estilos encapsulados para evitar conflictos */
        .oberstaff-footer {
            background-color: #1b1b1b;
            color: #ffffff;
            padding: 60px 20px 30px 20px;
            width: 100%;
            box-sizing: border-box;
            text-align: left; /* Asegura que el texto no esté centrado */
        }

        .footer-container {
            max-width: 1100px;
            margin: 0 auto;
        }

        .footer-main-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr 1fr;
            gap: 40px;
            margin-bottom: 40px;
        }

        /* Columna de Marca */
        .brand-logo-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
        }

        .pink-box {
            background-color: #ff66cc; /* Brand pink */
            width: 35px;
            height: 35px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 6px;
        }

        .brand-text {
            font-family: "Poppins", sans-serif;
            font-size: 24px;
            font-weight: bold;
        }

        .brand-description {
            color: #a0a0a0;
            font-size: 14px;
            line-height: 1.5;
            margin-bottom: 25px;
        }

        .brand-contact-info p {
            color: #a0a0a0;
            font-size: 14px;
            margin: 8px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .contact-icon {
            color: #ff66cc;
            font-size: 1.1rem;
        }

        /* Columnas de Enlaces */
        .footer-col-links h3 {
            font-family: "Poppins", sans-serif;
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 20px;
            color: #ffffff;
        }

        .footer-col-links ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .footer-col-links li {
            margin-bottom: 12px;
        }

        .footer-col-links a {
            color: #a0a0a0;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s;
        }

        .footer-col-links a:hover {
            color: #ff66cc;
        }

        /* Separador */
        .footer-line {
            border: 0;
            border-top: 1px solid #333;
            margin-bottom: 25px;
        }

        /* Barra inferior */
        .footer-bottom-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #666;
            font-size: 13px;
        }

        .legal-nav {
            display: flex;
            gap: 20px;
        }

        .legal-nav a {
            color: #666;
            text-decoration: none;
            transition: color 0.3s;
        }

        .legal-nav a:hover {
            color: #ffffff;
        }

        /* Responsive: Si la pantalla es pequeña, se apilan */
        @media (max-width: 850px) {
            .footer-main-grid {
                grid-template-columns: 1fr;
                gap: 30px;
            }
            .footer-col-brand {
                text-align: center;
                display: flex;
                flex-direction: column;
                align-items: center;
            }
            .brand-contact-info p {
                justify-content: center;
            }
            .footer-col-links {
                text-align: center;
            }
        }

        @media (max-width: 500px) {
            .footer-main-grid {
                grid-template-columns: 1fr;
            }
            .footer-bottom-bar {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }
        }
    </style>
</footer>
