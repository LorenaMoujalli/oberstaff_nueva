---
import FAQItem from "../faq/FAQItem.astro";
import "../../styles/faq/faq-section.css";

const faqs = [
    {
        question: "¿Qué es el IT staff augmentation?",
        answers: ["El staff augmentation IT es un modelo en el que incorporas un profesional técnico de LATAM directamente en tu equipo de producto o desarrollo. Tú le asignas tareas, diriges su trabajo y evalúas su rendimiento como a cualquier miembro interno."]
    },
    {
        question: "¿Qué perfiles encajan mejor en este modelo?",
        answers: ["Desarrolladores, QA, data, DevOps, UX/UI y otros perfiles vinculados a producto y tecnología."]
    },
    {
        question: "¿Cuánto tarda la incorporación?",
        answers: ["Depende del perfil, pero el proceso está pensado para acelerar la presentación y entrada de talento técnico validado."]
    },
    {
        question: "¿El profesional trabaja bajo mi dirección?",
        answers: ["Sí, 100%. Tú defines las tareas, el ritmo de trabajo, las herramientas y los criterios de calidad. Oberstaff gestiona la parte administrativa y contractual, pero la dirección técnica es tuya."]
    },
    {
        question: "¿Qué incluyen los servicios de nearshore staff augmentation con Oberstaff?",
        answers: ["Incluyen la búsqueda, validación e incorporación de talento IT de LATAM a tu equipo. Oberstaff presenta perfiles alineados con tu necesidad y facilita la contratación para que tu empresa mantenga el control operativo del trabajo diario."]
    }
]; 

interface Props {
    title?: string;
    ctaText?: string;
    ctaButtonText?: string;
    ctaButtonHref?: string;
}

const {
    title = "Todo lo que necesitas saber antes de su <strong>expansión en LATAM</strong>",
    ctaText = "¿No estás seguro de qué modelo necesitas? El staff augmentation es ideal para perfiles tech integrados en tu equipo. Pero dependiendo de tu operación, puede que necesites un servicio diferente o combinar varios.",
    ctaButtonText = "Agenda una llamada gratuita",
    ctaButtonHref = "#contacto"
} = Astro.props;
---

<style>
    .faq-cta-card {
        text-align: center !important;
    }

    .faq-cta-button {
        font-family: 'Poppins', sans-serif;
        background-color: transparent !important;
        background: none !important;
        color: #0000EE !important;
        border: none !important;
        padding: 0 !important;
        width: auto !important;
        text-align: center !important;
        display: inline-block !important;
        transition: none !important;
        font-size: 15px !important;
        margin: 0 auto !important;
    }

   
</style>

<section class="faq-section">
    <div class="faq-container">
        <div class="faq-columns">
            <div class="faq-left-column">
                <h2 class="faq-main-title" set:html={title} />
                
                <div class="faq-cta-card">
                    <p>{ctaText}</p>
                    <a href={ctaButtonHref} class="faq-cta-button">
                        {ctaButtonText}
                    </a>
                </div>
            </div>

            <div class="faq-right-column">
                <div class="faq-scroll-container">
                    {
                        faqs.map((faq) => (
                            <FAQItem question={faq.question}>
                                {faq.answers &&
                                    faq.answers.map((answer) => <p>{answer}</p>)}
                            </FAQItem>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>

    <script src="../../scripts/faq.js"></script>
</section>
