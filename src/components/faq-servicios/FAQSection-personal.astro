---
import FAQItem from "../faq/FAQItem.astro";
import "../../styles/faq/faq-section.css";

const faqs = [
    {
        question: "¿Qué es el outsourcing de personal con talento de LATAM?",
        answers: ["Es el servicio mediante el cual Oberstaff centraliza la selección, incorporación y gestión administrativa de perfiles comerciales, administrativos, de marketing y de soporte en Latinoamérica para empresas españolas. Tu organización define la necesidad; nosotros ordenamos la operación para reducir la carga interna asociada a funciones recurrentes."]
    },
    {
        question: "¿Qué tipo de perfiles cubre este servicio?",
        answers: ["Este modelo está diseñado para perfiles comerciales, administrativos, de marketing y soporte, como SDR, customer success, contabilidad, asistencia virtual, soporte al cliente y funciones de back office. Si necesitas perfiles tecnológicos como desarrolladores, QA, DevOps o data, el modelo adecuado es Staff Augmentation."]
    },
    {
        question: "¿Qué incluye el outsourcing de selección de personal?",
        answers: ["Publicación de la vacante en Latinoamérica, entrevistas por competencias, evaluación de candidatos y presentación de una terna finalista. Tu empresa toma la decisión final."]
    },
    {
        question: "¿Cuánto tarda la incorporación?",
        answers: ["Depende del perfil y de la disponibilidad, pero en funciones comerciales, administrativas, de marketing y soporte el proceso suele avanzar con agilidad una vez validado el candidato y completada la documentación necesaria."]
    },
    {
        question: "¿Qué pasa si el volumen de mi operativa baja?",
        answers: ["El modelo de outsourcing de personal es flexible, puedes ajustar el tamaño del equipo externalizado según las temporadas de alta o baja demanda de tu negocio sin lidiar con despidos o finiquitos en España."]
    }
]; 

interface Props {
    title?: string;
    ctaText?: string;
    ctaButtonText?: string;
    ctaButtonHref?: string;
}

const {
    title = "Todo lo que necesitas saber antes de su <strong>expansión en LATAM</strong>",
    ctaText = "¿No estás seguro de qué modelo necesitas? El staff augmentation es ideal para perfiles tech integrados en tu equipo. Pero dependiendo de tu operación, puede que necesites un servicio diferente o combinar varios.",
    ctaButtonText = "Agenda una llamada gratuita",
    ctaButtonHref = "#contacto"
} = Astro.props;
---

<style>
    .faq-cta-card {
        text-align: center !important;
    }

    .faq-cta-button {
        font-family: 'Poppins', sans-serif;
        background-color: transparent !important;
        background: none !important;
        color: #0000EE !important;
        border: none !important;
        padding: 0 !important;
        width: auto !important;
        text-align: center !important;
        display: inline-block !important;
        transition: none !important;
        font-size: 15px !important;
        margin: 0 auto !important;
    }

   
</style>

<section class="faq-section">
    <div class="faq-container">
        <div class="faq-columns">
            <div class="faq-left-column">
                <h2 class="faq-main-title" set:html={title} />
                
                <div class="faq-cta-card">
                    <p>{ctaText}</p>
                    <a href={ctaButtonHref} class="faq-cta-button">
                        {ctaButtonText}
                    </a>
                </div>
            </div>

            <div class="faq-right-column">
                <div class="faq-scroll-container">
                    {
                        faqs.map((faq) => (
                            <FAQItem question={faq.question}>
                                {faq.answers &&
                                    faq.answers.map((answer) => <p>{answer}</p>)}
                            </FAQItem>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>

    <script src="../../scripts/faq.js"></script>
</section>
