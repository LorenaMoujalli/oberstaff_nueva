---
import FAQItem from "../faq/FAQItem.astro";
import "../../styles/faq/faq-section.css";

const faqs = [
    {
        question: "¿Qué hace exactamente un Employer of Record?",
        answers: ["Es la entidad que asume el riesgo legal y laboral. Oberstaff firma el contrato local, liquida impuestos y paga la nómina; mientras que tu empresa define las tareas, horarios y métricas de evaluación del talento."]
    },
    {
        question: "¿Cuándo conviene usar EOR?",
        answers: ["Cuando el puesto sea estable, con continuidad, horario y relación laboral formal."]
    },
    {
        question: "¿Puedo contratar en varios países a la vez?",
        answers: ["Sí. Oberstaff opera en más de 10 países de Latinoamérica. Puedes tener profesionales en Colombia, Argentina y Venezuela al mismo tiempo con un único interlocutor."]
    },
    {
        question: "¿Cuánto tarda la puesta en marcha?",
        answers: ["Depende del país y del perfil, pero suele ser mucho más rápido que abrir una empresa local."]
    },
    {
        question: "¿Tengo que abrir una filial?",
        answers: ["No, el propósito del modelo EOR es que utilices nuestras entidades legales ya constituidas para contratar de forma inmediata y 100% legal."]
    },
    {
        question: "¿Qué pasa si necesito terminar la relación laboral?",
        answers: ["Oberstaff acompaña el proceso de desvinculación conforme a la legislación local y reduce la exposición operativa y jurídica de tu empresa."]
    },
    {
        question: "¿Hay permanencia mínima?",
        answers: ["No exigimos contratos de permanencia. Puedes ajustar o cancelar el servicio cuando lo necesites sin penalizaciones. Tu negocio es flexible y tú solución de employer of record en españa también lo es."]
    }
]; 

interface Props {
    title?: string;
    ctaText?: string;
    ctaButtonText?: string;
    ctaButtonHref?: string;
}

const {
    title = "Todo lo que necesitas saber antes de su <strong>expansión en LATAM</strong>",
    ctaText = "¿No sabes qué modelo de contratación necesitas para tu empresa?",
    ctaButtonText = "Agenda una llamada gratuita",
    ctaButtonHref = "#contacto"
} = Astro.props;
---

<style>
    .faq-cta-card {
        text-align: center !important;
    }

    .faq-cta-button {
        font-family: 'Poppins', sans-serif;
        background-color: transparent !important;
        background: none !important;
        color: #0000EE !important;
        border: none !important;
        padding: 0 !important;
        width: auto !important;
        text-align: center !important;
        display: inline-block !important;
        transition: none !important;
        font-size: 15px !important;
        margin: 0 auto !important;
    }

   
</style>

<section class="faq-section">
    <div class="faq-container">
        <div class="faq-columns">
            <div class="faq-left-column">
                <h2 class="faq-main-title" set:html={title} />
                
                <div class="faq-cta-card">
                    <p>{ctaText}</p>
                    <a href={ctaButtonHref} class="faq-cta-button">
                        {ctaButtonText}
                    </a>
                </div>
            </div>

            <div class="faq-right-column">
                <div class="faq-scroll-container">
                    {
                        faqs.map((faq) => (
                            <FAQItem question={faq.question}>
                                {faq.answers &&
                                    faq.answers.map((answer) => <p>{answer}</p>)}
                            </FAQItem>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>

    <script src="../../scripts/faq.js"></script>
</section>
