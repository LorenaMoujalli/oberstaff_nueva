---
import FAQItem from "../faq/FAQItem.astro";
import "../../styles/faq/faq-section.css";

const faqs = [
    {
        question: "¿Cómo elimina Oberstaff el riesgo de 'Falso Autónomo'?",
        answers: ["Contratar directamente a un freelancer en LATAM que trabaje a jornada completa para ti expone a la empresa española a sanciones por falsa autonomía. Bajo nuestro modelo, nosotros contratamos al contable remoto legalmente en su país de origen. Tu empresa está jurídicamente aislada y solo paga una factura por servicios B2B, eliminando el riesgo de auditorías de la Seguridad Social."]
    },
    {
        question: "¿Puede un contable de LATAM trabajar con el Plan General Contable (PGC) español?",
        answers: ["Sí, sin problema. La formación contable en Latinoamérica comparte los mismos fundamentos internacionales que el Plan General Contable español — principios de devengo, uniformidad, prudencia y la estructura de partida doble son universales. La adaptación a la terminología y los modelos fiscales españoles (IVA, IRPF, Sociedades) es rápida precisamente porque la base técnica ya está sólida."]
    },
    {
        question: "¿Quién gestiona las bajas o incidencias del profesional? ",
        answers: ["Nuestra infraestructura asume el 100% de la carga administrativa. En caso de que el perfil deba ausentarse o no cumpla con los SLAs financieros exigidos por tu gerencia, ejecutamos un protocolo de reemplazo ágil sin costes de intermediación adicionales, garantizando que tus cierres contables no sufran interrupciones."]
    },
    {
        question: "¿Qué confidencialidad existe sobre la facturación de mi empresa? ",
        answers: ["Total y auditable, antes del inicio de la operativa, el contable firma Acuerdos de Confidencialidad (NDA) vinculantes. Además, toda la operativa se realiza bajo el entorno de licencias de tu propia empresa (tu dominio de email, tus accesos Cloud), lo que te permite rastrear la actividad y revocar accesos en segundos si fuera necesario."]
    },
    {
        question: "¿De qué países de Latinoamérica son los contables?",
        answers: ["Reclutamos talento financiero de primer nivel operando principalmente desde Colombia, Argentina, México, Venezuela, Chile y Perú. Esto garantiza una sincronía perfecta con la zona horaria española y el acceso a mercados con excelente formación universitaria en contabilidad y finanzas."]
    }
]; 

interface Props {
    title?: string;
    ctaText?: string;
    ctaButtonText?: string;
    ctaButtonHref?: string;
}

const {
    title = "Todo lo que necesitas saber antes de su <strong>expansión en LATAM</strong>",
    ctaText = "¿No estás seguro de qué modelo necesitas? El staff augmentation es ideal para perfiles tech integrados en tu equipo. Pero dependiendo de tu operación, puede que necesites un servicio diferente o combinar varios.",
    ctaButtonText = "Agenda una llamada gratuita",
    ctaButtonHref = "#"
} = Astro.props;
---

<style>
    .faq-d-section {
        background-color: #FAFAFC;
        padding: 100px 20px;
    }

    .faq-d-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: start;
    }

    /* Left column: sticky, title + paragraph + button */
    .faq-d-left {
        position: sticky;
        top: 120px;
        align-self: start;
        z-index: 10;
    }

    .faq-d-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 32px;
        font-weight: 700;
        font-style: normal;
        color: #1a1a1a;
        line-height: 1.3;
        margin-bottom: 24px;
        letter-spacing: -1px;
    }

    .faq-d-title :global(strong) {
        font-weight: 900;
        color: #6663FD;
    }

    .faq-d-text {
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        font-weight: 400;
        color: #5A5A5A;
        line-height: 1.6;
        margin-bottom: 28px;
    }

    .faq-d-btn {
        display: inline-block;
        background-color: #6663FD;
        color: #ffffff;
        padding: 14px 32px;
        border: 2px solid #6663FD;
        border-radius: 50px;
        text-decoration: none;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: 15px;
        transition: all 0.3s ease;
    }

    .faq-d-btn:hover {
        background-color: transparent;
        color: #6663FD;
    }

    /* Right column: FAQ accordion — sin scroll interno, altura libre */
    .faq-d-right {
        padding-right: 0;
    }

    @media (max-width: 1024px) {
        .faq-d-container {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .faq-d-left {
            position: static;
        }

        .faq-d-right {
            padding-right: 5px;
        }
    }

    @media (max-width: 600px) {
        .faq-d-section {
            padding: 60px 20px;
        }

        .faq-d-left {
            text-align: center;
        }

        .faq-d-title {
            font-size: 24px;
        }

        .faq-d-text {
           text-align: center;
           margin-left: auto;
           margin-right: auto;
           max-width: 400px;
        }

        .faq-d-text :global(br) {
            display: none;
        }

        .faq-d-btn {
            display: table; /* To allow margin: 0 auto with width: max-content behavior */
            margin: 0 auto;
            font-size: 13px;
            padding: 12px 24px;
        }
    }
</style>

<section class="faq-d-section">
    <div class="faq-d-container">
        <div class="faq-d-left">
            <h2 class="faq-d-title" set:html={title} />
            <p class="faq-d-text" set:html={ctaText} />
            <a href={ctaButtonHref} class="faq-d-btn">
                {ctaButtonText}
            </a>
        </div>

        <div class="faq-d-right">
            {
                faqs.map((faq) => (
                    <FAQItem question={faq.question}>
                        {faq.answers &&
                            faq.answers.map((answer) => <p>{answer}</p>)}
                    </FAQItem>
                ))
            }
        </div>
    </div>

    <script src="../../scripts/faq.js"></script>
</section>
