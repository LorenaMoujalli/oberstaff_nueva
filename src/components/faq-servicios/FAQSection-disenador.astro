---
import FAQHeader from "../faq/FAQHeader.astro";
import FAQItem from "../faq/FAQItem.astro";
import "../../styles/faq-servicios/faq-section.css";

const faqs = [
    {
        question:
            "¿Cuánto cuesta contratar diseñador gráfico con Oberstaff?",
        answers: [
            "Para este perfil las suscripciones inician desde 850€/mes todo incluido (contrato, nómina, gestión laboral). El precio exacto varía según el nivel de experiencia, especialidad y país del profesional. No hay costes ocultos ni cargos adicionales. Solicita un presupuesto sin compromiso.",
        ],
    },
    {
        question: "¿El diseñador gráfico trabajará solo para mi empresa?",
        answers: [
            "Sí, 100% en exclusiva para tu empresa a jornada completa. Tu diseñador gráfico en remoto se integra en tu equipo, asiste a reuniones, usa tus herramientas y trabaja solo para ti. No es un freelance compartido.",
        ],
    },
    {
        question: "¿En qué herramientas están especializados los diseñadores de Oberstaff?",
        answers: [
            "Nuestros diseñadores gráficos dominan las principales herramientas del sector: Adobe Creative Cloud (Photoshop, Illustrator, InDesign, After Effects), Figma, Canva Pro, Sketch y otras. Al hacer el briefing, nos indicas qué herramientas necesitas.",
        ],
    },
    {
        question:
            "¿Cuánto tiempo tarda el proceso de contratación?", 
        answers: [
            "Menos de 30 días desde que nos contactas hasta que tu diseñador empieza a trabajar. ",
        ],
    },
    {
        question: "¿Tengo que pagar la Seguridad Social del diseñador?",
        answers: [
            "No, Oberstaff actúa como empleador legal del profesional en su país. Tú pagas una única factura de servicio mensual en euros, sin asumir ninguna obligación laboral directa.",
        ],
    },
    {
        question: "¿Puedo prescindir del diseñador si no funciona?",
        answers: [
            "Sí. Solo necesitamos 30 días de preaviso, sin penalizaciones ni indemnizaciones. Si el perfil no encaja durante los primeros días, también gestionamos el reemplazo sin coste adicional.",
        ],
    },
     {
        question: "¿De qué países de Latinoamérica son los diseñadores?",
        answers: [
            "Operamos principalmente en Colombia, Argentina, México, Venezuela, Chile y Perú. Todos los países tienen zona horaria compatible con España y alta concentración de talento creativo y de diseño.",
        ],
    },
     {
        question: "¿Qué diferencia hay entre contratar diseñador gráfico freelance y con Oberstaff?",
        answers: [
            "Con un freelance obtienes disponibilidad parcial y variable, sin compromiso de dedicación. Mientras en Oberstaff tienes un diseñador gráfico a jornada completa, exclusivo para tu empresa, con contrato estable y toda la gestión laboral resuelta.",
        ],
    },
];

interface Props {
    title?: string;
    subtitle?: string;
}

const {
    title = "FAQ",
    subtitle = "Todo lo que necesitas saber antes de empezar"
} = Astro.props;
---

<section class="faq-section">
    <div class="faq-container">
        <FAQHeader
            title={title}
            subtitle={subtitle}
        />

        <div class="faq-list">
            {
                faqs.map((faq) => (
                    <FAQItem question={faq.question}>
                        {faq.answers &&
                            faq.answers.map((answer) => <p>{answer}</p>)}
                    </FAQItem>
                ))
            }
        </div>
    </div>

    <script src="../../scripts/faq.js"></script>
</section>
