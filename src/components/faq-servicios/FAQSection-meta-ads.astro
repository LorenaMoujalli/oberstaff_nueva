---
import FAQItem from "../faq/FAQItem.astro";
import "../../styles/faq/faq-section.css";

const faqs = [
    {
        question: "¿A quién le pago la inversión publicitaria?",
        answers: ["La inversión en anuncios se paga directamente a Meta desde la cuenta publicitaria de tu empresa. A Oberstaff le pagas el fee mensual del especialista y la gestión del modelo de contratación."]
    },
    {
        question: "¿Qué accesos necesita el especialista Facebook Ads?",
        answers: ["La inversión en anuncios se paga directamente a Meta desde la cuenta publicitaria de tu empresa. A Oberstaff le pagas el fee mensual del especialista y la gestión del modelo de contratación."]
    },
    {
        question: "¿Qué accesos necesita el especialista Facebook Ads?", 
        answers: ["Habitualmente necesitará permisos sobre Business Manager, cuenta publicitaria, Pixel o Conversión API, catálogos y, si aplica, acceso coordinado a GTM, GA4 o CRM para revisar medición y calidad del dato."]
    },
    {
        question: "¿Puede trabajar con mi equipo creativo o de ventas?",
        answers: ["Si, y debería hacerlo. Meta Ads funciona mejor cuando el especialista recibe feedback de ventas, objeciones reales, piezas nuevas y datos sobre qué lead termina comprando."]
    },
    {
        question: "¿Qué pasa si mi cuenta ya tiene campañas activas?",
        answers: ["Parte del histórico, primero el profesional audita la estructura, la señal y la calidad del tráfico. Luego decide que mantener, que ordenar, que pausar y que escalar sin destruir aprendizajes útiles."]
    },
    {
        question: "¿Y si vendo por WhatsApp, llamada o CRM y no por ecommerce?",
        answers: ["También encaja, solo necesitas un sistema para devolver resultados de negocio al marketing: estados del lead, oportunidad, cierre, ticket o al menos feedback cualitativo del equipo comercial."]
    },
    { 
        question: "¿Qué flexibilidad tengo si el especialista Meta Ads no logra capturar el tono de mis campañas?",
        answers: ["Puedes solicitar reemplazo o detener el servicio según las condiciones del modelo. La ventaja de esta estructura es que reduces fricción laboral y mantienes control sobre tus activos."]
    }, 
    {
        question: "¿Qué pasa si mi cuenta publicitaria sufre un bloqueo o baneo?",
        answers: ["Nuestros expertos en facebook ads conocen las políticas comerciales de Meta y aplican buenas prácticas para minimizar riesgos. Si ocurre un bloqueo imprevisto por parte del algoritmo, el especialista se encargará de gestionar las apelaciones correspondientes con el soporte de Meta de forma proactiva."]
    },
    
]; 

interface Props {
    title?: string;
    ctaText?: string;
    ctaButtonText?: string;
    ctaButtonHref?: string;
}

const {
    title = "Todo lo que necesitas saber antes de su <strong>expansión en LATAM</strong>",
    ctaText = "¿No estás seguro de qué modelo necesitas? El staff augmentation es ideal para perfiles tech integrados en tu equipo. Pero dependiendo de tu operación, puede que necesites un servicio diferente o combinar varios.",
    ctaButtonText = "Agenda una llamada gratuita",
    ctaButtonHref = "#"
} = Astro.props;
---

<style>
    .faq-d-section {
        background-color: #FAFAFC;
        padding: 100px 20px;
    }

    .faq-d-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: start;
    }

    /* Left column: sticky, title + paragraph + button */
    .faq-d-left {
        position: sticky;
        top: 120px;
        align-self: start;
        z-index: 10;
    }

    .faq-d-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 32px;
        font-weight: 700;
        font-style: normal;
        color: #1a1a1a;
        line-height: 1.3;
        margin-bottom: 24px;
        letter-spacing: -1px;
    }

    .faq-d-title :global(strong) {
        font-weight: 900;
        color: #6663FD;
    }

    .faq-d-text {
        font-family: 'Poppins', sans-serif;
        font-size: 16px;
        font-weight: 400;
        color: #5A5A5A;
        line-height: 1.6;
        margin-bottom: 28px;
    }

    .faq-d-btn {
        display: inline-block;
        background-color: #6663FD;
        color: #ffffff;
        padding: 14px 32px;
        border: 2px solid #6663FD;
        border-radius: 50px;
        text-decoration: none;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: 15px;
        transition: all 0.3s ease;
    }

    .faq-d-btn:hover {
        background-color: transparent;
        color: #6663FD;
    }

    /* Right column: FAQ accordion — sin scroll interno, altura libre */
    .faq-d-right {
        padding-right: 0;
    }

    @media (max-width: 1024px) {
        .faq-d-container {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .faq-d-left {
            position: static;
        }

        .faq-d-right {
            padding-right: 5px;
        }
    }

    @media (max-width: 600px) {
        .faq-d-section {
            padding: 60px 20px;
        }

        .faq-d-left {
            text-align: center;
        }

        .faq-d-title {
            font-size: 24px;
        }

        .faq-d-text {
           text-align: center;
           margin-left: auto;
           margin-right: auto;
           max-width: 400px;
        }

        .faq-d-text :global(br) {
            display: none;
        }

        .faq-d-btn {
            display: table; /* To allow margin: 0 auto with width: max-content behavior */
            margin: 0 auto;
            font-size: 13px;
            padding: 12px 24px;
        }
    }
</style>

<section class="faq-d-section">
    <div class="faq-d-container">
        <div class="faq-d-left">
            <h2 class="faq-d-title" set:html={title} />
            <p class="faq-d-text" set:html={ctaText} />
            <a href={ctaButtonHref} class="faq-d-btn">
                {ctaButtonText}
            </a>
        </div>

        <div class="faq-d-right">
            {
                faqs.map((faq) => (
                    <FAQItem question={faq.question}>
                        {faq.answers &&
                            faq.answers.map((answer) => <p>{answer}</p>)}
                    </FAQItem>
                ))
            }
        </div>
    </div>

    <script src="../../scripts/faq.js"></script>
</section>
