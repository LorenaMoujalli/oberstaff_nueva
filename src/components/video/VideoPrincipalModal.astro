---
interface Props {
    modalTitle?: string;
    modalDescription?: string;
    modalBtnText?: string;
}

const {
    modalTitle = "¿Listo para expandir tu equipo en LATAM?",
    modalDescription = "Un especialista te explicará exactamente cuánto puedes ahorrar con nuestro modelo EOR.",
    modalBtnText = "Agendar asesoría gratuita"
} = Astro.props;
---

<div id="videoModal" class="modal-overlay">
    <div class="modal-content">
        <span class="close-modal"
            ><iconify-icon icon="solar:close-circle-bold"></iconify-icon></span
        >
        <div class="video-container">
            <div id="player"></div>
        </div>
        <div class="modal-info">
            <h2 set:html={modalTitle}></h2>
            <p set:html={modalDescription}></p>
            <a href="#contacto" id="modalCtaBtn" class="modal-btn"
                >{modalBtnText}</a
            >
        </div>
    </div>
</div>

<style>
    /* Fondo del modal */
    .modal-overlay {
        display: none; /* Oculto por defecto */
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(
            0,
            0,
            0,
            0.75
        ); /* Fondo negro con opacidad aumentada */
        backdrop-filter: blur(5px); /* Efecto de desenfoque al fondo */
    }

    /* Contenedor del video */
    .modal-content {
        position: relative;
        margin: auto;
        top: 50%;
        transform: translateY(-50%);
        width: 90%;
        max-width: 650px;
        background-color: #ffffff;
        border-radius: 16px;
        overflow: visible;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    .video-container {
        border-radius: 16px 16px 0 0;
        overflow: hidden;
        background-color: #000;
    }

    /* Cerrar (X) */
    .close-modal {
        position: absolute;
        top: -45px;
        right: -10px;
        color: #fff;
        font-size: 40px;
        cursor: pointer;
        line-height: 0;
        transition:
            transform 0.2s ease,
            color 0.2s ease;
    }

    .close-modal:hover {
        color: #ff66cc;
        transform: scale(1.1);
    }

    /* Mantener proporción 16:9 del video */
    .video-container {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
    }

    /* Use :global if standard CSS doesn't target the dynamically added iframe */
    .video-container :global(iframe) {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }

    /* Sección de info debajo del video */
    .modal-info {
        padding: 20px 30px 25px 30px;
        text-align: center;
        border-radius: 0 0 16px 16px;
    }

    .modal-info h2 {
        font-family: "Montserrat", sans-serif;
        font-size: 24px;
        color: #1b1b1b;
        margin: 0 0 8px 0;
        font-weight: 700;
    }

    .modal-info p {
        font-family: "Poppins", sans-serif;
        font-size: 15px;
        color: #5a5a5a;
        margin: 0 0 18px 0;
        line-height: 1.5;
    }

    .modal-btn {
        display: inline-block;
        background-color: #ff66cc;
        color: #ffffff;
        text-decoration: none;
        font-family: "Poppins", sans-serif;
        font-weight: 700;
        font-size: 14px;
        padding: 14px 32px;
        border-radius: 50px;
        transition: all 0.3s ease;
        border: 2px solid #ff66cc;
    }

    .modal-btn:hover {
        background-color: transparent;
        color: #ff66cc;
        box-shadow: 0 5px 15px rgba(255, 102, 204, 0.3);
    }

    /* Responsividad para móviles */
    @media (max-width: 768px) {
        .modal-content {
            width: 95%; /* Ocupa casi todo el ancho en móviles */
            top: 40%; /* Sube un poco el modal en móviles */
        }

        .close-modal {
            top: -40px;
            right: 0px; /* Alinea con el borde en móviles para que no se salga de la pantalla */
            font-size: 35px;
        }

        .modal-info {
            padding: 24px 20px;
        }

        .modal-info h2 {
            font-size: 20px;
        }

        .modal-info p {
            font-size: 14px;
        }
    }
</style>

<script src="../../scripts/video-principal.ts"></script>
