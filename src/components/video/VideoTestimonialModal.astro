---
// Reusable Testimonial Video Modal component
---

<div id="videoTestimonialModal" class="modal-overlay">
    <div class="modal-content">
        <span class="close-modal close-testimonial"><iconify-icon icon="solar:close-circle-bold"></iconify-icon></span>
        <div class="video-container">
            <div id="playerTestimonial"></div>
        </div>
    </div>
</div>

<style>
/* Fondo del modal */
.modal-overlay {
    display: none; /* Oculto por defecto */
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.75); /* Fondo negro con opacidad aumentada */
    backdrop-filter: blur(5px); /* Efecto de desenfoque al fondo */
}

/* Contenedor del video */
.modal-content {
    position: relative;
    margin: auto;
    top: 50%;
    transform: translateY(-50%);
    width: 70%;
    max-width: 800px;
    background-color: #000;
    border-radius: 16px;
    overflow: visible; /* Changed from hidden so the close button can pop out */
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
}

.video-container {
    border-radius: 16px;
    overflow: hidden;
}

/* Cerrar (X) */
.close-modal {
    position: absolute;
    top: -45px;
    right: -10px;
    color: #fff;
    font-size: 40px;
    cursor: pointer;
    line-height: 0;
    transition: transform 0.2s ease, color 0.2s ease;
}

.close-modal:hover { color: #ff66cc; transform: scale(1.1); }

/* Mantener proporción 16:9 del video */
.video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
}

/* Use :global if standard CSS doesn't target the dynamically added iframe */
.video-container :global(iframe) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
}

/* Responsividad para móviles */
@media (max-width: 768px) {
    .modal-content {
        width: 95%; /* Ocupa casi todo el ancho en móviles */
    }
    
    .close-modal {
        top: -40px;
        right: 0px; /* Alinea con el borde en móviles para que no se salga de la pantalla */
        font-size: 35px;
    }
}
</style>

<script src="../../scripts/videos-testimonios.ts"></script>
