---
import DashboardLayoutCalculadora from "../../layouts/DashboardLayoutCalculadora.astro";

const ogImage = "";
---

<DashboardLayoutCalculadora
  ogImage={ogImage}
  title="Resultados de tu Diagnóstico de Sobrecostes | Oberstaff"
>
  <link
    rel="canonical"
    href="https://oberstaff.com/recursos/resultados-calculadora-sobre-costes/"
    slot="head"
  />
  <meta slot="head" name="description" content="Resultados de tu Diagnóstico de Sobrecostes" />
  <meta slot="head" name="keywords" content="Calculadora Sobre Costes Resultados" />

  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
    slot="head"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
    slot="head"
  />

  <div class="quiz-body-wrapper">
    <div class="blur-glow pink-glow"></div>
    <div class="blur-glow purple-glow"></div>

    <header class="quiz-header">
      <a href="/" style="text-decoration: none;">
        <div class="brand-oberstaff">
          Oberstaff<span class="brand-dot">.</span>
        </div>
      </a>
    </header>

    <div class="quiz-main-wrapper">
      <div class="quiz-card-container">
        <div id="step-results" class="quiz-step active text-center">
          <div class="alert-box">
            <span style="font-size: 40px; display: block; margin-bottom: 15px;"
              >🚨</span
            >
            <h2
              style="color: #FF4D4D; font-family: var(--font-heading); font-size: 27px; margin-bottom: 20px; text-transform: uppercase;"
            >
              Alerta de Fuga Operativa
            </h2>
            <p
              style="color: #FFFFFF; font-size: 16px; line-height: 1.7; margin: 0;"
            >
              Basado en tu plantilla y rotación, tu empresa está asumiendo una
              fuga de capital anual estimada de <strong
                style="font-size: 32px; color: #FF4D4D; display: inline-block; margin: 0 8px;"
                id="result-fuga-total">[CALCULANDO...]</strong
              > en sobrecostes patronales (Seguridad Social + MEI) y pérdida de horas
              productivas.
            </p>
          </div>

          <p
            class="text-light-gray"
            style="font-size: 17px; margin: 40px 0 30px;"
          >
            La buena noticia: Tu estructura tiene el volumen perfecto para
            transicionar al modelo de talento remoto. <strong
              >Tienes que ver esto:</strong
            >
          </p>

          <div class="video-container">
            <iframe
              id="results-video"
              src="https://www.youtube.com/embed/HDb_Ps3rsQo?rel=0&modestbranding=1"
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"
              allow="autoplay"
              allowfullscreen></iframe>
          </div>

          <a
            href="https://info-oberstaff.zohobookings.com/#/4327750000006529861"
            target="_blank"
            style="text-decoration: none;"
          >
            <button
              class="btn-pink rounded-pill heartbeat-anim"
              style="width: 100%; font-size: 16px; padding: 21px;"
            >
              AGENDAR CONSULTORÍA DE VIABILIDAD &rarr;
            </button>
          </a>
        </div>
      </div>
    </div>
  </div>
</DashboardLayoutCalculadora>

<script>
  // Leer el valor de fuga desde los query params
  const params = new URLSearchParams(window.location.search);
  const fugaValue = params.get("fuga");

  const resultEl = document.getElementById("result-fuga-total");
  if (resultEl && fugaValue) {
    resultEl.innerText = decodeURIComponent(fugaValue);
  }

  // Autoplay del video 5 segundos después de cargar la página de resultados
  setTimeout(() => {
    const iframe = document.getElementById("results-video") as HTMLIFrameElement;
    if (iframe) {
      iframe.setAttribute(
        "src",
        "https://www.youtube.com/embed/HDb_Ps3rsQo?autoplay=1&rel=0&modestbranding=1",
      );
    }
  }, 5000);
</script>

<style>
  :root {
    --brand-pink: #ff66cc;
    --brand-purple: #6663fd;
    --font-heading: "Montserrat", sans-serif;
    --font-body: "Poppins", sans-serif;
  }

  .quiz-body-wrapper {
    font-family: var(--font-body);
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #ffffff;
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .quiz-header {
    width: 100%;
    text-align: center;
    padding: 27px 0;
    position: relative;
    z-index: 20;
  }
  .brand-oberstaff {
    font-weight: 900;
    font-family: var(--font-heading);
    color: #ffffff;
    font-size: 25px;
    transition: opacity 0.2s ease;
  }
  .brand-oberstaff:hover {
    opacity: 0.85;
  }
  .brand-dot {
    color: var(--brand-pink);
  }

  .quiz-main-wrapper {
    width: 100%;
    max-width: 800px;
    padding: 0 20px 37px 20px;
    position: relative;
    z-index: 10;
  }

  .quiz-card-container {
    background: #1e1e22;
    border-radius: 24px;
    padding: 47px;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.08);
    position: relative;
    overflow: hidden;
    min-height: 400px;
  }

  .text-light-gray {
    color: #d0d0d0;
    line-height: 1.6;
  }
  .text-center {
    text-align: center;
  }

  .blur-glow {
    position: absolute;
    filter: blur(100px);
    z-index: 1;
    border-radius: 50%;
    pointer-events: none;
  }
  .pink-glow {
    width: 500px;
    height: 500px;
    background: radial-gradient(
      circle,
      rgba(255, 102, 204, 0.15) 0%,
      transparent 70%
    );
    top: -10%;
    left: -10%;
  }
  .purple-glow {
    width: 600px;
    height: 600px;
    background: radial-gradient(
      circle,
      rgba(102, 99, 253, 0.15) 0%,
      transparent 70%
    );
    bottom: -10%;
    right: -10%;
  }

  .quiz-step {
    display: none;
    animation: fadeInRight 0.5s ease forwards;
  }
  .quiz-step.active {
    display: block;
  }

  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .rounded-pill {
    border-radius: 50px;
  }
  .btn-pink {
    background: linear-gradient(90deg, var(--brand-pink), #fa3ab5);
    color: #ffffff;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: var(--font-body);
    font-weight: 700;
    box-shadow: 0 10px 30px rgba(255, 102, 204, 0.25);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .btn-pink:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(255, 102, 204, 0.4);
  }

  .alert-box {
    background: rgba(255, 255, 255, 0.02);
    padding: 40px;
    border-radius: 20px;
    border: 1px solid rgba(255, 77, 77, 0.3);
    border-top: 6px solid #ff4d4d;
    box-shadow: 0 20px 50px rgba(255, 77, 77, 0.05);
  }

  .heartbeat-anim {
    animation: heartbeat 2s infinite;
  }
  @keyframes heartbeat {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.03);
    }
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    width: 100%;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 40px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .quiz-main-wrapper {
      padding: 0 8px 20px 8px;
    }
    .quiz-card-container {
      padding: 24px 16px;
      border-radius: 18px;
      min-height: auto;
    }
    .alert-box {
      padding: 25px 15px;
      border-radius: 16px;
    }
    .alert-box h2 {
      font-size: 21px !important;
    }
    .alert-box p {
      font-size: 14px !important;
    }
    .alert-box strong {
      font-size: 26px !important;
    }
    .btn-pink {
      padding: 16px 20px !important;
      font-size: 13px !important;
    }
    .video-container {
      width: 100%;
      margin-left: auto;
      margin-right: auto;
      border-radius: 12px;
      margin-bottom: 30px;
    }
  }

  @media (max-width: 480px) {
    .quiz-main-wrapper {
      padding: 0 4px 15px 4px;
    }
    .quiz-card-container {
      padding: 20px 12px;
    }
    .alert-box h2 {
      font-size: 18px !important;
    }
    .alert-box strong {
      font-size: 21px !important;
    }
    .video-container {
      width: 100%;
      margin-left: auto;
      margin-right: auto;
      border-radius: 10px;
      margin-bottom: 25px;
    }
  }
</style>
