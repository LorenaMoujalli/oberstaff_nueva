---
import DashboardLayoutCalculadora from "../../layouts/DashboardLayoutCalculadora.astro";

const ogImage = "";
const webhookUrl = "https://hooks.zapier.com/hooks/catch/12433184/4bfk2q7/";
---

<DashboardLayoutCalculadora
  ogImage={ogImage}
  title="Diagnóstico de Sobrecostes | Oberstaff"
>
  <link
    rel="canonical"
    href="https://oberstaff.com/recursos/calculadora-sobre-costes/"
    slot="head"
  />
  <meta slot="head" name="description" content="Calculadora Sobre Costes" />
  <meta slot="head" name="keywords" content="Calculadora Sobre Costes" />

  <link rel="preconnect" href="https://fonts.googleapis.com" slot="head" />
  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
    slot="head"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
    slot="head"
  />

  <div class="quiz-body-wrapper">
    <div class="blur-glow pink-glow"></div>
    <div class="blur-glow purple-glow"></div>

    <header class="quiz-header">
      <a href="/" style="text-decoration: none;">
        <div class="brand-oberstaff">
          Oberstaff<span class="brand-dot">.</span>
        </div>
      </a>
    </header>

    <div class="quiz-main-wrapper">
      <div id="quiz-progress-bar" class="progress-container hidden">
        <div class="progress-fill" id="progress-fill" style="width: 0%;"></div>
      </div>

      <div class="quiz-card-container">
        <div id="step-welcome" class="quiz-step active text-center">
          <span class="seo-kicker text-gradient-pink"
            >Diagnóstico Rápido de Sobrecostes (2026)</span
          >
          <h1
            class="hero-title-light"
            style="font-size: 37px; margin-bottom: 20px;"
          >
            ¿Cuánto dinero estás perdiendo por no actualizar tu modelo laboral?
          </h1>
          <p
            class="text-light-gray"
            style="font-size: 16px; margin-bottom: 40px; max-width: 650px; margin-left: auto; margin-right: auto;"
          >
            Responde estas 4 breves preguntas para calcular exactamente cuánto
            capital está perdiendo tu empresa debido a la inflación laboral, la
            alta rotación y las nuevas normativas (SMI, MEI y jornada de 37,5h).
          </p>
          <button
            id="btn-start-quiz"
            class="btn-pink rounded-pill"
            style="width: 100%; max-width: 420px; font-size: 14px; padding: 21px;"
          >
            Iniciar Diagnóstico Gratuito ⏱️<br /><span
              style="font-size: 11px; font-weight: 400; opacity: 0.9; display: block; margin-top: 6px; text-transform: none; letter-spacing: 0;"
              >(Toma menos de 60 segundos)</span
            >
          </button>
        </div>

        <div id="step-q1" class="quiz-step hidden">
          <h2 class="quiz-question">
            ¿Cuál es el tamaño actual de tu plantilla o equipo de trabajo?
          </h2>
          <div class="quiz-options">
            <button
              class="quiz-option-btn btn-q1"
              data-val="Solo yo / 1 empleado">Solo yo / 1 empleado</button
            >
            <button class="quiz-option-btn btn-q1" data-val="2 a 5 empleados"
              >2 a 5 empleados</button
            >
            <button class="quiz-option-btn btn-q1" data-val="6 a 15 empleados"
              >6 a 15 empleados</button
            >
            <button
              class="quiz-option-btn btn-q1"
              data-val="Más de 15 empleados">Más de 15 empleados</button
            >
          </div>
          <div class="insight-box">
            <strong>💡 ¿Sabías que...?</strong> Las empresas más pequeñas son las
            más vulnerables. Las micro y pequeñas empresas han sufrido un incremento
            acumulado de los costes laborales de casi un 29% en los últimos cuatro
            años.
          </div>
        </div>

        <div id="step-q2" class="quiz-step hidden">
          <h2 class="quiz-question">
            ¿Cuál es el salario bruto mensual promedio que pagas a tus
            empleados?
          </h2>
          <div class="quiz-options">
            <button class="quiz-option-btn btn-q2" data-val="Menos de 1.300€"
              >Menos de 1.300€</button
            >
            <button
              class="quiz-option-btn btn-q2"
              data-val="Entre 1.300€ y 1.800€">Entre 1.300€ y 1.800€</button
            >
            <button class="quiz-option-btn btn-q2" data-val="Más de 1.800€"
              >Más de 1.800€</button
            >
          </div>
          <div class="insight-box">
            <strong>💡 ¿Sabías que...?</strong> A este salario bruto debes sumarle
            las cotizaciones sociales y el MEI, que impone un cargo extra del 0,75%
            en 2026. Además, la reducción a 37,5 horas semanales contrae el tiempo
            productivo más del 6% por empleado.
          </div>
        </div>

        <div id="step-q3" class="quiz-step hidden">
          <h2 class="quiz-question">
            En los últimos 12 meses, ¿cuántas renuncias o reemplazos de personal
            has tenido?
          </h2>
          <div class="quiz-options">
            <button
              class="quiz-option-btn btn-q3"
              data-val="Ninguna, mi equipo es muy estable."
              >Ninguna, mi equipo es muy estable.</button
            >
            <button
              class="quiz-option-btn btn-q3"
              data-val="De 1 a 2 empleados.">De 1 a 2 empleados.</button
            >
            <button class="quiz-option-btn btn-q3" data-val="3 o más empleados."
              >3 o más empleados.</button
            >
          </div>
          <div class="insight-box">
            <strong>💡 ¿Sabías que...?</strong> La alta rotación es una hemorragia
            financiera oculta. En España, el coste medio directo e indirecto de reemplazar
            a un único empleado se sitúa en 7.400 euros.
          </div>
        </div>

        <div id="step-q4" class="quiz-step hidden">
          <h2 class="quiz-question">
            ¿En qué área específica te resulta más difícil, costoso o frustrante
            encontrar talento?
          </h2>
          <div class="quiz-options">
            <button
              class="quiz-option-btn btn-q4"
              data-area="Administración, Contabilidad y Soporte (Asistentes, Data entry)"
              >Administración, Contabilidad y Soporte (Asistentes, Data entry)</button
            >
            <button
              class="quiz-option-btn btn-q4"
              data-area="Atención al Cliente y Ventas (Soporte, Telemarketing, Prospectores)"
              >Atención al Cliente y Ventas (Soporte, Telemarketing,
              Prospectores)</button
            >
            <button
              class="quiz-option-btn btn-q4"
              data-area="Marketing Digital y Diseño (Gestión de Ads, Redes Sociales, Video)"
              >Marketing Digital y Diseño (Gestión de Ads, Redes Sociales,
              Video)</button
            >
            <button
              class="quiz-option-btn btn-q4"
              data-area="Tecnología (Desarrollo Web, Programadores)"
              >Tecnología (Desarrollo Web, Programadores)</button
            >
          </div>
          <div class="insight-box">
            <strong>💡 ¿Sabías que...?</strong> Actualmente, 8 de cada 10 pymes en
            España experimentan dificultades sistémicas, graves y continuadas para
            encontrar el talento cualificado que precisan para operar y crecer.
          </div>
        </div>

        <div id="step-lead" class="quiz-step hidden text-center">
          <div style="font-size: 60px; margin-bottom: 15px;">📊</div>
          <h2
            class="hero-title-light"
            style="font-size: 29px; margin-bottom: 15px;"
          >
            ¡Tu diagnóstico financiero está listo!
          </h2>
          <p
            class="text-light-gray"
            style="margin-bottom: 35px; font-size: 14px;"
          >
            El algoritmo ha procesado tus datos y calculado tu fuga de capital
            anual. ¿A qué correo enviamos el desglose de tu auditoría y el plan
            de acción?
          </p>

          <form
            id="calculator-lead-form"
            class="modern-form"
            data-webhook-url={webhookUrl}
            style="max-width: 400px; width: 100%; margin: 0 auto; text-align: left; box-sizing: border-box;"
          >
            <div class="form-group" style="margin-bottom: 15px;">
              <input
                type="text"
                id="leadName"
                name="name"
                required
                placeholder="Tu Nombre Completo *"
                class="quiz-input"
              />
            </div>
            <div class="form-group" style="margin-bottom: 25px;">
              <input
                type="email"
                id="leadEmail"
                name="email"
                required
                placeholder="Tu Email Corporativo *"
                class="quiz-input"
              />
            </div>
            <!-- SMS Consent Checkbox -->
            <div class="form-group full-width consent-group" style="margin-bottom: 15px; text-align: left;">
                <label class="consent-label" style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer; text-align: left;">
                    <input
                        type="checkbox"
                        id="sms-consent"
                        class="consent-checkbox"
                        required
                        style="flex-shrink: 0; width: 18px; height: 18px; margin-top: 3px; accent-color: #6663FD; cursor: pointer;"
                    />
                    <span class="consent-text" style="font-family: 'Poppins', sans-serif; font-size: 10px; line-height: 1.6; color: #d0d0d0;">
                        <strong>Al facilitar su número de teléfono</strong>, aceptas recibir mensajes SMS
                        "Mensajes relacionados con atención al cliente" de Oberstaff.
                        La frecuencia de los mensajes puede variar. Pueden aplicarse tarifas estándar de mensajes y datos.
                        Responde STOP para cancelar la suscripción. Responde Help para obtener ayuda.
                        <a href="https://oberstaff.com/politica-de-privacidad-y-cookies-de-oberstaff-com/" target="_blank" style="color: #6663FD; text-decoration: underline;">Política de privacidad y uso de cookies.</a>
                        <span style="color: #ef4444; font-weight: 700; margin-left: 2px;">*</span>
                    </span>
                </label>
                <p class="consent-error" id="consent-error" aria-live="polite" style="font-size: 12px; color: #ef4444; margin-top: 4px; min-height: 1em; text-align: left;"></p>
            </div>
            <!-- CAPTCHA Verification -->
            <div class="form-group full-width captcha-group" style="margin-bottom: 20px; text-align: left;">
                <label class="captcha-label" style="font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600; color: #ffffff; display: block; margin-bottom: 4px;">Código de verificación <span class="required-star" style="color: #ef4444; font-weight: 700; margin-left: 2px;">*</span></label>
                <p class="captcha-hint" style="font-family: 'Poppins', sans-serif; font-size: 12px; color: #888; margin: 0 0 8px 0;">Ingresa el texto que ves en la imagen</p>
                <div class="captcha-input-row" style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
                    <input
                        type="text"
                        id="captcha-input"
                        class="captcha-input"
                        placeholder="Escribe el código"
                        autocomplete="off"
                        maxlength="8"
                        style="font-family: 'Poppins', sans-serif; background-color: #FAFAFC; border: 1px solid #E0E0E0; padding: 10px 14px; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.3s ease, box-shadow 0.3s ease; width: 200px; color: #1B1B1B; letter-spacing: 2px;"
                    />
                    <button type="button" id="captcha-refresh" class="captcha-refresh-btn" title="Nuevo código" aria-label="Generar nuevo código" style="background: none; border: 1.5px solid #6663FD; border-radius: 6px; color: #6663FD; font-size: 18px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s, color 0.2s; padding: 0; flex-shrink: 0;">
                        &#x21bb;
                    </button>
                </div>
                <canvas id="captcha-canvas" class="captcha-canvas" width="200" height="60" aria-label="Código de verificación visual" style="display: block; border-radius: 8px; border: 1px solid #ddd; background: #f4f4f8; user-select: none; pointer-events: none;"></canvas>
                <p class="captcha-error" id="captcha-error" aria-live="polite" style="font-size: 12px; color: #ef4444; margin-top: 4px; min-height: 1em;"></p>
            </div>
            <button
              type="submit"
              class="btn-pink rounded-pill"
              style="width: 100%; font-size: 14px; padding: 17px;"
            >
              Ver Mis Resultados Ahora &rarr;
            </button>
            <p
              style="font-size: 12px; color: #888; text-align: center; margin-top: 15px;"
            >
              🔒 Datos protegidos. Cero Spam.
            </p>
          </form>
        </div>

        <div
          id="step-loading"
          class="quiz-step hidden text-center"
          style="padding: 60px 0;"
        >
          <div class="loader-spinner"></div>
          <h3
            class="hero-title-light"
            style="margin-top: 35px; font-size: 23px;"
          >
            Calculando fuga operativa...
          </h3>
          <p class="text-light-gray" id="loading-text" style="font-size: 16px;">
            Cruzando datos con el convenio laboral...
          </p>
        </div>

        <div id="step-results" class="quiz-step hidden text-center">
          <div class="alert-box">
            <span style="font-size: 40px; display: block; margin-bottom: 15px;"
              >🚨</span
            >
            <h2
              style="color: #FF4D4D; font-family: var(--font-heading); font-size: 27px; margin-bottom: 20px; text-transform: uppercase;"
            >
              Alerta de Fuga Operativa
            </h2>
            <p
              style="color: #FFFFFF; font-size: 16px; line-height: 1.7; margin: 0;"
            >
              Basado en tu plantilla y rotación, tu empresa está asumiendo una
              fuga de capital anual estimada de <strong
                style="font-size: 32px; color: #FF4D4D; display: inline-block; margin: 0 8px;"
                id="result-fuga-total">[CALCULANDO...]</strong
              > en sobrecostes patronales (Seguridad Social + MEI) y pérdida de horas
              productivas.
            </p>
          </div>

          <p
            class="text-light-gray"
            style="font-size: 17px; margin: 40px 0 30px;"
          >
            La buena noticia: Tu estructura tiene el volumen perfecto para
            transicionar al modelo de talento remoto. <strong
              >Tienes que ver esto:</strong
            >
          </p>

          <div class="video-container">
            <iframe
              src="https://www.youtube.com/embed/HDb_Ps3rsQo?rel=0&modestbranding=1"
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"
              allow="autoplay"
              allowfullscreen></iframe>
          </div>

          <a
            href="https://info-oberstaff.zohobookings.com/#/4327750000006529861"
            target="_blank"
            style="text-decoration: none;"
          >
            <button
              class="btn-pink rounded-pill heartbeat-anim"
              style="width: 100%; font-size: 16px; padding: 21px;"
            >
              AGENDAR CONSULTORÍA DE VIABILIDAD &rarr;
            </button>
          </a>
        </div>
      </div>
    </div>
  </div>
</DashboardLayoutCalculadora>

<script>
  let v1 = 0;
  let v2 = 0;
  let v3 = 0;
  let v4 = "";

  let responseQ1 = "";
  let responseQ2 = "";
  let responseQ3 = "";
  let responseQ4 = "";

  const CAPTCHA_CHARS = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';

  function generateCaptchaCode(length = 6): string {
      let code = '';
      for (let i = 0; i < length; i++) {
          code += CAPTCHA_CHARS[Math.floor(Math.random() * CAPTCHA_CHARS.length)];
      }
      return code;
  }

  function drawCaptcha(canvas: HTMLCanvasElement, code: string) {
      const ctx = canvas.getContext('2d')!;
      const w = canvas.width;
      const h = canvas.height;

      // Background
      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = '#f0f0f6';
      ctx.fillRect(0, 0, w, h);

      // Noise lines
      for (let i = 0; i < 6; i++) {
          ctx.strokeStyle = `hsl(${Math.random() * 360}, 40%, 70%)`;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(Math.random() * w, Math.random() * h);
          ctx.lineTo(Math.random() * w, Math.random() * h);
          ctx.stroke();
      }

      // Noise dots
      for (let i = 0; i < 40; i++) {
          ctx.fillStyle = `hsl(${Math.random() * 360}, 40%, 65%)`;
          ctx.beginPath();
          ctx.arc(Math.random() * w, Math.random() * h, 1, 0, Math.PI * 2);
          ctx.fill();
      }

      // Draw characters
      const charW = w / (code.length + 1);
      for (let i = 0; i < code.length; i++) {
          ctx.save();
          const x = charW * (i + 0.9);
          const y = h / 2 + 8;
          const angle = (Math.random() - 0.5) * 0.4;
          ctx.translate(x, y);
          ctx.rotate(angle);
          ctx.font = `bold ${20 + Math.random() * 6}px monospace`;
          ctx.fillStyle = `hsl(${240 + Math.random() * 60}, 55%, 35%)`;
          ctx.strokeStyle = `hsl(${240 + Math.random() * 60}, 40%, 60%)`;
          ctx.lineWidth = 0.5;
          ctx.strokeText(code[i], 0, 0);
          ctx.fillText(code[i], 0, 0);
          ctx.restore();
      }
  }

  let currentCode = '';
  const canvas = document.getElementById('captcha-canvas') as HTMLCanvasElement;
  const captchaInput = document.getElementById('captcha-input') as HTMLInputElement;
  const captchaRefresh = document.getElementById('captcha-refresh') as HTMLButtonElement;
  const captchaError = document.getElementById('captcha-error') as HTMLElement;

  function refreshCaptcha() {
      if (canvas && captchaInput) {
          currentCode = generateCaptchaCode();
          drawCaptcha(canvas, currentCode);
          captchaInput.value = '';
          captchaInput.classList.remove('invalid');
          if (captchaError) captchaError.textContent = '';
      }
  }

  const MULTIPLICADOR_SOCIAL = 1.33;
  const COSTE_FUGA_REEMPLAZO = 7400;
  const COSTE_MEDIO_OBERSTAFF = 9600;

  function hideAllSteps() {
    const steps = document.querySelectorAll(".quiz-step");
    steps.forEach((step) => {
      step.classList.remove("active");
      step.classList.add("hidden");
    });
  }

  function showStep(stepId: string) {
    hideAllSteps();
    const step = document.getElementById(stepId);
    if (step) {
      step.classList.remove("hidden");
      step.classList.add("active");
    }
  }

  function updateProgress(percentage: number) {
    const bar = document.getElementById("quiz-progress-bar");
    const fill = document.getElementById("progress-fill");
    if (bar && fill) {
      bar.classList.remove("hidden");
      fill.style.width = percentage + "%";
    }
  }

  // Configurar los listeners cuando el script se ejecute en el cliente
  document.getElementById("btn-start-quiz")?.addEventListener("click", () => {
    showStep("step-q1");
    updateProgress(25);
  });

  document.querySelectorAll(".btn-q1").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const target = e.target as HTMLButtonElement;
      responseQ1 = target.getAttribute("data-val") || "";

      // Mapear el texto a valor numérico para los cálculos
      if (responseQ1.includes("Solo") || responseQ1.includes("1")) {
        v1 = 1;
      } else if (responseQ1.includes("2 a 5")) {
        v1 = 3.5;
      } else if (responseQ1.includes("6 a 15")) {
        v1 = 10.5;
      } else if (responseQ1.includes("Más")) {
        v1 = 20;
      } else {
        v1 = 0;
      }

      showStep("step-q2");
      updateProgress(50);
    });
  });

  document.querySelectorAll(".btn-q2").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const target = e.target as HTMLButtonElement;
      responseQ2 = target.getAttribute("data-val") || "";

      // Mapear el texto a valor numérico para los cálculos
      if (responseQ2.includes("Menos") || responseQ2.includes("1.300")) {
        v2 = 1200;
      } else if (responseQ2.includes("Entre")) {
        v2 = 1550;
      } else if (responseQ2.includes("Más")) {
        v2 = 2200;
      } else {
        v2 = 0;
      }

      showStep("step-q3");
      updateProgress(75);
    });
  });

  document.querySelectorAll(".btn-q3").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const target = e.target as HTMLButtonElement;
      responseQ3 = target.getAttribute("data-val") || "";

      // Mapear el texto a valor numérico para los cálculos
      if (responseQ3.includes("Ninguna")) {
        v3 = 0;
      } else if (responseQ3.includes("1 a 2")) {
        v3 = 1.5;
      } else if (responseQ3.includes("3 o más")) {
        v3 = 4;
      } else {
        v3 = 0;
      }

      showStep("step-q4");
      updateProgress(90);
    });
  });

  document.querySelectorAll(".btn-q4").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const target = e.target as HTMLButtonElement;
      responseQ4 = target.getAttribute("data-area") || "";
      v4 = responseQ4;
      showStep("step-lead");
      updateProgress(100);
      refreshCaptcha();
      captchaRefresh?.addEventListener('click', refreshCaptcha);
      captchaInput?.addEventListener('input', () => {
          captchaInput.classList.remove('invalid');
          if (captchaError) captchaError.textContent = '';
      });
    });
  });

  // Manejo del envío del formulario
  const leadForm = document.getElementById(
    "calculator-lead-form",
  ) as HTMLFormElement;
  if (leadForm && !leadForm.dataset.listenerAdded) {
    leadForm.dataset.listenerAdded = "true";
    leadForm.addEventListener("submit", function (e) {
      e.preventDefault();

      const nameEl = document.getElementById("leadName") as HTMLInputElement;
      const emailEl = document.getElementById("leadEmail") as HTMLInputElement;
      const nombre = nameEl?.value?.trim() || "";
      const email = emailEl?.value?.trim() || "";

      let hasError = false;

      // ── Validate consent ──
      const consentCheckbox = document.getElementById('sms-consent') as HTMLInputElement;
      const consentError = document.getElementById('consent-error') as HTMLElement;
      if (!consentCheckbox?.checked) {
          if (consentError) consentError.textContent = '⚠ Debes aceptar el consentimiento para continuar.';
          hasError = true;
      } else {
          if (consentError) consentError.textContent = '';
      }

      // ── Validate CAPTCHA ──
      const userCode = captchaInput?.value.trim().toUpperCase();
      if (!userCode) {
          if (captchaError) captchaError.textContent = '⚠ Este campo es obligatorio. Ingresa el código de la imagen.';
          captchaInput?.classList.add('invalid');
          hasError = true;
      } else if (userCode !== currentCode) {
          refreshCaptcha();
          if (captchaError) captchaError.textContent = '❌ El código ingresado es incorrecto. Se generó un nuevo código, inténtalo de nuevo.';
          captchaInput?.classList.add('invalid');
          hasError = true;
      } else {
          if (captchaError) captchaError.textContent = '';
          captchaInput?.classList.remove('invalid');
      }

      if (hasError) return;

      if (!nombre || !email) {
        console.warn("Intento de envío con datos vacíos abortado.");
        return;
      }

      console.log("Simulación de guardado local exitosa:", {
        nombre,
        email,
        responseQ1,
        responseQ2,
        responseQ3,
        responseQ4,
      });

      // Algoritmo matemático para enviar al webhook antes de mostrar los pasos de carga
      const costoEspanaAnual = v2 * 12 * MULTIPLICADOR_SOCIAL;
      const fugaSobrecostes = (costoEspanaAnual - COSTE_MEDIO_OBERSTAFF) * v1;
      const fugaRotacion = v3 * COSTE_FUGA_REEMPLAZO;
      const fugaTotal = fugaSobrecostes + fugaRotacion;

      const formatoEuros = new Intl.NumberFormat("es-ES", {
        style: "currency",
        currency: "EUR",
        maximumFractionDigits: 0,
      }).format(fugaTotal);

      const urlWebhook = leadForm.dataset.webhookUrl || "";
      if (urlWebhook) {
        fetch(urlWebhook, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            Nombre: nombre,
            Email: email,
            "Tamaño plantilla": responseQ1,
            "Salario mensual": responseQ2,
            "Rotación anual": responseQ3,
            "Área de interés": responseQ4,
            "Fuga anual aproximada": formatoEuros,
          }),
          mode: "no-cors",
        }).catch((err) => console.error("Error sending lead to webhook:", err));
      }

      // Clear consent error on check
      consentCheckbox?.addEventListener('change', () => {
          if (consentCheckbox.checked && consentError) consentError.textContent = '';
      });

      const progressBar = document.getElementById("quiz-progress-bar");
      if (progressBar) progressBar.classList.add("hidden");

      showStep("step-loading");

      const loadingTexts = [
        "Cruzando datos con el convenio laboral...",
        "Calculando sobrecostes de Seguridad Social...",
        "Procesando impacto del MEI 2026...",
        "Generando auditoría de fuga...",
      ];

      let textIndex = 0;
      const loadingEl = document.getElementById("loading-text");
      const textInterval = setInterval(() => {
        textIndex++;
        if (loadingEl && textIndex < loadingTexts.length) {
          loadingEl.innerText = loadingTexts[textIndex];
        }
      }, 800);

      const resultEl = document.getElementById("result-fuga-total");
      if (resultEl) resultEl.innerText = formatoEuros;

      setTimeout(() => {
        clearInterval(textInterval);
        showStep("step-results");

        // Autoplay del video 5 segundos después de mostrar la pantalla de resultados (con sonido)
        setTimeout(() => {
          const iframe = document.querySelector("#step-results iframe");
          if (iframe) {
            iframe.setAttribute(
              "src",
              "https://www.youtube.com/embed/HDb_Ps3rsQo?autoplay=1&rel=0&modestbranding=1",
            );
          }
        }, 5000);
      }, 3500);
    });
  }
</script>

