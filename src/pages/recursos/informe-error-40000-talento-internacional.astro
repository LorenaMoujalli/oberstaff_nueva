---
import DashboardLayoutInformes from "../../layouts/DashboardLayoutInformes.astro";
import ContentSection from "../../components/informes/ContentSection.astro";
import ContentHeader from "../../components/informes/ContentHeader.astro";
import ContentForm from "../../components/informes/ContentForm.astro";
import ReportWebView from "../../components/informes/ReportWebView.astro";
const ogImage = "";
---
  
<DashboardLayoutInformes
  ogImage={ogImage}
  title="El Error de 40.000€ al Contratar Talento Internacional | Oberstaff"
>
  <link
    rel="canonical"
    href="https://oberstaff.com/recursos/informe-error-40000-talento-internacional/"
    slot="head"
  />
  <meta
    slot="head"
    name="description"
    content="Análisis estratégico para CEOs y CFOs: Cómo escalar tu equipo técnico fuera de España con un 70% de ahorro estructural y cero pasivo laboral."
  />
  <meta slot="head" name="keywords" content="Contratar talento internacional" />

  <!-- GATE: Formulario de acceso — se oculta tras el submit -->
  <div id="contentGateOverlay" class="welcome-section">
    <ContentSection>
      <ContentHeader
        kicker="Informe Estratégico Exclusivo"
        title="El Error de 40.000€ al Contratar Talento Internacional"
        description="Descubre cómo las empresas madrileñas están escalando sus equipos técnicos y esquivando las multas millonarias por 'Falsos Autónomos'."
      />
      <ContentForm webhookUrl="https://hooks.zapier.com/hooks/catch/12433184/4bt9jcm/" />
    </ContentSection>
  </div>

  <!-- CONTENIDO WEB: Se revela tras el submit -->
  <ReportWebView
    webhookUrl="https://hooks.zapier.com/hooks/catch/12433184/4bye64r/"
  />
</DashboardLayoutInformes>

<style>
  .welcome-section {
    width: 100%;
  }
</style>
