	description="¿Buscas contratar talento en LATAM? Oberstaff te ayuda a acceder a perfiles validados, reducir costes y ampliar tu equipo con agilidad."
	ogImage={ogImage}
> 
	
	<link rel="canonical" href="https://oberstaff.com" slot="head" />
	<link rel="alternate" hreflang="es-ES" href="https://oberstaff.com" slot="head" />
	<link rel="alternate" hreflang="es-PR" href="https://oberstaff.com/pr/" slot="head" />
	<link rel="alternate" hreflang="x-default" href="https://oberstaff.com" slot="head" />
	<script slot="head" type="application/ld+json">
