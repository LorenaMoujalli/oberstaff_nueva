								"description": "Servicio para contratar empleados en LATAM con relación laboral formal, payroll y cumplimiento local, sin abrir filial."
							}
						},
						{
							"@type": "ListItem",
							"position": 2,
							"item": {
								"@id": "https://oberstaff.com/servicios/outsourcing-de-personal#service",
								"name": "Outsourcing de Personal",
								"url": "https://oberstaff.com/servicios/outsourcing-de-personal",
