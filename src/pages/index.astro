---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import Hero from "../components/hero/Hero.astro";
import TrustSection from "../components/banner-patrocinadores/TrustSection.astro";
import StatsSection from "../components/stats-oberstaff/StatsSection.astro";
import ServicesSection from "../components/services-oberstaff/ServicesSection.astro";
import ProcessOberstaff from "../components/process/ProcessOberstaff.astro";
import ProfilesSection from "../components/profiles/ProfilesSection.astro";
import BenefitsSection from "../components/benefits/BenefitsSection.astro";
import TestimonialsSection from "../components/testimonios/TestimonialsSection.astro";
import FAQSection from "../components/faq/FAQSection.astro";
import ContactFormSection from "../components/form/ContactFormSection.astro";
import PressSection from "../components/press/PressSection.astro";
import BlogSection from "../components/blog-home/BlogSection.astro";
import EorCta from "../components/eor-cta-servicios/EorCta.astro";

const ogImage = "Contratar Talento.webp";
