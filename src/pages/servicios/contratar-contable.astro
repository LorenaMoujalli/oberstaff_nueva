---
import DashboardLayoutPerfiles from "../../layouts/DashboardLayoutPerfiles.astro";
import LeadHeroSection from "../../components/community-manager/LeadHeroSection.astro";
import ComparisonPerfiles from "../../components/comparison-perfiles/ComparisonPerfiles.astro";
import PricingCardPerfil from "../../components/pricing-perfil/PricingCardPerfil.astro";
import BeneficiosPerfilDisenador from "../../components/beneficios-perfil/BeneficiosPerfilDisenador.astro";
import PressSection from "../../components/press/PressSection.astro";
import ConversionPerfilDisenador from "../../components/conversion-perfil/ConversionPerfilDisenador.astro";
import RolesPerfil from "../../components/roles-del-perfil/RolesPerfil.astro";
import QueEsServicioSection from "../../components/QueEsServicio/QueEsServicioSection.astro";
import ServicesSection from "../../components/services-oberstaff/ServicesSection.astro";
import EorStepsSection from "../../components/eor-steps-servicios/EorStepsSection.astro";
import EorCta from "../../components/eor-cta-servicios/EorCta.astro";
import CasosExitoSection from "../../components/casos-exito-servicios/CasosExitoSection.astro";
import FAQSection from "../../components/faq-servicios/FAQSection-contable.astro";
---

 
<DashboardLayoutPerfiles
  title="Contratar contable remoto para tu empresa Española"
  description="Reduce costes y suma un perfil exclusivo a jornada completa al contratar contable de Latinoamérica sin asumir cargas laborales."
  footerTitle="Roles Relacionados"
  footerLinks={[
    { text: "🗂️ Contratar Asistente virtual", href: "#" },
    { text: "📱 Community Manager", href: "#" },
    { text: "🎨 Diseñador gráfico", href: "#" }
  ]}
  keywords="Contratar contable"
> 



  <div class="service-detail-container" id="inicio">
    <LeadHeroSection
      topLabel="Finanzas y Administración"
      title="Contratar contable remoto: toma el control de tu flujo de caja y blinda el departamento financiero de tu empresa"
      cardTitle="Encuentra a tu contable hoy"
      cardSubtitle="Accede a perfiles pre-evaluados listos para tu empresa."
      buttonText="👉 Ver perfiles pre-evaluados y solicitar propuesta"
      buttonIcon=""
      buttonSubtext="↳ Tardarás menos de 1 minuto · Sin compromiso"
      footerLinkText="Ver cómo funciona el modelo EOR →"
      footerLinkHref="#como-contratar"
      badges={[
        { text: "Dedicación financiera exclusiva", icon: "💼" },
        { text: "Perfiles contables evaluados", icon: "📋" },
        { text: "Integración rápida a tu software", icon: "⚡" },
        { text: "Horario compatible con España", icon: "🕒" },
      ]}
    >
      <Fragment slot="description">
   Al integrar un contable remoto dedicado desde LATAM, internalizas el control de tus finanzas: delegas la conciliación bancaria diaria, la gestión de cuentas por pagar/cobrar (AP/AR) y el mantenimiento de tu ERP financiero.

      </Fragment>
    </LeadHeroSection>


     <div class="fade-in-section">
			<QueEsServicioSection
				title="Del caos de las facturas al control del Cash Flow: el impacto de contratar a un contable In-House"
				highlightWord="el impacto de contratar a un contable In-House"
				description="Trabajar 'a ciegas' es el mayor riesgo para la liquidez de una empresa. Mantener un departamento financiero en nómina local dispara tus costes fijos, pero externalizar el día a día a una asesoría tradicional genera un desfase crítico en tus datos operativos."
				imageSrc="/img1-contable.webp"
				imageAlt="Profesional trabajando"
				badgeText="Control Financiero"
				quoteText="Al apostar por contratar contable remoto dedicado, integras a un analista que audita tus movimientos bancarios y facturación diariamente. Esto te permite tomar decisiones directivas basadas en balances reales actualizados, reduciendo drásticamente tus costes estructurales sin asumir riesgos de falso autónomo."
				checklistTitle="Checklist de ventajas:"
				checklistItems={[
					"Perfiles auditados en normativas contables y dominio avanzado de Excel/ERPs.",
					"Facturación B2B mensual 100% deducible, sin IRPF local ni Seguros Sociales",
					"Escala tu equipo de finanzas sin contratos de permanencia ni riesgos de indemnización."
				]}
				ctaText="Solicitar propuesta personalizada  →"
				ctaHref="#"
				diffIcon=""
				diffTitle=""
				diffDescription=""
			/>
		</div>


    	<div class="fade-in-section">
			<ServicesSection
				title="De la conciliación bancaria al reporte de márgenes: <strong>funciones técnicas </strong>de tu contable remoto"
				description="Nuestros profesionales dominan las disciplinas que necesita el contable de una empresa para operar con seguridad y eficiencia.Desde el registro diario de operaciones hasta la preparación de cuentas anuales y el apoyo fiscal con los modelos españoles."
				customClass="employer-use-cases"
				services={[
					{
						icon: "📊",
						title: "Contabilidad General",
						description:
							"Registro de operaciones, asientos, cuentas anuales, adaptación al PGC, libros oficiales y balance de situación.",
						linkText: "",
						href: "",
						customIconBg: "transparent",
						cardClass: "card-green",
					},
					{
						icon: "📑",
						title: "Cuentas por pagar y cuentas por cobrar",
						description:
							"Facturación, seguimiento de cobros, pagos, vencimientos y apoyo al control del flujo operativo.",
						linkText: "",
						href: "",
						customIconBg: "transparent",
						cardClass: "card-pink",
					},
					{
						icon: "🏦",
						title: "Conciliación Bancaria",
						description:
							"Cuadre de extractos, control riguroso de tesorería, gestión de pagos a proveedores y saldos.",
						linkText: "",
						href: "",
						customIconBg: "transparent",
						cardClass: "card-lime",
					},
					{
						icon: "💹",
						title: "Reporting Financiero",
						description:
							"Informes de situación financiera, análisis de márgenes, cash flow y cuadros de mando contables.",
						linkText: "",
						href: "",
						customIconBg: "transparent",
						cardClass: "card-purple",
					},
					{
						icon: "🏦 ",
						title: "Soporte a Fiscalidad Local",
						description:
							"Organización del libro mayor y documentación limpia para que tu asesoría en España solo tenga que liquidar impuestos.",
						linkText: "",
						href: "",
						customIconBg: "transparent",
						cardClass: "card-green",
					},
					{
						icon: "📋",
						title: "Gestión de ERP y Software contables",
						description:
							"Actualización y mantenimiento de la infraestructura financiera en Holded, Odoo, A3, Xero o QuickBooks.",
						linkText: "",
						href: "",
						customIconBg: "transparent",
						cardClass: "card-lime",
					},
				]}
			/>
		</div>

    <div class="fade-in-section">
			<EorStepsSection
				title="El roadmap de integración financiera:<strong> cómo delegar tus finanzas de forma segura</strong>"
				subtitle="Entregar el control de la información al contratar contable exigue un proceso metódico. Implementamos un protocolo de onboarding diseñado para garantizar la integridad de tus datos financieros desde el primer minuto"
				steps={[
					{
						title: "¿Qué requiere la contabilidad de tu negocio?",
						lineColorClass: "line-black",
						description:
							"Explícanos en una llamada gratuita el volumen de operaciones, el software contable que usas, si tienes asesor fiscal externo, los modelos fiscales que gestionar y el nivel de seniority requerido.",
						badge: "⚡ 15 min · Sin compromiso",
					},
					{
						title: "Headhunting de talento financiero",
						lineColorClass: "line-pink",
						description:
							"Te ahorramos decenas de horas de entrevistas sin valor. Recibes una terna de asesores contables especializados pre-evaluados en herramientas Cloud y rigor contable, listos para integrarse en tu estructura.",
						badgeIcon: "📋",
						badge: "Perfiles contables evaluado",
					},
					{
						title: "Entrevista y eliges tú",
						lineColorClass: "line-orange",
						description:
							"Entrevistas directas con los candidatos para validar su criterio contable, revisar su metodología de trabajo y el dominio del software que usas. Decides con quién quieres trabajar sin intermediarios.",
						badge: "Tú decides",
					},
					{
						title: "Arranque Operativo Blindado",
						lineColorClass: "line-blue",
						description:
							"Transferencia segura de accesos al ERP corporativo. El talento asume la gestión directa de las cuentas AP/AR manteniendo tú el control total.",
						badge: "Integración en días",
					},
				]}
			/>
		</div>



     	<div class="fade-in-section">
			<EorCta
				title="¿Ya sabes qué perfil financiero necesitas?"
				text="Si tu equipo directivo tiene que esperar al cierre de la gestoría para saber si un proyecto fue rentable, estás perdiendo competitividad. Internaliza tu operativa contable. Define el perfil financiero que necesitas y recibe una propuesta adaptada a tu volumen de transacciones en menos de 24 horas."
				buttonText="👉 Quiero Solicitar propuesta personalizada"
				buttonHref="#"
			/>
		</div>


    
    <div class="fade-in-section">
      <RolesPerfil
        title="<strong>Arquitectura de perfiles:</strong> El nivel técnico exacto para tu estructura financiera"
        subtitle="No todas las empresas necesitan un director financiero, ni todas las operativas se resuelven con un auxiliar básico. Filtramos y auditamos talento en LATAM basándonos en el nivel de complejidad de tus transacciones y tu stack tecnológico, ofreciendo niveles de integración."
        layout="modern"
        footerText=""
        footerLinkText=""
        footerLinkHref="#"
        roles={[
          {
            title: "📋 Auxiliar Contable Remoto",
            description: "",
            icon: "",
            iconColor: "#FF66CC",
            borderColorClass: "border-pink",
            subtitle: "Soporte operativo diario, registro contable y control documental para pymes. Gestiona asientos, facturas, conciliaciones básicas y archivo de documentación contable bajo tu supervisión directa.",
            techStack: ["Holded", "Factusol", "Asientos"],
            buttonText: "Solicitar más información →",
            buttonHref: "#",
          },
          {
            title: "🧾 Asistente Contable Remoto",
            description: "",
            icon: "",
            iconColor: "#3b76f6",
            borderColorClass: "border-blue",
            subtitle: "Apoyo transversal, conciliaciones y seguimiento de procesos contables. Da soporte en cuentas por cobrar y por pagar, cuadre de extractos, seguimiento de vencimientos y control de flujo de caja.",
            techStack: ["Sage 50", "Conciliaciones", "A3"],
            buttonText: "Solicitar más información →",
            buttonHref: "#",
          },
          {
            title: "💹 Asesores contables especializados",
            description: "",
            icon: "",
            iconColor: "#66FF99",
            borderColorClass: "border-green",
            subtitle: "Profesionales especializados en control financiero, presupuestos y herramientas como excel y Power BI. Perfil de mayor seniority. Orientado a reporting financiero, análisis de márgenes, cierres mensuales y cuadros de mando.",
            techStack: ["Excel avanzado", "Power BI", "Reporting"],
            buttonText: "Solicitar más información →",
            buttonHref: "#",
          },
          {
            title: "🌐 Contable de una empresa Generalista",
            description: "",
            icon: "",
            iconColor: "#CCFF66",
            borderColorClass: "border-yellow",
            subtitle: "Mayor autonomía para cierres, revisión y reporting. Gestiona el ciclo contable completo: desde el registro de operaciones hasta la preparación de cuentas anuales, apoyo en los modelos fiscales 303, 200 y 390, y libros oficiales.",
            techStack: ["Modelos fiscales", "Xero", "QuickBooks"],
            buttonText: "Solicitar más información → ",
            buttonHref: "#",
          },
        ]}
      />
    </div>
     

    <div class="fade-in-section">
      <ComparisonPerfiles
        title="<span style='color: #6663FD; font-weight: 800;'>Tabla comparativa: </span>contratar contable remoto dedicado vs. <br>Asesoría Tradicional"
        subtitle="Descubre cómo el modelo de talento remoto dedicado te proporciona exclusividad operativa, visibilidad diaria de tus cuentas por pagar/cobrar (AP/AR) y una estructura de costes predecible."
        footerNote="*Precios orientativos: el coste final varía según especialidad, experiencia y país del profesional contable."
        oberstaffLabel="<span style='font-weight:800; color:#1B1B1B;'>Contable remoto</span> <span style='color:#FF66CC; font-weight:700;'>(Oberstaff)</span>"
        criterioLabel="Factor financiero"
        competitors={[
          "Contable local en España",
          "Asesoría/Gestoría tradicional" 
        ]}
        rows={[
          {
            label: "Coste mensual",
            oberstaffValue: "<strong>Desde 875€/mes</strong>",
            competitorValues: [
              "2.100–3.500€ + SS",
              "Variable",
            ],
          },
          {
            label: "Foco Operativo",
            oberstaffValue: "<span class='icon-check'>✓</span> Día a día (Bookkeeping). Registra, concilia y reporta en tiempo real",
            competitorValues: [
              "<span class='icon-check'>✓</span> Día a día. Alto coste de estructura",
              "Normalmente Trimestral. Enfocada en liquidar impuestos",
            ],
          },
          {
            label: "Riesgo Laboral",
            oberstaffValue: "<span class='icon-check'>✓</span> Cero. Contrato B2B internacional ",
            competitorValues: [
              "Alto. IRPF, Seguros Sociales, despidos.",
              "Cero. Contrato de servicios",
            ],
          },
          {
            label: "Integración Tecnológica",
            oberstaffValue: "<span class='icon-check'>✓</span> Nativa. Opera dentro de tu Slack y tu propio ERP (Holded, QuickBooks, otros)",
            competitorValues: [
              "Nativa",
              "Externa. Debes enviarles Excel o PDFs constantemente",
            ],
          }
        ]}
      />
    </div>

    <div class="fade-in-section">
      <PricingCardPerfil
        sectionTitle="Previsibilidad financiera: estructura tus costes contables con una <span style='color:#6663FD; font-weight: 800;'>tarifa plana B2B</span>"
        sectionSubtitle="Estructura tus costes fijos con previsibilidad absoluta. Nuestra tarifa cubre todo el ciclo: headhunting, compliance legal internacional y nómina. El coste escala únicamente en función del seniority técnico (Bookkeeper vs. Controller)."
        cardTitle="Tarifa mensual unificada"
        cardSubtitle="Todo incluido · Jornada completa · Sin comisiones ocultas"
        priceLabel="DESDE"
        priceAmount="875€"
        pricePeriod="/ mes"
        features={[
          "Contabilidad general · registro, asientos y cierres",
          "Facturación y cobros · cuentas por pagar y por cobrar",
          "Herramientas · Sage, Holded, A3, QuickBooks y Xero"
        ]}
        ctaText="Solicitar propuesta"
        ctaHref="#"
        disclaimer="*Precios orientativos. El coste final depende del perfil, país y nivel de experiencia. Sin costes ocultos ni comisiones adicionales."
      />
    </div>

    
   <BeneficiosPerfilDisenador
    title="El ROI de un contable In-House: Por qué blindar tus finanzas con <span class='bp-brand'>Oberstaff<span class='bp-dot'>.</span></span>?"
    subtitle="Más control que con una gestoría externa y menos fricción que una contratación local."
    image="/img2-contable.webp"
    imageAlt=""
    infoTitle="Manual de validación financiera: cómo filtrar y contratar al contable ideal para tu negocio"
    features={[
        {
            icon: "🎯",
            title: "Eficiencia de Capital:",
            description: "Escala tu equipo de control financiero sin el lastre de los Seguros Sociales o IRPF del marco laboral español. Una cuota plana que protege tu Cash Flow."
        },
        {
            icon: "⚡",
            title: "Integridad de Datos Garantizada:",
            description: "Tu contable se integra directamente en tu software, con acceso a la contabilidad real de tu empresa y continuidad en los procesos"
        },
        {
            icon: "🛡️",
            title: "Tú controlas la estrategia financiera:",
            description: "Tu profesional gestiona el ciclo contable y te reporta la situación financiera. Sin que tu empresa asuma ningún riesgo laboral."
        }
    ]}
    infoItems={[
        {
            title: "¿Por qué las empresas españolas contratan contables remotos en LATAM?",
            description: "Los profesionales en finanzas y contabilidad en países como Colombia, Argentina o Venezuela tienen una formación académica equivalente, están habituados a trabajar con las Normas Internacionales de Información Financiera (NIIF), normativa fiscal internacional y pueden especializarse en los estándares españoles IVA, IRPF, Impuesto de Sociedades, modelos 303, 200 y 390 en un tiempo de adaptación muy corto. Oberstaff selecciona y evalúa ese talento por ti."
        },
        {
            title: "¿Qué definir antes de contratar un contador remoto?",
            description: "Define bien tus necesidades: ¿Buscas contabilidad general, apoyo fiscal, control financiero o un auxiliar contable? Cuanto más concreto sea el briefing, más rápido encontrarás al perfil ideal. En Oberstaff te ayudamos a definirlo en una llamada de 15 minutos sin compromiso."
        },
         {
            title: "¿Qué diferencia hay entre contratar contable por horas o a jornada completa?",
            description: "Si tu empresa tiene un volumen contable bajo o estacional, un contable por horas puede ser suficiente. Si necesitas registro diario de operaciones, cierres mensuales, conciliación bancaria continua y apoyo fiscal regular, contratar contable a jornada completa y en exclusiva ofrece mayor continuidad y profundidad de conocimiento de tu negocio. Oberstaff también ofrece opciones de media jornada para empresas con volumen contable moderado — consúltalo en el briefing."
        },
        {
            title: "¿Este perfil sustituye a mi asesoría fiscal en España?",
            description: "La complementa perfectamente. Tu asesoría local es experta en tributación española y presentación de impuestos ante Hacienda. Tu contador remoto dedicado actúa como tu Bookkeeper interno: prepara los números al milímetro diariamente para que la gestoría solo tenga que pulsar el botón de presentar los impuestos, evitando sobrecostes por desorden documental."
        },
        {
            title: "¿Qué nivel de fluidez técnica se exige en los ERPs?",
            description: "La ofimática básica no sirve en finanzas corporativas. Filtramos perfiles con experiencia real en ecosistemas financieros modernos. Ya sea que tu empresa utilice Holded, A3, QuickBooks, Xero, Odoo o SAP, validamos que el candidato posea una curva de aprendizaje mínima y entienda la arquitectura de las cuentas de tu negocio."
        }
    ]}
/>

 

 <div class="fade-in-section">
            <CasosExitoSection
                title="Casos de éxito corporativo: organziaciones españolas que ya trabajan con <span style='font-weight: 900; color: #6663FD;'>Oberstaff</span><span style='font-weight: 900; color: #FF66CC;'>.</span>"
                subtitle=""
                testimonials={[
                    {
                        stars: 5,
                        avatar: "/fernando.webp",
                        text: "Estaba en busca de talento remoto especializado para mi empresa y después de varias búsquedas sin éxito, encontré a <strong>Oberstaff<span style='color: #FF66CC;'>.</span></strong> en Instagram Desde nuestra primera llamada, su profesionalismo y calidad de trabajo me dejaron impresionado. Ahora, gracias a su excelente servicio, he expandido mi contrato con ellos para incluir más personal.",
                        author: "Fernando Calderón",
                        role: "CEO · BeautyPro",
                    },
                    {
                        stars: 5,
                        avatar: "/sha.webp",
                        text: "Con <strong>Oberstaff<span style='color: #FF66CC;'>.</span></strong> pude dar trabajo a dos personas a tiempo completo, ahorrando costes de reclutamiento, espacios de oficina y salario que tendría al hacerlo en España. Lo mejor de todo es que todo está incluido en una misma factura. Con <strong>Oberstaff<span style='color: #FF66CC;'>.</span></strong>, encontré la solución perfecta para mis necesidades de contratación remota y optimización de costes.",
                        author: "Shadai Iborra",
                        role: "CEO · @amediastory",
                    },
                ]}
            />
        </div>

   
  <div class="fade-in-section">
   <PressSection 
   title="Prensa y menciones" />

  </div>

    <FAQSection
            title="Compliance, contingencia laboral y facturación: <strong>dudas clave sobre contratar contable virtual</strong>"
            ctaText="Integrar talento financiero internacional exige garantías jurídicas absolutas. Bajo nuestra infraestructura externalizas el bookkeeping diario sin asumir riesgos de falsa autonomía ni contingencias patronales en España. Aclaramos cómo blindamos tu operativa legal y fiscal."
            ctaButtonText="Hablar con asesor →"
         
        />



  <div class="fade-in-section">
    <ConversionPerfilDisenador
      title="Elimina la latencia de tus <br>datos financieros: da el paso definitivo para <strong>contratar contable dedicado</strong>"
      subtitle="Depender de la contabilidad reactiva frena el crecimiento de tu empresa. Transforma tu departamento financiero externalizando el día a día operativo a talento dedicado y seguro. Completa el formulario inicial y recibe una propuesta en 24 horas. Primera consulta de viabilidad sin coste."
      buttonText="Solicitar propuesta gratuita →"
      noteText="Nota: Rellenarlo te lleva menos de 1 minuto"
    />
  </div>
  





</DashboardLayoutPerfiles>

<style>
  .service-detail-container {
  }

  /* Estilos específicos para QueEsServicioSection en esta página */
  :global(.que-es-servicio-section .quote-blue-border) {
    border-left: 4px solid #FF66CC !important;
    color: #FF66CC !important;
    font-size: 16px !important;
    margin-top: 0 !important; /* Para alinear con el inicio de la imagen */
    font-weight: 600 !important;
  }

  :global(.que-es-servicio-section .que-es-main-content) {
    align-items: flex-start !important;
  }

  :global(.employer-use-cases-grid) {
    grid-template-columns: repeat(3, 1fr) !important;
  }

  @media (max-width: 900px) {
    :global(.employer-use-cases-grid) {
      grid-template-columns: 1fr !important;
    }
  }

  :global(.employer-use-cases-grid .icon-box) {
    background-color: transparent !important;
    border: none !important;
    padding: 0 !important;
    width: 100% !important;
    height: auto !important;
    margin-bottom: 25px !important;
    justify-content: flex-start !important;
  }

  :global(.employer-use-cases-grid .icon-emoji-servicios-home) {
    font-size: 35px !important;
    padding: 0 !important;
  }

  /* Fondo exclusivo para la sección de áreas del contable */
  :global(section.employer-use-cases) {
    background-color: #FAFAFC !important;
 
  }

  /* Fondo exclusivo para la sección de casos de éxito en esta página */
  :global(.casos-exito) {
    background-color: #FAFAFC !important;
  
    padding-bottom: 80px !important;
  }

  /* Estilos específicos para la sección FAQ en esta página */
  :global(.faq-disenador-custom .faq-columns) {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
  }

  :global(.faq-disenador-custom .faq-left-column) {
    position: static !important;
    width: 100% !important;
    max-width: 800px !important;
    margin-bottom: 40px !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    text-align: left !important;
  }

  :global(.faq-disenador-custom .faq-main-title) {
    margin-left: 0 !important;
    margin-right: 0 !important;
    text-align: left !important;
  }

  :global(.faq-disenador-custom .faq-right-column) {
    display: none !important;
  }

  :global(.faq-disenador-custom .faq-cta-card) {
    margin: 0 !important;
    padding: 0 !important;
    max-width: 600px !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    text-align: left !important;
  }

  :global(.faq-disenador-custom .faq-cta-card p) {
    font-family: 'Poppins', sans-serif !important;
    font-size: 18px !important;
    font-weight: 400 !important;
    color: #5A5A5A !important;
    line-height: 1.6 !important;
    margin-bottom: 30px !important;
