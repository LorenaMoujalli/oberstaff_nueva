---
import DashboardLayoutPerfiles from "../../layouts/DashboardLayoutPerfiles.astro";
import LeadHeroSection from "../../components/community-manager/LeadHeroSection.astro";
import TrustBarPerfiles from "../../components/trust-bar-perfiles/TrustBarPerfiles.astro";
import InfoServicePerfil from "../../components/info-services-perfil/InfoServicePerfil.astro";
import AreasPerfiles from "../../components/areas-perfiles/AreasPerfiles.astro";
import TimelinePerfiles from "../../components/timeline-perfiles/TimelinePerfiles.astro";
import CTAIntermedioPerfil from "../../components/cta-intermedio-perfil/CTAIntermedioPerfil.astro";
import ComparisonPerfiles from "../../components/comparison-perfiles/ComparisonPerfiles.astro";
import PricingCardPerfil from "../../components/pricing-perfil/PricingCardPerfil.astro";
import BeneficiosPerfil from "../../components/beneficios-perfil/BeneficiosPerfil.astro";
import GuiaPerfiles from "../../components/guia-perfiles/GuiaPerfiles.astro";
import CasosExitoPerfiles from "../../components/casos-exito-perfiles/CasosExitoPerfiles.astro";
import FAQSectionSEO from "../../components/faq-servicios/FAQSection-seo.astro";
import PressSection from "../../components/press/PressSection.astro";
import ConversionPerfil from "../../components/conversion-perfil/ConversionPerfil.astro";
import RolesPerfil from "../../components/roles-del-perfil/RolesPerfil.astro";
---

<DashboardLayoutPerfiles
    title="Contratar Experto SEO Remoto | Oberstaff"
    description="Talento de LATAM exclusivo para tu empresa española. Con Oberstaff, contratar experto SEO es seguro, ágil y con zona horaria 100% compatible."
    keywords="contratar experto seo"
>
    <div class="service-detail-container" id="inicio">
        <LeadHeroSection
            topLabel=""
            title="Contratar experto SEO para tu empresa española"
            cardTitle="Comienza ahora"
            buttonText="Ver perfiles pre-evaluados y solicitar propuesta"
            footerLinkText="Ver cómo funciona →"
            footerLinkHref="#como-contratar"
        >
            <Fragment slot="description">
                Conecta tu negocio con un especialista en SEO evaluado, con
                horario compatible con España y capacidad para integrarse de
                verdad en tu equipo.
            </Fragment>
        </LeadHeroSection>

        <div class="fade-in-section">
            <TrustBarPerfiles
                title="+5.000 empresas confían en nosotros"
                features={[
                    "Dedicación exclusiva",
                    "Perfiles evaluados",
                    "Integración rápida",
                    "Horario compatible con España",
                ]}
            />
        </div>

        <div class="fade-in-section">
            <InfoServicePerfil
                mainQuestion="El talento que buscas, listo para trabajar contigo"
                answerText="Oberstaff  te conecta con expertos en posicionamiento SEO de Latinoamérica, que trabajan 100% en remoto bajo tu dirección."
                priceBoxTitle=""
                priceBoxText={`Sin complicaciones legales, gestión de nóminas ni costes laborales. Nosotros somos el empleador legal;  tú gestionas el día a día del profesional y los objetivos de negocio.`}
                summaryTitle="Checklist de ventajas"
                summaryItems={[
                    "Especialistas en posicionamiento web evaluados con pruebas técnicas y psicométricas",
                    "Sin riesgo legal",
                    "Factura mensual en euros para tu empresa",
                    "Sin permanencia mínima — cancela cuando quieras",
                    "Ahorro de hasta un 70% en costes de personal",
                ]}
                buttonText="Solicitar propuesta personalizada →"
                buttonHref="#inicio"
            />
        </div>

        <div class="fade-in-section">
            <AreasPerfiles
                title="¿Qué puede hacer un experto SEO remoto por tu empresa?"
                subtitle="Nuestros especialistas dominan el SEO técnico, de contenido y la optimización para que tu negocio escale en Google y sea mencionado en herramientas de IA generativa (ChatGPT, Gemini) para que captures tráfico cualificado y conviertas visitas en clientes."
                cards={[
                    {
                        icon: "ph:monitor-duotone",
                        iconColor: "#8b5cf6",
                        title: " SEO Técnico y Auditoría",
                        description:
                            "Análisis de estructura web, velocidad, Core Web Vitals y errores técnicos. Ideal si estas valorando contratar auditoria SEO antes de escalar.",
                    },
                    {
                        icon: "ph:article-duotone",
                        iconColor: "#ec4899",
                        title: "Contenido y Estrategia Editorial",
                        description:
                            "Investigación de keywords, arquitectura de contenidos, redacción optimizada y clústeres temáticos.",
                    },
                    {
                        icon: "ph:link-duotone",
                        iconColor: "#14b8a6",
                        title: "Link Building y Autoridad de Dominio",
                        description:
                            "Estrategias de construcción de enlaces, relaciones con medios digitales y digital PR.",
                    },
                    {
                        icon: "ph:map-pin-duotone",
                        iconColor: "#eab308",
                        title: "SEO Local para Empresas Españolas",
                        description:
                            "Optimización de Google Business Profile, búsquedas geolocalizadas y estrategias para destacar en tu ciudad.",
                    },
                    {
                        icon: "ph:chart-bar-duotone",
                        iconColor: "#ef4444",
                        title: "Analítica y Reporting",
                        description:
                            "Configuración de GA4, Search Console, seguimiento de rankings e informes mensuales orientados al negocio.",
                    },
                    {
                        icon: "ph:trend-up-duotone",
                        iconColor: "#3b82f6",
                        title: "Posicionamiento Web para Pymes",
                        description:
                            "Estrategias adaptadas a presupuestos de pymes españolas. Foco en keywords transaccionales de alta conversión.",
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <div id="como-contratar" style="scroll-margin-top: 80px;">
                <TimelinePerfiles
                    title="Tu especialista en SEO, listo en pocos días"
                    subtitle="Un proceso sencillo y transparente, sin burocracia ni sorpresas"
                    items={[
                        {
                            title: "Cuéntanos qué necesitas",
                            timeTag: "15 min · Sin compromiso",
                            description:
                                "Agenda una llamada gratuita y explícanos el perfil que necesitas: especialidad, horas, herramientas y objetivos.",
                        },
                        {
                            title: "Preseleccionamos candidatos",
                            timeTag: "En menos de 7 días",
                            description:
                                "Nuestro equipo selecciona entre 3-5 expertos en posicionamiento SEO evaluados que encajan con tus requisitos técnicos y zona horaria.",
                        },
                        {
                            title: "Entrevista y eliges tú",
                            timeTag: "Tú decides siempre",
                            description:
                                "Conoces a los perfiles, valoras su encaje con tu equipo y decides con quién quieres trabajar. La decisión final siempre es tuya.",
                        },
                        {
                            title: "Empieza a trabajar",
                            description:
                                "Una vez elegido el perfil, facilitamos el onboarding para que el especialista SEO se integre rápido en tu operativa, herramientas y objetivos.",
                        },
                    ]}
                />
            </div>
        </div>

        <div class="fade-in-section">
            <CTAIntermedioPerfil
                alertText=""
                title="¿Ya sabes lo que necesitas?"
                description="Cuéntanos el perfil que requieres y recibe una propuesta personalizada en menos de 24 horas. Sin compromiso."
                buttonText="Quiero Solicitar propuesta personalizada"
                buttonHref="#inicio"
            />
        </div>

        <div class="fade-in-section">
            <RolesPerfil
                title="Perfiles de especialistas en posicionamiento web disponibles"
                subtitle="Encuentra el profesional que mejor se adapte a las necesidades y objetivos de tu organización."
                customClass="grid-seo"
                roles={[
                    {
                        title: "Especialista en SEO Técnico",
                        description: "Optimización técnica y rendimiento web",
                        icon: "ph:gear-duotone",
                        iconColor: "#3b82f6",
                        borderColorClass: "border-pastel-blue",
                        techStack: [
                            "Screaming Frog",
                            "GSC",
                            "Core Web Vitals",
                            "Semrush",
                        ],
                    },
                    {
                        title: "Redactor SEO y Estratega",
                        description:
                            "Contenido optimizado y arquitectura de información",
                        icon: "ph:article-duotone",
                        iconColor: "#8b5cf6",
                        borderColorClass: "border-pastel-purple",
                        techStack: [
                            "Ahrefs",
                            "Surfer SEO",
                            "WordPress",
                            "Keywords",
                        ],
                    },
                    {
                        title: "Especialista en Link Building",
                        description:
                            "Construcción de autoridad y relaciones digitales",
                        icon: "ph:link-duotone",
                        iconColor: "#22c55e",
                        borderColorClass: "border-pastel-green",
                        techStack: ["Ahrefs", "Moz", "Outreach", "Digital PR"],
                    },
                    {
                        title: "SEO para eCommerce",
                        description:
                            "Optimiza categorías, fichas, filtros y enlazado.",
                        icon: "ph:shopping-cart-duotone",
                        iconColor: "#eab308",
                        borderColorClass: "border-pastel-yellow",
                        techStack: [
                            "eCommerce",
                            "taxonomías",
                            "CRO",
                            "tracking",
                        ],
                    },
                    {
                        title: "Especialista SEO local",
                        description:
                            "Perfecto para negocios con presencia física local.",
                        icon: "ph:map-pin-duotone",
                        iconColor: "#f97316",
                        borderColorClass: "border-pastel-orange",
                        techStack: ["GBP", "resenas", "landings locales"],
                    },
                    {
                        title: "Consultor SEO Generalista",
                        description: "Estrategia 360° y gestión integral",
                        icon: "ph:chart-bar-duotone",
                        iconColor: "#ec4899",
                        borderColorClass: "border-pastel-pink",
                        techStack: [
                            "Semrush",
                            "GA4",
                            "Search Console",
                            "Looker",
                        ],
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <ComparisonPerfiles
                title="¿Cuánto cuesta contratar experto SEO? Oberstaff vs alternativas"
                subtitle="Compara el coste real, la dedicación y la carga operativa de cada opción para tu organización."
                criterioLabel="Criterio"
                oberstaffLabel="Contratar SEO Oberstaff (LATAM)"
                competitors={[
                    "Especialista en posicionamiento Web en España",
                    "Experto SEO Freelance",
                    "Agencia",
                ]}
                rows={[
                    {
                        label: "Coste mensual",
                        oberstaffValue: "Desde 900€",
                        oberstaffBlueText: true,
                        competitorValues: [
                            "2.200–3.500€/mes + costes de Seguridad Social",
                            "1.500–2.500€/mes",
                            "Variable",
                        ],
                    },
                    {
                        label: "Dedicación exclusiva",
                        oberstaffValue: "Sí, full time",
                        competitorValues: [
                            "Sí",
                            `<iconify-icon icon="solar:danger-triangle-bold" class="icon-warning" style="color: #f59e0b;"></iconify-icon> No siempre`,
                            `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> No`,
                        ],
                    },
                    {
                        label: "Gestión legal",
                        oberstaffValue: "La asume Oberstaff",
                        competitorValues: [
                            `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> La asume tu empresa`,
                            "Facturación externa",
                            "Incluida (agencia)",
                        ],
                    },
                    {
                        label: "Horario España",
                        oberstaffValue: `<iconify-icon icon="solar:check-circle-bold" class="icon-check" style="color: #10b981;"></iconify-icon> 100% compatible`,
                        competitorValues: [
                            "Compatible",
                            `<iconify-icon icon="solar:danger-triangle-bold" class="icon-warning" style="color: #f59e0b;"></iconify-icon> Depende disponib.`,
                            "Depende de carga",
                        ],
                    },
                    {
                        label: "Integración en equipo",
                        oberstaffValue: `Alta`,
                        competitorValues: [
                            `Alta`,
                            `Media`,
                            `Media`,
                        ],
                    },
                    {
                        label: "Sin permanencia",
                        oberstaffValue: "Sí",
                        competitorValues: [
                            `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> No siempre`,
                            `Según contrato`,
                            "No siempre",
                        ],
                    },

                ]}
            />
        </div>

        <div class="fade-in-section">
            <PricingCardPerfil
                title="Precio consultor SEO con Oberstaff"
                subtitle="Tarifas claras y sin sorpresas. Todo incluido: gestión, nómina y compliance."
                priceLabel="DESDE"
                priceAmount="900€"
                pricePeriod="/mes"
                badgeText="Todo incluido · jornada completa · sin costes ocultos"
                features={[
                    "SEO técnico · auditorías, Core Web Vitals y velocidad",
                    "Investigación de keywords y arquitectura de contenidos",
                    "Link building · autoridad de dominio y digital PR",
                    "SEO local · Google Business Profile y búsquedas geolocalizadas",
                    "Analítica y reporting · GA4, Search Console y Semrush",
                ]}
                disclaimer="Precios orientativos. El coste final depende del perfil, país y nivel de experiencia. Sin costes ocultos ni comisiones adicionales."
            />
        </div>

        <div class="fade-in-section">
            <BeneficiosPerfil
                title="¿Por qué incorporar consultores SEO con Oberstaff?"
                subtitle="Combinamos integración real en equipo con una operativa más ligera para tu negocio, así te centras en resultados y no en fricción administrativa."
                items={[
                    {
                        icon: "solar:user-check-rounded-bold-duotone",
                        iconColor: "#3b82f6",
                        title: "Dedicación exclusiva:",
                        description:
                            "Tu experto SEO trabaja enfocado en tu organización, tus prioridades y tus objetivos, no repartido entre múltiples clientes.",
                    },
                    {
                        icon: "solar:rocket-bold-duotone",
                        iconColor: "#f59e0b",
                        title: "Integración rápida:",
                        description:
                            "El perfil se incorpora a tus reuniones, herramientas y dinámica de trabajo para aportar desde el principio.",
                    },
                    {
                        icon: "solar:shield-check-bold-duotone",
                        iconColor: "#8b5cf6",
                        title: "Operativa resuelta:",
                        description:
                            "Oberstaff simplifica la parte contractual y administrativa para que la incorporación del perfil sea más ágil para tu empresa.",
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <GuiaPerfiles
                title="¿Cómo contratar especialistas en posicionamiento web para tu negocio?"
                intro="Claves para tomar la mejor decisión antes de incorporar un especialista en posicionamiento web."
                items={[
                    {
                        icon: "ph:users-four-duotone",
                        iconColor: "#3b82f6",
                        title: "Especialista en SEO remoto vs consultor seo local",
                        description:
                            "Antes de decidir, compara bien las opciones, un experto en SEO presencial en España puede superar los 3.000€/mes en coste total; un consultor SEO freelance te da flexibilidad pero sin dedicación exclusiva. Un especialista remoto de Colombia, Argentina o Venezuela con Oberstaff combina lo mejor de ambos: jornada completa, exclusividad y desde 900€/mes, sin que asumas ninguna relación laboral directa.",
                    },
                    {
                        icon: "ph:magnifying-glass-duotone",
                        iconColor: "#f59e0b",
                        title: "¿Qué buscar al contratar consultor SEO?",
                        description:
                            "Antes de contratar especialista en posicionamiento web, es importante definir bien tus objetivos: ¿quieres aumentar tráfico orgánico, mejorar rankings para palabras clave concretas, hacer una auditoría o lanzar una estrategia de contenidos? Cuanto más concreto sea el briefing, más rápido adaptará el profesional la estrategia a los cambios del algoritmo de Google. En Oberstaff te ayudamos a definirlo en una llamada de 15 minutos.",
                    },
                    {
                        icon: "ph:cpu-duotone",
                        iconColor: "#ec4899",
                        title: "¿Cómo afecta la IA y el nuevo algoritmo de Google a tu estrategia?",
                        description:
                            "La irrupción de la Inteligencia Artificial en los resultados de búsqueda con funciones como la Search Generative Experience (SGE) de Google está redefiniendo cómo las empresas deben posicionarse. Un especialista SEO actualizado no solo trabaja keywords: entiende cómo los modelos de IA evalúan la relevancia y la autoridad de un contenido, y adapta la estrategia para mantener visibilidad orgánica en este nuevo entorno.",
                    },
                    {
                        icon: "ph:suitcase-simple-duotone",
                        iconColor: "#14b8a6",
                        title: "¿Dónde puedo contratar SEO?: ventajas de Oberstaff",
                        description:
                            "Existen varias plataformas para incorporar expertos en posicionamiento web, como marketplaces de freelancers o agencias. Sin embargo, Oberstaff ofrece un modelo diferente: talento dedicado en exclusiva a tu empresa, con contrato estable y toda la gestión laboral cubierta. Mayor compromiso, mejor integración y ausencia de riesgos legales para tu negocio.",
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <CasosExitoPerfiles
                title="Empresas Españolas que ya trabajan con Oberstaff"
                cases={[
                    {
                        name: "Shadai Iborra",
                        position: "CEO @amediastory - Barcelona",
                        achievements: [
                            { text: "· CM integrada en 3 semanas" },
                            {
                                text: "· Ahorro del 65% vs local",
                                highlight: true,
                            },
                            { text: "· Castellano perfecto" },
                        ],
                    },
                    {
                        name: "Fernando Calderón",
                        position: "CEO bybeautypro.com - Madrid",
                        achievements: [
                            { text: "· CM + editor de video" },
                            { text: "· Proceso rápido y sin complicaciones" },
                            {
                                text: "· Redes +40% en 4 meses",
                                highlight: true,
                            },
                        ],
                    },
                    {
                        name: "Kate McCaffert",
                        position: "KM Real Estate - Marbella",
                        achievements: [
                            {
                                text: "· +2 años con la misma CM",
                                highlight: true,
                            },
                            { text: "· Equipo remoto integrado al 100%" },
                            { text: "· LinkedIn e Instagram con éxito" },
                        ],
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <FAQSectionSEO
                title="Preguntas frecuentes"
                subtitle="Resolvemos las dudas más frecuentes sobre el proceso, precios y funcionamiento del servicio a negocios que deseen incorporar talento de LATAM."
            />
        </div>
    </div>

    <div class="fade-in-section">
        <PressSection />
    </div>

    <div class="fade-in-section">
        <ConversionPerfil
            title="¿Listo para contratar experto SEO remoto?"
            subtitle="Completa el formulario (tardarás menos de 1 minuto) y en menos de 24 horas recibirás una propuesta personalizada sin compromiso."
            buttonText="Solicitar propuesta gratuita"
            relatedRoles={[
                {
                    label: "Diseñador gráfico",
                    icon: "solar:pen-new-square-bold-duotone",
                    iconColor: "#ec4899",
                },
                {
                    label: "Diseñador Web",
                    icon: "solar:laptop-minimalistic-bold-duotone",
                    iconColor: "#eab308",
                },
                {
                    label: "Desarrollador Web",
                    icon: "solar:code-bold-duotone",
                    iconColor: "#10b981",
                },
            ]}
        />
    </div>
</DashboardLayoutPerfiles>

<style>
    .service-detail-container {
