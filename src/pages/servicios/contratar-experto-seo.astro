              "Multicliente",
              "Tu cuenta compite por horas de atención",
            ],
          },
          {
            label: "Velocidad de implementación",
            oberstaffValue:
              "<span class='icon-check'>✓</span>  Muy alta",
            competitorValues: [
              "Muy alta",
              "Media",
              "Lenta, sujeta a tickets de soporte",
            ],
          },
          {
            label: "Horario de sincronía",
            oberstaffValue:
              "<span class='icon-check'>✓</span> Compatible con España",
            competitorValues: [
              "<span class='icon-check'>✓</span> Compatible",
              "Depende disponib.",
              "Depende de carga",
            ],
          },
          {
            label: "Integración en herramientas",
            oberstaffValue:
              "GSC, GA4, Semrush",
            competitorValues: [
              "Alta",
              "Media",
              "Acceso parcial",
            ],
          }
          
        ]}
      />
    </div>

    <div class="fade-in-section">
      <PricingCardPerfil
        sectionTitle="Precio profesionales SEO <span style='color:#6663FD; font-weight: 900;'>con Oberstaff</span>"
        sectionSubtitle="Tarifas transparentes para escalar tu visibilidad y tráfico orgánico."
        cardTitle="Fee integral"
        cardSubtitle="Jornada completa dedicada a tus SERPs · sin costes ocultos."
        priceLabel="DESDE"
        priceAmount="900€"
        pricePeriod="/ mes"
        features={[
          "SEO técnico · auditorías, Core Web Vitals y velocidad",
          "Investigación de keywords y arquitectura semántica HTML",
          "Link building · autoridad de dominio y digital PR",
