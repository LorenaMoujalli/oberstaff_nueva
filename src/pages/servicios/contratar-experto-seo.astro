        subtitle="Encuentra el profesional de Search Engine Optimization que mejor encaja con el estado actual de tu web y los objetivos de posicionamiento de tu negocio."
        layout="modern"
        customClass="grid-seo" 
        footerText="💡 ¿Buscas resultados inmediatos con publicidad de pago?</> El SEO orgánico construye a largo plazo. Para campañas SEM/PPC "
        footerLinkText="Ver perfil de Especialista en Google Ads →"
        footerLinkHref="#"
        roles={[
          {
            title: "🔍 Especialista en SEO Técnico (Crawl & Index)",
            description: "",
            icon: "",
            iconColor: "#FF66CC",
            borderColorClass: "border-pink",
            subtitle: "Ideal para proyectos con problemas de rastreo, indexación, rendimiento, arquitectura o migraciones que requieren criterio técnico.",
            techStack: ["Screaming Frog", "GSC", "Core Web Vitals", "Semrush"],
            buttonText: "Solicitar más información →",
            buttonHref: "#",
          },
          {
            title: "✍️ Arquitecto de Contenidos y EEAT",
            description: "",
            icon: "",
            iconColor: "#3b76f6",
            borderColorClass: "border-blue",
            subtitle: "Pensado para marcas que necesitan alinear su blog con la intención de búsqueda y estructurar un marcado semántico impecable.",
            techStack: ["Surfer SEO", "Ahrefs", "WordPress", "Schema Markup"],
            buttonText: "Solicitar más información →",
            buttonHref: "#",
          },
          {
            title: "🔗 Especialista en Link Building (Off-Page)",
            description: "",
            icon: "",
            iconColor: "#66FF99",
            borderColorClass: "border-green",
            subtitle: "Enfocado en la captación de enlaces entrantes, auditoría de Anchor Texts y recuperación de PageRank perdido.",
            techStack: ["Moz", "Ahrefs", "Outreach", "Digital PR", "Disavow Tool"],
            buttonText: "Solicitar más información →",
            buttonHref: "#",
          },
          {
            title: "📊 Consultor SEO 360º (Generalista)",
            description: "",
            icon: "",
            iconColor: "#CCFF66",
            borderColorClass: "border-yellow",
            subtitle: "Un perfil Senior que orquesta el balance perfecto entre estado técnico, volumen de publicación editorial y crecimiento de autoridad de dominio.",
            techStack: ["Semrush", "GA4", "Search Console", "Looker Studio"],
            buttonText: "Solicitar más información → ",
            buttonHref: "#",
          },
          {
            title: "🛒 Contratar experto SEO para eCommerce",
            description: "",
            icon: "",
            iconColor: "#FF66CC",
            borderColorClass: "border-pink",
            subtitle: "Resuelve paginaciones tóxicas, categorías, faceted navigation y optimización de fichas de producto orientadas a la venta transaccional.",
            techStack: ["eCommerce", "taxonomías", "CRO", "tracking"],
            buttonText: "Solicitar más información →",
            buttonHref: "#",
          },
          {
            title: "📍 Especialista SEO local",
            description: "",
            icon: "",
            iconColor: "#3b76f6",
            borderColorClass: "border-blue",
            subtitle: "Para negocios con presencia en ciudades o provincias españolas: Google Business Profile, reseñas y búsquedas geolocalizadas.",
            techStack: ["GBP", "resenas", "landings geolocalizadas"],
            buttonText: "Solicitar más información →",
            buttonHref: "#",
          },
        ]}
      />
    </div>

    <div class="fade-in-section">
      <ComparisonPerfiles
        title="Elimina el pasivo laboral local: la ventaja estructural de contratar  <span style='color: #6663FD; font-weight: 900;'> experto SEO remoto</span>"
        subtitle="Evalúa el impacto económico, la dedicación en horas a tu proyecto y la rigidez laboral de cada modalidad de servicio SEO."
        footerNote="Nota: Las tarifas fluctúan en base al nivel técnico (Junior, Mid, Senior SEO), rama de especialidad y país de residencia."
        oberstaffLabel="<span style='font-weight:800; color:#1B1B1B;'>Contratar SEO OBERSTAFF</span> <span style='color:#FF66CC; font-weight:700;'>(LATAM)</span>"
        competitors={[
          "Especialista en posicionamiento Web en España",
          "FREELANCE",
          "AGENCIA",
