---
import DashboardLayoutPerfiles from "../../layouts/DashboardLayoutPerfiles.astro";
import LeadHeroSection from "../../components/community-manager/LeadHeroSection.astro";
import ComparisonPerfiles from "../../components/comparison-perfiles/ComparisonPerfiles.astro";
import PricingCardPerfil from "../../components/pricing-perfil/PricingCardPerfil.astro";
import BeneficiosPerfilDisenador from "../../components/beneficios-perfil/BeneficiosPerfilDisenador.astro";
import PressSection from "../../components/press/PressSection.astro";
import ConversionPerfilDisenador from "../../components/conversion-perfil/ConversionPerfilDisenador.astro";
import RolesPerfil from "../../components/roles-del-perfil/RolesPerfil.astro";
import QueEsServicioSection from "../../components/QueEsServicio/QueEsServicioSection.astro";
import ServicesSection from "../../components/services-oberstaff/ServicesSection.astro";
import EorStepsSection from "../../components/eor-steps-servicios/EorStepsSection.astro";
import EorCta from "../../components/eor-cta-servicios/EorCta.astro";
import CasosExitoSection from "../../components/casos-exito-servicios/CasosExitoSection.astro";
import FAQSection from "../../components/faq-servicios/FAQSection-seo.astro";
---
 
<DashboardLayoutPerfiles
  title="Contratar Experto SEO Remoto | Oberstaff"
  description="Talento de LATAM exclusivo para tu empresa española. Con Oberstaff, contratar experto SEO es seguro, ágil y con zona horaria 100% compatible."
  footerTitle="Roles Relacionados"
  footerLinks={[
    { text: "🎨 Diseñador web", href: "#" },
    { text: "💻 Desarrollador web", href: "#" }, 
    { text: "📱 Diseñador gráfico", href: "#" },
  ]}
  keywords="contratar experto seo"
>
  <div class="service-detail-container" id="inicio">
    <LeadHeroSection
      topLabel="Posicionamiento Web y Tráfico Orgánico"
      title="Contratar experto SEO: Internaliza tu estrategia orgánica y domina las SERPs con talento dedicado"
      cardTitle="Encuentra a tu experto SEO hoy"
      cardSubtitle="Accede a perfiles pre-evaluados listos para tu empresa."
      buttonText="👉 Ver perfiles pre-evaluados y solicitar propuesta"
      buttonIcon=""
      buttonSubtext="↳ Tardarás menos de 1 minuto · Sin compromiso"
      footerLinkText="Ver cómo funciona el modelo EOR →"
      footerLinkHref="#como-contratar"
      badges={[
        { text: "Dedicación exclusiva", icon: "🎯" },
        { text: "Perfiles evaluados", icon: "📋" },
        { text: "Integración rápida", icon: "⚡" },
        { text: "Horario compatible con España", icon: "🕒" },
      ]}
      badgesClass="community-badges"
    >
      <Fragment slot="description">
      Deja de perder tráfico por errores de indexación y penalizaciones algorítmicas. Domina las SERPs con talento In-House. Conecta tu proyecto con un especialista en SEO, perfiles técnicos auditados en optimización de arquitectura web, resolución de canibalizaciones y despliegue de estrategias EEAT.
      </Fragment>
    </LeadHeroSection>

     <div class="fade-in-section">
            <QueEsServicioSection
                title="El estratega que buscas para escalar posiciones en Google sin aumentar tu pasivo laboral local"
                highlightWord="escalar posiciones en Google"
                description="Integra expertos en posicionamiento SEO de Latinoamérica, perfiles técnicos capaces de auditar tu etiquetado semántico HTML, reestructurar tus silos de contenido y limpiar tu perfil de enlaces tóxicos, todo de forma 100% remota bajo tu dirección."
                imageSrc="/img1-seo.webp"
                imageAlt="Profesional trabajando"
                badgeText="Tráfico Orgánico"
                quoteText=""
                checklistTitle="Checklist de ventajas:"
                checklistItems={[
                    "Contratar experto SEO evaluado en (Web Performance Optimization) y resolución de caídas de tráfico.",
                    "Reacción inmediata ante los Core Updates de Google durante tu misma jornada laboral.",
                    "Tu datos y contraseñas protegidos en Google Search Console y GA4 Oberstaff firma los acuerdos de confidencialidad.",
                    "Tarifa plana B2B: escala tu captación orgánica sin las altas comisiones de las agencias tradicionales.",
                    "Flexibilidad estructural: si la estrategia del consultor no mueve la aguja del tráfico Non-Brand, cancela con 30 días de preaviso, sin indemnizaciones complejas."
                ]}
                ctaText="Solicitar propuesta de talento SEO →"
                ctaHref="#"
                diffIcon=""
                diffTitle=""
                diffDescription=""
            />
        </div>


    <div class="fade-in-section">
      <ServicesSection
        title="¿Qué ejecuta un experto SEO dedicado <strong>por tu dominio?</strong>"
        description="Nuestros especialistas dominan la arquitectura web, el SEO de contenidos y la optimización de autoridad para que tu negocio escale en las SERPs de Google y sea mencionado en herramientas de IA generativa (SGE, ChatGPT, Gemini), capturando tráfico cualificado de forma recurrente."
        customClass="employer-use-cases"
        services={[
          {
            icon: "🔍",
            title: "SEO Técnico y Auditoría",
            description:
              "Detección de bucles de redirección, optimización de Core Web Vitals, configuración del archivo robots.txt, uso correcto de etiquetas canonical. Ideal si estás valorando contratar auditoría SEO antes de escalar.",
            linkText: "",
            href: "",
            customIconBg: "transparent",
            cardClass: "card-green",
          },
          {
            icon: "✍️",
            title: "Estrategia de Contenidos y EEAT",
            description:
              "Investigación de palabras clave (keyword research), arquitectura de la información, resolución de canibalización de palabras clave, curación de Thin Content y estructuración de clústeres temáticos.",
            linkText: "",
            href: "",
            customIconBg: "transparent",
            cardClass: "card-pink",
          },
          {
            icon: "🔗",
            title: "Link Building y Autoridad de Dominio",
            description:
              "Estrategias de construcción de enlaces (backlinks), relaciones con medios digitales y digital PR para potenciar el PageRank.  auditoría de backlinks tóxicos para protegerte de penalizaciones manuales.",
            linkText: "",
            href: "",
            customIconBg: "transparent",
            cardClass: "card-lime",
          },
          {
            icon: "📍",
            title: "SEO Local y Dominio del Map Pack",
            description:
              "Estructuración de datos NAP, optimización del Google Business Profile, gestión de reseñas y creación de landings hiper-geolocalizadas para llegar a los clientes en tu ciudad.",
            linkText: "",
            href: "",
            customIconBg: "transparent",
            cardClass: "card-purple",
          },
          {
            icon: "📊",
            title: "Analítica Orgánica Avanzada",
            description:
              "Configuración de conversiones en GA4, monitorización en Search Console, seguimiento de rankings y cuadros de mando orgánicos orientados al negocio.",
            linkText: "",
            href: "",
            customIconBg: "transparent",
            cardClass: "card-green",
          },
          {
            icon: "🚀",
            title: "Posicionamiento Web para Pymes",
            description:
              "Estrategias adaptadas a presupuestos de pymes españolas. Foco en keywords transaccionales de alta conversión (Bottom of the Funnel).",
            linkText: "",
            href: "",
            customIconBg: "transparent",
            cardClass: "card-lime",
          },
        ]}
      />
    </div>

    <div class="fade-in-section">
      <EorStepsSection
        title="Headhunting técnico: cómo filtramos <span style='color: #6663FD; font-weight: 800;'>al especialista en SEO</span> que protegerá tu dominio"
