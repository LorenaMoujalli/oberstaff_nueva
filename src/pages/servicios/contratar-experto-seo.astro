        steps={[
          {
            title: "Analizamos tus objetivos de posicionamiento",
            lineColorClass: "line-black",
            description:
              "Explícanos en una llamada gratuita y el perfil y especialidad requerida (Técnico, Local, Contenidos), herramientas del stack (Ahrefs, Screaming Frog) y objetivos de negocio.",
            badge: "15 min · Sin compromiso",
          },
          {
            title: "Filtrado de consultores SEO",
            lineColorClass: "line-pink",
            description:
              "Nuestro equipo selecciona entre 3-5 expertos en posicionamiento SEO evaluados que hacen match con tus requisitos técnicos y zona horaria.",
            badgeIcon: "📋",
            badge: "Perfiles analíticos evaluados",
          },
          {
            title: "Entrevista y eliges tú",
            lineColorClass: "line-orange",
            description:
              "Pregúntales directamente cómo resolverían una indexación masiva de URLs o cómo estructuran sus prompts de contenido. Valida su visión estratégica.",
            badge: "Tú decides siempre",
          },
          {
            title: "Empieza a trabajar",
            lineColorClass: "line-blue",
            description:
              "Una vez elegido el perfil, facilitamos el onboarding para que el especialista SEO se integre rápido a tus herramientas (GSC, GA4, Semrush), realice la auditoría inicial y entregue el primer plan en los primeros días.",
            badge: "Integración técnica en días",
          },
        ]}
      />
    </div>

    <div class="fade-in-section">
