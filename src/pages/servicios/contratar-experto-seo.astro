        ctaText="Solicitar propuesta"
        ctaHref="#"
        disclaimer="*La suscripción final fluctúa según la profundidad técnica y nivel del analista"
      />
    </div>

    <BeneficiosPerfilDisenador
      title="Sanea tu arquitectura web y domina las SERPs apoyándote en <span style='color:#6663FD; font-weight: 900;'>consultores SEO dedicados.</span>"
      subtitle="Combinamos el análisis milimétrico de un perfil In-House en tu web con la flexibilidad estructural, permitiéndote priorizar el aumento de tráfico sin la fricción del reclutamiento tradicional."
      image="/img2-seo.webp"
      imageAlt=""
      infoTitle="El checklist técnico para auditar el criterio de tus futuros especialistas en posicionamiento web"
      features={[
        {
          icon: "🎯",
          title: "Ejecución continua",
          description:
            "Tu experto SEO audita tus URLs, monitoriza tus caídas de tráfico y detecta oportunidades de negocio diarias.",
        },
        {
          icon: "⚡",
          title: "Independencia del coste por clic (CPC)",
          description:
            "Tu experto SEO estructura un dominio con autoridad que capta leads a coste marginal cero sostenido en el tiempo.",
        },
        {
          icon: "🛡️",
