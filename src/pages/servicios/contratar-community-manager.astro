---
import DashboardLayoutPerfiles from "../../layouts/DashboardLayoutPerfiles.astro";
---

<style is:global>
  /* --- GLOBAL / SHARED --- */
  .pink-dot {
    color: #FF66CC;
    font-weight: 900;
  }

  .service-detail-container {
    width: 100%;
    background-color: transparent;
    color: #1a1a1a;
  }

  .gradient-text {
    background: linear-gradient(90deg, #6663FD, #6663FD);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 900;
  }

  .gradient-text-alt {
    background: linear-gradient(90deg, #6663FD, #FF66CC);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* --- HERO (DARK) --- */
  .hero-custom {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 0 80px;
    z-index: 1;
    background-color: #000;
    color: #fff;
    overflow: hidden;
    
  }

  .glow-bg {
    position: absolute;
    filter: blur(120px);
    opacity: 0.5;
    z-index: -1;
    border-radius: 50%;
    pointer-events: none;
  }

  .pink-glow {
    top: -10%;
    left: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 102, 204, 0.4) 0%, rgba(255, 102, 204, 0) 70%);
  }

  .purple-glow {
    bottom: 10%;
    right: -5%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(102, 99, 253, 0.3) 0%, rgba(102, 99, 253, 0) 70%);
  }

  .hero-content-wrapper {
    max-width: 1200px;
    width: 100%;
    display: flex;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }

  .label-accent {
    color: #FF66CC;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 1.5px;
    margin-bottom: 24px;
    display: block;
    text-transform: uppercase;
  }

  .hero-title {
    font-size: 42px;
    line-height: 1.15;
    font-weight: 800;
    margin-bottom: 32px;
    color: #fff;
    max-width: 850px;
    font-family: 'Poppins', sans-serif;
  }

  .hero-description {
    font-size: 16;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 48px;
    max-width: 640px;
    font-family: 'Poppins', sans-serif;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    width: 660px;
    height: 92.99px;
  }

  .badge-item {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 10px 20px;
    border-radius: 50px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
  }

  .badge-icon {
    font-size: 1.1rem;
  }

  .badge-text {
    font-size: 13px;
    font-weight: 600;
    color: #fff;
  }

  .hero-form-section {
    display: flex;
    justify-content: flex-end;
  }

  .form-card {
  background: #FFFFFF;
    border-radius: 20px;
    padding: 40px 35px;
    width: 100%;
    max-width: 450px;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .form-title {
    font-size: 22px;
    font-weight: 800;
    margin-bottom: 12px;
    line-height: 1.2;
    font-family: 'Montserrat', sans-serif;
    color: #1b1b1b;
    text-align: center;
  }

  .form-subtitle {
    font-size: 14px;
    font-family: 'Poppins', sans-serif;
    color: #5a5a5a;
    margin-bottom: 36px;
    line-height: 1.5;
    text-align: center;
    margin-bottom: 25px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .form-group input {
    width: 367.78px;
    height: 50.21px;
    padding: 20px 24px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    font-size: 14px;
    background-color: #fcfcfc;
    transition: all 0.3s ease;
    font-family: 'Poppins', sans-serif;
  }

  .form-group input:focus {
    outline: none;
    border-color: #FF66CC;
    background-color: #fff;
    box-shadow: 0 0 0 4px rgba(255, 102, 204, 0.1);
  }

  .submit-btn {
    width: 367.78px;
    height: 73.19px;
    background: #FF66CC;
    color: #fff;
    border: none;
    padding: 20px;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 700;
    margin-top: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    cursor: pointer;
    font-family: 'Poppins', sans-serif;
  }

  .submit-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(255, 102, 204, 0.4);
    filter: brightness(1.05);
  }

  .emoji-wave {
    font-size: 1.3rem;
  }

  .form-footer {
    margin-top: 28px;
    text-align: center;
  }

  .footer-note {
    font-size: 12px;
    color: #5a5a5a;
    margin-bottom: 14px;
    font-family: 'Poppins', sans-serif;
  }

  .footer-link {
    font-size: 13px;
    color: #5a5a5a;
    text-decoration: none;
    font-weight: 600;
    display: inline-block;
    transition: all 0.3s ease;
    font-family: 'Poppins', sans-serif;
  }

  .footer-link:hover {
    color: #1a1a1a;
    transform: translateX(5px);
  }

  /* --- SENCILLO SECTION --- */
  .sencillo-section {
    background-color: #fff;
    padding: 120px 5%;
    color: #1a1a1a;
  }

  .sencillo-container {
    max-width: 1300px;
    margin: 0 auto;
  }

  .sencillo-header {
    text-align: center;
    margin-bottom: 100px;
    max-width: 950px;
    margin-left: auto;
    margin-right: auto;
  }

  .sencillo-title {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 28px;
    line-height: 1.4;
    font-family: 'Montserrat', sans-serif;
    color: #1b1b1b;
  }

  .blue-text {
    color: #6366F1;
  }

  .sencillo-subtitle {
    font-size: 18px;
    color: #5a5a5a;
    line-height: 1.6;
    font-family: 'Poppins', sans-serif;
  }

  .sencillo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
  }

  .sencillo-visual {
    width: 100%;
  }

  .image-wrapper {
    position: relative;
    border-radius: 40px;
    overflow: visible;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.08);
  }

  .main-img {
    width: 100%;
    display: block;
    filter: grayscale(100%);
    border-radius: 40px;
    
  }

  .image-badge {
    width: 220.43px;
    height: 56.58pxpx;
    position: absolute;
    bottom: -30px;
    right: 20px;
    background: #fff;
    padding: 15px 30px;
    border-radius: 60px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12);
    z-index: 2;
  }

  .badge-check {
    color: #FF66CC;
    font-weight: 950;
    font-size: 1.1rem;
  }

  .badge-name {
    font-size: 14px;
    font-weight: 700;
    color: #1b1b1b;
    font-family: 'Poppins', sans-serif;
  }

  .pink-box {
    background: linear-gradient(90deg, rgba(102, 99, 253, 0.08), transparent);
    border-left: 6px solid #FF66CC;
    padding: 18px 20px;
    border-radius: 0 25px 25px 0;
    margin-bottom: 35px;
  }

  .pink-box p {
    color: #ff66cc;
    font-weight: 700;
    line-height: 1.7;
    font-size: 16px;
    font-family: 'Poppins', sans-serif;
  }

  .checklist-container {
    margin-bottom: 60px;
  }

  .checklist-title {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 32px;
    font-family: 'Montserrat', sans-serif;
    margin-top: 60px; 
  }

  .checklist {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .checklist li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .check-icon {
    color: #10B981;
    font-weight: 900;
    font-size: 1.3rem;
    margin-top: -2px;
  }

  .check-text {
    font-size: 15px;
    color: #1b1b1b;
    line-height: 1.6;
    font-family: 'Poppins', sans-serif;
  }

  .secondary-cta {
    width: 257.08px;
    height: 50.87px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 25px;
    background: #fff;
    border: 2px solid rgba(0, 0, 0, 0.05);;
    border-radius: 60px;
    color: #1b1b1b;
    text-decoration: none;
    font-weight: 700;
    font-size: 15px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.02);
    transition: all 0.3s ease;
    font-family: 'Poppins', sans-serif;
    text-align: center; 
  
  }

  /* --- RESPONSIBILITIES SECTION --- */
  .responsibilities-section {
    background-color: #FAFAFC;
    padding: 100px 0px 120px;
    position: relative;
  }

  .section-divider {
    height: 1px;
    background-color: #eee;
    margin-bottom: 60px;
    width: 100%;
  }

  .responsibilities-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .responsibilities-header {
    text-align: center;
    margin-bottom: 80px;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .responsibilities-title {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 24px;
    line-height: 1.4;
    font-family: 'Montserrat', sans-serif;
    color: #1b1b1b;
  }

  .responsibilities-description {
    font-size: 18px;
    color: #5a5a5a;
    line-height: 1.6;
    font-family: 'Poppins', sans-serif;
    margin-top: 20px;
  }

  .responsibilities-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .resp-card {
    background-color: #fff;
    padding: 40px 35px;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    border: 1px solid rgba(0, 0, 0, 0.05);
    font-size: 40px;
    line-height: 1;
    content-align: flex-start;

  }

  .resp-card-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.3;
    font-family: 'Montserrat', sans-serif;
    font-color: #1b1b1b;
    margin-top: 25px;
  }

  .resp-card-text {
    font-size: 14px;
    color: #5a5a5a;
    line-height: 1.6;
    font-family: 'Poppins', sans-serif;
    
  }

  /* --- HIRING PROCESS SECTION --- */
  .hiring-process-section {
    background-color: #ffffff;
    padding: 60px 5% 120px 5%;
    text-align: center;
  }

  .hiring-process-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .hiring-title {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 24px;
    line-height: 1.2;
    font-family: 'Montserrat', sans-serif;
  }

  .hiring-subtitle {
    font-size: 18px;
    color: #5a5a5a;
    line-height: 1.7;
    max-width: 850px;
    margin: 0 auto;
    font-family: 'Poppins', sans-serif;
    
  }

  .step-circle {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: #000;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 900;
    font-family: 'Montserrat', sans-serif;
    border: 6px solid #fff;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
  }

  .step-label {
    font-size: 17px;
    font-weight: 800;
    margin-bottom: 12px;
    font-family: 'Montserrat', sans-serif;
    line-height: 1.3;
    align-items: center;
  }

  .timeline-wrapper {
    position: relative;
    padding-top: 40px;
    margin-top: 40px;
  }

  .timeline-line {
    position: absolute;
    top: 70px; /* Centered with circles */
    left: 5%;
    width: 90%;
    height: 4px;
    background: linear-gradient(90deg, #FF66CC 0%, #6663FD 33%, #66FF99 66%, #CCFF66 100%);
    border-radius: 2px;
    z-index: 1;
    
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    position: relative;
    z-index: 2;
  }

  .step-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .step-visual {
    margin-bottom: 32px;
  }

  .step-text {
    font-size: 0.95rem;
    color: #666;
    line-height: 1.6;
    margin-bottom: 20px;
    font-family: 'Poppins', sans-serif;
  }

  .step-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;

  }

  .badge-purple {
    background-color: #F0F0F5;
    color: #6663FD;
  }

  .badge-blue {
    background-color: #F0F0F5;
    color: #6663FD;
  }

  /* --- FINAL CTA SECTION --- */
  .final-cta-section {
    background: linear-gradient(95deg, #441a45 0%, #111111 40%, #111111 100%) !important;
    padding: 120px 5% !important;
    text-align: center !important;
    color: #ffffff !important;
    position: relative;
    z-index: 10;
    display: block !important;
  }

  .final-cta-container {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  .final-cta-title {
    font-family: 'Poppins', sans-serif !important;
    font-size: 40px !important;
    font-weight: 800 !important;
    margin-bottom: 40px !important;
    line-height: 1.2 !important;
    color: #ffffff !important;
    display: block !important;
  }

  .final-cta-description {
    font-family: 'Poppins', sans-serif !important;
    font-size: 18px !important;
    color: #D0D0D0 !important;
    line-height: 1.6 !important;
    margin-bottom: 40px !important;
    max-width: 750px !important;
    margin-left: auto !important;
    margin-right: auto !important;
    display: block !important;
  }

  .final-cta-button {
    width: 410.56px;
    height: 54.18px;
    font-family: 'Poppins', sans-serif !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    background-color: #FF66CC !important;
    color: #FFFFFF !important;
    padding: 16px 32px !important;
    border-radius: 60px !important;
    font-size: 15px !important;
    font-weight: 600 !important;
    text-decoration: none !important;
    transition: all 0.3s ease;
    box-shadow: 0 15px 35px rgba(255, 102, 204, 0.4) !important;
    border: none !important;
    
  }

  .final-cta-button:hover {
    transform: translateY(-5px) !important;
    box-shadow: 0 25px 50px rgba(255, 102, 204, 0.6) !important;
    filter: brightness(1.1) !important;
  }

  /* --- AVAILABLE PROFILES SECTION --- */
  .available-profiles-section {
    background-color: #FAFAFC;
    padding: 120px 5%;
    text-align: center;
  }

  .profiles-wrapper {
    max-width: 1300px;
    margin: 0 auto;
  }

  .profiles-header-alt {
    margin-bottom: 80px;
  }

  .profiles-title-alt {
    font-family: 'Montserrat', sans-serif;
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 24px;
    color: #1b1b1b;
  }

  .profiles-subtitle-alt {
    font-family: 'Poppins', sans-serif;
    font-size: 18px;
    color: #5a5a5a;
    max-width: 800px;
    margin: 0 auto;
  }

  .profiles-grid-alt {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .profile-card-alt {
    width: 485px;
    height: 278.21px;
    background: #ffffff;
    padding: 40px;  
    border-radius: 21px;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.05);
    text-align: left;
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    border: 1px solid rgba(0,0,0,0.02);
    transition: all 0.4s ease;
  }

  .profile-card-alt:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 70px rgba(0, 0, 0, 0.08);
  }

  .profile-header-top {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 5px;
  }

  .profile-card-icon {
    font-size: 22px;
    align-items: center;
  }

  .profile-card-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 20px;
    font-weight: 800;
    color: #1b1b1b;
    margin: 0px 0px 0px
  }

  .profile-card-description {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: #5a5a5a;
    line-height: 1.6;
    margin-bottom: 0px;
    flex-grow: 1;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 25px;
    margin-top: 15px;
  }

  .tag-pill {
    background-color: #f1f1f1;
    color: #5a5a5a;
    padding: 6px 12px;
    border-radius: 50px;
    font-size: 11px;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
  }

  .profile-card-button {
    font-family: 'Poppins', sans-serif;
    display: flex;
    width: 402.78px;
    height: 40.66px;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px 24px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    background: #fff;
    color: #1a1a1a;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    width: 100%;
    font-size: 13px;
  }

  .profile-card-button:hover {
    background: #fdfdfd;
    border-color: #1a1a1a;
    transform: translateY(-2px);
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 1024px) {
    .hero-content-wrapper, .sencillo-grid {
      grid-template-columns: 1fr;
      gap: 60px;
      text-align: center;
    }
    .profiles-grid-alt {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .hero-custom, .sencillo-section, .responsibilities-section, .hiring-process-section, .final-cta-section, .available-profiles-section {
      padding: 80px 24px !important;
    }

    .final-cta-title, .profiles-title-alt {
      font-size: 2.3rem !important;
    }

    .profile-card-alt {
      padding: 30px;
    }

    .profile-card-title {
      font-size: 1.4rem;
    }
  }
</style>

<DashboardLayoutPerfiles
  title="Contratar Community Manager para Empresas Españolas"
  description="¿Buscas contratar community manager sin saber por dónde empezar? Perfiles evaluados de LATAM, zona horaria España y hasta un 70% de ahorro."
  keywords="Contratar community manager"
>
  <div class="service-detail-container" id="inicio">
    
    <!-- HERO SECTION (DARK) -->
    <section class="hero-custom">
      <div class="glow-bg pink-glow"></div>
      <div class="glow-bg purple-glow"></div>

      <div class="hero-content-wrapper">
        <div class="hero-text-section">
          <h1 class="label-accent">CONTRATAR COMMUNITY MANAGER REMOTO DESDE LATINOAMÉRICA</h1>
          <p class="hero-title">
            Delega el crecimiento de tu comunidad digital en talento experto, sin el riesgo ni la burocracia laboral local.
          </p>
          <p class="hero-description">
            Con <strong>Oberstaff<span class="pink-dot">.</span></strong> puedes contratar Community Manager especializado en social media, con dominio de los algoritmos actuales y la capacidad de disparar tu engagement.
          </p>

          <div class="hero-badges">
            <div class="badge-item">
              <span class="badge-icon">🎯</span>
              <span class="badge-text">Dedicación exclusiva a tu feed</span>
            </div>
            <div class="badge-item">
              <span class="badge-icon">📋</span>
              <span class="badge-text">Estrategas validados en social media</span>
            </div>
            <div class="badge-item">
              <span class="badge-icon">⚡</span>
              <span class="badge-text">Integración directa a tus Redes Sociales</span>
            </div>
            <div class="badge-item">
              <span class="badge-icon">🕒</span>
              <span class="badge-text">Moderación en horario español</span>
            </div>
          </div>
        </div>

        <div class="hero-form-section">
          <div class="form-card">
            <h2 class="form-title">Encuentra a tu CM ideal hoy</h2>
