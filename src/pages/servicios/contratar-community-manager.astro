---
import DashboardLayoutPerfiles from "../../layouts/DashboardLayoutPerfiles.astro";
import LeadHeroSection from "../../components/community-manager/LeadHeroSection.astro";
import TrustBarPerfiles from "../../components/trust-bar-perfiles/TrustBarPerfiles.astro";
import InfoServicePerfil from "../../components/info-services-perfil/InfoServicePerfil.astro";
import AreasPerfiles from "../../components/areas-perfiles/AreasPerfiles.astro";
import TimelinePerfiles from "../../components/timeline-perfiles/TimelinePerfiles.astro";
import CTAIntermedioPerfil from "../../components/cta-intermedio-perfil/CTAIntermedioPerfil.astro";
import ComparisonPerfiles from "../../components/comparison-perfiles/ComparisonPerfiles.astro";
import PricingCardPerfil from "../../components/pricing-perfil/PricingCardPerfil.astro";
import BeneficiosPerfil from "../../components/beneficios-perfil/BeneficiosPerfil.astro";
import GuiaPerfiles from "../../components/guia-perfiles/GuiaPerfiles.astro";
import CasosExitoPerfiles from "../../components/casos-exito-perfiles/CasosExitoPerfiles.astro";
import FAQSectionCommunity from "../../components/faq-servicios/FAQSection-community.astro";
import PressSection from "../../components/press/PressSection.astro";
import ConversionPerfil from "../../components/conversion-perfil/ConversionPerfil.astro";
import RolesPerfil from "../../components/roles-del-perfil/RolesPerfil.astro";

---
<DashboardLayoutPerfiles
	title="Contratar Community Manager para Empresas Españolas"
	description="¿Buscas contratar community manager sin saber por dónde empezar? Perfiles evaluados de LATAM, zona horaria España y hasta un 70% de ahorro."
	keywords="Contratar community manager"
>
	<div class="service-detail-container" id="inicio">
	

        <LeadHeroSection
            topLabel="CONTRATAR COMMUNITY MANAGER REMOTO DESDE LATINOAMÉRICA"
            title="Delega el crecimiento de tu comunidad digital en talento experto, sin el riesgo ni la burocracia laboral local."
            cardTitle="Comienza ahora"
            buttonText="Ver perfiles pre-evaluados y solicitar propuesta"
            footerLinkText="Ver cómo funciona el modelo EOR →"
            footerLinkHref="#como-contratar"
        >
            <Fragment slot="description">
                Conecta tu empresa española con Community Managers pre-evaluados de LATAM. Misma zona horaria, castellano nativo y <strong>hasta un 70% de ahorro</strong> en costes operativos.
            </Fragment>
        </LeadHeroSection>
 
        <div class="fade-in-section">
            <TrustBarPerfiles 
                title="+5.000 empresas confían en nosotros" 
                features={["Dedicación exclusiva", "Perfiles evaluados en social media", "Integración rápida", "Horario compatible con España"]} 
            />
        </div>

 
        <div class="fade-in-section">
            <InfoServicePerfil 
                mainQuestion="¿Qué hace un community manager para empresas?"
                answerText="Es la voz digital de tu marca: gestiona la reputación online, crea contenido de valor, responde a tu comunidad y convierte seguidores en clientes."
                priceBoxTitle="¿Cuánto cuesta contratar un community manager en España?"
                priceBoxText={`El precio de un community manager local puede superar los <strong>2.000€/mes</strong>. Con Oberstaff, accedes al mismo nivel de talento <span class="price-highlight">desde 750€/mes</span>, todo incluido y sin complicaciones legales.`}
                summaryTitle="Resumen del servicio"
                summaryItems={[
                    "Profesionales de social media evaluados con pruebas técnicas y psicométricas",
                    "Sin riesgo legal — Oberstaff es el empleador",
                    "Factura mensual en euros para tu empresa",
                    "Sin permanencia mínima — cancela cuando quieras"
                ]}
                buttonText="Solicitar candidatos →"
                buttonHref="#inicio" 
            />
        </div>



        <div class="fade-in-section">
        <AreasPerfiles 
  title="Desde la estrategia de contenido hasta la gestión de comunidades, tu CM de LATAM cubre todas las áreas clave de tu presencia digital."
  subtitle="Cuando una empresa busca contratar community manager, no solo necesita alguien que publique en redes. Necesita una persona que entienda la marca, mantenga la consistencia del mensaje y convierta la actividad social en una herramienta real de crecimiento."
  cards={[
     { 
        icon: "ph:device-mobile-duotone", 
        iconColor: "#8b5cf6", 
        title: "Gestión de redes sociales", 
        description: "Instagram, LinkedIn, Facebook, Tik Tok, X. Calendarios editoriales adaptados al sector." 
     },
     { 
        icon: "solar:pen-new-square-bold-duotone", 
        iconColor: "#ec4899", 
        title: "Creación de contenido", 
        description: "Copies, creatividades con Canva/Adobe, guiones para reels y stories. Voz de marca coherente." 
     },
     { 
        icon: "solar:chat-round-line-bold-duotone", 
        iconColor: "#14b8a6", 
        title: "Gestión de comunidad", 
        description: "Respuesta a DMs y comentarios, moderación, atención al cliente en redes. Marca siempre activa." 
     },
     { 
        icon: "solar:chart-square-bold-duotone", 
        iconColor: "#eab308", 
        title: "Analítica e informes", 
        description: "KPIs: alcance, engagement, conversiones. Informes mensuales con insights estratégicos." 
     },
     { 
        icon: "solar:target-bold-duotone", 
        iconColor: "#ef4444",   
        title: "Estrategia de contenido", 
        description: "Audiencias, posicionamiento de marca, hashtags, tendencias. Alineado con objetivos de negocio." 
     },
     { 
        icon: "ph:megaphone-duotone", 
        iconColor: "#3b82f6", 
        title: "Campañas y paid social", 
        description: "Apoyo en Meta Ads y LinkedIn Ads. Coordinación con el equipo de marketing." 
     }
  ]}
/>
</div>



<div class="fade-in-section">
<div id="como-contratar" style="scroll-margin-top: 80px;">
<TimelinePerfiles 
  title="Cómo contratar un community manager con Oberstaff"
  subtitle="Un proceso sencillo, rápido y sin riesgo. Desde que nos contactas hasta que tienes a tu CM trabajando para tu organización."
  items={[
    { 
      title: "Cuéntanos tu perfil", 
      timeTag: "30 minutos", 
      description: "Agenda una llamada gratuita. Analizamos las necesidades de tu empresa, el tipo de redes sociales, sector y nivel de experiencia requerido." 
    },
    { 
      title: "Seleccionamos candidatos", 
      description: "Preseleccionamos 3-5 perfiles evaluados con pruebas técnicas y psicométricas. Tú eliges con quién quieres entrevistarte." 
    },
    { 
      title: "Entrevistas y decisión", 
      timeTag: "A tu ritmo", 
      description: "Realizas entrevistas directamente con los candidatos preseleccionados. Tú tienes la última palabra. Sin compromisos hasta que decides." 
    },
    { 
      title: "Tu CM empieza a trabajar", 
      timeTag: "Franja de apoyo", 
      timeTagGray: true, 
      description: "Oberstaff gestiona contrato, nómina y compliance. Tu CM se integra en tu equipo y empieza desde el primer día." 
    }
  ]}
/>
</div>
</div>

<div class="fade-in-section">
<CTAIntermedioPerfil 
  alertText='Si estabas en modo <strong>"buscar community manager"</strong> sin saber por dónde empezar, aquí simplificamos el proceso para que tomes una decisión más rápida y con menos riesgo.'
  title="¿Ya sabes lo que necesitas?"
  description="Cuéntanos el perfil que requieres y recibe una propuesta personalizada en menos de 24 horas. Sin compromiso."
  buttonText="Quiero Solicitar propuesta personalizada"
  buttonHref="#inicio"
/>
</div>


<div class="fade-in-section">
<RolesPerfil 
    title="Perfiles de community manager remoto disponibles"
    subtitle="Encuentra el perfil que mejor se adapta a las necesidades de tu negocio."
    roles={[
        {
            title: "Gestor de Redes Sociales",
            description: "Gestión y publicación en Instagram, TikTok, Facebook y X. Crecimiento orgánico y engagement.",
            icon: "solar:smartphone-bold-duotone",
            iconColor: "#3b76f6",
            borderColorClass: "border-blue",
            techStack: ["Meta Business", "Creator Studio", "Metricool", "Canva"]
        },
        {
            title: "CM LinkedIn & B2B",
            description: "Comunicación corporativa y generación de leads en entornos profesionales.",
            icon: "solar:case-bold-duotone",
            iconColor: "#8b5cf6",
            borderColorClass: "border-purple",
            techStack: ["LinkedIn", "Sales Navigator", "Taplio", "Notion"]
        },
        {
            title: "CM para eCommerce",
            description: "Orientado a conversión y ventas. Gestiona reseñas, atención al cliente y campañas de producto.",
            icon: "solar:cart-large-bold-duotone",
            iconColor: "#f97316",
            borderColorClass: "border-orange",
            techStack: ["Shopify", "Klaviyo", "Meta Ads", "Trustpilot"]
        },
        {
            title: "Community Manager para Marca Personal",
            description: "Construye y gestiona la presencia digital de profesionales, influencers, coaches y emprendedores con voz propia.",
            icon: "solar:user-rounded-bold-duotone",
            iconColor: "#ff66cc",
            borderColorClass: "border-pink",
            techStack: ["Instagram", "LinkedIn", "TikTok", "Linktree"]
        }
    ]}
/>
</div>


<div class="fade-in-section">
<ComparisonPerfiles 
  title="Comparativa: Precio community manager Oberstaff vs. otras opciones"
  subtitle='Compara el coste real de <strong>contratar community manager</strong> para empresas en España, como freelance o a través de agencia frente a nuestro modelo de talento remoto desde LATAM.'
  competitors={["CM local España", "Contratar community manager freelance", "Agencia Social Media"]}
  rows={[
    {
      label: "Coste mensual",
      oberstaffValue: "750-1.200€",
      oberstaffBlueText: true,
      competitorValues: ["2.000-2.800€", "800-2.000€", "1.500-4.000€"]
    },
    {
      label: "Dedicación exclusiva",
      oberstaffValue: "Sí",
      competitorValues: [
        "Sí", 
        `<iconify-icon icon="solar:danger-triangle-bold" class="icon-warning" style="color: #f59e0b;"></iconify-icon> Gestiona varios clientes`, 
        `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> No`
      ]
    },
    {
      label: "Gestión legal y nómina",
      oberstaffValue: "Oberstaff",
      competitorValues: [
        `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> Tú lo gestionas`,
        "Factura autónomo",
        "Sí"
      ]
    },
    {
      label: "Zona horaria España",
      oberstaffValue: `<iconify-icon icon="solar:check-circle-bold" class="icon-check" style="color: #10b981;"></iconify-icon> Compatible`,
      competitorValues: [
        "Compatible",
        `<iconify-icon icon="solar:danger-triangle-bold" class="icon-warning" style="color: #f59e0b;"></iconify-icon> Sin horario fijo`,
        "Repartido entre clientes"
      ]
    },
    {
      label: "Sin permanencia",
      oberstaffValue: `<iconify-icon icon="solar:check-circle-bold" class="icon-check" style="color: #10b981;"></iconify-icon> Compatible`,
      competitorValues: [
        `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> Indemnizaciones`,
        `<iconify-icon icon="solar:danger-triangle-bold" class="icon-warning" style="color: #f59e0b;"></iconify-icon> Según contrato`,
        `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> Contratos largos`
      ]
    },
    {
      label: "Perfil evaluado",
      oberstaffValue: "Técnico + psico",
      competitorValues: [
        `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> Tú seleccionas`,
        `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> Solo CV/portafolio`,
        "Sí"
      ]
    },
    {
      label: "Ahorro vs local",
      oberstaffValue: `<span class="badge-blue">Hasta 70%</span>`,
      oberstaffNoPadding: true,
      competitorValues: [
        "-",
        `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> Sin cobertura`,
        "Variable"
      ]
    }
  ]}
/>
</div>


<div class="fade-in-section">
<PricingCardPerfil 
  title="Precio community manager con Oberstaff"
  subtitle="Tarifas claras y sin sorpresas, el precio varía según la experiencia del perfil. Todo incluido: gestión, nómina y compliance."
  priceLabel="DESDE"
  priceAmount="750€"
  pricePeriod="/mes"
  badgeText="Todo incluido · Jornada completa"
  features={[
    "Estrategia multicanal",
    "Analítica avanzada",
    "Campañas y paid social",
    "Coordinación de equipo"
  ]}
  disclaimer="Precios orientativos. El coste final depende del perfil, país y nivel de experiencia. Sin costes ocultos ni comisiones adicionales."
/>
</div>



<div class="fade-in-section">
<BeneficiosPerfil 
  title="Por qué contratar community manager con Oberstaff"
  subtitle="Combinamos integración real en equipo con una operativa más ligera para tu negocio, así te centras en resultados y no en fricción administrativa."
  items={[
    {
      icon: "solar:user-check-rounded-bold-duotone",
      iconColor: "#3b82f6",
      title: "Dedicación exclusiva:",
      description: "Tu CM trabaja enfocado en tu negocio y tus prioridades."
    },
    {
      icon: "solar:rocket-bold-duotone",
      iconColor: "#f59e0b",
      title: "Integración rápida:",
      description: "Se incorpora a tus reuniones, utiliza tus herramientas y sistema de feedback."
    },
    {
      icon: "solar:shield-check-bold-duotone",
      iconColor: "#8b5cf6",
      title: "Operativa resuelta:",
      description: "Oberstaff es el empleador legal — tú no asumes nada. Contratos, nóminas y seguridad social: todo bajo nuestra responsabilidad."
    }
  ]}
/>
</div>


<div class="fade-in-section">
<GuiaPerfiles 
  title="¿Cómo buscar community manager para tu negocio?"
  intro="Claves para tomar la mejor decisión antes de incorporar un CM remoto"
  items={[
    {
      icon: "solar:users-group-rounded-bold-duotone",
      iconColor: "#3b82f6",
      title: "Contratar community manager freelance vs CM remoto a dedicación exclusiva",
      description: "Con un CM freelance obtienes disponibilidad parcial y variable, sin compromiso de dedicación exclusiva. Con Oberstaff puedes contratar community manager a jornada completa, en exclusiva para tu compañía, con contrato estable y toda la gestión laboral resuelta."
    },
    {
      icon: "solar:rocket-bold-duotone",
      iconColor: "#f59e0b",
      title: "¿Dónde busco Community Manager?: ventajas de Oberstaff",
      description: "Existen varias plataformas para incorporar CM, como marketplaces de freelancers o agencias. Sin embargo, Oberstaff ofrece un modelo diferente: talento dedicado exclusivo para ti, con contrato estable y toda la gestión laboral cubierta. Mayor compromiso, mejor integración y ausencia de riesgos legales para tu negocio."
    },
    {
      icon: "solar:laptop-minimalistic-bold-duotone",
      iconColor: "#ec4899",
      title: "¿Qué herramientas debería dominar?",
      description: "Lo ideal es que maneje herramientas de programación y análisis, plataformas de diseño básico, calendarios editoriales y sistemas de organización como Notion, Metricool, Meta Business Suite, Canva."
    }
  ]}
/>
</div>


<div class="fade-in-section">
<CasosExitoPerfiles 
  title="Empresas Españolas que ya confían en Oberstaff"
  cases={[
    {
      name: "Shadai Iborra",
      position: "CEO @amediastory - Barcelona",
      achievements: [
        { text: "· CM integrada en 3 semanas" },
        { text: "· Ahorro del 65% vs local", highlight: true },
        { text: "· Castellano perfecto" }
      ]
    },
    {
      name: "Fernando Calderón",
      position: "CEO bybeautypro.com - Madrid",
      achievements: [
        { text: "· CM + editor de video" },
        { text: "· Proceso rápido y sin complicaciones" },
        { text: "· Redes +40% en 4 meses", highlight: true }
      ]
    },
    {
      name: "Kate McCaffert",
      position: "KM Real Estate - Marbella",
      achievements: [
        { text: "· +2 años con la misma CM", highlight: true },
        { text: "· Equipo remoto integrado al 100%" },
        { text: "· LinkedIn e Instagram con éxito" }
      ]
    }
  ]}
/>
</div>

  <div class="fade-in-section">
            <FAQSectionCommunity 
                title="Todo lo que necesitas saber antes de contratar tu community manager"
                subtitle=" Resolvemos las dudas más frecuentes sobre el proceso, precios y funcionamiento del servicio a negocios que deseen incorporar talento de LATAM"
            />
        </div>
	</div>


<div class="fade-in-section">
			<PressSection />
</div>

<div class="fade-in-section">
<ConversionPerfil
    title="Encuentra el perfil adecuado para tu empresa"
    subtitle="Rellena el formulario (tardarás menos de 1 minuto) y en menos de 24 horas recibirás de parte de nuestros especialistas una propuesta personalizada sin compromiso. Primera consulta gratuita."
    buttonText="Solicitar propuesta gratuita"
    relatedRoles={[
        { label: "Contratar diseñador gráfico", icon: "solar:pen-new-square-bold-duotone", iconColor: "#ec4899" },
        { label: "Asistente administrativo virtual", icon: "solar:folder-with-files-bold-duotone", iconColor: "#eab308" },
        { label: "Editor de video remoto", icon: "solar:videocamera-bold-duotone", iconColor: "#10b981" }
    ]}
/>
</div>



</DashboardLayoutPerfiles>

<style>
	.service-detail-container {
	}
</style>
