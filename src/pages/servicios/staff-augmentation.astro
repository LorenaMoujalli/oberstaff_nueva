    /* --- Estilos específicos para el componente de proceso en Employer --- */
    :global(.process-employer .process-menu) {
        background-color: #fafafc;
    }

    :global(.process-employer .process-tab-label) {
        color: #5a5a5a;
        font-weight: 600;
    }

    :global(.process-employer .process-tab:hover) {
        background-color: #f0f0f5;
        color: #1b1b1b;
    }

    :global(.process-employer .process-tab.active) {
        background-color: #ffffff;
    }

    /* --- Estilos específicos para el botón CTA en Staff Augmentation --- */
    :global(.process-employer .process-cta-btn) {
        background-color: #6663fd;
        color: #ffffff !important;
        padding: 15px 35px !important;
        border-radius: 50px !important;
        font-weight: 700 !important;
        font-family: "Montserrat", sans-serif !important;
        font-style: normal !important;
        font-size: 15px !important;
        border: 2px solid #6663fd !important;
        display: inline-block !important;
        transition: all 0.3s ease !important;
        text-decoration: none !important;
    }

    :global(.process-employer .process-cta-btn:hover) {
        background-color: transparent !important;
        color: #6663fd !important;
        border: 2px solid #6663fd !important;
        box-shadow: 0 8px 20px rgba(102, 99, 253, 0.15) !important;
    }

    /* --- Estilos específicos para el botón CTA en Pricing (Staff Augmentation) --- */
