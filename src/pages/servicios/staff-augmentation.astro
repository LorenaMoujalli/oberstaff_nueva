  <div class="fade-in-section">
            <RolesSectionStaff
                label="Ampliación del equipo (Team augmentation)"
                title="Talento IT y digital de LATAM para tu organización"
                description="Perfiles disponibles para incorporarse a tu empresa española."
            />
        </div>


        <div class="fade-in-section">
            <EorStepsSection
                label="Tu primer profesional remoto de LATAM"
                title="De cero a equipo ampliado "
                subtitle="Un proceso ágil para que tu empresa española incorpore talento IT de LATAM sin trámites, sin entidad local y sin riesgos legales."
                steps={[
                    {
                        title: "Defines el perfil",
                        lineColorClass: "line-black",
                        description:
                            "Nos explicas el rol, stack técnico y presupuesto. Buscamos en toda LATAM.",
                    },
                    {
                        title: "Selección del candidato",
                        lineColorClass: "line-pink",
                        description:
                            "Te presentamos 3-5 candidatos preseleccionados. Tú decides quién se incorpora.",
                    },
                    {
                        title: "Contratación y alta",
                        lineColorClass: "line-orange",
                        description:
                            "Contrato y documentación incluidos; inicio en 48h tras tu selección",
                    },
                    {
                        title: "Equipo ampliado",
                        lineColorClass: "line-blue",
                        description:
                            "El profesional se integra en tu equipo. Gestionamos nóminas mes a mes.",
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <EorCta
                title="¿Listo para ampliar tu equipo con talento de LATAM?"
                text=" Habla con nuestros especialistas y recibe una propuesta personalizada en menos de 24 horas."
                buttonText="Solicitar propuesta gratuita"
                buttonHref="#contacto"
            />
        </div>

        <div class="fade-in-section">
            <FeaturesSection
                eyebrow="Por qué elegir Oberstaff como tu staff augmentation company"
                title="Todo lo que necesita tu empresa española"
                subtitle="Diseñado para empresas españolas que quieren escalar con agilidad y acceder al mejor talento IT de LATAM."
                features={[
                    {
                        title: "Cero riesgo laboral",
                        description:
                            "Oberstaff asume la responsabilidad jurídica en LATAM. Tu empresa española queda completamente protegida.",
                        icon: "solar:shield-check-bold-duotone",
                        colorClass: "icon-blue",
                    },
                    {
                        title: "Zona horaria compatible",
                        description:
                            "Horario compatible con CET. Tu equipo en LATAM trabaja contigo en tiempo real, sin desfases.",
                        icon: "solar:global-bold-duotone",
                        colorClass: "icon-green",
                    },
                    {
                        title: "Español nativo",
                        description:
                            "Todo el talento de LATAM habla español como lengua materna. Comunicación fluida desde el primer día.",
                        icon: "solar:user-speak-bold-duotone",
                        colorClass: "icon-yellow",
                    },
                    {
                        title: "Una factura en euros",
                        description:
                            "Nos encargamos de pagar al profesional en LATAM. Tu empresa recibe una única factura mensual en euros.",
                        icon: "solar:chart-2-bold-duotone",
                        colorClass: "icon-red",
                    },
                    {
                        title: "Soporte humano",
                        description:
                            "Tendrás a tu disposición un equipo de soporte que estará disponible para cualquier incidencia. Acompañamiento continuo.",
                        icon: "solar:chat-round-dots-bold-duotone",
                        colorClass: "icon-indigo",
                    },
                    {
                        title: "Sin permanencia minima",
                        description:
                            "Adapta o cancela el servicio cuando tu negocio lo requiera. Flexibilidad total, sin penalizaciones.",
                        icon: "solar:refresh-square-bold-duotone",
                        colorClass: "icon-orange",
                    },
                ]}
            />
        </div>

