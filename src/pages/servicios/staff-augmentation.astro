<DashboardLayoutServicios
    title="Staff Augmentation con Talento de LATAM | Oberstaff"
    description="Amplía tu equipo con profesionales IT remotos de LATAM. Staff augmentation flexible para empresas españolas: hasta 70% de ahorro, sin permanencia mínima."
    keywords="staff augmentation"
>
    <div class="service-detail-container">
        <div class="fade-in-section">
            <HeroService
                label="Staff Augmentation"
                preTitle="Staff Augmentation para empresas españolas:"
                title="Staff Augmentation"
                highlight="para empresas españolas"
                description="Amplía tu equipo con profesionales remotos de LATAM. Con nuestro servicio de staff augmentation, accede a talento IT y digital top con hasta un 70% de ahorro frente al mercado español."
                videoImg="/fondo-video.webp"
                remoteCountry="CO"
                floatingText="Cero Riesgo Legal"
                primaryBtnText="Agendar llamada gratis"
                primaryBtnHref="#contacto"
                secondaryBtnText="Recibir propuesta en 24h"
                secondaryBtnHref="#"
            />
        </div>

        <QueEsStaffSection />

        <div class="fade-in-section">
            <ConEorService
                eyebrow="Staff Augmentation"
                title="Contratar en España vs. ampliar equipo en Latinoamérica"
                description="Conoce las diferencias clave entre contratar talento local en España y ampliar tu equipo con profesionales remotos de LATAM a través de Oberstaff."
                negativeTitle="Sin team augmentation"
                positiveTitle="Con Oberstaff (Talento LATAM)"
                badge="Recomendado"
                negativeIcon="solar:close-circle-linear"
                positiveIcon="solar:check-circle-linear"
                negativeItems={[
                    "Salarios elevados del mercado español",
                    "Procesos de selección lentos y costosos",
                    "Riesgo legal y laboral directo",
                    "Difícil escalar el equipo rápido",
                    "Administración de nóminas compleja",
                ]}
                positiveItems={[
                    "Talento IT de LATAM igual de cualificado por hasta un 70% menos ",
                    "Proceso ágil y mucho más económico en pocos días dispondrás de tu profesional remoto",
                    "Cumplimiento legal en LATAM gestionado al 100%",
                    "Amplía o reduce el equipo sin permanencia mínima",
                    "Una única factura mensual en euros para ti",
                ]}
            />
        </div>


