						roles: [
							{ label: "Ejecutivo de Ventas", href: "#" },
							{ label: "SDR", href: "#" },
						],
						iconColorClass: "purple-text",
					},
					{
						icon: "📊",
						title: "Finanzas y administración",
						quote: "Para perfiles con acceso a datos críticos. Este modelo asegura subordinación legal, exclusividad y cumplimiento normativo local.",
						roles: [
							{ label: "Auxiliar contable", href: "#" },
							{ label: "Asistente virtual", href: "#" },
						],
						iconColorClass: "blue-text",
					},
					{
