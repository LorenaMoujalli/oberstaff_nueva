							{ label: "Especialista Google Ads", href: "#" },
							{ label: "Especialista Meta Ads", href: "#" },
							{ label: "Community Manager", href: "#" },
						],
						iconColorClass: "pink-text",
					},
					{
						icon: "💻",
						title: "Tecnología",
						quote: "Para quienes desarrollan tu código o sistemas, necesitas un contrato laboral formal que garantice la cesión de Propiedad Intelectual (IP) y NDAs blindados.",
						roles: [
							{ label: "Desarrollador WordPress", href: "#" },
							{ label: "Desarrollador Web", href: "#" },
							{ label: "Desarrollador Mobile", href: "#" },
