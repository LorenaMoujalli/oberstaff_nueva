						colorClass: "icon-red",
						cardClass: "hover-yellow",
					},
					{
						title: "Soporte humano",
						description:
							"Tendrás a tu disposición un equipo de soporte que estará disponible cuando lo necesites.",
						icon: "🔄",
						colorClass: "icon-purple",
						cardClass: "hover-purple",
					},
					{
						title: "Sin permanencia mínima",
