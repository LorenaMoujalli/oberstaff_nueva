				ctaBtnText="Agendar llamada"
			/>
		</div>

		<div class="fade-in-section profiles-employer-page">
			<ProfilesSection
				title="Perfiles que puedes <strong>contratar con EOR</strong>"
				description="El servicio Employer of Record profesionaliza tu <br/> expansión en LATAM mediante una relación <br/> laboral formal. Protege la integridad de tu <br/> empresa integrando talento legalmente en <br/> departamentos clave:"
