						icon: "🔍",
						badgeColor: "#6663FD",
						badgeBg: "rgba(102, 99, 253, 0.1)",
					},
					{
						label: "Payroll",
						badge: "Gestión total",
						title: "Payroll y Administración",
						description:
							"Gestionamos payroll, recibos, calendario de pago y la administración mensual del profesional.",
						icon: "📝",
						badgeColor: "#6aca8a",
						badgeBg: "rgba(102, 255, 153, 0.15)",
