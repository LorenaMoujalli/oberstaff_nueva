					},
					{
						title: "Administramos payroll y cumplimiento",
						lineColorClass: "line-blue",
						description:
							"Gestionamos nómina, cumplimiento e incidencias laborales con una sola factura consolidada.",
					},
				]}
			/>
		</div>

		<div class="fade-in-section">
			<EorCta
				title="¿Necesitas contratar en LATAM sin crear estructura legal propia?"
