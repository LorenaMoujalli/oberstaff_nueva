---
import DashboardLayoutServicios from "../../layouts/DashboardLayoutServicios.astro";
import HeroService from "../../components/hero-servicios/HeroService.astro";
import FranjaEmpresasHome from "../../components/franja-empresas-home/FranjaEmpresasHome.astro";
import ConEorService from "../../components/conEorServicios/ConEorService.astro";
//import BeneficiosSeccion from "../../components/beneficios-eor-servicios/BeneficiosSeccion.astro";
import EorStepsSection from "../../components/eor-steps-servicios/EorStepsSection.astro";
import EorCta from "../../components/eor-cta-servicios/EorCta.astro";
import FeaturesSection from "../../components/oberstaff-features-servicios/FeaturesSection.astro";
import CoberturaSeccion from "../../components/geografica-servicios/CoberturaSeccion.astro";
import PricingSection from "../../components/pricing-servicios/PricingSection.astro";
import CasosExitoSection from "../../components/casos-exito-servicios/CasosExitoSection.astro";
import RolesSection from "../../components/roles-servicios/RolesSection.astro";
import FAQSection from "../../components/faq-servicios/FAQSection.astro";
import OtrosServiciosSection from "../../components/otros-servicios-servicios/OtrosServiciosSection.astro";
import ContactFormSection from "../../components/form/ContactFormSection.astro";
import ArticulosSection from "../../components/articulos-servicios/ArticulosSection.astro";
import QueEsServicioSection from "../../components/QueEsServicio/QueEsServicioSection.astro";
import ServicesSection from "../../components/services-oberstaff/ServicesSection.astro"; 
import ProcessOberstaff from "../../components/process/ProcessOberstaff.astro";
import ProfilesSection from "../../components/profiles/ProfilesSection.astro";
---
<DashboardLayoutServicios
	title="Employer of Record | Contrata en LATAM · Oberstaff"
	description="¿Quieres contratar en LATAM? Oberstaff es tu Employer of Record: gestionamos contratos, nómina e impuestos. Sin riesgos para tu empresa. Expandete en Latinoamérica sin riesgos gracias a un Employer of Record que se encarga de contratos, nómina y cumplimiento local."
	keywords="Employer of record"
>
	<div class="service-detail-container">
		<div class="fade-in-section">
			<HeroService
				label="EMPLOYER OF RECORD · EOR"
				preTitle="Employer of Record para empresas españolas:"
				title="Contrata profesionales"
				highlight="legalmente sin abrir filial"
				description="<span style='color: #1B1B1B; font-weight: 800;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> actúa como Employer of Record (EOR) en LATAM. Tú gestionas el trabajo, nosotros nos encargamos del contrato, la nómina y el cumplimiento legal. Todo en regla, sin riesgos."
				videoImg="/fondo-video.webp"
				remoteCountry="CO"
				floatingText="Cero Riesgo Legal"
				primaryBtnText="Recibir propuesta en <24h"
				primaryBtnHref="#contacto"
				secondaryBtnText="Hablar con un especialista EOR"
				secondaryBtnHref="#contacto"
			/>
		</div>

		<div class="fade-in-section">
			<FranjaEmpresasHome
				stat1Number="70%"
				stat1Label="AHORRO EN COSTOS"
				stat2Number="+500"
				stat2Label="EMPRESAS CONFÍAN EN NOSOTROS"
			/>
		</div> 

		<div class="fade-in-section">
			<QueEsServicioSection 
				title="¿Qué es un Employer of Record?"
				highlightWord="Employer of Record?"
				description="Un Employer of Record (EOR) es la entidad legal que contrata a los empleados en nombre de otra empresa. <span style='color: #1B1B1B; font-weight: 800;'>Tú defines las tareas, el horario y los objetivos.</span>"
				imageSrc="/img-queEs.webp"
				imageAlt="Profesional trabajando"
				badgeText="Contratos al día"
				quoteText="Tú diriges, nosotros somos el empleador legal."
				infoItems={[
					{
						icon: "⚙️",
						title: "¿Cómo funciona?",
						description: "En la práctica, <span style='color: #1B1B1B; font-weight: 700;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 700;'>.</span> se convierte en el empleador legal del profesional y asume la gestión del contrato, la nómina, la seguridad social, los impuestos laborales y el cumplimiento normativo aplicable."
					},
					{
						icon: "🏢",
						title: "¿Sirve para mi empresa?",
						description: "Para una organización española, el EOR es una vía rápida y segura para contratar empleados en LATAM sin abrir una filial, sin montar una estructura de RR. HH. local y sin asumir directamente el riesgo laboral en cada país."
					}
				]}
				diffIcon="💡"
				diffTitle="Diferencia clave frente a CoR"
				diffDescription="Con EOR el profesional entra como empleado y existe relación laboral formal. Con CoR el profesional opera como independiente. Si necesitas payroll, seguridad social y cumplimiento laboral continuo, el modelo correcto es EOR."
			/>
		</div> 

		<div class="fade-in-section">
			<ServicesSection 
				title="¿Cuándo usar este <strong>servicio?</strong>"
				description="El EOR España es la opción ideal cuando quieres contratar sin crear una entidad legal propia."
				customClass="employer-use-cases"
				services={[
					{
						icon: "🌎",
						title: "Expansión en LATAM sin filial",
						description: "Quieres incorporar empleados en Colombia, Venezuela, Argentina u otros mercados, sin esperar meses a constituir una compañía local.",
						linkText: "",
						href: "",
						customIconBg: "rgba(255, 102, 204, 0.1)",
						cardClass: "card-green"
					},
					{
						icon: "⚡",
						title: "Equipos estables y contratación recurrente",
						description: "Cuando el rol será estable, recurrente y parte estructural de tu operación diaria.",
						linkText: "",
						href: "",
						customIconBg: "rgba(102, 255, 153, 0.1)",
						cardClass: "card-pink"
					},
					{
						icon: "🛡️",
						title: "Cuando necesitas una relación laboral formal",
						description: "Cuando necesitas establecer horarios, supervisión directa, integración profunda en el equipo y continuidad a largo plazo.",
						linkText: "",
						href: "",
						customIconBg: "rgba(102, 99, 253, 0.1)",
						cardClass: "card-lime"
					},
					{
						icon: "👥",
						title: "Reducción de carga legal y administrativa",
						description: "Quieres que contratos, nómina, impuestos, vacaciones, bajas y desvinculaciones se gestionen correctamente desde el primer día.",
						linkText: "",
						href: "",
						customIconBg: "rgba(204, 255, 102, 0.2)",
						cardClass: "card-lime"
					}
				]}
			/>
		</div>



		<div class="fade-in-section">
			<ConEorService
				eyebrow=""
				title="Gestionarlo internamente vs. hacerlo con <span style='color: #6663FD; font-weight: 900;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> EOR"
				description=""
				negativeTitle="Sin EOR" 
				positiveTitle="Con <span style='font-weight: 900;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> EOR"
				badge="La opción inteligente"
				negativeIcon=""
				positiveIcon=""
				negativeItems={[
					"Obligación de abrir empresa local (3-6 meses)",
					"Gestión dispersa de nómina, bajas y obligaciones.",
					"Mayor exposición jurídica frente a empleados extranjeros.",
					"Más carga interna de RR. HH. y administración.",
					"Escalar en varios países implica más complejidad.",
				]}
				positiveItems={[
					"Alta laboral inmediata usando nuestra estructura legal.",
					"Una sola estructura para payroll y cumplimiento.",
					"<span style='font-weight: 800;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> asume el rol de empleador legal.",
					"Tu equipo se enfoca en dirigir, no en operar la nómina.",
					"Un solo partner para expansión laboral regional.",
				]}
			/>
		</div>


			<div class="fade-in-section">
		<ProcessOberstaff 
  className="process-employer"
  title="¿Qué incluye nuestra gestión como <strong>Empleador Legal?</strong>"
  items={[
    { 
      label: "Estructuración", 
      badge: "100% Legal", 
      title: "Estructuración Contractual", 
      description: "Redactamos y firmamos el contrato conforme a la legislación del país donde se incorpora el profesional.",
      icon: "🔍",
      badgeColor: "#6663FD",
      badgeBg: "rgba(102, 99, 253, 0.1)"
    },
    { 
      label: "Payroll", 
      badge: "Gestión total", 
      title: "Payroll y Administración", 
      description: "Gestionamos payroll, recibos, calendario de pago y la administración mensual del profesional.",
      icon: "📝",
      badgeColor: "#66FF99",
      badgeBg: "rgba(102, 255, 153, 0.15)"
    },
    { 
      label: "Nómina", 
      badge: "Sin riesgos", 
      title: "Nómina, impuestos y beneficios obligatorios", 
      description: "Gestionamos salarios, impuestos, seguridad social, vacaciones y demás obligaciones laborales aplicables.",
      icon: "🗂️",
      badgeColor: "#FF66CC",
      badgeBg: "rgba(255, 102, 204, 0.1)"
    },
    { 
      label: "Cumplimiento", 
      badge: "Soporte continuo", 
      title: "Cumplimiento y soporte continuo", 
      description: "Administramos incidencias, cambios contractuales, bajas y acompañamiento operativo mes a mes.",
      icon: "⚡",
      badgeColor: "#1B1B1B",
      badgeBg: "rgba(204, 255, 102, 0.3)"
    }
  ]}
  ctaTitle="Empieza a ahorrar hoy"
  ctaDescription="Un equipo dedicado gestionará todo el proceso por ti."
  ctaBtnText="Agendar llamada"
/>
</div>

