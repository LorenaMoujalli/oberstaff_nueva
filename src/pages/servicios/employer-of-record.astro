					{ code: "AR", name: "EOR Argentina" },
				]}
			/>
		</div>

		<div class="fade-in-section">
			<PricingSection
				eyebrow=""
				title="Precios simples para tu <span style='font-weight: 900; color: #6663FD;'>expansión legal</span>"
				subtitle="Paga por profesional, no por funcionalidades. Sin costes ocultos."
				plans={[
					{
						badge: "MÁS POPULAR",
