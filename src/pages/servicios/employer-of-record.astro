		<div class="fade-in-section">
			<CoberturaSeccion
				title="EOR España: Tu nómina<br/>centralizada en <span style='color: #6663FD; font-weight: 900; white-space: nowrap;'>10 países</span><br/><span style='color: #6663FD; font-weight: 900;'>de LATAM</span>"
				description="Presencia legal activa en los principales mercados de talento de habla hispana."
				countries={[
					{ code: "MX", name: "EOR México" },
					{ code: "VE", name: "EOR Venezuela" },
					{ code: "CO", name: "EOR Colombia" },
					{ code: "EC", name: "Ecuador" },
