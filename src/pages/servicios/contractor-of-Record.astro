                        description: "Para entregables por volumen. Relación estrictamente mercantil y sin riesgos laborales.",
                        roles: [
                            { label: "Experto SEO externo", href: "#" },
                            { label: "Especialista Google Ads por campaña", href: "#" },
                            { label: "Especialista Meta Ads por lanzamiento", href: "#" },
                            { label: "Email marketer por proyecto", href: "#" }
                        ],
                        iconColorClass: "pink-text",
                    },
                    {
                        icon: "📊",
                        title: "Diseño y producto",
                        quote: "",
                        description: "Especialistas independientes para diseño e interfaces. Pagos por hitos y entregables bajo contrato mercantil.",
                        roles: [
                            { label: "Diseñador UI/UX por sprint", href: "#" },
                            { label: "Diseñador gráfico por campañas", href: "#" },
                            { label: "Editor de vídeo para picos de producción", href: "#" }
                        ],
                        iconColorClass: "purple-text",
                    }
                ]}
            >
            <!-- 
                <div slot="bottom-alert" class="profiles-bottom-alert">
                    <span class="alert-icon">🚨</span>
                    <div class="alert-content">
                        <h4>¿Necesitas perfiles no tecnológicos?</h4>
                        <p>
                            (Comerciales, administrativos, marketing, atención
                            al cliente). Contamos con otros modelos con los
                            cuales cubrimos esas áreas. <a href="#"
                                >Ver soluciones globales →</a
                            >
                        </p>
                    </div>
                </div>
                -->
            </ProfilesSection>
