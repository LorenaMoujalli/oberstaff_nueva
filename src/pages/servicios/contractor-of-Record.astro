        <div class="fade-in-section">
            <CasosExitoSection
                title="Empresas españolas que ya contratan con Oberstaff"
                subtitle=""
                testimonials={[
                    {
                        stars: 5,
                        text: "Estaba en busca de un editor de video para mi empresa y después de varias búsquedas sin éxito, encontré a Oberstaff. Desde nuestra primera llamada, su profesionalismo me dejó impresionado. He expandido mi contrato para incluir más personal.",
                        author: "Fernando Calderón",
                        role: "CEO · BEAUTYPRO",
                    },
                    {
                        stars: 5,
                        text: "Gracias a Oberstaff pude dar trabajo a dos personas a tiempo completo, ahorrando costes de reclutamiento, espacios de oficina y salario que tendría al hacerlo en España. Lo mejor de todo es que todo está incluido en una misma factura.",
                        author: "Shadai Iborra",
                        role: "CEO · @AMEDIASTORY",
                    },
                    {
                        stars: 5,
                        text: "I've been working with Oberstaff for about 2 years. They handle everything: contracts, payments and HR admin. My team in Latin America is fantastic and the cost savings have been game-changing for our business.",
                        author: "Kate McCafferty",
                        role: "KM REAL ESTATE",
                    },
                ]}
            />
        </div>

     
        <div class="fade-in-section">
            <FAQSectionContractor 
                label=""
                title="Todo lo que necesitas saber antes de empezar"
                subtitle=""
            />
        </div>


        <!-- 
		<div class="fade-in-section">
			<OtrosServiciosSection />
		</div>
        -->

        <div class="fade-in-section">
            <ContactFormSection
                title="¿Listo para incorporar tu próximo profesional remoto?"
                subtitle="Cuéntanos qué perfil necesitas y en menos de 24 horas recibirás una propuesta personalizada sin compromiso. Primera consulta gratuita con nuestros especialistas en contratación internacional."
                buttonText="Solicitar propuesta gratuita"
            />
        </div>

