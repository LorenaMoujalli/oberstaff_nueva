import FeaturesSection from "../../components/oberstaff-features-servicios/FeaturesSection.astro";
import CoberturaSeccion from "../../components/geografica-servicios/CoberturaSeccion.astro";
import PricingSection from "../../components/pricing-servicios/PricingSection.astro";
import CasosExitoSection from "../../components/casos-exito-servicios/CasosExitoSection.astro";
//import RolesSection from "../../components/roles-servicios/RolesSection.astro";
import FAQSection from "../../components/faq-servicios/FAQSectionContractor.astro";
import OtrosServiciosSection from "../../components/otros-servicios-servicios/OtrosServiciosSection.astro";
import ContactFormSection from "../../components/form/ContactFormSection.astro";
//import ArticulosSection from "../../components/articulos-servicios/ArticulosSection.astro";
import QueEsServicioSection from "../../components/QueEsServicio/QueEsServicioSection.astro";
import ServicesSection from "../../components/services-oberstaff/ServicesSection.astro";
import ProcessOberstaff from "../../components/process/ProcessOberstaff.astro";
import ProfilesSection from "../../components/profiles/ProfilesSection.astro";
---

<DashboardLayoutServicios
    title="Contractor of Record para empresas españolas | Oberstaff"
    description="Contrata freelancers en LATAM ágilmente. Como tu Contractor of Record, gestionamos pagos, contratos y compliance internacional sin nexo laboral."
    keywords="Contractor of Record"
>
    <div class="service-detail-container">
        <div class="fade-in-section">
            <HeroService
                label="CONTRACTOR OF RECORD • COR"
                preTitle="Contractor of Record en LATAM:"
                title="Contrata freelancers e independientes con respaldo legal"
                highlight=""
                description="Colabora con freelancers y profesionales independientes en LATAM de forma ágil. Como tu Contractor of Record, centralizamos tus pagos internacionales y blindamos tus contratos mercantiles contra riesgos de 'falsos autónomos'. Todo en una única factura."
                videoImg="/fondo-video.webp"
                remoteCountry="CO"
                floatingText="Talento Tech Validado"
                floatingIcon="💻"
                badgeRightTitle=""
                badgeRightText="Integración Ágil"
                badgeRightIcon="⚡"
                primaryBtnText="Recibir propuesta en <24h"
                primaryBtnHref="#contacto"
                secondaryBtnText="Hablar con un especialista COR"
                secondaryBtnHref="#contacto"
                underBtnText="↳ Tardarás menos de 1 minuto · Sin compromiso"
                modalTitle="¿Listo para colaborar con talento independiente?"
                modalDescription="Un especialista te explicará cómo centralizar tus pagos internacionales sin riesgos."
                modalBtnText="Agendar asesoría gratuita"
            />
        </div>

        <div class="fade-in-section">
            <FranjaEmpresasHome
                stat1Number="100%"
                stat1Label="Compliance para trabajadores independientes"
                stat2Number="10"
                stat2Label="Países en LATAM con red de pagos centralizada"
                stat3Number="0"
                stat3Label="Riesgo de contingencia por falsos autónomos"
            />
        </div>

        <div class="fade-in-section">
            <QueEsServicioSection
                title="¿Qué es un Contractor of Record?"
                highlightWord="Contractor of Record?"
                description="<span style='color: #1B1B1B; font-weight: 700;'>Contratación ágil de talento independiente sin fricción internacional.</span>"
                imageSrc="/img-contractor.webp"
                imageAlt="Profesional trabajando"
                badgeText="Pago centralizado"
                quoteText="El contractor of record meaning en su definición más práctica: es la empresa que actúa como intermediaria legal para contratar profesionales independientes en otro país. Tú defines el proyecto, los entregables y la relación de trabajo; <span style='color: #1B1B1B; font-weight: 700;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> estructura el contrato, coordina los pagos y sostiene la administración del servicio."
                infoItems={[
                    {
                        icon: "🚀", 
                        title: "",
                        description:
                            "Para las organizaciones españolas, el COR es la vía más ágil cuando necesita incorporar talento por proyecto, por sprint o por especialidad, pero <span style=' font-weight: 700;'>no necesita crear una relación laboral de empleado</span><span style='color: #FF66CC; font-weight: 900;'>.</span> No es un modelo de nómina; es un modelo pensado para independientes.",
                    }
                ]}
                diffIcon="❌"
                diffTitle="COR NO es el modelo adecuado si..."
                diffDescription="Si necesitas horario fijo, subordinación continua, nómina, entonces no necesitas un COR; <a styles='color: #FF4D4D !important; text-decoration: none !important; font-weight: 700 !important;' href='/servicios/employer-of-record'>necesitas el modelo employer of record →</a>"
            />
        </div>

        <div class="fade-in-section">
            <ServicesSection
                title="Cuándo usar un <strong>Contractor of Record</strong>"
                description="El COR es la opción ideal cuando necesitas flexibilidad y velocidad sin estructura fija."
                customClass="employer-use-cases"
                services={[
                    {
                        icon: "🚀",
                        title: "Proyectos puntuales y de duración definida",
                        description:
                            "Necesitas un desarrollador o diseñador para un proyecto de 3-6 meses sin comprometer una contratación indefinida.",
                        linkText: "",
                        href: "",
                        customIconBg: "rgba(255, 102, 204, 0.1)",
                        cardClass: "card-green",
                    },
                    {
                        icon: "🔍",
                        title: "Colaboraciones con freelancers internacionales",
                        description:
                            "Trabaja con el experto en modalidad contractor antes de convertirlo en empleado fijo.",
                        linkText: "",
                        href: "",
                        customIconBg: "rgba(102, 255, 153, 0.1)",
                        cardClass: "card-pink",
                    },
                    {
                        icon: "🌐",
                        title: "Expansión flexible en varios países",
                        description:
                            "Cuándo quieres operar con especialistas independientes en distintos mercados sin abrir una estructura legal en cada uno.",
                        linkText: "",
                        href: "",
                        customIconBg: "rgba(102, 99, 253, 0.1)",
                        cardClass: "card-lime",
                    },
                    {
                        icon: "💡",
                        title: "Talento especializado y escaso",
                        description:
