                        icon: "⚡",
                        badgeColor: "#1B1B1B",
                        badgeBg: "rgba(204, 255, 102, 0.3)",
                    },
                ]}
                ctaTitle="Incorpora a tu freelance hoy"
                ctaDescription="Un equipo dedicado gestionará todo el proceso legal y de pagos por ti."
                ctaBtnText="Agendar llamada"
            />
        </div>

        <div class="fade-in-section">
            <ProfilesSection
                variant="grid"
                title="Especialistas independientes que <span style='color: #6663FD; font-weight: 900;'>puedes incorporar con COR</span>"
                description="Perfiles de alta especialización con disponibilidad para trabajar por proyecto. Español nativo y listos para integrarse a tu negocio."
                profiles={[
                    {
                        icon: "💻",
                        title: "Tecnología por proyecto",
                        quote: "",
                        description: "Talento autónomo para auditorías o desarrollo de módulos aislados, facturando honorarios por proyecto.",
                        roles: [
                            { label: "Desarrollador freelance", href: "#" },
                            { label: "QA por release", href: "#" },
                            { label: "DevOps por migración", href: "#" },
                            { label: "Especialista en IA/Data por implementación", href: "#" }
                        ],
                        iconColorClass: "blue-text",
                    },
                    {
                        icon: "🎨",
