                        linkText: "",
                        href: "",
                        customIconBg: "rgba(204, 255, 102, 0.2)",
                        cardClass: "card-lime",
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <ConEorService
                eyebrow=""
                title="Gestionarlo internamente vs. hacerlo con <span style='color: #6663FD; font-weight: 900;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span>"
                description=""
                negativeTitle="Sin contractor of record"
                positiveTitle="Con <span style='font-weight: 900;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span>"
                badge="La opción inteligente"
                negativeIcon=""
                positiveIcon=""
                negativeItems={[
                    "Buscas al freelancer en múltiples plataformas",
                    "Pagos manuales a múltiples países",
                    "Contratos sin validez local",
                    "Dificultad para escalar cuando trabajas con varios especialistas externos",
                    "Caos administrativo persiguiendo facturas (invoices) de múltiples proveedores",
                ]}
                positiveItems={[
                    "Acceso a nuestra red de especialistas pre-vetting",
                    "Pagos y seguimiento simplificados",
                    "Contrato local válido desde el primer día",
                    "Modelo pensado para operar con independientes en distintos países de LATAM",
                    "Centralización de toda tu red de talento externo en una sola factura.",
                ]}
            />
        </div>

