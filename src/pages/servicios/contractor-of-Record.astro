        <div class="fade-in-section">
            <CoberturaSeccion
                title="Contratación internacional en 10 países"
                description="Una única suscripción con Oberstaff te da acceso a contratación internacional en 10 mercados. Ideal para empresas que quieren acceso a perfiles cualificados sin abrir entidad local."
                countries={[
                    { code: "CO", name: "Colombia" },
                    { code: "AR", name: "Argentina" },
                    { code: "MX", name: "México" },
                    { code: "VE", name: "Venezuela" },
                    { code: "PE", name: "Perú" },
                    { code: "EC", name: "Ecuador" },
