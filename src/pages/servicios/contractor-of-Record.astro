<style>
    .service-detail-container {
    }

    /* --- Ajuste de tamaño de título para Hero (Solo esta página) --- */
    /*
    :global(.hero-section .main-title) {
        font-size: 45px !important;
    }*/

    @media (max-width: 768px) {
        :global(.hero-section .main-title) {
            font-size: 32px !important;
        }
    }

    /* --- Personalización de QueEsDifferenceSection (Solo esta página) --- */
    :global(.que-es-difference-box) {
        background: rgba(255, 77, 77, 0.05) !important;
        border-color: rgba(255, 77, 77, 0.2) !important;
    }

    :global(.que-es-difference-box .diff-text h3) {
        color: #FF4D4D !important;
    }

    :global(.que-es-difference-box .diff-text p a) {
        color: #FF4D4D !important;
        text-decoration: none !important;
        font-weight: 700 !important;
    }

    /* --- Perfiles Section (Solo esta página) --- */
    :global(.variant-grid .profile-card .card-description) {
        font-family: 'Poppins', sans-serif;
        font-size: 13px;
        color: #5A5A5A;
        line-height: 1.6;
        margin-bottom: 15px;
       
        border-top: none !important;
    }

    :global(.variant-grid .profile-card .card-header) {
        border-bottom: none !important;
        margin-bottom: 15px !important;
        padding-bottom: 0 !important;
    }

    :global(.variant-grid .profile-card .roles-list) {
        border-top: 1px solid rgba(0, 0, 0, 0.06) !important;
        padding-top: 15px !important;
        margin-top: 10px;
    }

    /* --- Estilos específicos para el componente de proceso en Employer --- */
    :global(.process-employer .process-menu) {
        background-color: #fafafc;
    }

    :global(.process-employer .process-tab-label) {
        color: #5a5a5a;
        font-weight: 600;
    }

