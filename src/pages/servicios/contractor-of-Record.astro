                description="Desde la firma del contrato hasta la gestión mensual de pagos. <span style='color: #1B1B1B; font-weight: 700;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> cubre cada fase para que solo tengas que dirigir el trabajo."
                items={[
                    {
                        label: "Validación",
                        badge: "Paso 1",
                        title: "Definición del modelo y validación de encaje",
                        description:
