                        icon: "🔍",
                        badgeColor: "#6663FD",
                        badgeBg: "rgba(102, 99, 253, 0.1)",
                    },
                    {
                        label: "Contrato",
                        badge: "Paso 2",
                        title: "Contrato y alta documental",
                        description:
                            "Estructuramos la documentación contractual y dejamos ordenado el marco de colaboración desde el primer día.",
                        icon: "📝",
                        badgeColor: "#6aca8a",
                        badgeBg: "rgba(102, 255, 153, 0.15)",
                    },
                    {
                        label: "Pagos",
                        badge: "Paso 3",
                        title: "Gestión mensual y pagos",
                        description:
