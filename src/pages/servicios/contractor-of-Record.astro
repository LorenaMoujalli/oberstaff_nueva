		<div class="fade-in-section">
			<PricingSection
				eyebrow="Planes EOR"
				title="Precios simples y sin sorpresas."
				subtitle="Paga por profesional, no por funcionalidades. Sin costes ocultos."
				plans={[
					{
						badge: "MÁS POPULAR",
						title: "EOR Completo",
						price: "690",
						currency: "€",
						period: "/ empleado / mes",
						teamSize: "Para equipos de 4-20 empleados",
