                    {
                        icon: "ph:calculator-duotone",
                        iconColor: "#ef4444",
                        title: "Facturación y control de gastos",
                        description:
                            "Gestión de facturas, seguimiento de pagos y soporte al departamento financiero.",
                    },
                    {
                        icon: "ph:wrench-duotone",
                        iconColor: "#3b82f6",
                        title: "Herramientas y sistemas de gestión",
                        description:
