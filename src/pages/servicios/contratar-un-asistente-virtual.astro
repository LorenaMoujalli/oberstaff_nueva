---
import DashboardLayoutPerfiles from "../../layouts/DashboardLayoutPerfiles.astro";
import LeadHeroSection from "../../components/community-manager/LeadHeroSection.astro";
import ComparisonPerfiles from "../../components/comparison-perfiles/ComparisonPerfiles.astro";
import PricingCardPerfil from "../../components/pricing-perfil/PricingCardPerfil.astro";
import BeneficiosPerfilDisenador from "../../components/beneficios-perfil/BeneficiosPerfilDisenador.astro";
import PressSection from "../../components/press/PressSection.astro";
import ConversionPerfilDisenador from "../../components/conversion-perfil/ConversionPerfilDisenador.astro";
import RolesPerfil from "../../components/roles-del-perfil/RolesPerfil.astro";
import QueEsServicioSection from "../../components/QueEsServicio/QueEsServicioSection.astro";
import ServicesSection from "../../components/services-oberstaff/ServicesSection.astro";
import EorStepsSection from "../../components/eor-steps-servicios/EorStepsSection.astro";
import EorCta from "../../components/eor-cta-servicios/EorCta.astro";
import CasosExitoSection from "../../components/casos-exito-servicios/CasosExitoSection.astro";
import FAQSection from "../../components/faq-servicios/FAQSection-asistente.astro";
---

<DashboardLayoutPerfiles
    title="Contratar un Asistente Virtual para tu empresa"
    description="Talento remoto de LATAM, español nativo y hasta un 70% de ahorro para empresas en España que buscan contratar un asistente virtual. Consulta gratuita."
    footerTitle="Roles Relacionados"
    footerLinks={[
        { text: "💰 Contratar contable remoto", href: "/servicios/contratar-contable" },
        { text: "📱 Community Manager", href: "/servicios/contratar-community-manager" },
        { text: "🔍 Experto SEO", href: "/servicios/contratar-experto-seo" },
    ]}
    keywords="contratar un asistente virtual "
>
    <div class="service-detail-container" id="inicio">
        <LeadHeroSection
            topLabel="Contratar un Asistente Virtual para tu empresa"
            title="Contratar un asistente virtual: Externaliza tu Back-Office y escala tu operativa sin pasivo laboral"
            cardTitle="Encuentra a tu asistente hoy"
            cardSubtitle="Accede a perfiles pre-evaluados listos para tu empresa."
            buttonText="👉 Ver perfiles pre-evaluados y solicitar propuesta"
            buttonIcon=""
            buttonSubtext="↳ Tardarás menos de 1 minuto · Sin compromiso"
            footerLinkText="Ver cómo funciona el modelo EOR →"
            footerLinkHref="/servicios/employer-of-record/"
            badges={[
                { text: "Dedicación exclusiva", icon: "🎯" },
                { text: "Perfiles evaluados en soporte", icon: "📋" },
                { text: "Integración rápida", icon: "⚡" },
                { text: "Horario compatible con España", icon: "🕒" },
            ]}
        >
            <Fragment slot="description">
                El mayor cuello de botella para el crecimiento de un negocio es
                tener a sus directivos atrapados en microtareas administrativas.
                Al incorporar un asistente virtual para empresas delegas la
                gestión de CRMs,la estandarización de procesos (SOPs) y la
                atención a proveedores en un perfil dedicado. Recupera el
                control de tu agenda corporativa mientras nosotros absorbemos el
                100% de la carga burocrática y legal internacional.
            </Fragment>
        </LeadHeroSection>

        <div class="fade-in-section">
            <QueEsServicioSection
                title="Descentraliza tu carga administrativa: el impacto financiero al contratar a un asistente virtual remoto In-House"
                highlightWord="asistente virtual remoto In-House"
                description="Mantener la gestión documental y el soporte de primer nivel en nómina local dispara tus costes de estructura antes de generar un solo euro de retorno. Al apostar por contratar un asistente virtual dedicado, integras a un profesional pre-evaluado que opera bajo tus propios protocolos de ciberseguridad, reduciendo tus costes operativos sin sacrificar exclusividad."
                imageSrc="/img1-asistente.webp"
                imageAlt="Profesional trabajando"
                badgeText="Orden y control"
                quoteText=""
                checklistTitle="Checklist de validación operativa:"
                checklistItems={[
                    "Validación de competencias: evaluación previa en gestión de archivos, redacción corporativa y herramientas Cloud.",
                    "Eficiencia fiscal: Facturación B2B internacional deducible como gasto de servicios profesionales.",
                    "Escalabilidad inmediata: ajusta tu capacidad de soporte administrativo sin procesos de despido ni indemnizaciones.",
                ]}
                ctaText="Solicitar asistente virtual →"
                ctaHref="#"
                diffIcon=""
                diffTitle=""
                diffDescription=""
            />
        </div>

        <div class="fade-in-section">
            <ServicesSection
                title="De la gestión de agendas al control del CRM: funciones técnicas de un <strong>asistente virtual para empresas?</strong>"
                description="Un asistente virtual administrativo ayuda a tu organización a descargar tareas operativas que frenan al equipo: manejo de agenda, filtrado de correo, seguimiento, reportes y coordinación interna. No es solo apoyo puntual; es una persona trabajando en remoto que aporta orden documental, velocidad de respuesta y continuidad."
                customClass="employer-use-cases"
                services={[
                    {
                        icon: "📅",
                        title: "Gestión de agenda y calendario",
                        description:
                            "Organización de reuniones, coordinación de horarios, recordatorios y gestión de viajes ejecutivos",
                        linkText: "",
                        href: "",
                        customIconBg: "rgba(255, 102, 204, 0.1)",
                        cardClass: "card-green",
                    },
                    {
                        icon: "📧",
                        title: "Gestión de correo y comunicaciones",
                        description:
                            "Clasificación de bandeja de entrada, respuesta y seguimiento de emails. Atención ágil a clientes y proveedores.",
                        linkText: "",
                        href: "",
                        customIconBg: "rgba(102, 255, 153, 0.1)",
                        cardClass: "card-pink",
                    },
                    {
                        icon: "📄",
                        title: "Documentación y gestión de archivos",
                        description:
                            "Actualización de documentos, bases de datos, SOPs y archivos compartidos para que la información esté accesible y limpia.",
                        linkText: "",
                        href: "",
                        customIconBg: "rgba(102, 99, 253, 0.1)",
                        cardClass: "card-lime",
                    },
                    {
                        icon: "💼",
                        title: "Soporte a dirección y gerencia",
                        description:
                            "Preparación de reuniones, seguimiento de tareas, recordatorios, consolidación de información y apoyo operativo a gerencia.",
                        linkText: "",
                        href: "",
                        customIconBg: "rgba(204, 255, 102, 0.2)",
                        cardClass: "card-lime",
                    },
                    {
                        icon: "🔢",
                        title: "Higiene de Datos en CRM",
                        description:
                            "Actualización de fichas de clientes, limpieza de pipelines y reportes de actividad comercial en tiempo real.",
                        linkText: "",
                        href: "",
                        customIconBg: "rgba(255, 153, 102, 0.1)",
                        cardClass: "card-green",
                    },
                    {
                        icon: "🛠️",
                        title: "Stack de Productividad",
                        description:
                            "G Suite, Microsoft 365, Notion, Asana, Slack, Calendly y plataformas de colaboración.",
                        linkText: "",
                        href: "",
                        customIconBg: "rgba(102, 204, 255, 0.1)",
                        cardClass: "card-pink",
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <EorStepsSection
                title="El roadmap de integración administrativa: contratar un <strong>asistente virtual de forma segura</strong>"
                subtitle="Externalizar el soporte administrativo requiere una transición técnica que proteja la privacidad de tu negocio. Aplicamos un proceso de onboarding diseñado para la seguridad de la información."
                steps={[
                    {
                        title: "Auditoría de cuellos de botella",
                        lineColorClass: "line-black",
                        description:
                            "Define el volumen de tareas, SLAs y stack tecnológico, requeridos para diseñar el perfil técnico exacto.",
                        badge: "15 min · Sin compromiso",
                    },
                    {
                        title: "Selección de Talento",
                        lineColorClass: "line-pink",
                        description:
                            "Te presentamos una terna (3 a 5) de perfiles de LATAM con ofimática avanzada y encaje cultural validado.",
                        badgeIcon: "📋",
                        badge: "Perfiles evaluados",
                    },
                    {
                        title: "Entrevistas de validación",
                        lineColorClass: "line-orange",
                        description:
                            "Sesiones directas con los candidatos. Tú validas su criterio operativo y decides a quién entregarle el control de tu agenda.",
                        badge: "Tú tienes la última palabra",
                    },
                    {
                        title: "Sincronización Operativa",
                        lineColorClass: "line-blue",
                        description:
                            "El perfil se integra en tus canales (Slack, Teams, otros), asimilando tu cultura y horarios desde el día uno.",
                        badge: "Integración en días",
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <EorCta
                title="¿Tu equipo directivo está asfixiado por microtareas? Recupera su tiempo al contratar a un asistente virtual"
                text="Cuéntanos cuál es el cuello de botella documental de tu empresa. Define el perfil exacto que necesitas y recibe una propuesta adaptada a tu modelo de negocio en menos de 24 horas."
                buttonText="👉 Solicitar propuesta personalizada"
                buttonHref="#"
            />
        </div>

        <div class="fade-in-section">
            <RolesPerfil
                title="Especialización operativa: asistentes virtuales para negocios a <strong>tu disposición</strong>"
                subtitle=""
                layout="modern"
                footerText="💡 ¿Necesitas también un perfil que lleve la contabilidad formal y las obligaciones fiscales?"
                footerLinkText="Ver perfil de Contable Remoto →"
                footerLinkHref="#"
                roles={[
                    {
                        title: "🗂️ Asistente Administrativo virtual",
                        description: "",
                        icon: "",
                        iconColor: "#FF66CC",
                        borderColorClass: "border-pink",
                        subtitle:
                            "Estandarización de SOPs, control de agenda, filtro de emails y auditoría de documentos internos.",
                        techStack: [
                            "Google Workspace",
                            "Notion",
                            "Trello",
                            "Slack",
                        ],
                        buttonText: "Solicitar más información →",
                        buttonHref: "#",
                    },
                    {
                        title: "🗣️ Soporte y Atención al Cliente",
                        description: "",
                        icon: "",
                        iconColor: "#3b76f6",
                        borderColorClass: "border-blue",
                        subtitle:
                            "Gestión de tickets, SLAs de respuesta (primer nivel), resolución de incidencias y fidelización B2B/B2C",
                        techStack: [
                            "Zendesk",
                            "Freshdesk",
                            "Intercom",
                            "WhatsApp Business",
                        ],
                        buttonText: "Solicitar más información →",
                        buttonHref: "#",
                    },
                    {
                        title: "🛒 Asistente Virtual remoto para eCommerce",
                        description: "",
                        icon: "",
                        iconColor: "#66FF99",
                        borderColorClass: "border-green",
                        subtitle:
                            "Actualización masiva de SKUs, control de inventario base y seguimiento de logística posventa.",
                        techStack: ["Shopify", "Amazon Seller", "Klaviyo"],
                        buttonText: "Solicitar más información →",
                        buttonHref: "#",
                    },
                    {
                        title: "💼 Asistente Personal Ejecutivo",
                        description: "",
                        icon: "",
                        iconColor: "#CCFF66",
                        borderColorClass: "border-yellow",
                        subtitle:
                            "Gestión de agendas directivas complejas (C-Level), filtro de comunicaciones críticas y preparación de juntas.",
                        techStack: ["Calendly", "Notion", "Zoom", "Asana"],
                        buttonText: "Solicitar más información → ",
                        buttonHref: "#",
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <ComparisonPerfiles
                title="Asistente virtual España vs Asistente remoto dedicado y <span style='color: #6663FD; font-weight: 800;'>otras opciones</span>"
                subtitle="Analiza la diferencia entre tener un recurso integrado en tu equipo frente a los riesgos de la fragmentación operativa."
                footerNote="Nota: Precios B2B orientativos. La inversión exacta depende del seniority y el nivel técnico requerido"
                oberstaffLabel="<span style='font-weight:800; color:#1B1B1B;'>Asistente dedicado <span style='color:#FF66CC; font-weight:700;'>(Oberstaff)</span>"
                competitors={["Contratación Local", "Freelance", "Agencia"]}
                rows={[
                    {
                        label: "Coste mensual",
                        oberstaffValue: "<strong>Desde 690€/mes</strong>",
                        competitorValues: [
                            "1.500–2.500€/mes",
                            "800–2.000€",
                            "1.200–4.000€",
                        ],
                    },
                    {
                        label: "Foco y Atención",
                        oberstaffValue:
                            "<span class='icon-check'>✓</span> 100% Exclusivo. Conoce tu empresa a fondo",
                        competitorValues: [
                            "<span class='icon-check'>✓</span>  Exclusivo. Pero con altos costes fijos",
                            "<span class='icon-warning'>⚠</span> Multicliente",
                            "<span class='icon-cross'>✕</span> No",
                        ],
                    },
                    {
                        label: "Seguridad de Datos",
                        oberstaffValue:
                            "<span class='icon-check'>✓</span> NDA Corporativo. Accesos controlados",
                        competitorValues: [
                            "<span class='icon-cross'>✕</span> Seguro. Pero costoso de escalar",
                            "<span class='icon-cross'>✕</span> Sin control sobre sus dispositivos",
                            "<span class='icon-check'>✓</span> Sí",
                        ],
                    },
                    {
                        label: "Latencia de Respuesta",
                        oberstaffValue:
                            "<span class='icon-check'>✓</span> Tiempo Real. En tu horario comercial",
                        competitorValues: [
                            "<span class='icon-check'>✓</span> Tiempo Real",
                            "<span class='icon-warning'>⚠</span> Asíncrono. Respuesta puede demorar horas",
                            "<span class='icon-warning'>⚠</span> Repartido",
                        ],
                    },
                    {
                        label: "Sin permanencia",
                        oberstaffValue: "<span class='icon-check'>✓</span> Sí",
                        competitorValues: [
                            "<span class='icon-cross'>✕</span> Indemnizaciones",
                            "<span class='icon-warning'>⚠</span> Según contrato",
                            "<span class='icon-cross'>✕</span> Contratos largos",
                        ],
                    },
                    {
                        label: "Auditoría de talento",
                        oberstaffValue:
                            "<span class='icon-check'>✓</span> Filtro técnico + psicométrico",
                        competitorValues: [
                            "<span class='icon-cross'>✕</span> Consumo de horas de RRHH",
                            "<span class='icon-warning'>⚠</span> Basado solo reseñas",
                            "<span class='icon-cross'>✕</span> Sin filtro",
                        ],
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <PricingCardPerfil
                sectionTitle="Fin a los sobrecostes: tarifa plana al contratar a un <span style='color:#6663FD; font-weight: 900;'>asistente virtual</span>"
                sectionSubtitle="Estructura tus costes fijos con previsibilidad. Nuestra tarifa incluye todo: headhunting, compliance legal internacional y nómina. El coste escala únicamente según la especialización del talento."
                cardTitle="Todo incluido"
                cardSubtitle="Jornada completa · sin costes ocultos"
                priceLabel="DESDE"
                priceAmount="690€"
                pricePeriod="/ mes"
                features={[
                    "Gestión de agenda ejecutiva y filtrado de comunicaciones.",
                    "Orden documental y soporte administrativo.",
                    "Dominio de CRMs y herramientas de trabajo asíncrono.",
                    "Soporte directo a direcciones de área.",
                    "Facturación B2B internacional en euros.",
                ]}
                ctaText="Solicitar propuesta"
                ctaHref="#"
                disclaimer="*Precios orientativos. El coste final depende del perfil, país y nivel de experiencia"
            />
        </div>

        <BeneficiosPerfilDisenador
            title="Exclusividad y latencia cero: el ROI operativo de tu <span style='color:#6663FD; font-weight: 900;'>asistente virtual</span>"
            subtitle="El retorno operativo de un perfil dedicado reside en la profundidad de su conocimiento sobre tus procesos.Esta dedicación total garantiza que la información corporativa sea precisa y esté siempre disponible, eliminando el coste oculto que suponen los errores humanos por falta de contexto en la gestión de datos."
            image="/img2-asistente.webp"
            imageAlt=""
            infoTitle="Manual de validación operativa: Cómo filtrar y contratar a un asistente virtual con dominio de SOPs"
            features={[
                {
                    icon: "🎯",
                    title: "Eliminación del pasivo laboral y cargas sociales:",
                    description:
                        "Al operar bajo nuestro modelo, tu empresa se libera de la rigidez del marco laboral español. No asumes costes de indemnización, seguros sociales ni impuestos de contratación local.",
                },
                {
                    icon: "⚡",
                    title: "Blindaje de información mediante NDAs corporativos:",
                    description:
                        "La confidencialidad es innegociable. Cada asistente opera bajo estrictos acuerdos de confidencialidad garantizando que tu base de datos de clientes permanezcan protegidas.",
                },
                {
                    icon: "🛡️",
                    title: "Recuperación del tiempo estratégico (Deep Work):",
                    description:
                        "Al delegar atención de correos y coordinación de agendas, liberas a tu equipo C-Level para tareas de alto impacto. Pasas de 'apagar fuegos' a liderar la estrategia de expansión de tu negocio.",
                },
            ]}
            infoItems={[
                {
                    title: "¿Es mejor contratar asistente virtual freelance o uno integrado en remoto?",
                    description:
                        "Si necesitas seguimiento diario, coordinación con tu equipo y una persona que forme parte de tu organización, un perfil remoto estable funciona mejor y a menor coste total.",
                },
                {
                    title: "¿Qué soft skills y competencias técnicas se deben exigir al contratar un asistente virtual administrativo?",
                    description:
                        "Descarta perfiles reactivos, audita su capacidad para mantener CRMs limpios, redactar procedimientos (SOPs) y estructurar bases de datos. Una llamada de 15 minutos con nuestros asesores te ayudará a trazar el perfil técnico exacto que tu operativa demanda.",
                },
                {
                    title: "¿Qué stack tecnológico deben dominar los asistentes virtuales para negocios?",
                    description:
                        "La ofimática básica ya no es suficiente. El perfil debe operar con fluidez en ecosistemas empresariales: Google Workspace, Microsoft 365, gestores de proyectos (Asana, Jira, Notion) y plataformas de comunicación síncrona (Slack, Teams).",
                },
                {
                    title: "¿Secretaria virtual clásica o asistente administrativo remoto? ",
                    description:
                        "Muchas búsquedas empiezan con el término secretaria virtual para empresas, pero hoy el rol suele ir mucho más allá de contestar correos o agendar reuniones. En la práctica, lo que mejor funciona es un asistente administrativo virtual capaz de seguir procesos, coordinar tareas y dar soporte operativo constante al negocio.",
                },
                 {
                    title: "¿Cuál es la ventaja de un asistente virtual remoto ante un asistente administrativo tradicional?",
                    description:
                        "Las funciones centrales son idénticas, pero contratar un asistente virtual en España a través del modelo de Oberstaff aporta una enorme agilidad, suprime los gastos fijos de oficina y te conecta con talento internacional perfectamente alineado con tu franja horaria.",
                }

            ]}
        />

        <div class="fade-in-section">
            <CasosExitoSection
                title="<span style='font-weight: 900; color: #6663FD;'>Casos de éxito corporativo: </span>negocios que ya contratan talento con nosotros"
                subtitle="Resultados reales de organizaciones que decidieron contratar asistente virtual con Oberstaff."
                testimonials={[
                    {
                        stars: 5,
                        avatar: "/fernando.webp",
                        text: "Estaba en busca de talento remoto especializado para mi empresa y después de varias búsquedas sin éxito, encontré a <strong>Oberstaff<span style='color: #FF66CC;'>.</span></strong> en Instagram. Desde nuestra primera llamada, su profesionalismo y calidad de trabajo me dejaron impresionado. Ahora, gracias a su excelente servicio, he expandido mi contrato con ellos para incluir más personal.",
                        author: "Fernando Calderón",
                        role: "CEO · BeautyPro",
                    },
                    {
                        stars: 5,
                        avatar: "/sha.webp",
                        text: "Con <strong>Oberstaff<span style='color: #FF66CC;'>.</span></strong> pude dar trabajo a dos personas a tiempo completo, ahorrando costes de reclutamiento, espacios de oficina y salario que tendría al hacerlo en España. Lo mejor de todo es que todo está incluido en una misma factura. Con <strong>Oberstaff<span style='color: #FF66CC;'>.</span></strong>, encontré la solución perfecta para mis necesidades de contratación remota y optimización de costes.",
                        author: "Shadai Iborra",
                        role: "CEO · @amediastory",
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <PressSection title="Prensa y menciones" />
        </div>

        <FAQSection
            title="Blindaje legal y contingencia laboral de tu <strong>asistente virtual</strong>"
            ctaText="Protege tu balance frente a la rigidez del marco laboral español. Al integrar tu asistente virtual bajo nuestra arquitectura legal, desplazas la carga administrativa y el pasivo laboral hacia nuestra infraestructura global."
            ctaButtonText="Hablar con asesor →"
        />

        <div class="fade-in-section">
            <ConversionPerfilDisenador
                title="Sistematiza tu empresa hoy: da el paso definitivo para contratar un <strong>asistente virtual</strong>"
                subtitle="Dejar tu back-office en manos del azar frena tu escalabilidad. Transforma tus costes fijos en una inversión operativa ágil.Rellena el formulario (tardarás menos de 1 minuto) y en menos de 24 horas recibirás una propuesta personalizada sin compromiso."
                buttonText="Solicitar propuesta gratuita →"
                noteText="Nota: Rellenarlo te lleva menos de 1 minuto"
            />
        </div>
    </div>

    <style>
        .service-detail-container {
        }

        /* Estilos específicos para QueEsServicioSection en esta página */
        :global(.que-es-servicio-section .ques-checklist-title) {
            margin-top: 0 !important;
        }

        :global(.que-es-servicio-section .que-es-main-content) {
            align-items: flex-start !important;
        }

        /* Grid de 3 arriba y 3 abajo para servicios solo en esta página */
        @media (min-width: 851px) {
            :global(.employer-use-cases-grid) {
                grid-template-columns: repeat(3, 1fr) !important;
            }

            :global(.employer-use-cases-grid .icon-box) {
                background-color: transparent !important;
                border: none !important;
                box-shadow: none !important;
                padding: 0 !important;
                justify-content: flex-start !important;
                width: auto !important;
                height: auto !important;
                margin-bottom: 20px !important;
            }
        }

        /* Fondo exclusivo para la sección de áreas del diseñador */
        :global(section.employer-use-cases) {
            background-color: #fafafc !important;
        }

        /* Fondo exclusivo para la sección de casos de éxito en esta página */
        :global(.casos-exito) {
            background-color: #fafafc !important;

            padding-bottom: 80px !important;
        }

        /* Estilos específicos para la sección FAQ en esta página */
        :global(.faq-disenador-custom .faq-columns) {
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            text-align: center !important;
        }

        :global(.faq-disenador-custom .faq-left-column) {
            position: static !important;
            width: 100% !important;
            max-width: 800px !important;
            margin-bottom: 40px !important;
            display: flex !important;
            flex-direction: column !important;
            align-items: flex-start !important;
            text-align: left !important;
        }

        :global(.faq-disenador-custom .faq-main-title) {
            margin-left: 0 !important;
            margin-right: 0 !important;
            text-align: left !important;
        }

        :global(.faq-disenador-custom .faq-right-column) {
            display: none !important;
        }

        :global(.faq-disenador-custom .faq-cta-card) {
            margin: 0 !important;
            padding: 0 !important;
            max-width: 600px !important;
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            text-align: left !important;
        }

        :global(.faq-disenador-custom .faq-cta-card p) {
            font-family: "Poppins", sans-serif !important;
            font-size: 18px !important;
            font-weight: 400 !important;
            color: #5a5a5a !important;
            line-height: 1.6 !important;
