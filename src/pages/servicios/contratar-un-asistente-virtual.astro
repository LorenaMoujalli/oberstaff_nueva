                        icon: "ph:suitcase-duotone",
                        iconColor: "#ff66cc",
                        borderColorClass: "border-pink",
                        techStack: ["Calendly", "Notion", "Zoom", "Asana"],
                    },
                ]}
            />
        </div>

        <div class="fade-in-section">
            <ComparisonPerfiles
                title="Asistente virtual España: Oberstaff vs. otras opciones"
                subtitle="Compara el coste real de contratar un asistente administrativo virtual en España frente a nuestro modelo de talento remoto desde LATAM."
