---
import DashboardLayoutPerfiles from "../../layouts/DashboardLayoutPerfiles.astro";
import LeadHeroSection from "../../components/community-manager/LeadHeroSection.astro";
import TrustBarPerfiles from "../../components/trust-bar-perfiles/TrustBarPerfiles.astro";
import InfoServicePerfil from "../../components/info-services-perfil/InfoServicePerfil.astro";
import AreasPerfiles from "../../components/areas-perfiles/AreasPerfiles.astro";
import TimelinePerfiles from "../../components/timeline-perfiles/TimelinePerfiles.astro";
import CTAIntermedioPerfil from "../../components/cta-intermedio-perfil/CTAIntermedioPerfil.astro";
import ComparisonPerfiles from "../../components/comparison-perfiles/ComparisonPerfiles.astro";
import PricingCardPerfil from "../../components/pricing-perfil/PricingCardPerfil.astro";
import BeneficiosPerfil from "../../components/beneficios-perfil/BeneficiosPerfil.astro";
import GuiaPerfiles from "../../components/guia-perfiles/GuiaPerfiles.astro";
import CasosExitoPerfiles from "../../components/casos-exito-perfiles/CasosExitoPerfiles.astro";
import FAQSectionAsistente from "../../components/faq-servicios/FAQSection-asistente.astro";
import PressSection from "../../components/press/PressSection.astro";
import ConversionPerfil from "../../components/conversion-perfil/ConversionPerfil.astro";
import RolesPerfil from "../../components/roles-del-perfil/RolesPerfil.astro";
---

<DashboardLayoutPerfiles
    title="Contratar un Asistente Virtual para tu empresa"
    description="Talento remoto de LATAM, español nativo y hasta un 70% de ahorro para empresas en España que buscan contratar un asistente virtual. Consulta gratuita. "
    keywords="contratar un asistente virtual"
>
    <div class="service-detail-container" id="inicio">
        <LeadHeroSection
            topLabel=""
            title="Contratar un asistente virtual desde Latinoamérica para tu negocio en España"
            cardTitle="Comienza ahora"
            buttonText="Solicitar propuesta personalizada"
            footerLinkText="Ver cómo funciona →"
            footerLinkHref="#como-contratar"
        >
            <Fragment slot="description">
                Incorpora un asistente virtual para empresas ya evaluado de
                LATAM. Mismo idioma, horario compatible, hasta un 70% de ahorro
                en costes y sin complicaciones legales ni administrativas.
            </Fragment>
        </LeadHeroSection>

        <div class="fade-in-section">
            <TrustBarPerfiles
                title="+5.000 empresas confían en nosotros"
                features={[
                    "Dedicación exclusiva",
                    "Perfiles evaluados",
                    "Integración rápida",
                    "Horario compatible con España",
                ]}
            />
        </div>

        <div class="fade-in-section">
            <InfoServicePerfil
                mainQuestion="¿Qué hace un asistente virtual para empresas?"
                answerText="Un asistente virtual administrativo ayuda a tu organización a descargar tareas operativas que frenan al equipo: agenda, correo, seguimiento, reportes, atención al cliente y coordinación interna. "
                priceBoxTitle="¿Cuánto cuesta contratar un asistente virtual en España?"
                priceBoxText={`El coste de contratar una persona local para tareas administrativas puede crecer rápido cuando sumas salario, Seguridad Social, selección y gestión, aproximadamente entre 1500-2500€/mes. Con Oberstaff, puedes acceder a un asistente virtual remoto desde a partir de 690 €/mes, con todo incluido y sin asumir riesgos legales.`}
                summaryTitle="Checklist de ventajas"
                summaryItems={[
                    "Asistentes virtuales evaluados con pruebas técnicas y psicométricas",
                    "Sin riesgo legal",
                    "Factura mensual en euros para tu empresa",
                    "Sin permanencia mínima — cancela cuando quieras",
                ]}
                buttonText="Solicitar propuesta personalizada →"
                buttonHref="#inicio"
            /> 
        </div> 


        

