                ]}
            />
        </div>

        <div class="fade-in-section">
            <div id="como-contratar" style="scroll-margin-top: 80px;">
                <TimelinePerfiles
                    title="Cómo contratar un asistente virtual con Oberstaff"
                    subtitle="Un proceso ágil y sin riesgo. Desde que nos contactas hasta que tu asistente virtual está trabajando para ti."
                    items={[
                        {
                            title: "Cuéntanos tu perfil",
                            timeTag: "15 minutos",
                            description:
                                "Llamada gratuita de 15 min. Analizamos necesidades, herramientas y experiencia requerida.",
                        },
                        {
                            title: "Seleccionamos candidatos",
                            timeTag: "Perfiles evaluados",
                            timeTagGray: true,
                            description:
                                "Preseleccionamos 3–5 perfiles evaluados técnica y psicométricamente.",
                        },
                        {
                            title: "Entrevistas y decisión",
                            timeTag: "A tu ritmo",
                            description:
                                "Entrevistas directas con los candidatos. Tú eliges a quién contratar.",
                        },
                        {
                            title: "Tu AV empieza a trabajar",
                            timeTag: "En <48 horas después de tu elección",
                            timeTagGray: true,
                            description:
                                "Oberstaff gestiona contrato, nómina y compliance. ",
                        },
                    ]}
                />
            </div>
        </div>

        <div class="fade-in-section">
            <CTAIntermedioPerfil
                alertText="Si estás comparando opciones de asistentes virtuales para negocios, aquí simplificamos el proceso para que contrates más rápido y con menos riesgo."
