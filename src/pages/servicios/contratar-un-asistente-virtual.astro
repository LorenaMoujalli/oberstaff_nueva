        <div class="fade-in-section">
            <AreasPerfiles
                title="Todo lo que puede hacer tu asistente virtual remoto"
                subtitle="Desde la gestión de agenda hasta el soporte a clientes, tu AV cubre todas las áreas administrativas clave de tu negocio."
                cards={[
                    {
                        icon: "ph:calendar-duotone",
                        iconColor: "#8b5cf6",
                        title: "Gestión de agenda y calendario",
                        description:
                            "Organización de reuniones, coordinación de horarios, recordatorios y gestión de viajes.",
                    },
                    {
                        icon: "ph:envelope-simple-duotone",
                        iconColor: "#ec4899",
                        title: "Gestión de correo y comunicaciones",
                        description:
                            " Clasificación, respuesta y seguimiento de emails. Atención a clientes y proveedores.",
                    },
                    {
                        icon: "ph:file-text-duotone",
                        iconColor: "#14b8a6",
                        title: "Documentación y archivo",
                        description:
