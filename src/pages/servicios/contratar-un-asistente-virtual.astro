            />
        </div>

        <div class="fade-in-section">
            <RolesPerfil
                title="Perfiles de asistentes virtuales disponibles"
                subtitle=""
                roles={[
                    {
                        title: "Asistente Administrativo virtual",
                        description:
                            "Gestión de agenda, emails, documentos y coordinación interna.",
                        icon: "ph:desktop-duotone",
                        iconColor: "#3b76f6",
                        borderColorClass: "border-blue",
                        techStack: [
                            "Google Workspace",
                            "Notion",
                            "Asana",
                            "Trello",
                            "Slack",
