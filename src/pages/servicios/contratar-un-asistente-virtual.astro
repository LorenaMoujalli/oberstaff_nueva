                        oberstaffValue: `<span class="badge-blue">Hasta 70%</span>`,
                        oberstaffNoPadding: true,
                        competitorValues: [
                            "-",
                            `<iconify-icon icon="solar:danger-triangle-bold" class="icon-cross" style="color: #f59e0b;"></iconify-icon> Variable`,
                            "Variable",
                        ],
                    },
                ]}
            />
