                    {
                        label: "Coste mensual",
                        oberstaffValue: "Desde 690€",
                        oberstaffBlueText: true,
                        competitorValues: [
                            "1.500-2.500€/mes",
                            "800-2.000€",
                            "1.200-4.000€",
                        ],
                    },
                    {
                        label: "Dedicación exclusiva",
                        oberstaffValue: "Sí",
                        competitorValues: [
                            "Sí",
                            `<iconify-icon icon="solar:danger-triangle-bold" class="icon-warning" style="color: #f59e0b;"></iconify-icon> Varios clientes`,
                            `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> No`,
                        ],
                    },
                    {
                        label: "Gestión legal",
                        oberstaffValue: "Oberstaff",
                        competitorValues: [
                            `<iconify-icon icon="solar:close-circle-bold" class="icon-cross" style="color: #ef4444;"></iconify-icon> Tú lo gestionas`,
                            "Autónomo",
                            "Sí",
                        ],
                    },
                    {
                        label: "Zona horaria España",
                        oberstaffValue: `<iconify-icon icon="solar:check-circle-bold" class="icon-check" style="color: #10b981;"></iconify-icon> Compatible`,
                        competitorValues: [
                            "Compatible",
                            `<iconify-icon icon="solar:danger-triangle-bold" class="icon-warning" style="color: #f59e0b;"></iconify-icon> Sin horario fijo`,
                            "Repartido",
                        ],
                    },
                    {
                        label: "Sin permanencia",
                        oberstaffValue: `<iconify-icon icon="solar:check-circle-bold" class="icon-check" style="color: #10b981;"></iconify-icon> Sí`,
