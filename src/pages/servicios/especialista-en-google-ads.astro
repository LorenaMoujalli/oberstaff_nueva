import CasosExitoSection from "../../components/casos-exito-servicios/CasosExitoSection.astro";
import FAQSection from "../../components/faq-servicios/FAQSection-google-ads.astro";
---

<DashboardLayoutPerfiles
    title="Especialista en Google Ads | Remoto para España"
    description="Contrata un especialista en Google Ads para tu empresa Española. Talento de LATAM, dedicación exclusiva, horario compatible y sin riesgos legales"
    footerTitle="Roles Relacionados"
    footerLinks={[
        { text: "🔍 Experto SEO", href: "#" },
        { text: "📈 Especialista Meta Ads", href: "#" },
        { text: "💻 Diseñador web", href: "#" },
        { text: "🎨 Diseñador web", href: "#" }, 
        { text: "💻 Desarrollador web", href: "#" }, 
    ]}
    keywords="especialista en google ads"
>
    <div class="service-detail-container" id="inicio">
        <LeadHeroSection
            topLabel="Publicidad y Performance (SEM)"
            title="Especialista en Google Ads: Internaliza tu inversión y escala tu ROAS"
            cardTitle="Encuentra a tu experto SEM hoy"
            cardSubtitle="Accede a perfiles pre-evaluados listos para tu empresa."
            buttonText="👉 Ver perfiles pre-evaluados y solicitar propuesta"
            buttonIcon=""
            buttonSubtext="↳ Tardarás menos de 1 minuto · Sin compromiso"
            footerLinkText="Ver cómo funciona el modelo EOR →"
            footerLinkHref="#como-contratar"
            badges={[
                { text: "Dedicación exclusiva", icon: "🎯" },
                { text: "Perfiles evaluados", icon: "📋" },
                { text: "Integración rápida", icon: "⚡" },
                { text: "Horario compatible con España", icon: "🕒" },
            ]}
            badgesClass="community-badges"
        >
            <Fragment slot="description">
                Contrata a un especialista en Google Ads y PPC de Latinoamérica. Accede a perfiles auditados en la gestión de todo el ecosistema —Search, Shopping, Display, YouTube Ads y Performance Max— dedicados exclusivamente a optimizar tu ROAS.
            </Fragment>
        </LeadHeroSection>

      <div class="fade-in-section">
			<QueEsServicioSection
				title="Pasa de acumular clics a captar leads cualificados apoyándote en expertos en Google Ads"
				highlightWord="expertos en Google Ads"
				description="Incorporar especialistas en Google Ads en nómina local dispara tus costes operativos antes de encender la primera campaña. Por eso, te facilitamos la incorporación de estrategas senior de LATAM habituados a exprimir presupuestos bajo un control estricto del Coste por Adquisición (CPA)."
				imageSrc="/img1-asistente.webp"
				imageAlt="Profesional trabajando"
				badgeText="Optimización de ROAS"
				quoteText="Mientras tu especialista in-house está enfocado en tu panel de pujas de Google, nosotros gestionamos la burocracia internacional mediante una sola factura mensual B2B. "
				checklistTitle="Checklist de ventajas operativas:"
				checklistItems={[
					"Optimización en tiempo real durante tu jornada comercial, apagando o encendiendo campañas al instante.",
					"Tarifa plana B2B: aumenta tu inversión en Google sin que te cobremos un porcentaje adicional por gestión.",
					"Sin ataduras: si el especialista Google Ads no alcanza el CPA objetivo, cancela sin indemnizaciones o gestiona un cambio del profesional."
				]}
				ctaText="Solicita perfiles de especialistas de Google Ads →"
				ctaHref="#"
				diffIcon=""
				diffTitle=""
				diffDescription="" 
			/>
		</div>

        <div class="fade-in-section">
            <ServicesSection
                title="De la auditoría inicial al ajuste de ROAS: el despliegue de <strong>tu especialista en Google Ads</strong>"
                description="Nuestros expertos en Google Ads se ocupan de la captación de pago: estructura de campañas, anuncios, segmentación, pujas, audiencias, feeds, medición y optimización del presupuesto."
                customClass="employer-use-cases"
                services={[
                    {
                        icon: "🎯",
                        title: "Captacion de leads B2B y B2C con Google Ads",
                        description:
                            "Configuración, lanzamiento y optimización de campañas orientadas a generación de oportunidades comerciales. Ideal para negocios B2B que necesiten reuniones, formularios o llamadas cualificadas.",
                        linkText: "",
                        href: "",
                        customIconBg: "transparent",
                        cardClass: "card-green",
                    },
                    {
                        icon: "🛒 ",
                        title: "Google Ads para eCommerce",
                        description:
                            "Gestión de campañas de Shopping, Search, Performance Max y remarketing para aumentar ventas, mejorar ROAS y escalar cuentas sin disparar el coste por adquisición.",
                        linkText: "",
                        href: "",
                        customIconBg: "transparent",
                        cardClass: "card-pink",
                    },
                    {
                        icon: "📈",
                        title: "Optimizacion de rendimiento y escalado",
                        description:
                            "Análisis profundo de términos de búsqueda, smart bidding, segmentación de audiencias y extensiones para eliminar la inversión ineficaz y maximizar las conversiones mes a mes.",
                        linkText: "",
                        href: "",
                        customIconBg: "transparent",
                        cardClass: "card-lime",
                    },
                    {
                        icon: "📊 ",
                        title: "Tracking, medicion y atribucion",
                        description:
                            "Configuración precisa de píxeles de conversión, Google Tag Manager (GTM), GA4 y eventos para asegurar que la toma de decisiones publicitarias esté basada en datos reales.",
                        linkText: "",
                        href: "",
                        customIconBg: "transparent",
                        cardClass: "card-purple",
                    },
                    {
                        icon: "🚀",
                        title: "Estrategia SEM y PPC para pymes",
                        description:
                            "Nuestros especialistas PPC y expertos SEM adaptan la estrategia al presupuesto y madurez de tu negocio, priorizando campanas con impacto comercial real.",
                        linkText: "",
                        href: "",
                        customIconBg: "transparent",
                        cardClass: "card-green",
                    },
                    {
                        icon: "💡",
                        title: "Campañas de alta intención de compra",
                        description:
                            "Arquitectura de campañas, investigación de keywords transaccionales (Search Intent) y redacción de copys persuasivos para interceptar demanda activa.",
                        linkText: "",
                        href: "",
                        customIconBg: "transparent",
                        cardClass: "card-pink",
                    },
                ]}
