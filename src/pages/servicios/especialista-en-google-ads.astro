                priceAmount="850€"
                pricePeriod="/ mes"
                features={[
                    "Creación, reestructuración y testeo A/B diario de anuncios.",
                    "Gestión proactiva de pujas, concordancias y listas negativas.",
                    "Gestión proactiva de pujas, concordancias y listas negativas.",
                    "Analítica GA4 y reporting mensual.",
                    "Blindaje contractual de tus accesos y cuentas."
                ]}
                ctaText="Solicitar propuesta"
                ctaHref="#"
                disclaimer="*Precios orientativos. El coste final depende del perfil, país y nivel de experiencia. Sin costes ocultos ni comisiones adicionales."
