                    },
                    {
                        title: "🛍️ Experto en Google Shopping y Performance Max",
                        description: "",
                        icon: "",
                        iconColor: "#3b76f6",
                        borderColorClass: "border-blue",
                        subtitle:
                            "Optimización de feeds de producto, Performance Max y campañas de Shopping para tiendas online. Especializado en mejorar ROAS y reducir CPA en cuentas de eCommerce.",
                        techStack: ["Shopping", "P.Max", "Merchant Center", "ROAS"],
                        buttonText: "Solicitar más información →",
                        buttonHref: "#",
                    },
                    {
                        title: "🖼️ Especialista en Display y Remarketing",
                        description: "",
                        icon: "",
                        iconColor: "#66FF99",
                        borderColorClass: "border-green",
                        subtitle:
                            "Creación de audiencias personalizadas, retargeting de carritos abandonados y dominio de la Display Network para impactar al usuario a lo largo de todo el customer journey.",
                        techStack: ["Display", "Remarketing", "Audiencias"],
                        buttonText: "Solicitar más información →",
                        buttonHref: "#",
                    },
                    {
                        title: "🎬 Especialista en YouTube Ads",
                        description: "",
                        icon: "",
                        iconColor: "#CCFF66",
                        borderColorClass: "border-yellow",
                        subtitle:
                            "Campañas de vídeo publicitario: TrueView, Bumper Ads y YouTube Discovery para generar demanda, reconocimiento de marca y captar audiencias en el mayor motor de vídeo del mundo.",
                        techStack: [
                            "YouTube",
                            "Vídeo Ads",
                            "Branding",
                        ],
                        buttonText: "Solicitar más información → ",
                        buttonHref: "#",
                    },
                    {
                        title: "⚙️ Especialista en Tracking y Medición",
