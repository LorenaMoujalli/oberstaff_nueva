                footerText="💡 Para posicionamiento orgánico accede a nuestro perfil:"
                footerLinkText=" contratar experto SEO →"
                footerLinkHref="#"
                roles={[
                    {
                        title: "🔍 Especialista Google Ads Search",
                        description: "",
                        icon: "",
                        iconColor: "#FF66CC",
                        borderColorClass: "border-pink",
                        subtitle:
                            "Perfil centrado en dominar la red de búsqueda, optimización del nivel de calidad (Quality Score), estrategias de pujas automatizadas y captación de leads con intención de compra.",
