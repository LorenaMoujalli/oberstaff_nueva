</style>

<script>
  // Validación de seguridad antes de cargar el resto de la lógica
  if (sessionStorage.getItem('isAdminLoggedIn') !== 'true') {
    window.location.href = '/registro-leads/login';
  }

  // @ts-ignore
  import html2pdf from 'html2pdf.js';
  declare let Swal: any;

  // Dashboard Logic
  interface Lead {
    id: number;
    timestamp: string;
    form_name: string;
    pais: string;
    data: any;
    parsedData: any;
    searchableText?: string;
  }

  let allLeads: Lead[] = [];
  let filteredLeads: Lead[] = [];
  
  // Pagination State
  let currentPage = 1;
  const itemsPerPage = 5;

  // DOM Elements
  const tbody = document.getElementById('leads-tbody') as HTMLElement;
  const tableShowingText = document.getElementById('table-showing-text') as HTMLElement;
  
  const statTotal = document.getElementById('stat-total') as HTMLElement;
  const statRecent = document.getElementById('stat-recent') as HTMLElement;
  const statCountries = document.getElementById('stat-countries') as HTMLElement;
  const statForms = document.getElementById('stat-forms') as HTMLElement;

  const filterSearch = document.getElementById('filter-search') as HTMLInputElement;
  const filterDate = document.getElementById('filter-date') as HTMLInputElement;
  const filterForm = document.getElementById('filter-form') as HTMLSelectElement;
  const filterCountry = document.getElementById('filter-country') as HTMLSelectElement;
  const btnClearFilters = document.getElementById('btn-clear-filters') as HTMLButtonElement;

  const btnExportPDF = document.getElementById('btn-export-pdf') as HTMLButtonElement;
  const btnExportExcel = document.getElementById('btn-export-excel') as HTMLButtonElement;
  const btnLogout = document.getElementById('btn-logout') as HTMLButtonElement;
  
  const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
  const pageInfo = document.getElementById('page-info') as HTMLElement;



  // Load leads from internal API with real-time support
  async function fetchLeads(silent = false) {
    if (!silent) showTableLoading();
    try {
      const response = await fetch('/api/leads-dashboard');
      if (!response.ok) throw new Error('Error al cargar leads');
      const data = await response.json();
      
      // Parse JSON data property if it is a string and compute search string
      const newLeads = data.map((lead: any) => {
        let parsedData: any = {};
        if (typeof lead.data === 'string') {
          try {
            parsedData = JSON.parse(lead.data);
          } catch(e) {
            parsedData = {};
          }
        } else {
          parsedData = lead.data || {};
        }
        
        // Dynamic search string pre-compiled in lowercase
        const searchableText = `${lead.id} ${lead.timestamp || ''} ${lead.form_name || ''} ${lead.pais || ''} ${JSON.stringify(parsedData)}`.toLowerCase();
        
        return {
          ...lead,
          parsedData,
          searchableText
        };
      });

      // Optimized check: only re-render table if data actually changed
      const hasChanged = allLeads.length !== newLeads.length || 
                         JSON.stringify(allLeads[0]) !== JSON.stringify(newLeads[0]);

      if (hasChanged || !silent) {
        allLeads = newLeads;
        populateFilterOptions();
        applyFilters();
        updateStats();
      }
    } catch (error) {
      console.error(error);
      if (!silent) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" class="text-center py-8 text-muted">
              <p>⚠️ No se pudieron obtener los datos. Asegúrate de que el servidor API esté corriendo.</p>
            </td>
          </tr>
        `;
      }
    }
  }

  function showTableLoading() {
    tbody.innerHTML = `
      <tr>
        <td colspan="6" class="text-center py-8">
          <div class="spinner"></div>
          <p class="mt-2 text-muted">Cargando base de datos de leads...</p>
        </td>
      </tr>
    `;
  }

  // Populate Filter Dropdowns dynamically
  function populateFilterOptions() {
    // Keep standard options
    filterForm.innerHTML = '<option value="all">Todos los formularios</option>';
    filterCountry.innerHTML = '<option value="all">Todos los países</option>';

    const forms = new Set<string>();
    const countries = new Set<string>();

    allLeads.forEach(lead => {
      if (lead.form_name) forms.add(lead.form_name);
      if (lead.pais) countries.add(lead.pais);
    });

    forms.forEach(form => {
      const opt = document.createElement('option');
      opt.value = form;
      opt.textContent = form;
      filterForm.appendChild(opt);
    });

    countries.forEach(country => {
      const opt = document.createElement('option');
      opt.value = country;
      opt.textContent = country;
      filterCountry.appendChild(opt);
    });
  }

  // Calculate and display quick stats
  function updateStats() {
    statTotal.textContent = allLeads.length.toString();

    // Recent in last 7 days
    const sevenDaysAgo = new Date();
    sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
    const recentLeads = allLeads.filter(lead => {
      if (!lead.timestamp) return false;
      const leadDate = new Date(lead.timestamp.replace(/-/g, '/')); // simple replace for browser compatibility
      return leadDate >= sevenDaysAgo;
    });
    statRecent.textContent = recentLeads.length.toString();

    // Unique countries
    const countries = new Set(allLeads.map(l => l.pais).filter(Boolean));
    statCountries.textContent = countries.size.toString();

    // Unique forms
    const forms = new Set(allLeads.map(l => l.form_name).filter(Boolean));
    statForms.textContent = forms.size.toString();
  }

  // Apply filters and updates Table
  function applyFilters() {
    const searchText = filterSearch.value.toLowerCase().trim();
    const selectedForm = filterForm.value;
    const selectedCountry = filterCountry.value;
    const selectedDate = filterDate.value; // Format: YYYY-MM-DD

    filteredLeads = allLeads.filter(lead => {
      // Search text match (ultra optimized using pre-computed searchableText string)
      let matchesSearch = true;
      if (searchText) {
        matchesSearch = lead.searchableText ? lead.searchableText.includes(searchText) : false;
      }

      // Date filter match (compares date part YYYY-MM-DD)
      let matchesDate = true;
      if (selectedDate) {
        matchesDate = lead.timestamp ? lead.timestamp.startsWith(selectedDate) : false;
      }

      // Form filter match
      const matchesForm = selectedForm === 'all' || lead.form_name === selectedForm;

      // Country filter match
      const matchesCountry = selectedCountry === 'all' || lead.pais === selectedCountry;

      return matchesSearch && matchesDate && matchesForm && matchesCountry;
    });

    currentPage = 1;
    renderTable();
  }

  // Friendly date formatter
  function formatDateFriendly(dateStr: string) {
    if (!dateStr) return 'N/A';
    try {
      const parts = dateStr.split(' ');
      const dateParts = parts[0].split('-');
      const year = dateParts[0];
      const monthNum = parseInt(dateParts[1]) - 1;
      const day = dateParts[2];
      const months = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
      return `${parseInt(day)} ${months[monthNum]} ${year}`;
    } catch (e) {
      return dateStr;
    }
  }

  // Render rows based on filters and pagination
  function renderTable() {
    tbody.innerHTML = '';
    
    if (filteredLeads.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="4" class="text-center py-8 text-muted">
            No se encontraron leads con los filtros actuales.
          </td>
        </tr>
      `;
      tableShowingText.textContent = 'Mostrando 0 de 0 leads';
      updatePaginationControls(0);
      return;
    }

    const startIndex = (currentPage - 1) * itemsPerPage;
    const endIndex = Math.min(startIndex + itemsPerPage, filteredLeads.length);
    const paginatedItems = filteredLeads.slice(startIndex, endIndex);

    tableShowingText.textContent = `Mostrando ${startIndex + 1}-${endIndex} de ${filteredLeads.length} leads`;

    paginatedItems.forEach(lead => {
      const tr = document.createElement('tr');
      
      const data = lead.parsedData;

      // Form name badge
      const formName = lead.form_name || 'LEAD';
      const badgeClass = formName.toUpperCase() === 'ADMIN' ? 'badge-blue' : 'badge-gray';

      // Date & Time (timestamp)
      const timestampText = lead.timestamp || 'N/A';

      // Expiration look for Country (Pais)
      let countryHtml = '';
      if (lead.pais) {
        countryHtml = `<span class="expiration-pill">${lead.pais}</span>`;
      } else {
        countryHtml = `<span class="expiration-pill">No especificado</span>`;
      }

      // Dynamic Data listing — Key: Value rows
      let dataSummary = '';
      Object.keys(data).forEach(key => {
        const val = data[key];
        const lowerKey = key.toLowerCase().trim();
        if (
          lowerKey === 'consentimiento sms' || 
          lowerKey === 'search' || 
          lowerKey === 'pais' || 
          lowerKey === 'origen formulario'
        ) {
          return;
        }
        if (val !== undefined && val !== null && val !== '') {
          dataSummary += `
            <div class="data-row">
              <span class="data-key">${key}:</span>
              <span class="data-val">${typeof val === 'object' ? JSON.stringify(val) : val}</span>
            </div>`;
        }
      });
      if (!dataSummary) {
        dataSummary = '<span class="text-muted">Sin datos</span>';
      }

      tr.innerHTML = `
        <td><span class="lead-timestamp">${timestampText}</span></td>
        <td><span class="${badgeClass}">${formName}</span></td>
        <td>${countryHtml}</td>
        <td>
          <div class="lead-summary-data">
            ${dataSummary}
          </div>
        </td>
        <td>
          <button class="btn-delete-row" data-id="${lead.id}" title="Eliminar Registro">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
          </button>
        </td>
      `;

      tbody.appendChild(tr);
    });

    document.querySelectorAll('.btn-delete-row').forEach(button => {
      button.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = button.getAttribute('data-id');
        if (!id) return;

        Swal.fire({
          title: '¿Estás seguro?',
          text: "Esta acción eliminará el registro de forma permanente de la base de datos.",
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#ef4444',
          cancelButtonColor: '#475569',
          confirmButtonText: 'Sí, eliminar',
          cancelButtonText: 'Cancelar',
          background: '#ffffff',
          color: '#1e293b'
        }).then(async (result: any) => {
          if (result.isConfirmed) {
            try {
              const res = await fetch('/api/eliminar-lead', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: parseInt(id) })
              });
              const data = await res.json();
              if (data.success) {
                Swal.fire({
                  title: '¡Eliminado!',
                  text: 'El registro ha sido borrado.',
                  icon: 'success',
                  timer: 1500,
                  showConfirmButton: false
                });
                await fetchLeads();
              } else {
                Swal.fire('Error', 'No se pudo eliminar el registro.', 'error');
              }
            } catch (err) {
              console.error('Error al borrar:', err);
              Swal.fire('Error', 'Hubo un error de conexión al procesar la solicitud.', 'error');
            }
          }
        });
      });
    });

    updatePaginationControls(filteredLeads.length);
  }

  function updatePaginationControls(totalItems: number) {
    const totalPages = Math.ceil(totalItems / itemsPerPage) || 1;
    pageInfo.textContent = `Página ${currentPage} de ${totalPages}`;
    btnPrev.disabled = currentPage === 1;
    btnNext.disabled = currentPage === totalPages || totalItems === 0;
  }

  // Detail Modal Logic


  // Generate Excel (.xls HTML table wrapper) with custom filtered leads list
  function generateExcel(leadsList: Lead[]) {
    let html = `
      <html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40">
      <head>
        <meta charset="utf-8" />
        <!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Leads</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]-->
      </head>
      <body>
        <table border="1">
          <thead>
            <tr style="background-color: #f8fafc; font-weight: bold; height: 30px;">
              <th style="background-color: #f1f5f9;">FECHA Y HORA DE REGISTRO</th>
              <th style="background-color: #f1f5f9;">FORMULARIO</th>
              <th style="background-color: #f1f5f9;">PAÍS</th>
              <th style="background-color: #f1f5f9;">DATOS</th>
            </tr>
          </thead>
          <tbody>
    `;

    leadsList.forEach(lead => {
      let dataText = '';
      const data = lead.parsedData;
      Object.keys(data).forEach(key => {
        const val = data[key];
        const lowerKey = key.toLowerCase().trim();
        if (
          lowerKey === 'consentimiento sms' || 
          lowerKey === 'search' || 
          lowerKey === 'pais' || 
          lowerKey === 'origen formulario'
        ) {
          return;
        }
        if (val !== undefined && val !== null && val !== '') {
          dataText += `${key}: ${typeof val === 'object' ? JSON.stringify(val) : val}\n`;
        }
      });

      html += `
        <tr>
          <td>${lead.timestamp || 'N/A'}</td>
          <td>${lead.form_name || 'LEAD'}</td>
          <td>${lead.pais || 'No especificado'}</td>
          <td style="white-space: pre-wrap; vertical-align: top;">${dataText || 'Sin datos'}</td>
        </tr>
      `;
    });

    html += `
          </tbody>
        </table>
      </body>
      </html>
    `;

    const blob = new Blob([html], { type: 'application/vnd.ms-excel;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `leads_oberstaff_${new Date().toISOString().split('T')[0]}.xls`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }

  // Generate PDF using html2pdf with custom filtered leads list
  function generatePDF(leadsList: Lead[]) {
    const element = document.createElement('div');
    element.style.padding = '35px';
    element.style.fontFamily = "'Plus Jakarta Sans', sans-serif";
    element.style.color = '#1e293b';

    let rowsHtml = '';
    leadsList.forEach(lead => {
      let dataText = '';
      const data = lead.parsedData;
      Object.keys(data).forEach(key => {
        const val = data[key];
        const lowerKey = key.toLowerCase().trim();
        if (
          lowerKey === 'consentimiento sms' || 
          lowerKey === 'search' || 
          lowerKey === 'pais' || 
          lowerKey === 'origen formulario'
        ) {
          return;
        }
        if (val !== undefined && val !== null && val !== '') {
          dataText += `<div style="margin-bottom: 2px;"><strong>${key}:</strong> ${typeof val === 'object' ? JSON.stringify(val) : val}</div>`;
        }
      });

      rowsHtml += `
        <tr style="border-bottom: 1px solid #cbd5e1; font-size: 11px; page-break-inside: avoid;">
          <td style="padding: 10px; border-right: 1px solid #cbd5e1; vertical-align: top;">${lead.timestamp || 'N/A'}</td>
          <td style="padding: 10px; border-right: 1px solid #cbd5e1; vertical-align: top; font-weight: 600; color: #1e293b;">${lead.form_name || 'LEAD'}</td>
          <td style="padding: 10px; border-right: 1px solid #cbd5e1; vertical-align: top;">${lead.pais || 'No especificado'}</td>
          <td style="padding: 10px; vertical-align: top; line-height: 1.4;">${dataText || 'Sin datos'}</td>
        </tr>
      `;
    });

    element.innerHTML = `
      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #cbd5e1; padding-bottom: 15px; margin-bottom: 20px;">
        <img src="/logo-oberstaff.webp" style="height: 38px; width: auto;" />
        <span style="font-size: 12px; color: #475569; font-weight: 600;">Generado el: ${new Date().toLocaleString('es-ES')}</span>
      </div>
      <div style="display: flex; justify-content: space-between; font-size: 16px; color: #0f172a; margin-bottom: 20px; font-weight: 800; letter-spacing: -0.02em;">
        <span>Registro de leads</span>
      </div>
      <table style="width: 100%; border-collapse: collapse; border: 1px solid #cbd5e1; background-color: #ffffff;">
        <thead>
          <tr style="background-color: #f8fafc; border-bottom: 2px solid #cbd5e1; font-size: 11px; font-weight: bold; text-align: left;">
            <th style="padding: 10px; border-right: 1px solid #cbd5e1; color: #475569; width: 150px;">FECHA Y HORA</th>
            <th style="padding: 10px; border-right: 1px solid #cbd5e1; color: #475569; width: 180px;">FORMULARIO</th>
            <th style="padding: 10px; border-right: 1px solid #cbd5e1; color: #475569; width: 130px;">PAÍS</th>
            <th style="padding: 10px; color: #475569;">DATOS</th>
          </tr>
        </thead>
        <tbody>
          ${rowsHtml}
        </tbody>
      </table>
    `;

    const opt = {
      margin: [10, 10],
      filename: `leads_oberstaff_${new Date().toISOString().split('T')[0]}.pdf`,
      image: { type: 'jpeg', quality: 0.98 },
      html2canvas: { scale: 2, useCORS: true },
      jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' }
    };

    html2pdf().from(element).set(opt).save();
  }

  // Show SweetAlert2 Modal to dynamically select filters for export
  function showExportModal(type: 'pdf' | 'excel') {
    if (allLeads.length === 0) {
      Swal.fire('Atención', 'No hay registros en la base de datos para exportar.', 'info');
      return;
    }

    // Get unique forms and countries dynamically from allLeads
    const uniqueForms = Array.from(new Set(allLeads.map(l => l.form_name).filter(Boolean))).sort();
    const uniqueCountries = Array.from(new Set(allLeads.map(l => l.pais).filter(Boolean))).sort();

    let formOptions = '<option value="all">Todos los formularios</option>';
    uniqueForms.forEach(f => {
      const displayForm = f.length > 28 ? f.substring(0, 25) + '...' : f;
      formOptions += `<option value="${f}">${displayForm}</option>`;
    });

    let countryOptions = '<option value="all">Todos los países</option>';
    uniqueCountries.forEach(c => {
      const displayCountry = c.length > 28 ? c.substring(0, 25) + '...' : c;
      countryOptions += `<option value="${c}">${displayCountry}</option>`;
    });

    Swal.fire({
      title: `Exportar a ${type.toUpperCase()}`,
      html: `
        <div style="text-align: left; font-family: 'Plus Jakarta Sans', sans-serif;">
          <p style="font-size: 13px; color: #64748b; margin-bottom: 16px; line-height: 1.4;">Filtra opcionalmente los datos que deseas incluir en el archivo de descarga. Deja en blanco o "Todos" para omitir el filtro.</p>
          
          <div style="margin-bottom: 12px;">
            <label style="display: block; font-size: 12px; font-weight: bold; color: #475569; margin-bottom: 5px;">Filtrar por Fecha</label>
            <input type="date" id="swal-export-date" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 13px; color: #1e293b;" />
          </div>

          <div style="margin-bottom: 12px;">
            <label style="display: block; font-size: 12px; font-weight: bold; color: #475569; margin-bottom: 5px;">Filtrar por Formulario</label>
            <select id="swal-export-form" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 13px; color: #1e293b; background-color: #ffffff;">
              ${formOptions}
            </select>
          </div>

          <div style="margin-bottom: 15px;">
            <label style="display: block; font-size: 12px; font-weight: bold; color: #475569; margin-bottom: 5px;">Filtrar por País</label>
            <select id="swal-export-country" style="width: 100%; box-sizing: border-box; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 13px; color: #1e293b; background-color: #ffffff;">
              ${countryOptions}
            </select>
          </div>
        </div>
      `,
      showCancelButton: true,
      confirmButtonText: 'Descargar archivo',
      cancelButtonText: 'Cancelar',
      confirmButtonColor: type === 'pdf' ? '#d9261c' : '#16a34a',
      cancelButtonColor: '#475569',
      background: '#ffffff',
      color: '#1e293b',
      preConfirm: () => {
        return {
          date: (document.getElementById('swal-export-date') as HTMLInputElement).value,
          form: (document.getElementById('swal-export-form') as HTMLSelectElement).value,
          country: (document.getElementById('swal-export-country') as HTMLSelectElement).value,
        };
      }
    }).then((result: any) => {
      if (result.isConfirmed) {
        const filters = result.value;

        // Apply filters only for export target
        const exportLeads = allLeads.filter(lead => {
          let matchesDate = true;
          if (filters.date) {
            matchesDate = lead.timestamp ? lead.timestamp.startsWith(filters.date) : false;
          }
          const matchesForm = filters.form === 'all' || lead.form_name === filters.form;
          const matchesCountry = filters.country === 'all' || lead.pais === filters.country;
          return matchesDate && matchesForm && matchesCountry;
        });

        if (exportLeads.length === 0) {
          Swal.fire('Atención', 'No hay registros que coincidan con los filtros seleccionados.', 'info');
          return;
        }

        if (type === 'pdf') {
          generatePDF(exportLeads);
        } else {
          generateExcel(exportLeads);
        }
      }
    });
  }

  // Event Listeners
  filterSearch.addEventListener('input', () => applyFilters());
  filterDate.addEventListener('change', () => applyFilters());
  filterForm.addEventListener('change', () => applyFilters());
  filterCountry.addEventListener('change', () => applyFilters());
  
  btnClearFilters.addEventListener('click', () => {
    filterSearch.value = '';
    filterDate.value = '';
    filterForm.value = 'all';
    filterCountry.value = 'all';
    applyFilters();
  });

  btnExportPDF.addEventListener('click', () => showExportModal('pdf'));
  btnExportExcel.addEventListener('click', () => showExportModal('excel'));

  btnLogout.addEventListener('click', () => {
    sessionStorage.removeItem('isAdminLoggedIn');
    window.location.replace('/registro-leads/login');
  });

  btnPrev.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderTable();
    }
  });

  btnNext.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredLeads.length / itemsPerPage);
    if (currentPage < totalPages) {
      currentPage++;
      renderTable();
    }
  });

  // Initial Fetch & Real-time polling (every 5 seconds)
  fetchLeads();
  setInterval(() => {
    fetchLeads(true);
  }, 5000);
</script>

