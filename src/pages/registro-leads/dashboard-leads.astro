    .controls-bar {
      flex-wrap: wrap;
    }
    .controls-bar .search-input-wrapper {
      flex: 1 1 100%;
    }
    .controls-filters {
      flex: 1 1 100%;
      flex-wrap: wrap;
    }
    .controls-filters select,
    .controls-filters input[type="date"] {
      flex: 1 1 auto;
      width: 100% !important;
    }
