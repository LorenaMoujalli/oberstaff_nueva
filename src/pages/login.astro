---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Iniciar Sesión | Agent">
	<main>
		<div class="header-container">
			<h1 class="main-title">¡Hola de nuevo!</h1>
			<p class="subtitle">Accede para gestionar tu agente de Inteligencia Artificial y potenciar tus resultados.</p>
		</div>

		<div class="card">
			<h2>Inicio de sesión</h2>
			
			<form>
				<div class="form-group">
					<label for="email">Email</label>
					<input type="email" id="email" name="email" placeholder="" />
				</div>

				<div class="form-group">
					<label for="password">Contraseña</label>
					<input type="password" id="password" name="password" placeholder="" />
				</div>

				<div class="forgot-password">
					<a href="#">¿Olvidaste tu contraseña?</a>
				</div>

				<button type="submit" class="submit-btn" onclick="event.preventDefault(); window.location.href='/'">Ingresar</button>
			</form>

			<div class="register-link">
				<p>¿Todavía no tienes una cuenta? <a href="/register"><strong>Regístrate</strong></a></p>
			</div>
		</div>
	</main>
</Layout>

<style>
	main {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		width: 100%;
	}

	.header-container {
		text-align: center;
		margin-bottom: 2.5rem;
		max-width: 600px;
	}

	.main-title {
		font-size: 2.5rem;
		font-weight: 800;
		color: #ff69b4; /* Hot pink approximation */
		margin-bottom: 0.5rem;
	}

	.subtitle {
		font-size: 1rem;
		color: #333;
		line-height: 1.5;
	}

	.card {
		background: white;
		padding: 3rem;
		border-radius: 20px;
		width: 100%;
		max-width: 450px;
		box-shadow: 0 10px 25px rgba(255, 105, 180, 0.1); /* Soft pinkish shadow */
		text-align: center;
	}

	h2 {
		font-size: 1.8rem;
		margin-bottom: 2rem;
		font-weight: 600;
		color: #1a1a1a;
	}

	.form-group {
		margin-bottom: 1.5rem;
		text-align: left;
	}

	label {
		display: block;
		margin-bottom: 0.5rem;
		font-weight: 600;
		font-size: 0.9rem;
		color: #333;
	}

	input {
		width: 100%;
		padding: 0.8rem 1rem;
		border-radius: 8px;
		border: none;
		background-color: #f3f4f6;
		font-size: 1rem;
		outline: none;
		transition: background-color 0.2s;
	}

	input:focus {
		background-color: #e5e7eb;
	}

	.forgot-password {
		text-align: right;
		margin-bottom: 2rem;
	}

	.forgot-password a {
		font-size: 0.85rem;
		font-style: italic;
		color: #4a5568;
	}

	.submit-btn {
		width: 100%;
		padding: 0.8rem;
		background-color: #2d2d2d;
		color: white;
		border: none;
		border-radius: 50px;
		font-size: 1rem;
		font-weight: 500;
		margin-bottom: 2rem;
		transition: background-color 0.2s, transform 0.1s;
	}

	.submit-btn:hover {
		background-color: #000;
		transform: translateY(-1px);
	}

	.register-link p {
		font-size: 0.9rem;
		color: #4a5568;
	}

	.register-link strong {
		color: #1a1a1a;
		text-decoration: underline;
	}
</style>
