---
import DashboardLayoutPr from "../../layouts/DashboardLayoutPr.astro";

const API_URL = "http://wordpress-efas5wlyxu4ne04hxofezoa9.109.199.104.87.nip.io/wp-json/wp/v2/posts?_embed&per_page=100";
let posts: any[] = [];

const isDev = import.meta.env.DEV;
const cacheTTL = 5 * 60 * 1000; // 5 minutes
const now = Date.now();

const shouldFetch = 
    !(globalThis as any).cachedWordPressRawPosts ||
    !(globalThis as any).lastCacheTime ||
    (isDev && now - (globalThis as any).lastCacheTime > cacheTTL);

if (shouldFetch) {
    try {
        const response = await fetch(API_URL);
        if (response.ok) {
            (globalThis as any).cachedWordPressRawPosts = await response.json();
            (globalThis as any).lastCacheTime = now;
        }
    } catch (e) {
        console.error("Error fetching posts from WordPress:", e);
    }
}

posts = ((globalThis as any).cachedWordPressRawPosts || []).filter((post: any) => post.status === "publish");

// Helpers
function cleanHTML(htmlString: string) {
    if (!htmlString) return "";
    // Remove HTML tags
    let clean = htmlString.replace(/<\/?[^>]+(>|$)/g, "");
    
    // Decode HTML entities
    const entities: { [key: string]: string } = {
        "&nbsp;": " ",
        "&#8211;": "—",
        "&#8216;": "‘",
        "&#8217;": "’",
        "&#8220;": "“",
        "&#8221;": "”",
        "&amp;": "&",
        "&lt;": "<",
        "&gt;": ">",
        "&quot;": '"',
        "&#039;": "'",
        "&aacute;": "á",
        "&eacute;": "é",
        "&iacute;": "í",
        "&oacute;": "ó",
        "&uacute;": "ú",
        "&Ntilde;": "Ñ",
        "&ntilde;": "ñ",
        "&iquest;": "¿",
        "&iexcl;": "¡",
        "&#8230;": "..."
    };
    
    Object.keys(entities).forEach((entity) => {
        clean = clean.replace(new RegExp(entity, "g"), entities[entity]);
    });
    
    // Remove any leftover &...; entities
    clean = clean.replace(/&[a-zA-Z0-9#]+;/g, "");
    
    return clean.trim();
}

function formatDate(dateString: string) {
    if (!dateString) return "";
    const date = new Date(dateString);
    return date.toLocaleDateString("es-ES", {
        year: "numeric",
        month: "long",
        day: "numeric",
    });
}

function getFeaturedImage(post: any) {
    if (
        post._embedded &&
        post._embedded["wp:featuredmedia"] &&
        post._embedded["wp:featuredmedia"][0]
    ) {
        return post._embedded["wp:featuredmedia"][0].source_url || "/Portada-de-blog.webp";
    }
    return "/Portada-de-blog.webp";
}
---

<DashboardLayoutPr title="Blog de Talento Remoto | Oberstaff">
    <link rel="canonical" href="https://oberstaff.com/blog/" slot="head" />
    <div class="blog-main-content">
        <div class="blog-container">
            {posts.length === 0 ? (
                <div class="no-posts">
                    <p>No se encontraron artículos publicados en este momento.</p>
                </div>
            ) : (
                <div class="articles-list" id="articles-list">
                    {posts.map((post: any) => {
                        const image = getFeaturedImage(post);
                        const title = cleanHTML(post.title?.rendered);
                        const rawExcerpt = cleanHTML(post.excerpt?.rendered);
                        const excerpt = rawExcerpt.length > 180 ? rawExcerpt.substring(0, 180) + "..." : rawExcerpt;
                        const date = formatDate(post.date);

                        return (
                            <article class="article-card" data-slug={post.slug}>
                                <div class="article-image-wrapper">
                                    <img src={image} alt={title} loading="lazy" />
                                </div>
                                <div class="article-info">
                                    <div class="article-meta">
                                        <time datetime={post.date}>{date}</time>
                                    </div>
                                    <h2 class="article-title">{title}</h2>
                                    <p class="article-excerpt">{excerpt}</p>
                                    <a href={`/pr/blog/${post.slug}`} class="read-more-btn">
                                        Leer artículo
                                        <iconify-icon icon="solar:arrow-right-linear" class="arrow-icon"></iconify-icon>
                                    </a>
                                </div>
                            </article>
                        );
                    })}
                </div>

                <div class="pagination-container" id="pagination-container">
                    <button class="pagination-btn prev-btn" id="prev-page-btn" aria-label="Página anterior">
                        <iconify-icon icon="solar:alt-arrow-left-linear"></iconify-icon>
                        <span>Anterior</span>
                    </button>
                    <div class="pagination-pages" id="pagination-pages-list">
                        <!-- Generado dinámicamente por JS -->
                    </div>
                    <button class="pagination-btn next-btn" id="next-page-btn" aria-label="Página siguiente">
                        <span>Siguiente</span>
                        <iconify-icon icon="solar:alt-arrow-right-linear"></iconify-icon>
                    </button>
                </div>
            )}
        </div>
    </div>
</DashboardLayoutPr>

<script>
    function initPagination() {
        const postsPerPage = 5;
        const articles = Array.from(document.querySelectorAll('.article-card'));
        const totalPosts = articles.length;
        if (totalPosts === 0) return;

        const totalPages = Math.ceil(totalPosts / postsPerPage);
        let currentPage = 1;

        const prevBtn = document.getElementById('prev-page-btn');
        const nextBtn = document.getElementById('next-page-btn');
        const pagesList = document.getElementById('pagination-pages-list');

        // Leer página desde la URL si existe (ej: ?page=2)
        const urlParams = new URLSearchParams(window.location.search);
        const pageParam = parseInt(urlParams.get('page') || '1');
        if (pageParam && pageParam >= 1 && pageParam <= totalPages) {
            currentPage = pageParam;
        }

        function updatePage(pageNum: number, isInitial = false) {
            currentPage = pageNum;
            
            // Actualizar URL sin recargar la página
            const newUrl = new URL(window.location.href);
            newUrl.searchParams.set('page', currentPage.toString());
            window.history.pushState({ page: currentPage }, '', newUrl.toString());

            // Mostrar/Ocultar artículos correspondientes
            const startIndex = (currentPage - 1) * postsPerPage;
            const endIndex = startIndex + postsPerPage;

            articles.forEach((article, index) => {
                const htmlArticle = article as HTMLElement;
                if (index >= startIndex && index < endIndex) {
                    htmlArticle.style.display = 'flex';
                } else {
                    htmlArticle.style.display = 'none';
                }
            });

            // Desplazar arriba con suavidad solo si no es la carga inicial
            if (!isInitial) {
                const articlesList = document.getElementById('articles-list');
                if (articlesList) {
                    const yOffset = -120; // Compensación por el menú flotante
                    const y = articlesList.getBoundingClientRect().top + window.pageYOffset + yOffset;
                    window.scrollTo({ top: y, behavior: 'smooth' });
                } else {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }
            }

            renderPaginationControls();
        }

        function renderPaginationControls() {
            if (!pagesList) return;
            pagesList.innerHTML = '';

            // Habilitar/Deshabilitar anterior/siguiente
            if (prevBtn) {
                if (currentPage === 1) {
                    prevBtn.setAttribute('disabled', 'true');
                } else {
                    prevBtn.removeAttribute('disabled');
                }
            }

            if (nextBtn) {
                if (currentPage === totalPages) {
                    nextBtn.setAttribute('disabled', 'true');
                } else {
                    nextBtn.removeAttribute('disabled');
                }
            }

            // Generar botones numéricos
            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement('button');
                btn.className = `page-num-btn ${i === currentPage ? 'active' : ''}`;
                btn.innerText = i.toString();
                btn.addEventListener('click', () => updatePage(i));
                pagesList.appendChild(btn);
            }
        }

        // Listeners de botones
        prevBtn?.addEventListener('click', () => {
            if (currentPage > 1) {
                updatePage(currentPage - 1);
            }
        });

        nextBtn?.addEventListener('click', () => {
            if (currentPage < totalPages) {
                updatePage(currentPage + 1);
            }
        });

        // Inicializar
        updatePage(currentPage, true);
    }

    // Inicializar con eventos de Astro o carga tradicional
    document.addEventListener('astro:page-load', initPagination);
    document.addEventListener('DOMContentLoaded', initPagination);
</script>

<style>
    /* Hero section */
    .blog-hero {
        background: radial-gradient(circle at 10% 20%, rgba(102, 99, 253, 0.05) 0%, rgba(255, 102, 204, 0.05) 90.1%), #0d0d0d;
        color: #ffffff;
        padding: 90px 20px 70px;
        text-align: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .hero-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .category-badge {
        font-family: "Poppins", sans-serif;
        background-color: rgba(102, 99, 253, 0.15);
        color: #6663fd;
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
        display: inline-block;
        margin-bottom: 25px;
        border: 1px solid rgba(102, 99, 253, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .blog-hero h1 {
        font-family: "Montserrat", sans-serif;
        font-size: 44px;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 20px;
        color: #ffffff;
        letter-spacing: -1px;
    }

    .blog-hero h1 strong {
        color: #ff66cc;
    }

    .blog-hero p {
        font-family: "Poppins", sans-serif;
        font-size: 16px;
        color: #a0a0a0;
        line-height: 1.6;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Main Content */
    .blog-main-content {
        background-color: #fafafc;
        padding: 80px 20px;
        flex: 1;
    }

    .blog-container {
        max-width: 1000px;
        margin: 0 auto;
    }

    .no-posts {
        text-align: center;
        padding: 60px 20px;
        background: #ffffff;
        border-radius: 20px;
        border: 1px solid #f0f0f5;
        color: #666;
        font-family: "Poppins", sans-serif;
    }

    /* List and Cards */
    .articles-list {
        display: flex;
        flex-direction: column;
        gap: 40px;
        margin-bottom: 60px;
    }

    .article-card {
        display: flex;
        background: #ffffff;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #e9eaf0;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .article-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(102, 99, 253, 0.08);
        border-color: rgba(102, 99, 253, 0.2);
    }

    .article-image-wrapper {
        flex: 0 0 45%;
        max-width: 450px;
        position: relative;
        overflow: hidden;
        background-color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .article-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transition: transform 0.5s ease;
    }

    .article-card:hover .article-image-wrapper img {
        transform: scale(1.05);
    }

    .article-info {
        flex: 1;
        padding: 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding-left: 15px;
    }

    .article-meta {
        margin-bottom: 12px;
    }

    .article-meta time {
        font-family: "Poppins", sans-serif;
        font-size: 13px;
        color: #888899;
        font-weight: 500;
    }

    .article-title {
        font-family: "Montserrat", sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: #1a1a1a;
        line-height: 1.35;
        margin-bottom: 15px;
        transition: color 0.3s ease;
    }

    .article-card:hover .article-title {
        color: #6663fd;
    }

    .article-excerpt {
        font-family: "Poppins", sans-serif;
        font-size: 15px;
        color: #555566;
        line-height: 1.6;
        margin-bottom: 25px;
    }

    .read-more-btn {
        font-family: "Poppins", sans-serif;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #6663fd;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        transition: gap 0.3s ease, color 0.3s ease;
        align-self: flex-start;
    }

    .read-more-btn:hover {
        color: #ff66cc;
        gap: 12px;
    }

    .arrow-icon {
        font-size: 16px;
    }

    /* Pagination */
    .pagination-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
        margin-top: 40px;
    }

    .pagination-btn {
        font-family: "Poppins", sans-serif;
        background: #ffffff;
        border: 1px solid #e9eaf0;
        padding: 10px 20px;
        border-radius: 50px;
        color: #555566;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        transition: all 0.3s ease;
    }

    .pagination-btn:hover:not(:disabled) {
        background: #6663fd;
        color: #ffffff;
        border-color: #6663fd;
    }

    .pagination-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        background: #f0f0f5;
        color: #9999aa;
    }

    .pagination-pages {
        display: flex;
        gap: 8px;
    }

    :global(.page-num-btn) {
        font-family: "Poppins", sans-serif;
        background: #ffffff;
        border: 1px solid #e9eaf0;
        width: 42px;
        height: 42px;
        border-radius: 50%;
        color: #555566;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
        transition: all 0.3s ease;
    }

    :global(.page-num-btn:hover) {
        background: rgba(102, 99, 253, 0.1);
        color: #6663fd;
        border-color: rgba(102, 99, 253, 0.3);
    }

    :global(.page-num-btn.active) {
        background: #6663fd;
        color: #ffffff;
        border-color: #6663fd;
    }

    @media (max-width: 900px) {
        .blog-hero {
            padding: 70px 20px 50px;
        }

        .blog-hero h1 {
            font-size: 32px;
        }

        .article-info {
            padding: 30px;
        }
    }

    @media (max-width: 768px) {
        .blog-main-content {
            padding: 50px 15px;
        }

        .article-card {
            flex-direction: column;
        }

        .article-image-wrapper {
            flex: 0 0 240px;
            width: 100%;
        }

        .article-info {
            padding: 25px;
        }

        .article-title {
            font-size: 20px;
        }

        .pagination-btn span {
            display: none;
        }
    }
</style>
