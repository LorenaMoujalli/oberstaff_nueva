const ogImage = "Outsourcing-de-Personal.webp";

const faqsList = [
    {
        question:
            "¿Qué es el outsourcing de personal con talento de Sudamérica?",
        answers: [
            "Es el servicio con el que <span style='font-weight: 800; color: #1b1b1b;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> centraliza la selección, incorporación y administración de perfiles comerciales, administrativos, de mercadeo y de soporte en Sudamérica. Tu empresa define la necesidad y nosotros estructuramos la operación para reducir carga interna y sostener continuidad.",
        ],
    },
    {
        question: "¿Qué tipo de perfiles cubre este servicio?",
        answers: [
            "Cubre perfiles comerciales, administrativos, de mercadeo, soporte al cliente, back office, operaciones, finanzas y contenido. Si necesitas desarrolladores, QA, DevOps o roles de data, el modelo adecuado es Staff Augmentation.",
        ],
    },
    {
        question: "¿Qué incluye el outsourcing de selección de personal?",
        answers: [
            "Incluye búsqueda de talento en Sudamérica, evaluación inicial, entrevistas por competencias, validación del perfil y presentación de candidatos finalistas. Tu empresa toma la decisión final antes de la incorporación.",
        ],
    },
    {
        question:
            "¿<span style='font-weight: 800; color: #1b1b1b;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> funciona como outsourcing company para empresas en Puerto Rico?",
        answers: [
            "Sí. <span style='font-weight: 800; color: #1b1b1b;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> funciona como una outsourcing company enfocada en conectar empresas de Puerto Rico con talento remoto de Sudamérica, centralizando selección, contratación, administración y seguimiento mensual del servicio.",
        ],
    },
    {
        question: "¿Qué significa outsourcing PR dentro de este servicio?",
        answers: [
            "En este contexto, outsourcing PR es una solución de externalización pensada para empresas ubicadas en Puerto Rico que quieren cubrir funciones operativas con talento de Sudamérica, sin asumir toda la carga administrativa de la contratación local.",
        ],
    },
    {
        question:
            "¿Qué incluyen los outsourcing HR services de <span style='font-weight: 800; color: #1b1b1b;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span>?",
        answers: [
            "Nuestros outsourcing HR services incluyen búsqueda, preselección, incorporación, administración mensual, coordinación de pagos y gestión operativa del personal externalizado. El objetivo es liberar tiempo de Recursos Humanos y reducir complejidad interna.",
        ],
    },
    {
        question:
            "¿Cuál es la diferencia entre outsourcing HR, EOR y Staff Augmentation?",
        answers: [
            "El outsourcing HR delega procesos de selección, contratación y administración de personal. El EOR permite contratar empleados en otro país sin abrir entidad local. El Staff Augmentation suma talento especializado, normalmente técnico, bajo tu dirección diaria.",
        ],
    },
    {
        question: "¿Cuánto tarda la incorporación?",
        answers: [
            "Depende del perfil, la seniority y la disponibilidad del mercado. En funciones administrativas, de mercadeo, ventas y soporte, el proceso suele avanzar con agilidad una vez validado el candidato y completada la documentación.",
        ],
    },
    {
        question: "¿Qué pasa si el volumen de mi operación baja?",
        answers: [
            "El modelo es flexible. Ajustas el tamaño del equipo externalizado según temporadas de alta o baja demanda, sin añadir procesos internos complejos ni asumir pasivos laborales por desvinculación."
        ]
    }
];
