import ProcessOberstaff from "../../../components/process/ProcessOberstaff.astro";
import ProfilesSection from "../../../components/profiles/ProfilesSection.astro";
const ogImage = "Contractor Of Record.webp"; 

const faqsList = [
	{
		question: "¿Qué significa Contractor of Record?",
		answers: ["Contractor of Record es un servicio para formalizar, administrar y pagar a profesionales independientes en otros países. Tu empresa dirige el proyecto y los entregables; nosotros gestionamos el contrato, la documentación, los pagos internacionales y la administración operativa."]
	},
	{
		question: "¿Qué permite un remote contractor para empresas en Puerto Rico?",
		answers: ["Permite colaborar con talento remoto en Sudamérica sin que tu empresa abra una entidad legal en el país del profesional. Es útil para proyectos, campañas, sprints, consultorías o necesidades temporales de talento especializado."]
	},
	{
		question: "¿Qué diferencia hay entre contratar un contratista en Puerto Rico y usar Contractor of Record?",
		answers: ["Si buscas un contratista en Puerto Rico, piensas en talento externo. Pero si ese talento está en Sudamérica, debes resolver contratos, pagos internacionales y documentación. El Contractor of Record centraliza esa operación para que la colaboración sea más simple."]
	},
	{
		question: "¿Un agent of record es lo mismo que un COR?",
		answers: ["No siempre. El término agent of record se usa en otros contextos, como seguros o representación comercial. Para contratar profesionales remotos internacionales, el término correcto es Contractor of Record. Si dudas qué modelo encaja, nuestro equipo te orienta sin compromiso."]
	},
	{
		question: "¿Qué pasa si el proyecto cambia de alcance o se alarga?",
		answers: ["Oberstaff. acompaña renovaciones, ampliaciones, sustituciones y cambios de alcance. Solo debes comunicarlo a tu gestor de cuenta para actualizar la estructura operativa correspondiente."]
	}
];
