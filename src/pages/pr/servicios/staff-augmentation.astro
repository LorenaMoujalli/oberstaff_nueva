const faqsList = [
    {
        question:
            "¿Qué es el IT staff augmentation?",
        answers: [
            "El staff augmentation IT es un modelo en el que incorporas un profesional técnico de Sudamérica directamente en tu equipo de producto o desarrollo. Tú le asignas tareas, diriges su trabajo y evalúas su rendimiento como a cualquier miembro interno.",
        ],
    },
    {
        question: "¿Qué perfiles encajan mejor en este modelo?",
        answers: [
            "Desarrolladores, QA, ingeniería de datos, DevOps, UX/UI y otros perfiles vinculados a producto y tecnología.",
        ],
    },
    {
        question: "¿Cuánto tarda la incorporación?",
        answers: [
            "Depende del perfil, pero el proceso está diseñado para acelerar la presentación y la entrada de talento técnico ya validado.",
        ],
    },
    {
        question:
            "¿El profesional trabaja bajo mi dirección?",
        answers: [
            "Sí. Tu empresa define tareas, prioridades, herramientas, estándares y criterios de calidad. <span style='font-weight: 800; color: #1b1b1b;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> acompaña la parte operativa y administrativa para que tu equipo se enfoque en la ejecución.",
        ],
    },
    {
        question:
            "¿Cómo funciona la facturación para empresas en Puerto Rico?",
        answers: [
            "La facturación se realiza en dólares (USD), lo que simplifica la contabilidad de empresas puertorriqueñas bajo regulación fiscal de EE. UU. Recibes una única factura mensual por todos los profesionales contratados.",
        ],
    },
    {
        question: "¿Qué incluyen los servicios de nearshore staff augmentation con <span style='font-weight: 800; color: #1b1b1b;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span>?",
        answers: [
            "Incluyen la búsqueda, validación e incorporación de talento IT de Sudamérica a tu equipo. <span style='font-weight: 800; color: #1b1b1b;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> presenta perfiles alineados con tu necesidad y facilita la contratación para que mantengas el control operativo del trabajo diario.",
        ],
    }
];
