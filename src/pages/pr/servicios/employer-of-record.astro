const ogImage = "Employer Of Record.webp"; 

const faqsList = [
	{
		question: "¿Qué hace exactamente un Employer of Record?",
		answers: ["Un Employer of Record contrata legalmente al profesional en su país y administra nómina, beneficios, documentación y cumplimiento. Tu empresa dirige tareas, metas y desempeño."]
	},
	{
		question: "¿Cuándo conviene usar EOR services en lugar de contratistas independientes?",
		answers: ["Cuando el puesto exige dedicación exclusiva, horarios fijos y una relación laboral estable. Mantenerlos como contratistas foráneos te expone a contingencias con el IRS y Hacienda."]
	},
	{
		question: "¿Mi empresa en Puerto Rico tiene que registrarse en Sudamérica?",
		answers: ["No. Con el employer of record Puerto Rico, <span style='font-weight: 800; color: #1b1b1b;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> usa su infraestructura local para contratar, así que no abres una entidad propia en cada país de Sudamérica."]
	},
	{
		question: "¿Puedo contratar profesionales en varios países de América del Sur a la vez?",
		answers: ["Sí. Puedes tener profesionales en distintos países y centralizar la administración con <span style='font-weight: 800; color: #1b1b1b;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> Así mantienes una operación más simple para tu empresa en Puerto Rico."]
	},
	{
		question: "¿Cuánto tiempo toma integrar a un nuevo profesional con el EOR?",
		answers: ["Suele completarse en pocos días hábiles, frente a los 3–6 meses que toma registrar una LLC o corporación en el extranjero por tu cuenta."]
	},
	{
		question: "¿Qué sucede si necesito terminar el contrato de un empleado?",
		answers: ["<span style='font-weight: 800; color: #1b1b1b;'>Oberstaff</span><span style='color: #FF66CC; font-weight: 900;'>.</span> lidera todo el proceso de desvinculación y asegura el cumplimiento de las leyes de liquidación locales, aislando a tu empresa de exposición legal."]
	},
	{
		question: "¿Exigen compromisos a largo plazo para usar el EOR service?",
		answers: ["No exigimos permanencia mínima. Si tu negocio en la Isla necesita pivotar, ajustas tu plantilla internacional sin penalizaciones por cancelación."]
	}
];
