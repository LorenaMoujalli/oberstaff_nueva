---
import DashboardLayoutContactoPr from "../../layouts/DashboardLayoutContactoPr.astro";
//import HeroContactoSection from "../../components/hero-contacto/HeroContactoSection.astro";
//import FormContactoSection from "../../components/form-contacto/FormContactoSection.astro";
//import ChannelsSection from "../../components/canales-contacto/ChannelsSection.astro";
import LeadHeroSection from "../../components/community-manager/LeadHeroSection.astro";
import QueEsServicioSection from "../../components/QueEsServicio/QueEsServicioSection.astro";
import VisionMisionSection from "../../components/vision-mision-contacto/VisionMisionSection.astro";
import VisionMisionCard from "../../components/vision-mision-contacto/VisionMisionCard.astro";
import FAQSection from "../../components/faq-servicios/FAQSection-quienes-somos.astro";
const ogImage = "Quienes somos Oberstaff.webp";

const faqs = [
    {
        question: "¿Qué es <strong style='color: #1B1B1B; font-weight: 800;'>Oberstaff</strong><span style='color: #ff66cc; font-weight: 800;'>.</span>?",
        answers: ["Es una plataforma integral y partner estratégico que conecta corporaciones y pymes con profesionales evaluados en América del Sur bajo modalidades de trabajo remoto claras, seguras y altamente eficientes."]
    },
    {
        question: "¿Cuál es el beneficio de <strong style='color: #1B1B1B; font-weight: 800;'>Oberstaff</strong><span style='color: #ff66cc; font-weight: 800;'>.</span> para un patrono en Puerto Rico?", 
        answers: ["Permite mitigar la escasez de talento local, optimizar los costos operacionales y de nómina, y delegar la carga administrativa del reclutamiento, asegurando una integración fluida con los objetivos de la empresa."]
    },
    {
        question: "¿Cómo se manejan los pagos y la facturación?",
        answers: ["Simplificamos todo el proceso. Tu empresa recibe una sola factura comercial transparente en dólares (USD), lo que elimina complicaciones fiscales internacionales, burocracia de nómina y reduce significativamente los sobrecostos laborales."]
    },
    {
        question: "¿Qué diferencia a <strong style='color: #1B1B1B; font-weight: 800;'>Oberstaff</strong><span style='color: #ff66cc; font-weight: 800;'>.</span> de una agencia de empleo tradicional?",
        answers: ["No nos limitamos a enviar hojas de vida (resumes). Evaluamos con filtros rigurosos y acompañamos de manera activa la relación laboral y el cumplimiento normativo para garantizar que el rendimiento y la cultura organizacional se mantengan alineados a largo plazo."]
    }
];
---

