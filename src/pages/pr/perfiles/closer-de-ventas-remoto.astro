const ogImage = "Contratar closer de ventas.webp";

const faqs = [
    {
        question: "¿Qué ocurre si el closer no mejora la tasa de cierre?",
        answers: [
            "Si en el período inicial el perfil no se alinea con los KPIs acordados, solicitas revisión, reemplazo o cancelación con 30 días de preaviso, sin indemnizaciones ni compromisos laborales con el profesional.",
        ],
    },
    {
        question: "¿El closer puede adaptarse a mi CRM y mis scripts de venta?",
        answers: [
            "Sí. Trabajan con HubSpot, Salesforce, Pipedrive, Notion, Slack, Zoom o Google Meet. Se integran a tu metodología y documentan cada avance.",
        ],
    },
    {
        question: "¿Qué diferencia al modelo <strong>Oberstaff<span style='color: #ff62c4;'>.</span></strong> de buscar freelance closer en marketplaces?",
        answers: [
            "Un freelance en marketplaces sirve para proyectos puntuales, pero depende de perfiles autodeclarados y poca integración. Con <strong>Oberstaff<span style='color: #ff62c4;'>.</span></strong> recibes closers de ventas con dedicación estable que trabajan dentro de tu CRM, bajo NDA, con continuidad en el seguimiento.",
        ],
    },
    {
        question: "¿Quién entrega los leads y quién hace el seguimiento?",
        answers: [
            "Depende de tu modelo. Algunas empresas ya generan oportunidades; otras necesitan que el closer tome llamadas entrantes y reactive propuestas abiertas. Se define antes de incorporar el perfil.",
        ],
    },
    {
        question: "¿Es útil para empresas que buscan closer de ventas en Puerto Rico?",
        answers: [
            "Sí, para negocios con leads calificados, demos, propuestas abiertas o ciclos que requieren seguimiento profesional. La clave es elegir un perfil con experiencia en tu ticket y sector.",
        ],
    },
];
