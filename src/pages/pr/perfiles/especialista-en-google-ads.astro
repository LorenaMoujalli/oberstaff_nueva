const ogImage = "Especialista-en-Google-Ads.webp";

const faqs = [
    {
        question: "¿Qué nivel de permisos necesita el especialista en mi cuenta de Google Ads?",
        answers: [
            "Normalmente requiere acceso estándar o administrador a Google Ads, más permisos en GA4 y Google Tag Manager si configura conversiones, eventos o etiquetas. El nivel exacto se define según el alcance del trabajo y tus políticas de seguridad.",
        ],
    },
    {
        question: "¿Cómo superviso los cambios que hace en mi inversión publicitaria?",
        answers: [
            "El profesional trabaja dentro de tus herramientas. Google Ads guarda un historial de cambios para revisar ajustes de presupuesto, keywords, anuncios, pujas, activos y conversiones. Además, puedes pedir reportes periódicos con acciones y resultados.",
        ],
    },
    {
        question: "¿Qué ocurre si las campañas no son rentables en los primeros meses?",
        answers: [
            "Toda cuenta requiere una fase inicial de diagnóstico, aprendizaje y optimización antes de un rendimiento estable. En ese periodo el especialista analiza CPA, ROAS, conversiones, calidad del tráfico y eficiencia del presupuesto.",
            "Si la estrategia no se alinea con los objetivos comerciales de tu organización, puedes pedir una revisión del plan, el cambio del perfil asignado o la cancelación con 30 días de preaviso.",
        ],
    },
    {
        question: "¿A quién le pago el presupuesto de los anuncios?",
        answers: [
            "La inversión publicitaria se paga directo a Google Ads desde tu cuenta, tarjeta o método de facturación. <span style='font-weight: 700; color: #1b1b1b;'>Oberstaff<span style='color: #ff66cc;'>.</span></span> solo factura el fee mensual del especialista y el servicio de contratación remota.",
        ],
    },
    {
        question: "¿Me conviene un especialista dedicado o una agencia Google Ads en Puerto Rico?",
        answers: [
            "Si necesitas estrategia de marca amplia, una agencia puede servir. Si tu prioridad es operación diaria, control de CPA, seguimiento técnico, limpieza de cuenta y foco exclusivo, un especialista dedicado ofrece más integración y velocidad de optimización.",
        ],
    },
    {
        question: "¿Es mejor un freelance Google Ads o un especialista dedicado?",
        answers: [
            "Un freelance Google Ads specialist sirve para proyectos puntuales. Para optimización diaria, acceso ordenado al MCC, reporting y coordinación con ventas, un especialista dedicado ofrece más continuidad operativa.",
        ],
    },
    {
        question: "¿Puedo solicitar un especialista en Google Ads certificado?",
        answers: [
            "Sí. Puedes pedir un profesional certificado, con experiencia en Search, Performance Max, Shopping, medición y optimización de CPA/ROAS. La certificación ayuda, pero se valida junto con experiencia real, criterio analítico y manejo de presupuesto.",
        ],
    },
    {
        question: "¿Existe riesgo de impuestos o contingencias laborales por el experto Google Ads?",
        answers: [
            "Ninguno. Contratamos al talento bajo la legislación de su país de origen. Tu departamento de contabilidad solo registra una factura de servicios profesionales internacionales.",
        ],
    },
];
