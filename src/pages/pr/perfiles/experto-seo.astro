const ogImage = "experto-seo-pr.webp";

const faqs = [
    {
        question:
            "¿Quién paga herramientas como Semrush, Ahrefs o Screaming Frog?",
        answers: [
            "Lo ideal es que tu empresa provea los accesos a sus cuentas corporativas de Ahrefs, Semrush, Screaming Frog o Sistrix. Así el historial de auditoría SEO, los proyectos guardados y las keywords quedan bajo tu propiedad y control.",
        ],
    },
    {
        question: "¿En cuánto tiempo puedo ver resultados SEO?",
        answers: [
            "Las correcciones de errores técnicos críticos pueden mostrar impacto en semanas. Una estrategia integral con clústeres de contenido, on-page y backlinks suele madurar entre 3 y 6 meses, según competencia y punto de partida.",
        ],
    },
    {
        question: "¿El experto SEO implementa cambios directamente?",
        answers: [
            "Sí, dentro de los accesos que le otorgues. Puede aplicar cambios on-page, técnicos y de contenido en tu CMS, o entregar las indicaciones a tu equipo de desarrollo cuando el despliegue lo requiera.",
        ],
    },
    {
        question: "¿Qué accesos debo entregar?",
        answers: [
            "Solo los necesarios: Google Search Console, GA4, Google Tag Manager, CMS, herramientas SEO y dashboards. Recomendamos permisos controlados, no accesos de propietario absoluto.",
        ],
    },
    {
        question: "¿Qué pasa si el perfil no se ajusta a lo que necesito?",
        answers: [
            "Si el perfil no encaja técnica o estratégicamente, solicitas un cambio por un especialista con mayor seniority o una especialidad más alineada con tu proyecto.",
        ],
    },
    {
        question:
            "¿Cuál es la diferencia entre SEO en Puerto Rico y SEO local Puerto Rico?",
        answers: [
            "SEO en Puerto Rico abarca la estrategia orgánica completa para empresas que venden en la Isla o desde la Isla: técnica, contenidos, autoridad y analítica. SEO local Puerto Rico se enfoca en búsquedas por zona: Google Business Profile, reseñas, mapas y señales geográficas.",
        ],
    },
    {
        question:
            "¿Puedo contratar un SEO para un proyecto local en San Juan, Bayamón, Carolina o Ponce?",
        answers: [
            "Sí. Puedes contratar un especialista SEO con foco local para trabajar Google Business Profile, reseñas, landings geolocalizadas y búsquedas comerciales dentro de Puerto Rico.",
