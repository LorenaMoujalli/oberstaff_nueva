const ogImage = "Contratar editor de videos.webp";

const faqs = [
    {
        question: "¿Quién asume el costo de las licencias de software o bancos de música?",
        answers: [
            "El editor cuenta con su propia estación y hardware para procesar archivos de alta resolución. Para garantizar el control y la seguridad, sugerimos que tu empresa provea el acceso (asiento de usuario) a Adobe Creative Cloud y a las plataformas de música de stock que uses (Epidemic Sound, Envato o Artlist).",
        ],
    },
    {
        question: "¿Qué pasa si el estilo o el ritmo del editor no se adapta a la marca?",
        answers: [
            "La edición es una disciplina subjetiva. Si en las primeras asignaciones el editor no captura tu identidad o tono, tienes flexibilidad total: cancelas con 30 días de aviso, sin penalidades, o pides la transición inmediata a otro perfil pre-evaluado.",
        ],
    },
    {
        question: "¿Los editores dominan herramientas en la nube como Frame.io o Drive?",
        answers: [
            "Sí. Nuestros editores de video profesional trabajan a diario con Frame.io para aprobación de cortes, Google Drive, Dropbox, Notion, Slack y Asana, e integran de inmediato a tus canales de comunicación.",
        ],
    },
    {
        question: "¿Qué relación patronal o laboral se genera con el editor a través de <strong style='font-weight: 700;'>Oberstaff<span style='color: #ff62c4;'>.</span></strong>?",
        answers: [
            "Ninguna directa a nivel legal o de nómina. Tú llevas la dirección creativa y las prioridades diarias; <strong style='font-weight: 700;'>Oberstaff<span style='color: #ff62c4;'>.</span></strong> administra el contrato, el cumplimiento fiscal internacional y los pagos. Tu negocio solo procesa una factura B2B.",
        ],
    },
    {
        question: "¿Puedo pedir videos para redes, YouTube, ads y contenido corporativo al mismo editor?",
        answers: [
            "Sí, si el perfil tiene experiencia en esos formatos y el volumen cabe en su jornada. En la selección definimos el contenido prioritario para no sobrecargar el rol.",
        ],
    },
    {
        question: "¿Cómo se protege la propiedad intelectual de mis videos?",
        answers: [
            "Trabajamos con acuerdos de confidencialidad, control de accesos y cesión de derechos sobre el material editado. Brutos, archivos fuente, versiones editables y exports quedan bajo propiedad de tu empresa.",
        ],
    },
    {
        question: "¿Cuándo conviene contratar editor de videos en lugar de pagar piezas sueltas?",
        answers: [
            "Conviene cuando publicas contenido cada semana, necesitas respuesta rápida, manejas varias campañas o quieres una línea visual consistente. Ahí un perfil dedicado rinde más que pagar por pieza, esperar disponibilidad o renegociar cada corrección.",
        ],
    },
];
