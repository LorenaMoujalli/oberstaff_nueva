const ogImage = "Contratar Copywriter.webp";

const faqs = [
    {
        question: "¿Qué diferencia hay entre un copywriter y un redactor de contenidos o SEO?",
        answers: [
            "El redactor de contenidos informa, educa o posiciona en buscadores. El copywriter mueve una acción concreta: convertir visitas, responder objeciones, conseguir leads o empujar una venta. Conviven, pero no buscan lo mismo.",
        ],
    },
    {
        question: "¿Puede adaptarse al tono del mercado puertorriqueño y a mi sector?",
        answers: [
            "Sí. Priorizamos profesionales con capacidad de modular registro, referencias, claridad y estilo según tu público. Si necesitas copywriting para empresas en Puerto Rico, ese ajuste cultural y comercial forma parte del filtro.",
        ],
    },
    {
        question: "¿Qué pasa si ya tengo diseñador, SEO, paid media o SDRs?",
        answers: [
            "Es el escenario ideal: el copywriter potencia el trabajo de esos equipos y garantiza que los mensajes se alineen con la pauta, el diseño y los guiones de prospección. El copy de alta conversión brilla cuando tráfico y mensaje operan en sintonía.",
        ],
    },
    {
        question: "¿Qué ocurre si el estilo de redacción no encaja con nuestra marca?",
        answers: [
            "El encaje de voz es crítico. Si en los primeros textos notas que el tono no se alinea con tu identidad, solicitas revisión, pides un reemplazo o cancelas el servicio con 30 días de aviso.",
        ],
    },
    {
        question: "¿Pueden ayudarnos si vendemos en Puerto Rico y también en Estados Unidos?",
        answers: [
            "Sí. Priorizamos perfiles con sensibilidad para adaptar mensajes a audiencias locales y a campañas bilingües. La clave es definir desde el inicio qué piezas son para Puerto Rico, cuáles para otros mercados y qué nivel de adaptación necesita cada una.",
        ],
    },
    {
        question: "¿También apoyan campañas en inglés tipo copywriting service o copywriter advertising?",
        answers: [
            "Sí. Cuando tu operación requiere piezas bilingües, filtramos perfiles capaces de trabajar el español comercial y coordinar versiones en inglés para anuncios, emails, landings o materiales de ventas, manteniendo la intención local y evitando traducciones literales.",
        ],
    },
];
