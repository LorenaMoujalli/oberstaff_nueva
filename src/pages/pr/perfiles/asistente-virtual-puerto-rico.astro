const ogImage = "Contratar Asistente Virtual.webp";

const faqs = [
    {
        question: "¿Cuánto cuesta contratar un asistente virtual Puerto Rico?",
        answers: [
            "Un asistente administrativo local sube rápido al sumar salario, nómina, beneficios y reclutamiento (fácilmente $1,800–$3,000/mes). Con nosotros accedes al mismo nivel en formato asistente virtual online desde $820/mes.",
        ],
    },
    {
        question:
            "¿Cuándo conviene contratar un asistente virtual administrativo?",
        answers: [
            "Cuando tu equipo directivo o de ventas necesita apoyo constante para no frenar la operación, pero no quieres los altos costos fijos ni la rigidez de una contratación local.",
        ],
    },
    {
        question: "¿Este recurso dará soporte a otras empresas a la vez?",
        answers: [
            "No. El modelo de virtual assistant puerto rico es de asignación exclusiva: jornada completa, integrado en tus canales y enfocado 100% en tus KPIs.",
        ],
    },
    {
        question: "¿Qué flexibilidad tengo si cambian mis necesidades?",
        answers: [
            "Total. El contrato B2B para integrar un asistente virtual remoto permite cancelar con 30 días de preaviso, protegiéndote de reclamos laborales locales.",
        ],
    },
    {
        question:
            '¿Cómo garantiza <strong class="brand-oberstaff">Oberstaff<span class="brand-dot">.</span></strong> la calidad del talento?',
        answers: [
            "Aplicamos un embudo de tres fases para validar cada virtual assistant: test de ofimática, evaluación psicométrica y entrevista final con nuestro equipo de Recursos Humanos.",
        ],
    },
];
