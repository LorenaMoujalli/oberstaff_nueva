const ogImage = "Contratar Contable.webp";

const faqs = [
    {
        question:
            "¿Cómo elimina <strong style='font-weight: 700;'>Oberstaff<span style='color: #ff62c4;'>.</span></strong> el riesgo de clasificación incorrecta de contratistas?",
        answers: [
            "Contratar directo a un freelancer en Sudamérica que trabaje a jornada completa para ti expone al negocio a reclamos y multas por tratarlo como contratista cuando opera como empleado. Con nuestro modelo, contratamos al contable remoto legalmente en su país de origen. Tu negocio queda aislado y solo paga una factura B2B.",
        ],
    },
    {
        question:
            "¿Puede un contable de Sudamérica trabajar con los sistemas financieros que se usan en Puerto Rico?",
        answers: [
            "Sí. La formación contable en América del Sur comparte los fundamentos internacionales y de partida doble que se aplican universalmente. La adaptación a la terminología americana y a las planillas corporativas es rápida porque la base técnica y analítica ya es sólida.",
        ],
    },
    {
        question:
            "¿El contable remoto puede manejar información de IVU y SURI?",
        answers: [
            "Puede apoyar en la organización operativa de documentos, reportes de ventas, conciliaciones, facturas y soportes. La radicación, validación o interpretación contributiva debe alinearse con el CPA o especialista local.",
        ],
    },
    {
        question:
            "¿Qué diferencia hay entre un contador freelance remoto y el modelo <strong style='font-weight: 700;'>Oberstaff<span style='color: #ff62c4;'>.</span></strong>?",
        answers: [
            "Un contador freelance remoto resuelve tareas puntuales, pero suele exigir que tu empresa asuma la búsqueda, validación, acuerdos, seguimiento y reemplazo. <strong style='font-weight: 700;'>Oberstaff<span style='color: #ff62c4;'>.</span></strong> centraliza selección, contratación, administración, acompañamiento y continuidad operativa.",
        ],
    },
    {
        question:
            "¿Qué confidencialidad existe sobre la facturación y los datos financieros?",
        answers: [
            "Antes de iniciar, el talento trabaja bajo acuerdos de confidencialidad y protocolos de acceso. Recomendamos cuentas corporativas, permisos por rol, autenticación de dos factores y trazabilidad dentro de tus herramientas.",
        ],
    },
    {
        question: "¿Quién gestiona ausencias o incidencias del profesional?",
        answers: [
            "<strong style='font-weight: 700;'>Oberstaff<span style='color: #ff62c4;'>.</span></strong> acompaña la operación y activa un protocolo de seguimiento o reemplazo si el perfil no cumple lo acordado. El objetivo es proteger la continuidad de tus cierres, conciliaciones y reportes.",
        ],
    },
    {
        question: "¿De qué países son los contables remotos?",
        answers: [
            "Reclutamos talento financiero principalmente en Sudamérica —Colombia, Argentina, Venezuela, Chile y Perú— y también en México, priorizando experiencia, comunicación, disciplina contable, dominio de herramientas y compatibilidad horaria.",
        ],
    },
