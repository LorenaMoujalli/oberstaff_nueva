const ogImage = "Contratar community manager.webp";

const faqs = [
    {
        question: "¿El CM trabajará con cuentas de otras empresas al mismo tiempo?",
        answers: ["No. Tu profesional está asignado 100 % en exclusiva a tu marca, trabajando únicamente en tu calendario editorial y analizando a tus competidores."]
    },
    {
        question: "¿Puede un CM de Sudamérica gestionar mi comunidad en inglés y español?",
        answers: ["Sí. Muchos perfiles tienen nivel B2-C1 de inglés escrito. Indícalo en el brief y lo filtramos desde la primera terna de candidatos."]
    },
    {
        question: '¿Qué diferencia hay entre un community manager freelance y el modelo <span class="brand-oberstaff">Oberstaff<span class="brand-dot">.</span></span>?',
        answers: ['El community manager freelance suele trabajar por proyecto o por horas, con disponibilidad variable. Con <span class="brand-oberstaff">Oberstaff<span class="brand-dot">.</span></span>, el perfil se integra de forma dedicada, con evaluación previa, más continuidad y soporte administrativo.']
    },
    {
        question: "¿Cuándo conviene contratar un community manager?",
        answers: ["Conviene cuando tu empresa en Puerto Rico necesita presencia constante en redes, responder a su comunidad en tiempo real y publicar con regularidad, sin cargar esa tarea sobre el equipo interno. Un perfil remoto especializado profesionaliza el manejo de redes y trabaja alineado al horario AST."]
    },
    {
        question: "¿Qué pasa si el perfil no se adapta a nuestra voz de marca?",
        answers: ["Puedes cancelar el servicio con 30 días de preaviso, sin indemnizaciones ni pleitos, o solicitar un reemplazo inmediato del profesional."]
    },
    {
        question: "¿De qué países provienen los perfiles?",
        answers: ["Reclutamos perfiles de comunicación, mercadeo y social media en Sudamérica —Colombia, Argentina, Perú, Venezuela— y también en México, mercados con talento digital competitivo."]
    },
    {
        question: "¿Cómo validan las competencias técnicas?",
        answers: ["Los candidatos pasan por revisión de experiencia, entrevistas, pruebas técnicas, análisis de criterio comunicacional y validación de herramientas antes de presentarse a tu empresa."]
    }
];
