const ogImage = "Contratar diseñador gráfico.webp";

const faqs = [
    {
        question: "¿Quién asume el costo de las licencias de Adobe Creative Cloud?",
        answers: ["El diseñador tiene su propia estación y equipo. Para que retengas el control de los archivos fuente, accesos e historial, recomendamos asignarle un usuario (seat) en tu plan corporativo de Adobe o la herramienta que uses."]
    },
    {
        question: "¿Qué flexibilidad tengo si la línea estética no cumple mis expectativas?",
        answers: ["En diseño remoto, la afinidad visual es clave. Si el estilo no encaja con tus brand guidelines, cancelas con 30 días de preaviso, sin penalidades. También gestionamos el reemplazo por un perfil con otro enfoque, más corporativo o más disruptivo."]
    },
    {
        question: "¿El diseñador usará nuestras plataformas de gestión de proyectos?",
        answers: ["Sí. Se acopla a tu cultura como uno más del equipo y usa las herramientas que ya tengas (Asana, Trello, Notion, ClickUp, Jira, Slack o Teams), guardando a diario los editables en tus repositorios."]
    },
    {
        question: "¿Garantizan la exclusividad y confidencialidad de nuestras campañas en desarrollo?",
        answers: ["Sí. El diseñador dedica toda su jornada en exclusiva a tu marca y, antes de empezar, se firman NDA estrictos respaldados por nuestro equipo legal. Tu estrategia e información quedan protegidas."]
    }
];
