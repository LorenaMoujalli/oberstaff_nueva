---
import DashboardLayoutContacto from "../../layouts/DashboardLayoutContacto.astro";
//import HeroContactoSection from "../../components/hero-contacto/HeroContactoSection.astro";
//import FormContactoSection from "../../components/form-contacto/FormContactoSection.astro";
//import ChannelsSection from "../../components/canales-contacto/ChannelsSection.astro";
import LeadHeroSection from "../../components/community-manager/LeadHeroSection.astro";
import QueEsServicioSection from "../../components/QueEsServicio/QueEsServicioSection.astro";
import VisionMisionSection from "../../components/vision-mision-contacto/VisionMisionSection.astro";
import VisionMisionCard from "../../components/vision-mision-contacto/VisionMisionCard.astro";
import FAQSection from "../../components/faq-servicios/FAQSection-quienes-somos.astro";
---

<DashboardLayoutContacto
    title="Conoce Oberstaff | Un puente de talento"
    description="Descubre el propósito de Oberstaff y la visión que nos mueve: conectar empresas españolas con profesionales de LATAM mediante trabajo remoto estructurado."
>
    <link rel="canonical" href="https://www.oberstaff.com/quienes-somos" slot="head" />
    <script slot="head" type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@graph": [
                {
                    "@type": "AboutPage",
                    "@id": "https://www.oberstaff.com/quienes-somos#webpage",
                    "url": "https://www.oberstaff.com/quienes-somos",
                    "name": "Conoce Oberstaff | Un puente de talento",
                    "description": "Descubre el propósito de Oberstaff y la visión que nos mueve: conectar empresas españolas con profesionales de LATAM mediante trabajo remoto estructurado.",
                    "inLanguage": "es-ES",
                    "isPartOf": {
                        "@id": "https://www.oberstaff.com/#website"
                    },
                    "publisher": {
                        "@id": "https://www.oberstaff.com/#organization"
                    },
                    "about": {
                        "@id": "https://www.oberstaff.com/#organization"
                    },
                    "mainEntity": {
                        "@id": "https://www.oberstaff.com/#organization"
                    },
                    "audience": {
                        "@type": "BusinessAudience",
                        "audienceType": "Empresas españolas que buscan contratar, externalizar o incorporar talento remoto en LATAM mediante modelos estructurados",
                        "geographicArea": {
                            "@type": "Country",
                            "name": "España"
                        }
                    },
                    "breadcrumb": {
                        "@id": "https://www.oberstaff.com/quienes-somos#breadcrumb"
                    },
                    "mentions": [
                        {
                            "@id": "https://www.oberstaff.com/quienes-somos#identity"
                        },
                        {
                            "@id": "https://www.oberstaff.com/quienes-somos#purpose"
                        },
                        {
                            "@id": "https://www.oberstaff.com/quienes-somos#trust"
                        },
                        {
                            "@id": "https://www.oberstaff.com/quienes-somos#faq"
                        }
                    ]
                },
                {
                    "@type": "Organization",
                    "@id": "https://www.oberstaff.com/#organization",
                    "name": "Oberstaff",
                    "url": "https://www.oberstaff.com",
                    "description": "Oberstaff conecta empresas españolas con profesionales preparados de LATAM mediante modelos de trabajo remoto claros, estructurados y eficientes.",
                    "slogan": "Un puente entre empresas y talento con propósito.",
                    "foundingDate": "2017",
                    "founder": {
                        "@type": "Person",
                        "name": "Edgardo Vázquez",
                        "url": "https://www.linkedin.com/in/edgardomvazquez/"
                    },
                    "areaServed": [
                        {
                            "@type": "Country",
                            "name": "España"
                        },
                        {
                            "@type": "Country",
                            "name": "Colombia"
                        },
                        {
                            "@type": "Country",
                            "name": "México"
                        },
                        {
                            "@type": "Country",
                            "name": "Argentina"
                        },
                        {
                            "@type": "Country",
                            "name": "Chile"
                        },
                        {
                            "@type": "Country",
                            "name": "Perú"
                        },
                        {
                            "@type": "Country",
                            "name": "Venezuela"
                        },
                        {
                            "@type": "Country",
                            "name": "Ecuador"
                        },
                        {
                            "@type": "Country",
                            "name": "Uruguay"
                        },
                        {
                            "@type": "Country",
                            "name": "Panamá"
                        },
                        {
                            "@type": "Country",
                            "name": "Paraguay"
                        }
                    ],
                    "knowsAbout": [
                        "Contratación de talento remoto en LATAM",
                        "Trabajo remoto estructurado",
                        "Employer of Record",
                        "Outsourcing de Personal",
                        "Staff Augmentation",
                        "Contractor of Record",
                        "Gestión de talento remoto",
                        "Contratación internacional",
                        "Modelos de trabajo remoto para empresas españolas",
                        "Talento profesional de Latinoamérica"
                    ],
                    "sameAs": [
                        "https://www.linkedin.com/company/oberstaff",
                        "https://www.instagram.com/oberstaff"
                    ]
                },
                {
                    "@type": "ItemList",
                    "@id": "https://www.oberstaff.com/quienes-somos#identity",
                    "name": "Identidad de Oberstaff",
                    "description": "Elementos principales que explican qué es Oberstaff, por qué nació y cómo conecta empresas españolas con talento de LATAM.",
                    "itemListElement": [
                        {
                            "@type": "ListItem",
                            "position": 1,
                            "name": "Qué es Oberstaff",
                            "description": "Oberstaff es una empresa que conecta compañías españolas con profesionales preparados de LATAM mediante modelos de trabajo remoto claros, estructurados y eficientes."
                        },
                        {
                            "@type": "ListItem",
                            "position": 2,
                            "name": "Por qué nació Oberstaff",
                            "description": "Oberstaff surge al observar una brecha entre empresas que necesitan crecer con agilidad sin aumentar su carga operativa y profesionales capaces que pueden aportar valor desde nuevas geografías de trabajo."
                        },
                        {
                            "@type": "ListItem",
                            "position": 3,
                            "name": "Quiénes somos",
                            "description": "Fundada en 2017 por Edgardo Vázquez, Oberstaff conecta necesidades empresariales cuidando la claridad del modelo, la responsabilidad operativa, la continuidad de la relación y la experiencia de ambas partes."
                        }
                    ]
                },
                {
                    "@type": "ItemList",
                    "@id": "https://www.oberstaff.com/quienes-somos#purpose",
                    "name": "Propósito, misión y visión de Oberstaff",
                    "description": "Principios que explican el propósito institucional de Oberstaff y su visión sobre el trabajo remoto entre España y LATAM.",
                    "itemListElement": [
                        {
                            "@type": "ListItem",
                            "position": 1,
                            "name": "Propósito",
                            "description": "Construir una forma de trabajo remoto más clara, organizada y sostenible para que empresas españolas y profesionales de LATAM colaboren con estructura, confianza y objetivos compartidos."
                        },
                        {
                            "@type": "ListItem",
                            "position": 2,
                            "name": "Misión",
                            "description": "Hacer que el trabajo remoto entre empresas y profesionales funcione mejor, con más claridad, más confianza y más sentido humano."
                        },
                        {
                            "@type": "ListItem",
                            "position": 3,
                            "name": "Visión",
                            "description": "Impulsar un futuro donde las empresas construyen equipos con menos barreras y más inteligencia operativa, sin que la ubicación limite la oportunidad."
                        },
                        {
                            "@type": "ListItem",
                            "position": 4,
                            "name": "Modelo de trabajo",
                            "description": "Oberstaff entiende que el trabajo remoto necesita procesos claros, comunicación responsable y acompañamiento real."
                        }
                    ]
                },
                {
                    "@type": "ItemList",
                    "@id": "https://www.oberstaff.com/quienes-somos#trust",
                    "name": "Principios de confianza de Oberstaff",
                    "description": "Pilares que resumen el enfoque institucional de Oberstaff.",
                    "itemListElement": [
                        {
                            "@type": "ListItem",
                            "position": 1,
                            "name": "Talento de LATAM para España"
                        },
                        {
                            "@type": "ListItem",
                            "position": 2,
                            "name": "Estructura y confianza"
                        },
                        {
                            "@type": "ListItem",
                            "position": 3,
                            "name": "Relaciones a largo plazo"
                        }
                    ]
                },
                {
                    "@type": "FAQPage",
                    "@id": "https://www.oberstaff.com/quienes-somos#faq",
                    "mainEntity": [
                        {
                            "@type": "Question",
                            "name": "¿Qué es Oberstaff?",
                            "acceptedAnswer": {
                                "@type": "Answer",
                                "text": "Oberstaff es una empresa que conecta empresas españolas con profesionales preparados de LATAM mediante modelos de trabajo remoto claros, estructurados y eficientes."
                            }
                        },
                        {
                            "@type": "Question",
                            "name": "¿Cuál es el propósito de Oberstaff?",
                            "acceptedAnswer": {
                                "@type": "Answer",
                                "text": "El propósito de Oberstaff es ayudar a que el trabajo remoto entre empresas y profesionales funcione con más claridad, confianza y sentido humano."
                            }
                        }
                    ]
                },
                {
                    "@type": "BreadcrumbList",
                    "@id": "https://www.oberstaff.com/quienes-somos#breadcrumb",
                    "itemListElement": [
                        {
                            "@type": "ListItem",
                            "position": 1,
                            "name": "Inicio",
                            "item": "https://www.oberstaff.com/home"
                        },
                        {
                            "@type": "ListItem",
                            "position": 2,
                            "name": "Quiénes somos",
                            "item": "https://www.oberstaff.com/quienes-somos"
                        }
                    ]
                }
            ]
        }
    </script>
    <LeadHeroSection
        topLabel="Nuestra Identidad"
        title="Somos Oberstaff<span style='color: #FF66CC;'>.</span> un puente<br> entre empresas  y talento <br> con propósito"
        cardTitle="Conoce cómo trabajamos"
        cardSubtitle="Completa tus datos para recibir asesoría sobre nuestro modelo."
        buttonText="Agendar llamada gratuita →"
        buttonIcon=""
        buttonSubtext=""
        footerLinkText=""
        footerLinkHref="#" 
        badges={[
            { text: "Talento de LATAM para España", icon: "🌍" },
            { text: "Estructura y confianza", icon: "🛡️" },
            { text: "Relaciones a largo plazo", icon: "📈" },
        ]}
        badgesClass="community-badges"
        cardTitleTag="p"
    >
        <Fragment slot="description">
            Nacimos para construir una forma de trabajo remoto más clara,
            organizada y sostenible. En Oberstaff ayudamos a que empresas
            españolas y profesionales de LATAM puedan colaborar con estructura,
            confianza y objetivos compartidos.
        </Fragment>
    </LeadHeroSection>

    <div class="fade-in-section">
        <div class="fade-in-section quienesomos-que-es">
            <QueEsServicioSection
                title="No somos solo una forma de ahorrar. <br> Somos una forma más inteligente de crecer."
                highlightWord="Somos una forma más inteligente de crecer."
                description=""
                imageSrc="/img-quienes.webp" 
                imageAlt="Talento profesional en Oberstaff"
                badgeText="Conexión Estratégica"
                itemTitleTag="h3"
                quoteText="<h3 style='color: #ff66cc; font-size: 15px; font-weight: 800; display: block; margin-bottom: 5px; font-family: inherit;'>¿Qué es <span style='color: #1B1B1B;'>Oberstaff</span><span style='color: #ff66cc;'>.</span>?</h3> Una empresa que conecta compañías españolas con profesionales preparados de LATAM mediante modelos de trabajo remoto claros, estructurados y eficientes."
                infoItems={[
                    {
                        icon: "",
                        title: "Por qué nació <span style='color: #1B1B1B; font-weight: 700;'>Oberstaff</span><span style='color: #ff66cc; font-weight: 900;'>.</span>",
                        description:
                            "<strong style='color: #1B1B1B; font-weight: 800;'>Oberstaff<span style='color: #ff66cc; font-weight: 800;'>.</span></strong> surge al observar una brecha cada vez más evidente: empresas que necesitan crecer con agilidad sin aumentar innecesariamente su carga operativa, y profesionales altamente capaces que pueden aportar valor desde nuevas geografías de trabajo.",
                    },
                    {
                        icon: "",
                        title: "Quiénes Somos",
                        description:
                            "Oberstaff es una empresa fundada en 2017 por Edgardo Vázquez con una idea clara: el trabajo remoto puede ser mucho más que una solución de ahorro. Bien gestionado, puede convertirse en una forma más eficiente y flexible de construir equipos.",
                    },
                ]} 
                ctaText="Agendar llamada gratuita →"
                ctaHref="#"
            />
        </div>
    </div>

    <div class="fade-in-section">
        <VisionMisionSection>
            <VisionMisionCard
                icon="🎯"
                iconBgClass="bg-soft-pink"
                title="Nuestra misión"
                customClass="card-mision"
            >
                Hacer que el trabajo remoto entre empresas y profesionales
                funcione mejor: con más claridad, más confianza y más sentido
                humano.
                <br /><br />
                Queremos que las compañías puedan crecer sin depender únicamente de
                estructuras tradicionales, y que el talento de LATAM tenga acceso
                a oportunidades donde su experiencia, compromiso y capacidad sean
                reconocidos.
            </VisionMisionCard>

            <VisionMisionCard
                icon="👁️"
                iconBgClass="bg-soft-purple"
                title="Nuestra visión"
                customClass="card-vision"
            >
                Vemos un futuro donde las empresas construyen equipos con menos
                barreras y más inteligencia operativa. Un futuro donde la
                ubicación no limite la oportunidad, pero donde la flexibilidad
                tampoco signifique desorden.
                <br /><br />
                Para nosotros, el trabajo remoto necesita una nueva capa de confianza:
                procesos claros, comunicación responsable, modelos adecuados y acompañamiento
                real. Esa es la visión que guía a Oberstaff.
            </VisionMisionCard>
        </VisionMisionSection>
    </div>

    <div class="fade-in-section faq-quienesomos-wrapper">
        <FAQSection
            title="Preguntas frecuentes <br> sobre <span style='color: #6663FD; font-weight: 900;'>Oberstaff</span><span style='color: #ff66cc; font-weight: 900;'></span>"
            ctaText="Resolvemos tus dudas sobre cómo conectamos a las <br> empresas españolas con el talento de LATAM de forma <br> segura."
            ctaButtonText="Hablar con asesor →"
        />
    </div>
</DashboardLayoutContacto>

<style is:global>
    /* Estilos para el Título Principal */
    .quienesomos-que-es .que-es-header h2 {
        font-size: 32px;
        font-weight: 700;
        line-height: 1.2;
    }
    .quienesomos-que-es .que-es-header .blue-text {
        color: #6663fd;
        display: block;
        font-size: 32px;
        margin-top: 5px;
        font-weight: 800;
    }

    /* Estilos para la Cita Rosa */
    .quienesomos-que-es .quote-blue-border {
        border-left: 4px solid #ff66cc !important;
        background: linear-gradient(
            90deg,
            rgba(102, 99, 253, 0.08),
            transparent
        ) !important;
        color: #ff66cc !important;
        font-size: 15px !important;
        font-weight: 400 !important;
        padding: 20px 25px !important;
        border-radius: 0 12px 12px 0 !important;
        margin-bottom: 35px !important;
    }
    .quienesomos-que-es .quote-blue-border h3 {
        margin: 0 !important;
        padding: 0 !important;
        font-family: 'Montserrat', sans-serif !important;
        font-size: 15px !important;
    }

    /* Ocultar iconos y ajustar info-items */
    .quienesomos-que-es .icon-box {
        display: none !important;
    }
    .quienesomos-que-es .info-item {
        margin-bottom: 30px !important;
    }
    .quienesomos-que-es .text-box .text-box-title {
        font-size: 20px !important;
        font-weight: 500 !important;
        color: #1b1b1b !important;
        margin-bottom: 12px !important;
        font-family: 'Poppins', sans-serif !important;
    }
    .quienesomos-que-es .text-box p {
        font-size: 15px !important;
        color: #5a5a5a !important;
        line-height: 1.6 !important;
    }

    /* Botón CTA Outlined */
    .quienesomos-que-es .ques-cta-btn {
        background: transparent !important;
        border: 1.5px solid #e5e5e5 !important;
        color: #1b1b1b !important;
        padding: 14px 35px !important;
        border-radius: 50px !important;
        font-weight: 600 !important;
        transition: all 0.3s ease !important;
        box-shadow: none !important;
        margin-top: 20px !important;
    }
    .quienesomos-que-es .ques-cta-btn:hover {
        border-color: #1b1b1b !important;
    }

    /* Imagen en Blanco y Negro */
    .quienesomos-que-es .image-card {
        filter: grayscale(100%) !important;
        border-radius: 30px !important;
    }

    .faq-quienesomos-wrapper {
        border-top: 1px solid #e0e0e0;
    }

    @media screen and (max-width: 768px) {
        .quienesomos-que-es .que-es-header h2 {
            font-size: 28px !important;
        }
        .quienesomos-que-es .que-es-header .blue-text {
            font-size: 28px !important;
        }

        .quienesomos-que-es .quote-blue-border {
            margin-top: 1px !important;
        }
    }
</style>
