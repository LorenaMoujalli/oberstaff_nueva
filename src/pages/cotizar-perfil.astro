  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Oberstaff - Contratación de Talento LATAM</title>

  <!-- ================= ESTILOS CSS ================= -->
  <style>
    /* ================= IMPORTACIÓN DE FUENTES ================= */
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Poppins:wght@400;500;600;700&display=swap');

    /* ================= VARIABLES BASE ================= */
    :root {
      --bg-porcelain: #FEFFFA;
      --bg-alternate: #FAFAFC;
      --bg-white: #FFFFFF;
      --text-dark: #1B1B1B;
      --text-gray: #5A5A5A;
      
      --brand-pink: #FF66CC;   
      --brand-purple: #6663FD; 
      --brand-green: #66FF99;  
      --brand-yellow: #CCFF66; 
      
      --font-heading: 'Montserrat', sans-serif;
      --font-body: 'Poppins', sans-serif;
    }

    /* ================= RESET Y GLOBALES ================= */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); background-color: var(--bg-porcelain); color: var(--text-dark); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

    /* Utilidades de fondo */
    .bg-porcelain { background-color: var(--bg-porcelain); }
    .bg-alternate { background-color: var(--bg-alternate); }
    .bg-white { background-color: var(--bg-white); }
    .bg-dark-hero { background-color: #25262B; }
    .text-white { color: #FFFFFF !important; }

    /* ================= BLINDAJE DE MARCA ================= */
    .brand-oberstaff { font-family: var(--font-heading) !important; font-weight: 900 !important; color: var(--text-dark) !important; }

    /* Aquí añadimos .guarantee-section para que también se pinte de blanco */
    .bg-dark-hero .brand-oberstaff, 
    .guarantee-section .brand-oberstaff { 
      color: #FFFFFF !important; 
    }

    .brand-dot { color: var(--brand-pink) !important; }

    /* ================= TIPOGRAFÍA ================= */
    .visual-h1-large { font-family: var(--font-heading); font-size: 46px; font-weight: 900; line-height: 1.15; margin-bottom: 20px; letter-spacing: -1px; }
    .visual-section-title { font-family: var(--font-heading); font-size: 36px; font-weight: 800; color: var(--text-dark); line-height: 1.3; letter-spacing: -0.5px; }
    .visual-section-title.text-left { text-align: left; }
    .visual-h3-card-title { font-family: var(--font-heading); font-size: 20px; font-weight: 700; color: var(--text-dark); margin-bottom: 12px; }
    .editorial-p { font-size: 16px; color: var(--text-gray); line-height: 1.7; margin-bottom: 15px; }

    .seo-kicker { font-family: var(--font-heading); font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 20px; font-size: 14px; display: block; }
    .text-gradient-pink { background: linear-gradient(90deg, var(--brand-pink), #FA3AB5); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 900; }

    /* ================= BOTONES ================= */
    .rounded-pill { display: inline-flex; align-items: center; justify-content: center; padding: 16px 32px; border-radius: 50px; font-weight: 700; transition: all 0.3s ease; cursor: pointer; border: none; font-size: 16px; width: 100%; font-family: var(--font-body); }
    .btn-pink, .btn-primary { background-color: var(--brand-pink); color: #FFFFFF; border: 2px solid var(--brand-pink); }
    .btn-pink:hover, .btn-primary:hover { background-color: transparent; color: var(--brand-pink); box-shadow: 0 5px 15px rgba(255, 102, 204, 0.3); }

    /* ================= HERO & SPLIT LAYOUT ================= */
    .hero-profile-container { display: flex; align-items: center; gap: 60px; position: relative; z-index: 2; }
    .hero-profile-text { flex: 1.2; }
    .hero-subtitle { font-size: 18px; margin-bottom: 30px; }
    .hero-trust-bullets { display: flex; flex-direction: column; gap: 10px; margin-top: 20px; }
    .bullet-item { display: flex; align-items: center; gap: 10px; color: #FFFFFF; font-weight: 500; font-size: 15px; }
    .bullet-item .check { color: var(--brand-green); font-weight: 900; }

    .blur-glow { position: absolute; filter: blur(100px); opacity: 0.65; z-index: 1; border-radius: 50%; pointer-events: none; }
    .pink-glow { top: -20%; left: -10%; width: 600px; height: 600px; background: linear-gradient(135deg, var(--brand-pink) 0%, rgba(255, 102, 204, 0.4) 100%); } 
    .purple-glow { top: 10%; right: -15%; width: 500px; height: 700px; background: linear-gradient(135deg, var(--brand-purple) 0%, rgba(102, 99, 253, 0.4) 100%); }

    .split-header-row { display: flex; align-items: center; gap: 60px; margin-bottom: 60px; }
    .split-header-text { flex: 1.2; }
    .split-header-visual { flex: 0.8; display: flex; justify-content: center; }

    /* ================= FORMULARIOS MODERNOS ================= */
    .hero-profile-form, .cta-form-side { flex: 0.8; }
    .form-card { background: #FFFFFF; border-radius: 20px; padding: 40px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
    .form-title { font-family: var(--font-heading); font-size: 22px; color: var(--text-dark); margin-bottom: 10px; text-align: center;}
    .form-group { margin-bottom: 15px; }
    .form-group input, .form-select { width: 100%; padding: 14px 18px; border: 1px solid #E0E0E0; border-radius: 8px; font-family: var(--font-body); font-size: 14px; background: #FAFAFC; outline: none; transition: all 0.3s; color: var(--text-dark); }
    .form-group input:focus, .form-select:focus { border-color: var(--brand-purple); background: #FFFFFF; box-shadow: 0 0 0 4px rgba(102, 99, 253, 0.1); }
    .rgpd-label { display: flex; gap: 8px; align-items: flex-start; font-size: 12px; color: var(--text-gray); margin-bottom: 15px; cursor: pointer; }
    .rgpd-label input { margin-top: 3px; width: auto !important; }
    .rgpd-label a { color: var(--brand-pink); font-weight: 600; }
    .error-msg { display: none; font-size: 12px; color: #FF4D4D; margin-top: 4px; font-weight: 500; }
    .campo.invalido input, .campo.invalido select { border-color: #FF4D4D; background: rgba(255, 77, 77, 0.05); }
    .campo.invalido .error-msg { display: block; }
    .micro-cta { display: block; text-align: center; font-size: 12px; color: var(--text-gray); margin-top: 10px; font-weight: 500; }
    .form-desc {
        text-align: center;
        padding-bottom: 10px;

    }

    /* ================= TABLA SAAS ================= */
    .table-responsive { width: 100%; overflow-x: auto; background: #FFFFFF; border-radius: 20px; box-shadow: 0 15px 40px rgba(0,0,0,0.03); border: 1px solid rgba(0,0,0,0.05); }
    .saas-comparison-table { width: 100%; min-width: 800px; border-collapse: separate; border-spacing: 0; text-align: left; }
    .saas-comparison-table th, .saas-comparison-table td { padding: 20px 25px; border-bottom: 1px solid rgba(0,0,0,0.05); font-size: 14px; }
    .saas-comparison-table th { font-family: var(--font-heading); font-size: 16px; color: var(--text-dark); background: #FAFAFC; }
    .saas-comparison-table thead th:first-child { border-top-left-radius: 19px; }
    .saas-comparison-table thead th:last-child { border-top-right-radius: 19px; }
    .saas-comparison-table tbody tr:last-child td:first-child { border-bottom-left-radius: 19px; }
    .saas-comparison-table tbody tr:last-child td:last-child { border-bottom-right-radius: 19px; }
    .feature-col { font-weight: 600; color: var(--text-dark); width: 30%; background: #FAFAFC; }
    .oberstaff-col { background-color: rgba(102, 99, 253, 0.03); border-left: 2px solid var(--brand-purple); border-right: 2px solid var(--brand-purple); font-weight: 600; color: var(--text-dark); }
    .saas-comparison-table thead th.oberstaff-col { background-color: rgba(102, 99, 253, 0.08); border-top: 2px solid var(--brand-purple); }
    .saas-comparison-table tbody tr:last-child .oberstaff-col { border-bottom: 2px solid var(--brand-purple); }
    .check { color: var(--brand-green); font-weight: 900; margin-right: 5px; }
    .cross { color: #FF4D4D; font-weight: 900; margin-right: 5px; }
    .warn { color: #FFA500; font-weight: 900; margin-right: 5px; }

    /* ================= CHIPS & LISTAS ================= */
    .editorial-checklist { list-style: none; display: flex; flex-direction: column; gap: 15px; }
    .editorial-checklist li { display: flex; align-items: flex-start; gap: 15px; }
    .profiles-chips-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 15px; }
    .chip-btn { background: #FFFFFF; border: 1.5px solid rgba(0,0,0,0.1); border-radius: 12px; padding: 16px; font-family: var(--font-body); font-weight: 600; font-size: 14px; color: var(--text-dark); cursor: pointer; transition: all 0.3s; text-align: center; }
    .chip-btn:hover { border-color: var(--brand-pink); transform: translateY(-3px); box-shadow: 0 10px 20px rgba(255, 102, 204, 0.1); color: var(--brand-pink); }

    /* ================= PASOS Y MÉTRICAS ================= */
    .steps-3-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; }
    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; text-align: center; margin-top: 60px; }
    .guarantee-box { background: linear-gradient(140deg, #1B1B1B, #25262B); border-radius: 24px; padding: 60px; display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 50px; align-items: center; box-shadow: 0 30px 60px rgba(0,0,0,0.15); }

    /* ================= GARANTÍA ================= */
    .guarantee-item { background: rgba(255,255,255,0.1); padding: 15px 20px; border-radius: 12px; color: #FFFFFF; font-weight: 600; font-size: 15px; border: 1px solid rgba(255,255,255,0.1); }

    /* ================= TESTIMONIOS ================= */
    .testimonials-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 30px; }
    .testimonial-card { background: #FFFFFF; border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; padding: 35px 30px; box-shadow: 0 5px 20px rgba(0,0,0,0.02); }
    .stars { color: #FFC107; font-size: 16px; letter-spacing: 2px; margin-bottom: 5px; }
    .testimonial-quote { font-size: 15px; color: var(--text-dark); font-style: italic; margin-top: 15px; }

    /* ================= FAQ ================= */
    .faq-container { display: flex; align-items: flex-start; gap: 60px; }
    .faq-sticky-side { flex: 0 0 35%; position: sticky; top: 40px; }
    .faq-accordion-side { flex: 1; display: flex; flex-direction: column; gap: 15px; }
    .faq-item { background: #FFFFFF; border: 1px solid rgba(0,0,0,0.05); border-radius: 12px; overflow: hidden; transition: all 0.3s; }
    .faq-question { padding: 25px 30px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
    .faq-title { font-size: 16px; font-weight: 600; margin: 0; }
    .faq-icon { font-size: 24px; color: var(--brand-purple); font-weight: 300; transition: transform 0.3s; }
    .faq-answer-wrapper { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.3s; }
    .faq-answer { overflow: hidden; }
    .faq-answer p { padding: 0 30px 25px 30px; font-size: 14px; color: var(--text-gray); }
    .faq-item.active { border-color: var(--brand-purple); box-shadow: 0 5px 20px rgba(102, 99, 253, 0.08); }
    .faq-item.active .faq-answer-wrapper { grid-template-rows: 1fr; }
    .faq-item.active .faq-icon { transform: rotate(45deg); color: var(--brand-pink); }

    /* ================= RESPONSIVE ================= */
    @media (max-width: 992px) {
      .hero-profile-container, .split-header-row, .faq-container, .cta-form-container { flex-direction: column; text-align: center; gap: 40px; }
      .visual-section-title.text-left, .editorial-checklist li { text-align: center; justify-content: center; }
      .testimonials-grid { grid-template-columns: 1fr; }
      .stats-grid { grid-template-columns: 1fr; gap: 40px; }
      .guarantee-section > div > div { grid-template-columns: 1fr !important; display: flex; flex-direction: column; }
      .faq-sticky-side { position: relative; top: 0; }
    }
    
    /* ================= ESPACIADO GLOBAL DE SECCIONES ================= */
    section {
      padding: 100px 0;
    }

    /* Reducimos un poco el espaciado en pantallas más pequeñas para móviles/tablets */
    @media (max-width: 992px) {
      .hero-profile-container, .split-header-row, .faq-container, .cta-form-container { flex-direction: column; text-align: center; gap: 40px; }
      .visual-section-title.text-left, .editorial-checklist li { text-align: center; justify-content: center; }
      .testimonials-grid { grid-template-columns: 1fr; }
      .stats-grid { grid-template-columns: 1fr; gap: 40px; }
      .guarantee-section > div > div { grid-template-columns: 1fr !important; display: flex; flex-direction: column; }
      .faq-sticky-side { position: relative; top: 0; }
      .guarantee-box { grid-template-columns: 1fr; padding: 40px 20px; gap: 30px; }
      section {
        padding: 70px 0;
      }
    }
    @media (max-width: 768px) {
      .visual-h1-large { font-size: 32px !important; }
      .visual-section-title { font-size: 26px !important; }
      .form-card { padding: 25px 20px !important; }
      .hero-subtitle { font-size: 16px !important; }
      .bullet-item { font-size: 14px !important; text-align: left; }
      .bullet-item p { text-align: left; }
      .hero-profile-section { padding: 60px 0 80px !important; }
      .steps-3-grid { grid-template-columns: 1fr; gap: 20px; }
      .trust-bar-simple .container { flex-direction: column; gap: 15px; }
    }
    @media (max-width: 576px) {
      .captcha-input-row { flex-wrap: wrap; }
      .captcha-input { width: 100% !important; max-width: none !important; }
      .captcha-canvas { width: 100% !important; max-width: 200px; }
    }
    :global(.iti) { display: block !important; width: 100% !important; }
  </style>
