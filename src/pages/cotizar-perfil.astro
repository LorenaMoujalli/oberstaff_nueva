  <script>
    // ── CAPTCHA Generator ──────────────────────────────────────────
    const CAPTCHA_CHARS = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';

    function generateCaptchaCode(length = 6): string {
        let code = '';
        for (let i = 0; i < length; i++) {
            code += CAPTCHA_CHARS[Math.floor(Math.random() * CAPTCHA_CHARS.length)];
        }
        return code;
    }

    function drawCaptcha(canvas: HTMLCanvasElement, code: string) {
        const ctx = canvas.getContext('2d')!;
        const w = canvas.width;
        const h = canvas.height;

        // Background
        ctx.clearRect(0, 0, w, h);
        ctx.fillStyle = '#f0f0f6';
        ctx.fillRect(0, 0, w, h);

        // Noise lines
        for (let i = 0; i < 6; i++) {
            ctx.strokeStyle = `hsl(${Math.random() * 360}, 40%, 70%)`;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(Math.random() * w, Math.random() * h);
            ctx.lineTo(Math.random() * w, Math.random() * h);
            ctx.stroke();
        }

        // Noise dots
        for (let i = 0; i < 40; i++) {
            ctx.fillStyle = `hsl(${Math.random() * 360}, 40%, 65%)`;
            ctx.beginPath();
            ctx.arc(Math.random() * w, Math.random() * h, 1, 0, Math.PI * 2);
            ctx.fill();
        }

        // Draw characters
        const charW = w / (code.length + 1);
        for (let i = 0; i < code.length; i++) {
            ctx.save();
            const x = charW * (i + 0.9);
            const y = h / 2 + 8;
            const angle = (Math.random() - 0.5) * 0.4;
            ctx.translate(x, y);
            ctx.rotate(angle);
            ctx.font = `bold ${20 + Math.random() * 6}px monospace`;
            ctx.fillStyle = `hsl(${240 + Math.random() * 60}, 55%, 35%)`;
            ctx.strokeStyle = `hsl(${240 + Math.random() * 60}, 40%, 60%)`;
            ctx.lineWidth = 0.5;
            ctx.strokeText(code[i], 0, 0);
            ctx.fillText(code[i], 0, 0);
            ctx.restore();
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
      
      /* ================= VALIDACIÓN Y ENVÍO DE FORMULARIOS ================= */
      document.querySelectorAll('.form-lead').forEach((el, index) => {
        const form = el as HTMLFormElement;
        const isFirstForm = index === 0;
        
        // Inicializar intl-tel-input
        const phoneInput = form.querySelector('input[data-phone="true"]') as HTMLInputElement;
        let iti: any = null;
        if (phoneInput && (window as any).intlTelInput) {
          iti = (window as any).intlTelInput(phoneInput, {
            initialCountry: "es",
            separateDialCode: true,
            preferredCountries: ["es", "co", "ar", "mx", "cl", "pe", "ve"],
            utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.10/build/js/utils.js",
          });
        }

        // Inicializar CAPTCHA
        let currentCode = '';
        const canvas = form.querySelector('.captcha-canvas') as HTMLCanvasElement;
        const captchaInput = form.querySelector('.captcha-input') as HTMLInputElement;
        const captchaRefresh = form.querySelector('.captcha-refresh-btn') as HTMLButtonElement;
        const captchaError = form.querySelector('.captcha-error') as HTMLElement;

        function refreshCaptcha() {
            currentCode = generateCaptchaCode();
            if (canvas) {
              drawCaptcha(canvas, currentCode);
            }
            if (captchaInput) {
              captchaInput.value = '';
            }
            const captchaCampo = form.querySelector('.captcha-group') as HTMLElement | null;
            if (captchaCampo) {
              captchaCampo.classList.remove('invalido');
            }
            if (captchaError) {
              captchaError.textContent = '';
            }
        }

        if (canvas) {
          refreshCaptcha();
          captchaRefresh?.addEventListener('click', refreshCaptcha);
          captchaInput?.addEventListener('input', () => {
            const captchaCampo = form.querySelector('.captcha-group') as HTMLElement | null;
            if (captchaCampo) {
              captchaCampo.classList.remove('invalido');
            }
            if (captchaError) {
              captchaError.textContent = '';
            }
          });
        }

        form.addEventListener('submit', function(e) {
          // 1. Validar CAPTCHA personalizado usando setCustomValidity y reportValidity
          const userCode = captchaInput?.value.trim().toUpperCase();
          if (captchaInput) {
            if (!userCode) {
              captchaInput.setCustomValidity('Indica el código de verificación.');
              captchaInput.reportValidity();
              e.preventDefault();
              return;
            } else if (userCode !== currentCode) {
              captchaInput.setCustomValidity('Código incorrecto. Inténtalo de nuevo.');
              captchaInput.reportValidity();
              refreshCaptcha();
              e.preventDefault();
              return;
            } else {
              captchaInput.setCustomValidity('');
            }
          }

          // 2. Si el resto del formulario no es válido por el navegador, no hacer nada (dejar que el navegador muestre sus burbujas)
          if (!form.checkValidity()) {
            return;
          }

          // 3. Prevenir el envío si es válido para simular el éxito
          e.preventDefault();

          // Honeypot antispam
          const honeypot = form.querySelector('.honeypot input') as HTMLInputElement | null;
          if (honeypot && honeypot.value !== '') return;

          // Asignar el número completo al input antes de leer FormData
          if (iti && phoneInput) {
            phoneInput.value = iti.getNumber();
          }

          // Simulador de envío / Datos
          const datos = Object.fromEntries(new FormData(form).entries());
          console.log('Lead capturado:', datos);

          // Enviar al webhook de Zapier según corresponda
          const webhookUrl = isFirstForm 
            ? 'https://hooks.zapier.com/hooks/catch/12433184/4ujlm5u/'
            : 'https://hooks.zapier.com/hooks/catch/12433184/4ujecl6/';

          fetch(webhookUrl, {
            method: 'POST',
            body: JSON.stringify(datos)
          }).catch(err => console.error('Error al enviar webhook:', err));

          // Mostrar mensaje de éxito
          form.style.display = 'none';
          const formExito = form.parentElement?.querySelector('.form-exito') as HTMLElement | null;
          if (formExito) {
            formExito.style.display = 'block';
          }
        });

        if (captchaInput) {
          captchaInput.addEventListener('input', () => {
            captchaInput.setCustomValidity('');
          });
        }
      });

      /* ================= CHIPS DE PERFILES -> AUTO-SELECT ================= */
      document.querySelectorAll('.chip-btn').forEach(chip => {
        chip.addEventListener('click', () => {
          const perfil = chip.getAttribute('data-perfil');
          
          // Busca los selects de todos los formularios de la página
          document.querySelectorAll('select[name="perfil"]').forEach(elSel => {
            const sel = elSel as HTMLSelectElement;
            for (let i = 0; i < sel.options.length; i++) {
              if (sel.options[i].text === perfil) { 
                sel.selectedIndex = i; 
                break; 
              }
            }
          });
          // Scroll suave hacia el formulario del Hero
          document.getElementById('cotizar-hero')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      });

      /* ================= LÓGICA DE FAQ (ACORDEÓN) ================= */
      const faqQuestions = document.querySelectorAll('.faq-question');
      faqQuestions.forEach(question => {
        question.addEventListener('click', () => {
          const parentItem = question.parentElement;
          if (parentItem) {
            const isActive = parentItem.classList.contains('active');
              
            document.querySelectorAll('.faq-item').forEach(item => {
              item.classList.remove('active');
            });
              
            if (!isActive) {
              parentItem.classList.add('active');
            }
          }
        });
      });

    }); 
  </script>
</body>
</html>