  <!-- ================= HERO SECTION ================= -->
  <section class="hero-profile-section bg-dark-hero" style="background: linear-gradient(to right, rgba(27, 27, 27, 0.95) 40%, rgba(27, 27, 27, 0.6) 100%), url('/hero-cotizar-perfil.webp') center/cover no-repeat; position: relative; padding: 100px 0 120px; overflow: hidden;">
    <div class="blur-glow pink-glow"></div>
    <div class="blur-glow purple-glow"></div>

    <div class="container hero-profile-container">
      <div class="hero-profile-text">
        <span class="seo-kicker text-gradient-pink">Contratación Remota para España</span>
        <h1 class="visual-h1-large text-white">Ahorra hasta un <span class="text-gradient-pink">70% en costes de personal</span> contratando talento LATAM desde 820 €/mes</h1>
        
        <p class="hero-subtitle text-white" style="opacity: 0.9;">
          Profesionales evaluados, en tu misma franja horaria que España, con garantía legal y una única factura mensual. Sin permanencia.
        </p>
        
        <div class="hero-trust-bullets">
          <div class="bullet-item"><span class="check">✓</span> <p><strong>Incorporación en menos de 30 días</strong></p></div>
          <div class="bullet-item"><span class="check">✓</span> <p><strong>Talento validado con pruebas técnicas y entrevista previa</strong></p></div>
          <div class="bullet-item"><span class="check">✓</span> <p><strong><span class="brand-oberstaff">Oberstaff<span class="brand-dot">.</span></span> asume toda la gestión laboral y legal</strong></p></div>
          <div class="bullet-item"><span class="check">✓</span> <p><strong>Más de 500 empresas ya confían en nosotros</strong></p></div>
        </div>
      </div>

      <!-- Zona de captación inicial -->
      <div class="hero-profile-form" id="cotizar-hero">
        <div class="form-card">
          <h3 class="form-title">Cotiza tu perfil sin compromiso</h3>
          <p class="form-desc" style="font-size: 13px;">1 minuto. Recibe tu propuesta de ahorro en menos de 24 horas.</p>
          <form class="modern-form form-lead" action="#" method="POST">
            <div class="honeypot" aria-hidden="true" style="display:none;"><input type="text" name="empresa_web" tabindex="-1" autocomplete="off"></div>
            
            <div class="form-group light-mode campo">
              <input type="text" name="nombre" required placeholder="Nombre y apellido *">
            </div>
            <div class="form-group light-mode campo">
              <input type="email" name="email" required placeholder="Email corporativo *">
            </div>
            <div class="form-group light-mode campo">
              <input type="tel" name="telefono" required placeholder="Teléfono *" data-phone="true" style="width: 100%; box-sizing: border-box;" oninput="this.value = this.value.replace(/[^0-9 ]/g, '')">
            </div>
            <div class="form-group light-mode campo">
              <select name="perfil" required class="form-select">
                <option value="" selected disabled>¿Qué perfil necesitas? *</option>
                <option>Community Manager</option>
                <option>Copywriter</option>
                <option>Editor de Vídeo</option>
                <option>Diseñador Gráfico</option>
                <option>Especialista SEO</option>
                <option>Especialista Meta Ads</option>
                <option>Especialista Google Ads</option>
                <option>Asistente Virtual</option>
                <option>Contable</option>
                <option>Closer de Ventas</option>
                <option>Desarrollador</option>
                <option>Otro perfil</option>
              </select>
            </div>
            <div class="form-group light-mode campo">
              <select name="tamano" required class="form-select">
                <option value="" selected disabled>Tamaño de tu empresa *</option>
                <option>1–10 empleados</option>
                <option>11–50 empleados</option>
                <option>51–200 empleados</option>
                <option>Más de 200 empleados</option>
              </select>
            </div>
            <div class="form-group campo">
              <label class="rgpd-label">
                <input type="checkbox" name="rgpd" required>
                <span>Acepto la <a href="/politica-de-privacidad-y-cookies-de-oberstaff" target="_blank">política de privacidad</a>.</span>
              </label>
            </div>
            
            <!-- CAPTCHA Verification -->
            <div class="form-group captcha-group campo" style="margin-bottom: 20px; text-align: left;">
                <label class="captcha-label" style="font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600; color: #1B1B1B; display: block; margin-bottom: 4px;">Código de verificación <span class="required-star" style="color: #ef4444; font-weight: 700; margin-left: 2px;">*</span></label>
                <p class="captcha-hint" style="font-family: 'Poppins', sans-serif; font-size: 12px; color: #888; margin: 0 0 8px 0;">Ingresa el texto que ves en la imagen</p>
                <div class="captcha-input-row" style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
                    <input
                        type="text"
                        class="captcha-input"
                        placeholder="Escribe el código"
                        autocomplete="off"
                        maxlength="8"
                        required
                        style="font-family: 'Poppins', sans-serif; background-color: #FAFAFC; border: 1px solid #E0E0E0; padding: 10px 14px; border-radius: 8px; font-size: 15px; outline: none; transition: border-color 0.3s ease, box-shadow 0.3s ease; width: 200px; color: #1B1B1B; letter-spacing: 2px;"
                    />
                    <button type="button" class="captcha-refresh-btn" title="Nuevo código" aria-label="Generar nuevo código" style="background: none; border: 1.5px solid #6663FD; border-radius: 6px; color: #6663FD; font-size: 18px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s, color 0.2s; padding: 0; flex-shrink: 0;">
                        &#x21bb;
                    </button>
                </div>
                <canvas class="captcha-canvas" width="200" height="60" aria-label="Código de verificación visual" style="display: block; border-radius: 8px; border: 1px solid #ddd; background: #f4f4f8; user-select: none; pointer-events: none;"></canvas>
            </div>

            <button type="submit" class="btn-pink rounded-pill btn-submit">Cotizar perfil</button>
            <span class="micro-cta">Gratis · Sin permanencia · Respuesta en &lt;24 h</span>
          </form>
          <div class="form-exito" style="display: none; text-align: center;">
            <div class="check-icon" style="font-size: 40px; color: #1F9E4B; text-align: center;">✓</div>
            <h4 style="font-family: var(--font-heading); font-size: 20px; color: var(--text-dark); margin: 10px 0;">¡Solicitud recibida!</h4>
            <p style="color: var(--text-gray); font-size: 14px;">Un especialista te contactará en menos de 24 horas con tu propuesta de ahorro personalizada.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= BARRA DE CONFIANZA ================= -->
  <div class="trust-bar-simple bg-white" style="padding: 30px 0; border-bottom: 1px solid rgba(0,0,0,0.05);">
    <div class="container" style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 20px; text-align: center;">
      <div style="flex: 1; font-weight: 700; color: var(--text-dark); font-size: 15px;">🏢 +500 empresas confían en nosotros</div>
      <div style="flex: 1; font-weight: 700; color: var(--text-dark); font-size: 15px;">🛡️ Contratación 100% legal</div>
      <div style="flex: 1; font-weight: 700; color: var(--text-dark); font-size: 15px;">🕐 Misma franja horaria que España</div>
      <div style="flex: 1; font-weight: 700; color: var(--text-dark); font-size: 15px;">📅 Sin permanencia ni costes ocultos</div>
    </div>
  </div>

  <!-- ================= COMPARATIVA DE COSTES ================= -->
  <section class="comparison-table-section bg-alternate">
